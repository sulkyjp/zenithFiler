<UserControl x:Class="ZenithFiler.DocViewerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ZenithFiler"
             xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Background="Transparent">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="MarkdownStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <local:IndentToMarginConverter x:Key="IndentToMarginConverter" />
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

            <SolidColorBrush x:Key="CardBackgroundBrush" Color="{DynamicResource BackgroundColor}" />
            <SolidColorBrush x:Key="CardHoverBrush" Color="{DynamicResource ListHoverColor}" />
            <SolidColorBrush x:Key="AcrylicSidebarBrush" Color="{DynamicResource SidebarColor}" />
            <SolidColorBrush x:Key="AcrylicBackgroundBrush" Color="{DynamicResource BackgroundColor}" />
            <SolidColorBrush x:Key="InvertedTextBrush" Color="#FFFFFF" />

            <Style x:Key="TocItemContainerStyle" TargetType="ListBoxItem">
                <Setter Property="Margin" Value="0,0" />
                <Setter Property="Padding" Value="8,5" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="ToolTipService.ShowDuration" Value="60000" />
                <Setter Property="ToolTip" Value="{Binding Title}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="Bd"
                                    CornerRadius="4"
                                    Background="{TemplateBinding Background}">
                                <ContentPresenter Margin="4,0" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardHoverBrush}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource InvertedTextBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <DataTemplate x:Key="TocItemTemplate" DataType="{x:Type local:ManualTocItem}">
                <Grid Margin="{Binding Indent, Converter={StaticResource IndentToMarginConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <icon:PackIconLucide x:Name="Icon" Grid.Column="0"
                                          Width="16"
                                          Height="16"
                                          Margin="4,0,6,0"
                                          Foreground="{DynamicResource AccentBrush}"
                                          Kind="{Binding IconKind}" />
                    <TextBlock Grid.Column="1"
                               TextWrapping="Wrap"
                               FontSize="12.5"
                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}">
                        <Run Text="{Binding Title, Mode=OneWay}" />
                        <Run x:Name="SummaryRun" Text="{Binding Summary, Mode=OneWay, StringFormat={}  {0}}" 
                             FontSize="11" Foreground="{DynamicResource SubTextBrush}" />
                    </TextBlock>
                </Grid>
                <DataTemplate.Triggers>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                        <Setter TargetName="Icon" Property="Foreground" Value="{DynamicResource InvertedTextBrush}" />
                        <Setter TargetName="SummaryRun" Property="Foreground" Value="{DynamicResource InvertedTextBrush}" />
                    </DataTrigger>
                </DataTemplate.Triggers>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="8,8,8,12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition MinWidth="260" Width="400" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                CornerRadius="10"
                Background="{DynamicResource AcrylicSidebarBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                Padding="10,10,0,10"
                SnapsToDevicePixels="True">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top"
                            Orientation="Horizontal"
                            Margin="0,0,0,6">
                    <icon:PackIconLucide Width="16"
                                          Height="16"
                                          Margin="0,0,4,0"
                                          Foreground="{DynamicResource AccentBrush}"
                                          Kind="ListTree" />
                    <TextBlock Text="目次"
                               FontWeight="SemiBold"
                               FontSize="13" />
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ListBox x:Name="TocListBox"
                             ItemsSource="{Binding TocItems}"
                             SelectedItem="{Binding SelectedTocItem, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemTemplate="{StaticResource TocItemTemplate}"
                             ItemContainerStyle="{StaticResource TocItemContainerStyle}"
                             SelectionChanged="TocListBox_SelectionChanged" />
                </ScrollViewer>
            </DockPanel>
        </Border>

        <GridSplitter Grid.Column="1"
                      Width="8"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Background="Transparent"
                      ShowsPreview="True" />

        <Border Grid.Column="2"
                CornerRadius="10"
                Background="{DynamicResource AcrylicBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                Padding="0"
                SnapsToDevicePixels="True">
            <Grid>
                <FlowDocumentScrollViewer x:Name="DocViewer"
                                          Margin="0"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          PreviewMouseWheel="DocViewer_PreviewMouseWheel" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
