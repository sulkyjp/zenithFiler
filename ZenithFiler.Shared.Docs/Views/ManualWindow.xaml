<Window x:Class="ZenithFiler.ManualWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ZenithFiler"
        xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="ヘルプ / ドキュメント"
        Height="900"
        Width="1400"
        PreviewKeyDown="Window_PreviewKeyDown"
        WindowStartupLocation="CenterOwner"
        Background="#F5F1E3"
        Foreground="#1A1A1A"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="CardHoverBrush" Color="#DFDAC8" />

            <Style x:Key="SegmentToggleButtonStyle" TargetType="ToggleButton">
                <Setter Property="Margin" Value="4,4" />
                <Setter Property="Padding" Value="16,6" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter TargetName="Bd" Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.2" Direction="270" />
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsMouseOver" Value="True" />
                                        <Condition Property="IsChecked" Value="False" />
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardHoverBrush}" />
                                </MultiTrigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.6" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,12"
                SnapsToDevicePixels="True">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <icon:PackIconLucide Width="18"
                                         Height="18"
                                         Margin="0,0,10,0"
                                         VerticalAlignment="Center"
                                         Foreground="{DynamicResource AccentBrush}"
                                         Kind="BookOpen" />
                    <TextBlock x:Name="HeaderTitleTextBlock"
                               Text="Zenith Filer ドキュメント"
                               FontWeight="SemiBold"
                               FontSize="15"
                               VerticalAlignment="Center"
                               Margin="0" />
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#F3F4F6"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Margin="24,0,24,0"
                        VerticalAlignment="Center"
                        SnapsToDevicePixels="True">
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton x:Name="ManualTabButton"
                                      Style="{StaticResource SegmentToggleButtonStyle}"
                                      Content="マニュアル"
                                      IsChecked="True"
                                      Click="ManualTabButton_Click" />
                        <ToggleButton x:Name="ChangelogTabButton"
                                      Style="{StaticResource SegmentToggleButtonStyle}"
                                      Content="更新履歴"
                                      Click="ChangelogTabButton_Click" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Margin="16,0,16,0"
                        VerticalAlignment="Center"
                        Height="34"
                        Background="{DynamicResource CardBackgroundBrush}"
                        CornerRadius="4"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <icon:PackIconLucide Grid.Column="0"
                                             Width="14"
                                             Height="14"
                                             Margin="10,0,4,0"
                                             VerticalAlignment="Center"
                                             Foreground="{DynamicResource SubTextBrush}"
                                             Kind="Search" />

                        <TextBox Grid.Column="1"
                                 x:Name="SearchTextBox"
                                 VerticalAlignment="Center"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{DynamicResource TextBrush}"
                                 Padding="4,0"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Column="2"
                                   Text="{Binding SearchStatusText}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SubTextBrush}"
                                   FontSize="12"
                                   Margin="4,0,8,0"
                                   Visibility="{Binding HasSearchMatches, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <StackPanel Grid.Column="3" 
                                    Orientation="Horizontal"
                                    Margin="0,0,4,0">
                            <Button Width="24"
                                    Height="24"
                                    Margin="0,0,2,0"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding SearchPreviousCommand}"
                                    ToolTip="前へ">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="3">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasSearchMatches}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <icon:PackIconLucide Kind="ArrowUp" Width="14" Height="14" Foreground="{DynamicResource TextBrush}" />
                            </Button>

                            <Button Width="24"
                                    Height="24"
                                    Margin="0,0,2,0"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding SearchNextCommand}"
                                    ToolTip="次へ">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="3">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasSearchMatches}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <icon:PackIconLucide Kind="ArrowDown" Width="14" Height="14" Foreground="{DynamicResource TextBrush}" />
                            </Button>

                            <Button Width="24"
                                    Height="24"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding ClearSearchQueryCommand}"
                                    ToolTip="検索クリア">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="3">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchQuery}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SearchQuery}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <icon:PackIconLucide Kind="X" Width="14" Height="14" Foreground="{DynamicResource SubTextBrush}" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Button Grid.Column="3"
                        Width="28"
                        Height="28"
                        Padding="0"
                        Margin="8,0,8,0"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="CloseButton_Click"
                        ToolTip="閉じる (Esc)">
                    <icon:PackIconLucide Width="16"
                                         Height="16"
                                         VerticalAlignment="Center"
                                         HorizontalAlignment="Center"
                                         Foreground="{DynamicResource SubTextBrush}"
                                         Kind="X" />
                </Button>
            </Grid>
        </Border>

        <local:DocViewerControl Grid.Row="1" />
    </Grid>
</Window>
