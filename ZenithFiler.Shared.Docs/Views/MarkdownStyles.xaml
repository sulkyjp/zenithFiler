<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:md="clr-namespace:Markdig.Wpf;assembly=Markdig.Wpf">

    <!-- テーマ対応: ハードコードから DynamicResource 参照に変更。テーマ切替で即時更新される -->

    <Style x:Key="{x:Static md:Styles.DocumentStyleKey}"
           TargetType="{x:Type FlowDocument}">
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI, Meiryo UI" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Background" Value="{DynamicResource AcrylicBackgroundBrush}" />
        <Setter Property="TextAlignment" Value="Left" />
        <Setter Property="PagePadding" Value="48,32,48,36" />
        <Setter Property="LineHeight" Value="25" />
    </Style>

    <Style x:Key="{x:Static md:Styles.ParagraphStyleKey}"
           TargetType="{x:Type Paragraph}">
        <Setter Property="Margin" Value="0,6,0,14" />
    </Style>

    <Style x:Key="{x:Static md:Styles.Heading1StyleKey}"
           TargetType="{x:Type Paragraph}"
           BasedOn="{StaticResource {x:Static md:Styles.ParagraphStyleKey}}">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,20,0,12" />
    </Style>

    <Style x:Key="{x:Static md:Styles.Heading2StyleKey}"
           TargetType="{x:Type Paragraph}"
           BasedOn="{StaticResource {x:Static md:Styles.ParagraphStyleKey}}">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,30,0,14" />
        <Setter Property="BorderThickness" Value="6,0,0,0" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Background" Value="{DynamicResource ListHoverBrush}" />
        <Setter Property="Padding" Value="14,8,12,10" />
    </Style>

    <Style x:Key="{x:Static md:Styles.Heading3StyleKey}"
           TargetType="{x:Type Paragraph}"
           BasedOn="{StaticResource {x:Static md:Styles.ParagraphStyleKey}}">
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Margin" Value="6,18,0,6" />
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style TargetType="{x:Type List}">
        <Setter Property="Margin" Value="18,4,0,16" />
        <Setter Property="MarkerStyle" Value="Disc" />
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style TargetType="{x:Type ListItem}">
        <Setter Property="Margin" Value="0,2,0,2" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <Style x:Key="{x:Static md:Styles.HyperlinkStyleKey}"
           TargetType="{x:Type Hyperlink}">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        <Setter Property="TextDecorations" Value="None" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="TextDecorations" Value="Underline" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="{x:Static md:Styles.CodeStyleKey}"
           TargetType="{x:Type Run}">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
        <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
        <Setter Property="FontSize" Value="12.5" />
    </Style>

    <Style x:Key="{x:Static md:Styles.QuoteBlockStyleKey}"
           TargetType="{x:Type Section}">
        <Setter Property="Margin" Value="0,14,0,18" />
        <Setter Property="Padding" Value="18,10,14,10" />
        <Setter Property="BorderThickness" Value="3,0,0,0" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Background" Value="{DynamicResource ListHoverBrush}" />
    </Style>

    <Style x:Key="{x:Static md:Styles.TableStyleKey}"
           TargetType="{x:Type Table}">
        <Setter Property="CellSpacing" Value="0" />
        <Setter Property="Margin" Value="0,12,0,20" />
        <Setter Property="TextAlignment" Value="Left" />
        <Setter Property="BorderThickness" Value="0,2,0,0" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style x:Key="{x:Static md:Styles.TableCellStyleKey}"
           TargetType="{x:Type TableCell}">
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="TextAlignment" Value="Left" />
    </Style>

    <Style x:Key="{x:Static md:Styles.TableHeaderStyleKey}"
           TargetType="{x:Type TableRow}">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Background" Value="{DynamicResource SelectionBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

</ResourceDictionary>
