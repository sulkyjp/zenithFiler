<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ZenithDocViewer 単独起動時のテーマ。チャコールブラック(#545B64)・Solarized Blue 等を AppResources と揃える -->
    <Color x:Key="BackgroundColor">#F5F1E3</Color>
    <Color x:Key="SidebarColor">#E6E1D3</Color>
    <Color x:Key="BorderColor">#D3D0C3</Color>
    <Color x:Key="AccentColor">#268BD2</Color>
    <Color x:Key="PrimaryTextColor">#1A1A1A</Color>
    <Color x:Key="SecondaryTextColor">#777777</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource PrimaryTextColor}"/>
    <SolidColorBrush x:Key="SubTextBrush" Color="{StaticResource SecondaryTextColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
</ResourceDictionary>
