<Application x:Class="ZenithFiler.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
    <Application.Resources>
        <ResourceDictionary>
            <!-- コンテキストメニュー用（ハンドラがAppに必要）のみ最小限保持。他は AppResources.xaml で遅延読み込み -->
            <primitives:PopupAnimation x:Key="{x:Static SystemParameters.MenuPopupAnimationKey}">None</primitives:PopupAnimation>
            <Style TargetType="ContextMenu">
                <Setter Property="Placement" Value="MousePoint"/>
                <Setter Property="HasDropShadow" Value="True"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <EventSetter Event="Opened" Handler="ContextMenu_Opened"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ContextMenu">
                            <!-- DynamicResource はポップアップ内でも PlacementTarget 経由で解決される -->
                            <Border x:Name="ContextMenuBorder"
                                    BorderBrush="{DynamicResource ContextMenuBorderBrush}"
                                    BorderThickness="1"
                                    Background="{DynamicResource ContextMenuOuterBackgroundBrush}"
                                    CornerRadius="5" Padding="1" MinWidth="180"
                                    Margin="0,0,28,28">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.22" Direction="315" Color="#000000"/>
                                </Border.Effect>
                                <Border Background="{DynamicResource ContextMenuBackgroundBrush}" CornerRadius="4" ClipToBounds="True">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  Focusable="False"
                                                  MaxHeight="600">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" Margin="0,3,0,3"/>
                                    </ScrollViewer>
                                </Border>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
