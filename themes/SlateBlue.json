{
  // ============================================================
  //  Zenith Filer Theme Configuration: SlateBlue (Professional)
  //  コンセプト：深夜のオフィスに漂う静寂と、精密な情報処理の融合
  //  ブラッシュアップ：フォームの境界確定、ボタンの立体感、履歴の可読性向上
  // ============================================================

  "Description": "深夜のオフィスのような静寂と、高度な情報処理をイメージした濃紺",
  "Author": "K.AKASAKA",
  "Category": "Professional",

  // ── 基本 UI 要素 ──
  "Base": {
    "BackgroundColor": "#151B24",                      // メイン背景：深みのあるスレートネイビー
    "SidebarColor": "#1E2530",                         // サイドバー：操作エリアとの境界を定義
    "HeaderColor": "#0D1219",                          // アドレスバー・タブ背景：一段深く沈ませて集中力を高める
    "TitleBarColor": "#252D3A",                        // タイトルバー背景
    "BorderColor": "#506175",                          // ★枠線：ホーム等のフォーム外枠を見やすくするため、エッジをシャープに調整
    "PrimaryTextColor": "#E1E8F0",                     // ★メイン文字：純白を避け、目に優しくも視認性の高いスレートホワイト
    "SecondaryTextColor": "#A5B2C1",                   // ★サブ文字：履歴ページ等で背景に埋もれないよう、輝度を適切に強化
    "InputBackgroundColor": "#0D1219",                 // ★入力欄背景：フォームを「情報の箱」として認識させるため、背景より暗く設定
    "FocusedPaneBackgroundColor": "#1E2530",           // フォーカス中ペイン背景
    "FocusedPaneTextColor": "#FFFFFF",                 // フォーカス中文字色
    "FocusedPaneHeaderBackgroundColor": "#252D3A",     // フォーカス中ヘッダー
    "OnePointDarkColor": "#569CD6",                    // アクセントのブルー帯
    "TabSeparatorColor": "#506175",                    // タブ区切り
    "TabHoverColor": "#252D3A",                        // タブホバー
    "ToolbarSeparatorColor": "#6A737D",                // ツールバーセパレーター
    "TreeLineColor": "#3A4556"                         // ツリービュー接続線
  },

  // ── リスト・選択・ボタン（リカバリボタンの視認性を劇的改善） ──
  "List": {
    "ListHoverColor": "#252D3A",                       // リスト項目ホバー
    "SelectionColor": "#264F78",                       // リスト項目選択
    "ButtonHoverColor": "#324156",                     // ★ボタンホバー：リカバリ画面で「押せる」変化をはっきりと表現
    "InactiveSelectionColor": "#1E2530",               // 非アクティブ選択
    "OptionSelectedColor": "#5DADE2",                  // ★選択ボタン背景：暗い画面でも「選ばれている」ことが瞬時にわかる知的ブルー
    "OptionSelectedHoverColor": "#85C1E9",             // 選択中ホバー
    "CheckboxHoverColor": "#252D3A",                   // チェックボックスホバー
    "CheckedHoverAccentColor": "#569CD6"               // チェック済み強調
  },

  // ── 検索機能 ──
  "Search": {
    "IndexSearchBackgroundColor": "#1E2A3A",           // 検索バー背景
    "IndexSearchIconColor": "#DCDCAA",                 // 検索アイコン
    "IndexSearchFocusBorderColor": "#569CD6"           // 検索フォーカス枠
  },

  // ── アクセント・エラー ──
  "Accent": {
    "AccentColor": "#569CD6",                          // 強調色：スカイブルー
    "ErrorTextColor": "#F44747",                       // エラー文字
    "DestructiveHoverBackgroundColor": "#611616",      // 破壊的ホバー
    "DestructiveIconColor": "#F44747"                  // 破壊的アイコン
  },

  // ── 右クリックメニュー ──
  "ContextMenu": {
    "ContextMenuSeparatorColor": "#3A4556",            // メニュー区切り線
    "ContextMenuBackgroundColor": "#1E2530",           // メニュー背景
    "ContextMenuBorderColor": "#506175",               // メニュー枠線
    "ContextMenuTextColor": "#D0D8E0",                 // メニュー文字
    "ContextMenuIconColor": "#D0D8E0",                 // メニューアイコン
    "ContextMenuShortcutColor": "#6A737D",             // ショートカット文字
    "ContextMenuDisabledColor": "#3A4556",             // 無効項目文字
    "ContextMenuDisabledIconColor": "#3A4556",         // 無効アイコン
    "ContextMenuHighlightShortcutColor": "#FFFFFF",    // ハイライト時文字
    "ContextMenuOuterBackgroundColor": "#151B24"       // メニュー外周背景
  },

  // ── その他（マニュアル・履歴パネル） ──
  "Misc": {
    "GlowBarGlowColor": "#569CD6",                     // 進捗バー光
    "ScanBarColor": "#569CD6",                         // スキャンバー
    "LoadingOverlayColor": "#CC151B24",                // マニュアル背景
    "ShadowColor": "#000000",                          // シャドウ
    "TelemetryBackgroundColor": "#E6151B24",           // テレメトリーパネル背景
    "TelemetryBorderColor": "#40569CD6",               // 枠線
    "TelemetryTitleColor": "#569CD6",                  // パネルタイトル色
    "TelemetryValueColor": "#E1E8F0"                   // ★数値・履歴テキスト：背景に溶け込まない高コントラスト・グレー
  }
}