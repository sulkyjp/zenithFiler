{
  // ============================================================
  //  Zenith Filer Theme Configuration
  //  カラーコード: #RRGGBB / #AARRGGBB / 色名 (例: Cyan)
  //  テーマ選択時に即座に反映されます（再起動不要）
  // ============================================================

  // テーマのメタデータ
  "Description": "色によるバイアスを排除し、データの形だけに集中するための作業環境",
  "Author": "KAKASAKA",
  "Category": "Professional",

  // ── 基本 UI 要素 ──
  "Base": {
    "BackgroundColor": "#121212",                      // メイン背景色
    "SidebarColor": "#1E1E1E",                         // サイドバー（ナビペイン）背景色
    "HeaderColor": "#121212",                          // ヘッダー背景色
    "TitleBarColor": "#333333",                        // タイトルバー背景色（チャコールブラック）
    "BorderColor": "#444444",                          // 枠線・区切り線の色
    "PrimaryTextColor": "#E0E0E0",                     // メインテキスト色（ほぼ黒）
    "SecondaryTextColor": "#888888",                   // サブテキスト・補足情報の色
    "InputBackgroundColor": "#1E1E1E",                 // テキスト入力欄の背景色
    "FocusedPaneBackgroundColor": "#1E1E1E",           // フォーカス中ペインの背景色（標準よりわずかに濃い）
    "FocusedPaneTextColor": "#FFFFFF",                 // フォーカス中ペインのテキスト色
    "FocusedPaneHeaderBackgroundColor": "#333333",     // フォーカス中ペインのヘッダー背景色（一覧より濃い）
    "OnePointDarkColor": "#AAAAAA",                    // ワンポイント用ダーク帯（お気に入り第1階層・アクティブタブ）
    "TabSeparatorColor": "#444444",                    // タブ間の区切り線
    "TabHoverColor": "#333333",                        // タブホバー時の背景色
    "ToolbarSeparatorColor": "#888888",                // ツールバーセパレーター色
    "TreeLineColor": "#444444"                         // ツリービュー接続線の色
  },

  // ── リスト・選択・ホバー ──
  "List": {
    "ListHoverColor": "#333333",                       // リスト項目ホバー時の背景色
    "SelectionColor": "#444444",                       // 選択項目のハイライト色
    "ButtonHoverColor": "#444444",                     // ボタンホバー時の背景色
    "InactiveSelectionColor": "#1E1E1E",               // 非アクティブペインの選択色
    "OptionSelectedColor": "#AAAAAA",                  // ラジオボタン等の選択時背景色
    "OptionSelectedHoverColor": "#CCCCCC",             // ラジオボタン等の選択＋ホバー時背景色
    "CheckboxHoverColor": "#333333",                   // チェックボックスホバー時の背景色
    "CheckedHoverAccentColor": "#FFFFFF"               // チェック済みホバー時のアクセント色（暗めのアクセント）
  },

  // ── インデックス検索 ──
  "Search": {
    "IndexSearchBackgroundColor": "#1E1E1E",           // インデックス検索モード時の背景色（穏やかな黄色）
    "IndexSearchIconColor": "#FFFFFF",                 // インデックス検索の雷アイコン色（ゴールド）
    "IndexSearchFocusBorderColor": "#FFFFFF"           // インデックス検索＋フォーカス時のボーダー色（アンバー）
  },

  // ── アクセント・エラー・破壊的操作 ──
  "Accent": {
    "AccentColor": "#AAAAAA",                          // アクセントカラー（リンク・強調 / Solarized Blue）
    "ErrorTextColor": "#FFFFFF",                       // エラーテキスト色
    "DestructiveHoverBackgroundColor": "#FFFFFF",      // 破壊的操作ホバー時の背景色（暗い赤）
    "DestructiveIconColor": "#000000"                  // 破壊的操作のアイコン色（明るい赤）
  },

  // ── 右クリックメニュー ──
  "ContextMenu": {
    "ContextMenuSeparatorColor": "#444444",            // コンテキストメニューのセパレーター色
    "ContextMenuBackgroundColor": "#1E1E1E",           // コンテキストメニューの背景色
    "ContextMenuBorderColor": "#AAAAAA",               // コンテキストメニューの枠線色
    "ContextMenuTextColor": "#E0E0E0",                 // コンテキストメニューのテキスト色
    "ContextMenuIconColor": "#E0E0E0",                 // コンテキストメニューのアイコン色
    "ContextMenuShortcutColor": "#888888",             // コンテキストメニューのショートカットキー表示色
    "ContextMenuDisabledColor": "#444444",             // コンテキストメニューの無効項目テキスト色
    "ContextMenuDisabledIconColor": "#444444",         // コンテキストメニューの無効項目アイコン色
    "ContextMenuHighlightShortcutColor": "#FFFFFF",    // ハイライト時のショートカットキー表示色
    "ContextMenuOuterBackgroundColor": "#121212"       // コンテキストメニュー外枠の背景色
  },

  // ── その他（進捗バー・オーバーレイ・テレメトリー） ──
  "Misc": {
    "GlowBarGlowColor": "#FFFFFF",                     // 進捗バー（GlowBar）のグロー色
    "ScanBarColor": "#AAAAAA",                         // スキャンバーの色
    "LoadingOverlayColor": "#99000000",                // ローディングオーバーレイ色（#AARRGGBB 半透明）
    "ShadowColor": "#000000",                          // ダイアログのシャドウ色
    "TelemetryBackgroundColor": "#E6000000",           // テレメトリーパネル背景色（#AARRGGBB 半透明）
    "TelemetryBorderColor": "#40FFFFFF",               // テレメトリーパネル枠線色（#AARRGGBB 半透明）
    "TelemetryTitleColor": "#FFFFFF",                  // テレメトリーパネルのタイトル色
    "TelemetryValueColor": "#E0E0E0"                   // テレメトリーパネルの値テキスト色
  }
}