    "DestructiveIconColor": "#E08E8E"                  // 破壊的操作のアイコン色
  },

  // ── 右クリックメニュー ──
  "ContextMenu": {
    "ContextMenuSeparatorColor": "#D6CFDE",            // コンテキストメニューのセパレーター色
    "ContextMenuBackgroundColor": "#F3F0F5",           // コンテキストメニューの背景色
    "ContextMenuBorderColor": "#B4ADC2",               // コンテキストメニューの枠線色
    "ContextMenuTextColor": "#4A4452",                 // コンテキストメニューのテキスト色
    "ContextMenuIconColor": "#7E718A",                 // コンテキストメニューのアイコン色
    "ContextMenuShortcutColor": "#8B8496",             // コンテキストメニューのショートカットキー表示色
    "ContextMenuDisabledColor": "#D6CFDE",             // コンテキストメニューの無効項目テキスト色
    "ContextMenuDisabledIconColor": "#D6CFDE",         // コンテキストメニューの無効項目アイコン色
    "ContextMenuHighlightShortcutColor": "#4A4452",    // ハイライト時のショートカットキー表示色
    "ContextMenuOuterBackgroundColor": "#FFFFFF"       // コンテキストメニュー外枠の背景色
  },

  // ── その他（進捗バー・オーバーレイ・テレメトリー） ──
  "Misc": {
    "GlowBarGlowColor": "#D6CFDE",                     // 進捗バー（GlowBar）のグロー色
    "ScanBarColor": "#B4ADC2",                         // スキャンバーの色
    "LoadingOverlayColor": "#667E718A",                // ローディングオーバーレイ色
    "ShadowColor": "#000000",                          // ダイアログのシャドウ色
    "TelemetryBackgroundColor": "#E64A4452",           // テレメトリーパネル背景色
    "TelemetryBorderColor": "#40B4ADC2",               // テレメトリーパネル枠線色
    "TelemetryTitleColor": "#B4ADC2",                  // テレメトリーパネルのタイトル色
    "TelemetryValueColor": "#F3F0F5"                   // テレメトリーパネルの値テキスト色
  }
}