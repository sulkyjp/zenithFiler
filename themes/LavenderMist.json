{
  // ============================================================
  //  Zenith Filer Theme Configuration
  //  カラーコード: #RRGGBB / #AARRGGBB / 色名 (例: Cyan)
  //  テーマ選択時に即座に反映されます（再起動不要）
  // ============================================================

  // テーマのメタデータ
  "Description": "優雅なラベンダーとミスティグレーが織りなす、上品で落ち着いたフェミニン・スタイル（女性向け）",
  "Author": "赤阪和彦",

  // ── 基本 UI 要素 ──
  "Base": {
    "BackgroundColor": "#F3F0F5",                      // メイン背景色
    "SidebarColor": "#EBE7F0",                         // サイドバー背景色
    "HeaderColor": "#F3F0F5",                          // ヘッダー背景色
    "TitleBarColor": "#7E718A",                        // タイトルバー背景色（ダスティパープル）
    "BorderColor": "#D6CFDE",                          // 枠線・区切り線の色
    "PrimaryTextColor": "#4A4452",                     // メインテキスト色
    "SecondaryTextColor": "#8B8496",                   // サブテキスト・補足情報の色
    "InputBackgroundColor": "#FFFFFF",                 // テキスト入力欄の背景色
    "FocusedPaneBackgroundColor": "#EFEBFC",           // フォーカス中ペインの背景色
    "FocusedPaneTextColor": "#4A4452",                 // フォーカス中ペインのテキスト色
    "FocusedPaneHeaderBackgroundColor": "#DFD8E8",     // フォーカス中ペインのヘッダー背景色
    "OnePointDarkColor": "#7E718A",                    // ワンポイント用ダーク帯
    "TabSeparatorColor": "#D6CFDE",                    // タブ間の区切り線
    "TabHoverColor": "#EFEBFC",                        // タブホバー時の背景色
    "ToolbarSeparatorColor": "#8B8496",                // ツールバーセパレーター色
    "TreeLineColor": "#B4ADC2"                         // ツリービュー接続線の色
  },

  // ── リスト・選択・ホバー ──
  "List": {
    "ListHoverColor": "#DFD8E8",                       // リスト項目ホバー時の背景色
    "SelectionColor": "#E2D9F0",                       // 選択項目のハイライト色
    "ButtonHoverColor": "#D6CFDE",                     // ボタンホバー時の背景色
    "InactiveSelectionColor": "#EFEBFC",               // 非アクティブペインの選択色
    "OptionSelectedColor": "#B4ADC2",                  // ラジオボタン等の選択時背景色
    "OptionSelectedHoverColor": "#A39AB5",             // ラジオボタン等の選択＋ホバー時背景色
    "CheckboxHoverColor": "#EFEBFC",                   // チェックボックスホバー時の背景色
    "CheckedHoverAccentColor": "#7E718A"               // チェック済みホバー時のアクセント色
  },

  // ── インデックス検索 ──
  "Search": {
    "IndexSearchBackgroundColor": "#F8F6FA",           // インデックス検索モード時の背景色
    "IndexSearchIconColor": "#B4ADC2",                 // インデックス検索の雷アイコン色
    "IndexSearchFocusBorderColor": "#7E718A"           // インデックス検索＋フォーカス時のボーダー色
  },

  // ── アクセント・エラー・破壊的操作 ──
  "Accent": {
    "AccentColor": "#9B8AB0",                          // アクセントカラー
    "ErrorTextColor": "#D17A7A",                       // エラーテキスト色
