{
  // ============================================================
  //  Zenith Filer Theme Configuration: PaperWhite (Optimized)
  //  改善点: 選択時のコントラスト確保、サブテキストの視認性向上
  // ============================================================

  "Description": "紙とインクのコントラストを再現した、文字情報の整理に特化したテーマ",
  "Author": "K.AKASAKA",
  "Category": "Standard",

  "Base": {
    "BackgroundColor": "#FFFFFF",
    "SidebarColor": "#F8F8F8",                         // わずかに明度を下げ、メイン領域との境界を明確化
    "HeaderColor": "#FFFFFF",
    "TitleBarColor": "#1A1A1A",                        // 純黒よりわずかに柔らかい黒で高級感を演出
    "BorderColor": "#D0D0D0",                          // 境界線を少し濃くし、骨格を強調
    "PrimaryTextColor": "#000000",
    "SecondaryTextColor": "#444444",                   // #666666から濃くし、補足情報の読みやすさを改善
    "InputBackgroundColor": "#FFFFFF",
    "FocusedPaneBackgroundColor": "#FDFDFD",
    "FocusedPaneTextColor": "#000000",
    "FocusedPaneHeaderBackgroundColor": "#EFEFEF",
    "OnePointDarkColor": "#000000",
    "TabSeparatorColor": "#D0D0D0",
    "TabHoverColor": "#F0F0F0",
    "ToolbarSeparatorColor": "#444444",
    "TreeLineColor": "#BBBBBB"                         // 視認性向上のため少し濃く調整
  },

  "List": {
    "ListHoverColor": "#F2F2F2",
    "SelectionColor": "#E8E8E8",
    "ButtonHoverColor": "#E8E8E8",
    "InactiveSelectionColor": "#F5F5F5",
    "OptionSelectedColor": "#D0D0D0",                  // #333333から変更。黒文字が最も読みやすいグレーに
    "OptionSelectedHoverColor": "#C0C0C0",             // ホバー時も黒文字を維持できる濃度
    "CheckboxHoverColor": "#F0F0F0",
    "CheckedHoverAccentColor": "#1A1A1A"
  },

  "Search": {
    "IndexSearchBackgroundColor": "#FFFFF0",
    "IndexSearchIconColor": "#DAA520",                 // 視認性の高い落ち着いたゴールド
    "IndexSearchFocusBorderColor": "#000000"
  },

  "Accent": {
    "AccentColor": "#004488",                          // 純黒と区別するため、万年筆の「ブルーブラック」を採用
    "ErrorTextColor": "#B22222",                       // 白背景で目に刺さらない深い赤
    "DestructiveHoverBackgroundColor": "#440000",
    "DestructiveIconColor": "#CC0000"
  },

  "ContextMenu": {
    "ContextMenuSeparatorColor": "#E5E5E5",
    "ContextMenuBackgroundColor": "#FFFFFF",
    "ContextMenuBorderColor": "#C0C0C0",
    "ContextMenuTextColor": "#000000",
    "ContextMenuIconColor": "#1A1A1A",
    "ContextMenuShortcutColor": "#555555",
    "ContextMenuDisabledColor": "#BBBBBB",
    "ContextMenuDisabledIconColor": "#D0D0D0",
    "ContextMenuHighlightShortcutColor": "#000000",
    "ContextMenuOuterBackgroundColor": "#FFFFFF"
  },

  "Misc": {
    "GlowBarGlowColor": "#000000",
    "ScanBarColor": "#1A1A1A",
    "LoadingOverlayColor": "#4D000000",                // 透明度を調整し、背後が微かに見えるように
    "ShadowColor": "#000000",
    "TelemetryBackgroundColor": "#F2000000",
    "TelemetryBorderColor": "#22000000",
    "TelemetryTitleColor": "#FFFFFF",
    "TelemetryValueColor": "#FFFFFF"
  }
}