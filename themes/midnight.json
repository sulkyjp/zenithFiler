{
  // ============================================================
  //  Zenith Filer Theme Configuration: Midnight (Professional)
  //  抜本的改善：境界線の強調、ボタン・フォームの視認性を最大化
  // ============================================================

  "Description": "暗所での集中力を極限まで高める、目に優しいモダンな漆黒のダークモード",
  "Author": "K.AKASAKA",
  "Category": "Professional",

  // ── 基本 UI 要素（境界線とテキストのコントラストを強化） ──
  "Base": {
    "BackgroundColor": "#121212",                      // メイン背景：より深い漆黒へ
    "SidebarColor": "#1A1A1A",                         // サイドバー：操作エリアとの分離を明確化
    "HeaderColor": "#121212",                          // ヘッダー背景
    "TitleBarColor": "#252525",                        // タイトルバー
    "TitleBarTextColor": "#F0F0F0",                    // タイトルバーの文字・ボタン色
    "BorderColor": "#4A4A4A",                          // ★枠線：ボタンやフォームの輪郭を「見える」ように明度を大幅向上
    "PrimaryTextColor": "#F0F0F0",                     // ★メイン文字色：暗い背景で最も読みやすい高輝度グレーへ
    "SecondaryTextColor": "#B0B0B0",                   // ★サブ文字色：補足情報が消えないよう濃度を調整
    "InputBackgroundColor": "#222222",                 // ★入力欄背景：枠線を目立たせるため、あえて背景より一段深く設定
    "FocusedPaneBackgroundColor": "#1E1E1E",           // フォーカス中ペイン背景
    "FocusedPaneTextColor": "#FFFFFF",                 // フォーカス中文字色：純白
    "FocusedPaneHeaderBackgroundColor": "#2A2A2A",     // フォーカス中ヘッダー
    "OnePointDarkColor": "#3E3E42",                    // アクセント用ダーク帯
    "TabSeparatorColor": "#4A4A4A",                    // タブ区切り線
    "TabHoverColor": "#2D2D2E",                        // タブホバー背景
    "ToolbarSeparatorColor": "#454545",                // ツールバーセパレーター
    "TreeLineColor": "#606060",                         // ツリー階層線：視認性を向上
    "PopupBackgroundColor": "#1E1E1E",                 // フローティングポップアップの背景色
    "PopupTextColor": "#E0E0E0",                       // ポップアップ内のテキスト色
    "PopupHoverBackgroundColor": "#3E3E42"            // ポップアップリスト項目のホバー背景色
  },

  // ── リスト・選択・ボタン（リカバリ画面等の視認性を解決） ──
  "List": {
    "ListHoverColor": "#2A2D2E",                       // リスト項目ホバー
    "SelectionColor": "#264F78",                       // リスト項目選択
    "ButtonHoverColor": "#4E4E52",                     // ★ボタンホバー：マウスを乗せた際に確実に「押せる」ことを明示
    "InactiveSelectionColor": "#37373D",               // 非アクティブ選択背景
    "OptionSelectedColor": "#335C99",                  // ★選択ボタン背景：リカバリ画面等の「選んでいる」ボタンを際立たせる
    "OptionSelectedHoverColor": "#4070B0",             // 選択中ホバー
    "CheckboxHoverColor": "#2D2D30",                   // チェックボックスホバー
    "CheckedHoverAccentColor": "#007ACC",               // チェック済み強調
    "FilterActiveIndicatorColor": "#007ACC",           // アクティブフィルターのインジケーター色
    "FilterChipBackgroundColor": "#2A2A2A",            // フィルターチップのデフォルト背景色
    "FilterChipBorderColor": "#606060",                // フィルターチップの枠線色
    "FilterToggleCheckedBackgroundColor": "#264F78"   // フィルタートグルのチェック済み背景色
  },

  // ── インデックス検索 ──
  "Search": {
    "IndexSearchBackgroundColor": "#3E3723",           // 検索バー背景
    "IndexSearchIconColor": "#F1C40F",                 // 検索アイコン
    "IndexSearchFocusBorderColor": "#D4AC0D"           // 検索フォーカス枠
  },

  // ── アクセント・エラー ──
  "Accent": {
    "AccentColor": "#007ACC",                          // 強調色：VSCode風ブルー
    "ErrorTextColor": "#F44747",                       // エラー文字
    "DestructiveHoverBackgroundColor": "#611616",      // 破壊的ホバー
    "DestructiveIconColor": "#D16969",                  // 破壊的アイコン
    "SuccessColor": "#4EC94E"                         // 成功・有効状態のアイコン色
  },

  // ── 右クリックメニュー ──
  "ContextMenu": {
    "ContextMenuSeparatorColor": "#454545",            // メニュー区切り線
    "ContextMenuBackgroundColor": "#1E1E1E",           // メニュー背景
    "ContextMenuBorderColor": "#4A4A4A",               // メニュー枠線
    "ContextMenuTextColor": "#E0E0E0",                 // メニュー文字色
    "ContextMenuIconColor": "#BBBBBB",                 // メニューアイコン
    "ContextMenuShortcutColor": "#909090",             // ショートカット文字
    "ContextMenuDisabledColor": "#666666",             // 無効項目
    "ContextMenuDisabledIconColor": "#555555",         // 無効アイコン
    "ContextMenuHighlightShortcutColor": "#FFFFFF",    // ハイライト時ショートカット
    "ContextMenuOuterBackgroundColor": "#121212"       // メニュー外枠
  },

  // ── その他（マニュアル・統計情報） ──
  "Misc": {
    "GlowBarGlowColor": "#00CCFF",                     // 進捗バー光
    "ScanBarColor": "#007ACC",                         // スキャンバー
    "LoadingOverlayColor": "#CC121212",                // マニュアル背景
    "ShadowColor": "#000000",                          // シャドウ
    "TelemetryBackgroundColor": "#E61A1A1A",           // 統計・マニュアルパネル背景
    "TelemetryBorderColor": "#40808080",               // パネル枠線
    "TelemetryTitleColor": "#569CD6",                  // マニュアルタイトル
    "TelemetryValueColor": "#DCDCDC",                   // マニュアル本文・数値
    "PreviewPanelBorderColor": "#4A4A4A",              // クイックプレビューパネルの枠線色
    "PreviewPdfBackgroundColor": "#2A2A2A",            // PDFプレビューのキャンバス背景色
    "IndexStatusNormalColor": "#E6B800",               // インデックス状態テキストの通常色
    "IndexStatusWarmColor": "#D08770"                 // インデックスの日時・件数バッジ色
  }
}