{
  // ============================================================
  //  Zenith Filer Theme Configuration
  //  カラーコード: #RRGGBB / #AARRGGBB / 色名 (例: Cyan)
  //  テーマ選択時に即座に反映されます（再起動不要）
  // ============================================================

  // テーマのメタデータ
  "Description": "暗所での集中力を高める、目に優しいダークモード",
  "Author": "赤阪和彦",

  // ── 基本 UI 要素 ──
  "Base": {
    "BackgroundColor": "#181818",                      // メイン背景色
    "SidebarColor": "#1E1E1E",                         // サイドバー（ナビペイン）背景色
    "HeaderColor": "#181818",                          // ヘッダー背景色
    "TitleBarColor": "#2D2D2D",                        // タイトルバー背景色（チャコールブラック）
    "BorderColor": "#333333",                          // 枠線・区切り線の色
    "PrimaryTextColor": "#D4D4D4",                     // メインテキスト色（ほぼ黒）
    "SecondaryTextColor": "#808080",                   // サブテキスト・補足情報の色
    "InputBackgroundColor": "#2D2D2D",                 // テキスト入力欄の背景色
    "FocusedPaneBackgroundColor": "#1E1E1E",           // フォーカス中ペインの背景色（標準よりわずかに濃い）
    "FocusedPaneTextColor": "#FFFFFF",                 // フォーカス中ペインのテキスト色
    "FocusedPaneHeaderBackgroundColor": "#252526",     // フォーカス中ペインのヘッダー背景色（一覧より濃い）
    "OnePointDarkColor": "#3E3E42",                    // ワンポイント用ダーク帯（お気に入り第1階層・アクティブタブ）
    "TabSeparatorColor": "#333333",                    // タブ間の区切り線
    "TabHoverColor": "#2A2D2E",                        // タブホバー時の背景色
    "ToolbarSeparatorColor": "#454545",                // ツールバーセパレーター色
    "TreeLineColor": "#454545"                        // ツリービュー接続線の色
  },

  // ── リスト・選択・ホバー ──
  "List": {
    "ListHoverColor": "#2A2D2E",                       // リスト項目ホバー時の背景色
    "SelectionColor": "#264F78",                       // 選択項目のハイライト色
    "ButtonHoverColor": "#3E3E42",                     // ボタンホバー時の背景色
    "InactiveSelectionColor": "#37373D",               // 非アクティブペインの選択色
    "OptionSelectedColor": "#094771",                  // ラジオボタン等の選択時背景色
    "OptionSelectedHoverColor": "#0C5A94",             // ラジオボタン等の選択＋ホバー時背景色
    "CheckboxHoverColor": "#2D2D30",                   // チェックボックスホバー時の背景色
    "CheckedHoverAccentColor": "#007ACC"              // チェック済みホバー時のアクセント色（暗めのアクセント）
  },

  // ── インデックス検索 ──
  "Search": {
    "IndexSearchBackgroundColor": "#3E3723",           // インデックス検索モード時の背景色（穏やかな黄色）
    "IndexSearchIconColor": "#F1C40F",                 // インデックス検索の雷アイコン色（ゴールド）
    "IndexSearchFocusBorderColor": "#D4AC0D"          // インデックス検索＋フォーカス時のボーダー色（アンバー）
  },

  // ── アクセント・エラー・破壊的操作 ──
  "Accent": {
    "AccentColor": "#007ACC",                          // アクセントカラー（リンク・強調 / Solarized Blue）
    "ErrorTextColor": "#F44747",                       // エラーテキスト色
    "DestructiveHoverBackgroundColor": "#611616",      // 破壊的操作ホバー時の背景色（暗い赤）
    "DestructiveIconColor": "#D16969"                 // 破壊的操作のアイコン色（明るい赤）
  },

  // ── 右クリックメニュー ──
  "ContextMenu": {
    "ContextMenuSeparatorColor": "#454545",            // コンテキストメニューのセパレーター色
    "ContextMenuBackgroundColor": "#252526",           // コンテキストメニューの背景色
    "ContextMenuBorderColor": "#454545",               // コンテキストメニューの枠線色
    "ContextMenuTextColor": "#CCCCCC",                 // コンテキストメニューのテキスト色
    "ContextMenuIconColor": "#BBBBBB",                 // コンテキストメニューのアイコン色
    "ContextMenuShortcutColor": "#808080",             // コンテキストメニューのショートカットキー表示色
    "ContextMenuDisabledColor": "#666666",             // コンテキストメニューの無効項目テキスト色
    "ContextMenuDisabledIconColor": "#555555",         // コンテキストメニューの無効項目アイコン色
    "ContextMenuHighlightShortcutColor": "#FFFFFF",    // ハイライト時のショートカットキー表示色
    "ContextMenuOuterBackgroundColor": "#1E1E1E"      // コンテキストメニュー外枠の背景色
  },

  // ── その他（進捗バー・オーバーレイ・テレメトリー） ──
  "Misc": {
    "GlowBarGlowColor": "#00CCFF",                     // 進捗バー（GlowBar）のグロー色
    "ScanBarColor": "#007ACC",                         // スキャンバーの色
    "LoadingOverlayColor": "#99181818",                // ローディングオーバーレイ色（#AARRGGBB 半透明）
    "ShadowColor": "#000000",                          // ダイアログのシャドウ色
    "TelemetryBackgroundColor": "#E61E1E1E",           // テレメトリーパネル背景色（#AARRGGBB 半透明）
    "TelemetryBorderColor": "#40808080",               // テレメトリーパネル枠線色（#AARRGGBB 半透明）
    "TelemetryTitleColor": "#569CD6",                  // テレメトリーパネルのタイトル色
    "TelemetryValueColor": "#DCDCDC"                  // テレメトリーパネルの値テキスト色
  }
}
