{
  "Description": "深煎りコーヒーとラテの配色。書斎で落ち着いて作業するためのテーマ",
  "Author": "K.AKASAKA",
  "Category": "WarmCozy",

  // ── 基本 UI 要素 ──
  "Base": {
    "BackgroundColor": "#FFF8E7",                      // メイン領域（ファイルリスト等）の背景色：クリーム
    "SidebarColor": "#E8DCCA",                         // サイドバー（ナビペイン）の背景色：ラテ
    "HeaderColor": "#FFF8E7",                          // カラムヘッダーの背景色
    "TitleBarColor": "#2C1B0E",                        // タイトルバー（最上部）の背景色：エスプレッソ
    "TitleBarTextColor": "#FFF8E7",                    // タイトルバーの文字・ボタン色
    "BorderColor": "#D2B48C",                          // ボタンやペインの境界線の色：タン
    "PrimaryTextColor": "#2C1B0E",                     // メインテキスト色（ファイル名等）：焦げ茶
    "SecondaryTextColor": "#8B5A2B",                   // サブテキスト（サイズ、説明文等）の色
    "InputBackgroundColor": "#FFFFFF",                 // テキストボックス等の入力エリア背景色
    "FocusedPaneBackgroundColor": "#F2E8D5",           // フォーカスされているペインの背景色
    "FocusedPaneTextColor": "#1A0F08",                 // フォーカスされているペイン内のテキスト色
    "FocusedPaneHeaderBackgroundColor": "#DBCFB6",     // フォーカスされているペインのヘッダー強調背景色
    "OnePointDarkColor": "#4E3629",                    // UIのアクセントとなる濃い茶色
    "TabSeparatorColor": "#D2B48C",                    // タブ間の区切り線
    "TabHoverColor": "#E8DCCA",                        // タブをホバーした際の色
    "ToolbarSeparatorColor": "#8B5A2B",                // ツールバー内の区切り線
    "TreeLineColor": "#A68966",                         // ツリービューの階層を示す線の色
    "PopupBackgroundColor": "#FFF8E7",                 // フローティングポップアップの背景色
    "PopupTextColor": "#2C1B0E",                       // ポップアップ内のテキスト色
    "PopupHoverBackgroundColor": "#4E3629"            // ポップアップリスト項目のホバー背景色
  },

  // ── リスト・選択状態 ──
  "List": {
    "ListHoverColor": "#E8DCCA",                       // リスト項目をホバーした際の背景色
    "SelectionColor": "#D2B48C",                       // リスト項目を選択した際の背景色
    "ButtonHoverColor": "#C4A484",                     // ボタンをホバーした際の背景色
    "InactiveSelectionColor": "#F2E8D5",               // フォーカスが外れた状態の選択背景色
    "OptionSelectedColor": "#FCF5E5",                  // ★選択されたボタン背景（焦げ茶文字が最も鮮明に読めるよう極限まで明るく調整）
    "OptionSelectedHoverColor": "#F5EAD6",             // 選択中のボタンをホバーした際の色
    "CheckboxHoverColor": "#F2E8D5",                   // チェックボックスのホバー背景色
    "CheckedHoverAccentColor": "#4E3629",               // チェック済み項目の強調アクセント色
    "FilterActiveIndicatorColor": "#4E3629",           // アクティブフィルターのインジケーター色
    "FilterChipBackgroundColor": "#FFFFFF",            // フィルターチップのデフォルト背景色
    "FilterChipBorderColor": "#8B5A2B",                // フィルターチップの枠線色
    "FilterToggleCheckedBackgroundColor": "#F2E8D5"   // フィルタートグルのチェック済み背景色
  },

  // ── 検索機能 ──
  "Search": {
    "IndexSearchBackgroundColor": "#FAF3E0",           // 検索バーの背景色
    "IndexSearchIconColor": "#8B4513",                 // 検索アイコンの色
    "IndexSearchFocusBorderColor": "#2C1B0E"           // 検索フォーカス時の枠線
  },

  // ── 強調・エラー ──
  "Accent": {
    "AccentColor": "#8B4513",                          // 強調箇所、プログレスバー等のアクセント色：シナモン
    "ErrorTextColor": "#A52A2A",                       // エラーメッセージのテキスト色
    "DestructiveHoverBackgroundColor": "#3D0000",      // 削除等の危険な操作のホバー背景色
    "DestructiveIconColor": "#CD5C5C",                  // 破壊的操作のアイコン色
    "SuccessColor": "#6B8E23"                         // 成功・有効状態のアイコン色
  },

  // ── 右クリックメニュー ──
  "ContextMenu": {
    "ContextMenuSeparatorColor": "#D2B48C",            // メニュー内の区切り線の色
    "ContextMenuBackgroundColor": "#FFF8E7",           // メニュー自体の背景色
    "ContextMenuBorderColor": "#4E3629",               // メメニューの外枠の色
    "ContextMenuTextColor": "#2C1B0E",                 // メニュー内のテキスト色
    "ContextMenuIconColor": "#4E3629",                 // メニュー内のアイコン色
    "ContextMenuShortcutColor": "#8B5A2B",             // ショートカットキーの文字色
    "ContextMenuDisabledColor": "#BC8F8F",             // 無効なメニュー項目のテキスト色
    "ContextMenuDisabledIconColor": "#D2B48C",         // 無効な項目のアイコン色
    "ContextMenuHighlightShortcutColor": "#000000",    // ハイライト時のショートカットキー色
    "ContextMenuOuterBackgroundColor": "#FFFFFF"       // メニュー外周の背景色
  },

  // ── その他 ──
  "Misc": {
    "GlowBarGlowColor": "#8B4513",                     // プログレスバー（GlowBar）の光るエフェクト色
    "ScanBarColor": "#A0522D",                         // スキャン実行中のバーの色
    "LoadingOverlayColor": "#664E3629",                // 読み込み中画面の被せ色（半透明）
    "ShadowColor": "#2C1B0E",                          // ダイアログ等の影の色
    "TelemetryBackgroundColor": "#E62C1B0E",           // 統計情報等のオーバーレイ背景
    "TelemetryBorderColor": "#40D2B48C",               // 統計情報の枠線
    "TelemetryTitleColor": "#F5DEB3",                  // 統計情報のタイトル文字色
    "TelemetryValueColor": "#FFF8E7",                   // 統計情報の数値文字色
    "PreviewPanelBorderColor": "#D2B48C",              // クイックプレビューパネルの枠線色
    "PreviewPdfBackgroundColor": "#FFF8E7",            // PDFプレビューのキャンバス背景色
    "IndexStatusNormalColor": "#8B6914",               // インデックス状態テキストの通常色
    "IndexStatusWarmColor": "#A0522D"                 // インデックスの日時・件数バッジ色
  }
}