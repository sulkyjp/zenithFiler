  // ── その他（進捗バー・オーバーレイ・テレメトリー） ──
  "Misc": {
    "GlowBarGlowColor": "#FFD700",                     // 進捗バー（GlowBar）のグロー色（黄金の輝き）
    "ScanBarColor": "#D4AF37",                         // スキャンバーの色
    "LoadingOverlayColor": "#99000000",                // ローディングオーバーレイ色（#AARRGGBB 半透明）
    "ShadowColor": "#000000",                          // ダイアログのシャドウ色
    "TelemetryBackgroundColor": "#E6121212",           // テレメトリーパネル背景色（#AARRGGBB 半透明）
    "TelemetryBorderColor": "#40D4AF37",               // テレメトリーパネル枠線色（#AARRGGBB 半透明）
    "TelemetryTitleColor": "#FFD700",                  // テレメトリーパネルのタイトル色
    "TelemetryValueColor": "#E0E0E0"                   // テレメトリーパネルの値テキスト色
