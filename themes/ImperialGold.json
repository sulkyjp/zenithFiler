    "TreeLineColor": "#5C5238"                         // ツリービュー接続線の色
  },

  // ── リスト・選択・ホバー ──
  "List": {
    "ListHoverColor": "#2A2A2A",                       // リスト項目ホバー時の背景色
    "SelectionColor": "#403820",                       // 選択項目のハイライト色（深いゴールド）
    "ButtonHoverColor": "#333333",                     // ボタンホバー時の背景色
