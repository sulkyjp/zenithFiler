    "HeaderColor": "#121212",                          // ヘッダー背景色
    "TitleBarColor": "#000000",                        // タイトルバー背景色（純黒）
    "BorderColor": "#332B1A",                          // 枠線・区切り線の色（暗いブロンズ）
    "PrimaryTextColor": "#E0E0E0",                     // メインテキスト色（オフホワイト）
    "SecondaryTextColor": "#888888",                   // サブテキスト・補足情報の色
    "InputBackgroundColor": "#1E1E1E",                 // テキスト入力欄の背景色
    "FocusedPaneBackgroundColor": "#1A1A1A",           // フォーカス中ペインの背景色
