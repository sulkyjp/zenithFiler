{
  // ============================================================
  //  Zenith Filer Theme Configuration
  //  カラーコード: #RRGGBB / #AARRGGBB / 色名 (例: Cyan)
  //  テーマ選択時に即座に反映されます（再起動不要）
  // ============================================================

  // テーマのメタデータ
  "Description": "漆黒の闇に黄金が煌めく、圧倒的な重厚感と気品を兼ね備えた至高のテーマ",
  "Author": "KAKASAKA",
  "Category": "Premium",

  // ── 基本 UI 要素 ──
  "Base": {
    "BackgroundColor": "#121212",                      // メイン背景色（漆黒）
