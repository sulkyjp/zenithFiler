    "ContextMenuBorderColor": "#D4AF37",               // コンテキストメニューの枠線色（ゴールド）
    "ContextMenuTextColor": "#E0E0E0",                 // コンテキストメニューのテキスト色
    "ContextMenuIconColor": "#D4AF37",                 // コンテキストメニューのアイコン色
