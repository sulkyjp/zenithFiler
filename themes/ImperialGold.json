    "CheckedHoverAccentColor": "#FFD700"               // チェック済みホバー時のアクセント色（純金）
  },

  // ── インデックス検索 ──
  "Search": {
    "IndexSearchBackgroundColor": "#1E1C15",           // インデックス検索モード時の背景色（暗い琥珀）
