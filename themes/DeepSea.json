{
  // ============================================================
  //  Zenith Filer Theme Configuration: DeepSea (Modern Premium)
  //  コンセプト：深海の層を感じさせる奥行きと、サイバーな発光ディテールの融合
  //  ブラッシュアップ：のっぺり感を排した立体的な明度設計、全要素の視認性確保
  // ============================================================

  "Description": "深海のレイヤーを感じさせる奥行きと、ネオンが美しく浮かび上がるモダン・サイバー",
  "Author": "K.AKASAKA",
  "Category": "Premium",

  // ── 基本 UI 要素（レイヤー構造を意識した明度設計） ──
  "Base": {
    "BackgroundColor": "#000D1A",                      // メイン背景色：さらに深く、インクのような濃紺で奥行きを演出
    "SidebarColor": "#051626",                         // サイドバー：メインより僅かに浮かせた質感
    "HeaderColor": "#000810",                          // ★パンくず・ヘッダー：一段沈ませることでコンテンツを際立たせる
    "TitleBarColor": "#0A243D",                        // タイトルバー：金属的な光沢を感じさせるダークネイビー
    "TitleBarTextColor": "#B0EFFF",                    // タイトルバーの文字・ボタン色
    "BorderColor": "#004060",                          // ★枠線：主張しすぎず、かつパーツの境界を明確にする「リムライト」
    "PrimaryTextColor": "#B0EFFF",                     // メイン文字：発光感のあるシアンホワイト
    "SecondaryTextColor": "#5080A0",                   // サブ文字：あえて彩度を落とし、情報の優先順位を明確化
    "InputBackgroundColor": "#00050A",                 // ★入力欄背景：深海に空いた「溝」のような暗色でフォームを明確化
    "FocusedPaneBackgroundColor": "#081F33",           // フォーカス中ペイン：発光が周囲に漏れているような質感を演出
    "FocusedPaneTextColor": "#00FFFF",                 // フォーカス中文字：鋭いネオンシアン
    "FocusedPaneHeaderBackgroundColor": "#0D3050",     // フォーカス中ヘッダー
    "OnePointDarkColor": "#000D1A",                    // ★強調時テキスト：発光背景の上で「影」として文字を浮き立たせる
    "TabSeparatorColor": "#004060",                    // タブ区切り
    "TabHoverColor": "#0D3050",                        // タブホバー背景
    "ToolbarSeparatorColor": "#1A4060",                // ツールバーセパレーター
    "TreeLineColor": "#004B73",                         // ツリービュー接続線
    "PopupBackgroundColor": "#051626",                 // フローティングポップアップの背景色
    "PopupTextColor": "#B0EFFF",                       // ポップアップ内のテキスト色
    "PopupHoverBackgroundColor": "#0D253D"            // ポップアップリスト項目のホバー背景色
  },

  // ── リスト・選択・ボタン（「押せる」質感を強化したモダン・トーン） ──
  "List": {
    "ListHoverColor": "#0D253D",                       // リスト項目ホバー：かすかな輝き
    "SelectionColor": "#153050",                       // リスト項目選択
    "ButtonHoverColor": "#1A4066",                     // ★ボタンホバー：立体感を感じさせる明度変化
    "InactiveSelectionColor": "#051626",               // 非アクティブ選択
    "OptionSelectedColor": "#00F0F0",                  // ★選択ボタン背景：バイオルミネセンス（生物発光）のような鮮烈なシアン
    "OptionSelectedHoverColor": "#33FFFF",             // 選択中ホバー
    "CheckboxHoverColor": "#0D253D",                   // チェックボックスホバー
    "CheckedHoverAccentColor": "#00FFFF",               // チェック済み強調
    "FilterActiveIndicatorColor": "#00D1D1",           // アクティブフィルターのインジケーター色
    "FilterChipBackgroundColor": "#001D33",            // フィルターチップのデフォルト背景色
    "FilterChipBorderColor": "#5080A0",                // フィルターチップの枠線色
    "FilterToggleCheckedBackgroundColor": "#0D253D"   // フィルタートグルのチェック済み背景色
  },

  // ── 検索機能 ──
  "Search": {
    "IndexSearchBackgroundColor": "#001D33",           // 検索バー背景
    "IndexSearchIconColor": "#FFB000",                 // 検索アイコン：補色に近いオレンジでアクセント
    "IndexSearchFocusBorderColor": "#00FFFF"           // 検索フォーカス枠
  },

  // ── アクセント・エラー ──
  "Accent": {
    "AccentColor": "#00D1D1",                          // ★強調色：仮想フォルダ背景。闇の中で「自ら光っている」ような透明感
    "ErrorTextColor": "#FF5555",                       // エラー文字色
    "DestructiveHoverBackgroundColor": "#500000",      // 破壊的ホバー
    "DestructiveIconColor": "#FF5555",                  // 破壊的アイコン
    "SuccessColor": "#00CC88"                         // 成功・有効状態のアイコン色
  },

  // ── 右クリックメニュー（フローティング感を演出） ──
  "ContextMenu": {
    "ContextMenuSeparatorColor": "#1A4060",            // メニュー区切り線
    "ContextMenuBackgroundColor": "#051626",           // メニュー背景
    "ContextMenuBorderColor": "#00FFFF",               // メニュー枠線：鋭いネオンの縁取り
    "ContextMenuTextColor": "#B0EFFF",                 // メニュー文字
    "ContextMenuIconColor": "#00FFFF",                 // メニューアイコン
    "ContextMenuShortcutColor": "#5080A0",             // ショートカット文字
    "ContextMenuDisabledColor": "#0D3050",             // 無効項目文字
    "ContextMenuDisabledIconColor": "#0D3050",         // 無効アイコン
    "ContextMenuHighlightShortcutColor": "#00FFFF",    // ハイライト時文字
    "ContextMenuOuterBackgroundColor": "#00050A"       // メニュー外周背景：浮遊感を強調
  },

  // ── その他（マニュアル・履歴・オーバーレイ） ──
  "Misc": {
    "GlowBarGlowColor": "#00FFFF",                     // 進捗バー光
    "ScanBarColor": "#00FFFF",                         // スキャンバー
    "LoadingOverlayColor": "#E6000D1A",                // マニュアル背景：不透明度を高め、没入感を演出
    "ShadowColor": "#000000",                          // シャドウ：深い闇を表現
    "TelemetryBackgroundColor": "#F2000D1A",           // 履歴パネル背景：透過度を抑え、情報を浮かび上がらせる
    "TelemetryBorderColor": "#4000FFFF",               // 枠線
    "TelemetryTitleColor": "#00FFFF",                  // パネルタイトル色
    "TelemetryValueColor": "#B0EFFF",                   // 履歴テキスト：視認性最大化
    "PreviewPanelBorderColor": "#004060",              // クイックプレビューパネルの枠線色
    "PreviewPdfBackgroundColor": "#051626",            // PDFプレビューのキャンバス背景色
    "IndexStatusNormalColor": "#FFB000",               // インデックス状態テキストの通常色
    "IndexStatusWarmColor": "#FF8844"                 // インデックスの日時・件数バッジ色
  }
}