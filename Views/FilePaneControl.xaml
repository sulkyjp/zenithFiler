<UserControl x:Class="ZenithFiler.FilePaneControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:local="clr-namespace:ZenithFiler"
             UseLayoutRounding="True"
             GotFocus="FilePaneControl_GotFocus"
             PreviewMouseLeftButtonDown="FilePaneControl_PreviewMouseLeftButtonDown">
    
    <UserControl.InputBindings>
        <KeyBinding Modifiers="Control" Key="T" Command="{Binding AddTabCommand}"/>
        <KeyBinding Modifiers="Control" Key="W" Command="{Binding CloseTabCommand}"/>
        <KeyBinding Modifiers="Control" Key="Tab" Command="{Binding NextTabCommand}"/>
    </UserControl.InputBindings>

    <UserControl.Resources>
        <local:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- タブの閉じるボタンのスタイル（Chrome風の円形ホバー） -->
        <Style x:Key="TabCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <!-- ホバー円がタブの上下境界線に干渉しないよう、若干小さめの余白にする -->
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- 18px ボタン前提で CornerRadius を 9 に調整し、円形ホバーがタブ内に収まるようにする -->
                        <!-- ClipToBounds="False" を設定してハイライトが欠けないようにする -->
                        <Border x:Name="BtnBorder" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="9"
                                ClipToBounds="False"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="{DynamicResource ListHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="{DynamicResource BorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- フォーカス中ペインの文字色（黒）を適用する TextBlock スタイル -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI, Meiryo UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsActive, RelativeSource={RelativeSource AncestorType=local:FilePaneControl}}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource FocusedPaneTextBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ソースタイプに応じたアイコンのスタイル -->
        <Style x:Key="SourceTypeIconStyle" TargetType="icon:PackIconLucide">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Kind" Value="HardDrive"/> <!-- Default Local -->
            <Style.Triggers>
                <DataTrigger Binding="{Binding SourceType}" Value="Server">
                    <Setter Property="Kind" Value="Server"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding SourceType}" Value="Box">
                    <Setter Property="Kind" Value="Archive"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding SourceType}" Value="SPO">
                    <Setter Property="Kind" Value="Cloud"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                            <Setter Property="Background" Value="{DynamicResource FocusedPaneBackgroundBrush}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <TabControl x:Name="MainTabControl"
                    ItemsSource="{Binding Tabs}" 
                    SelectedItem="{Binding SelectedTab}"
                    local:TabControlDragDropBehavior.IsEnabled="True"
                    local:TabContentTransitionBehavior.IsEnabled="True"
                    local:TabIndicatorSlideBehavior.IsEnabled="True"
                    BorderThickness="0" 
                    Background="Transparent"
                    Padding="0">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- タブヘッダー領域（ナビペインのビュー切り替えバーと高さを一致） -->
                        <Grid Grid.Row="0" Height="32">
                            <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}" PreviewMouseLeftButtonDown="TabHeader_PreviewMouseLeftButtonDown">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource HeaderBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource FocusedPaneHeaderBackgroundBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <DockPanel Background="Transparent" AllowDrop="True" DragOver="TabHeader_DragOver" Drop="TabHeader_Drop" VerticalAlignment="Center">
                                    <!-- タブ一覧ボタン -->
                                    <Button x:Name="TabListButton"
                                            DockPanel.Dock="Right" 
                                            Style="{StaticResource IconButton}" 
                                            Width="24" Height="24"
                                            ToolTip="タブ一覧を表示"
                                            Margin="0,0,4,0"
                                            VerticalAlignment="Center"
                                            Click="TabListButton_Click">
                                        <icon:PackIconLucide Kind="List" Width="12" Height="12" Foreground="{DynamicResource SubTextBrush}"/>
                                    </Button>
                                    
                                    <!-- 新規タブ追加ボタン -->
                                    <Button DockPanel.Dock="Right" 
                                            Style="{StaticResource IconButton}" 
                                            Command="{Binding AddTabCommand}"
                                            Width="24" Height="24"
                                            ToolTip="タブを追加 (Ctrl+T)"
                                            Margin="0,0,4,0"
                                            VerticalAlignment="Center">
                                        <icon:PackIconLucide Kind="Plus" Width="12" Height="12" Foreground="{DynamicResource SubTextBrush}"/>
                                    </Button>
                                    
                                    <ScrollViewer Background="Transparent" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" PanningMode="HorizontalOnly">
                                        <TabPanel IsItemsHost="True" Background="Transparent" Margin="0,1,0,-1"/>
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>
                            
                            <!-- タブ一覧Popup（リスト表示ボタンの下で×ボタン列が揃うよう右端揃え） -->
                            <Popup x:Name="TabListPopup"
                                   PlacementTarget="{Binding ElementName=TabListButton}"
                                   Placement="Custom"
                                   IsOpen="{Binding IsTabListPopupOpen, Mode=TwoWay}"
                                   StaysOpen="True"
                                   PopupAnimation="None"
                                   AllowsTransparency="True">
                                <Border x:Name="TabListPopupBorder"
                                        Background="{DynamicResource BackgroundBrush}"
                                        BorderBrush="#C5C0B0" BorderThickness="1"
                                        CornerRadius="6" Padding="4,4"
                                        MaxHeight="480" MinWidth="300" MaxWidth="520"
                                        Margin="0,0,28,28"
                                        RenderTransformOrigin="0.5,0" Opacity="0">
                                    <Border.RenderTransform>
                                        <TranslateTransform X="0" Y="-5"/>
                                    </Border.RenderTransform>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.22" Direction="315" Color="#000000"/>
                                    </Border.Effect>
                                    <ListBox ItemsSource="{Binding Tabs}"
                                             SelectedItem="{Binding SelectedTab}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             SelectionChanged="TabListBox_SelectionChanged">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0" ClipToBounds="False">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>  <!-- Icon -->
                                                        <ColumnDefinition Width="*"/>     <!-- Title -->
                                                        <ColumnDefinition Width="Auto"/>  <!-- Lock -->
                                                        <ColumnDefinition Width="Auto"/>  <!-- Close -->
                                                    </Grid.ColumnDefinitions>

                                                    <icon:PackIconLucide x:Name="TypeIcon" Grid.Column="0"
                                                                         Style="{StaticResource SourceTypeIconStyle}"
                                                                         Width="13" Height="13"
                                                                         Foreground="{DynamicResource SubTextBrush}"
                                                                         VerticalAlignment="Center"
                                                                         Margin="0,0,7,0"/>

                                                    <TextBlock x:Name="TitleText" Grid.Column="1"
                                                               Text="{Binding TabTitle}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Foreground="{DynamicResource SubTextBrush}"
                                                               FontSize="12"
                                                               VerticalAlignment="Center"/>

                                                    <icon:PackIconLucide x:Name="LockIcon" Grid.Column="2" Kind="Lock"
                                                                         Width="9" Height="9"
                                                                         Foreground="{DynamicResource SubTextBrush}"
                                                                         Visibility="{Binding IsLocked, Converter={StaticResource BoolToVis}}"
                                                                         Margin="5,0,0,0"
                                                                         VerticalAlignment="Center"/>

                                                    <!-- 閉じるボタン（行ホバーで白、ボタンホバーで赤） -->
                                                    <Button x:Name="CloseBtn" Grid.Column="3"
                                                            Command="{Binding CloseTabCommand}"
                                                            CommandParameter="{Binding}"
                                                            Width="18" Height="18"
                                                            ClipToBounds="False"
                                                            VerticalAlignment="Center"
                                                            Margin="4,0,0,0"
                                                            ToolTip="閉じる"
                                                            Opacity="0"
                                                            Visibility="{Binding IsLocked, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"
                                                            Click="TabListCloseButton_Click">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="CloseBtnBg" Background="Transparent"
                                                                        CornerRadius="3"
                                                                        Width="{TemplateBinding Width}" Height="{TemplateBinding Height}"
                                                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                    <icon:PackIconLucide x:Name="CloseIcon" Kind="X"
                                                                                         Width="8" Height="8"
                                                                                         HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                         Foreground="#CCCCCC"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="CloseBtnBg" Property="Background" Value="{DynamicResource DestructiveHoverBackgroundBrush}"/>
                                                                        <Setter TargetName="CloseIcon" Property="Foreground" Value="{DynamicResource DestructiveIconBrush}"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="CloseBtnBg" Property="Background" Value="#550000"/>
                                                                        <Setter TargetName="CloseIcon" Property="Foreground" Value="#FF4444"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </Grid>
                                                <DataTemplate.Triggers>
                                                    <!-- 選択行: テキスト強調 (先に定義 → ホバーで上書きされる) -->
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter TargetName="TitleText" Property="Foreground" Value="#333333"/>
                                                        <Setter TargetName="TitleText" Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                    <!-- 行ホバー: 閉じるボタン + テキスト白反転 (後に定義 → 選択行でも白が優先) -->
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter TargetName="TitleText" Property="Foreground" Value="#FFFFFF"/>
                                                        <Setter TargetName="TypeIcon" Property="Foreground" Value="#CCCCCC"/>
                                                        <Setter TargetName="LockIcon" Property="Foreground" Value="#CCCCCC"/>
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="CloseBtn"
                                                                                     Storyboard.TargetProperty="Opacity"
                                                                                     To="1" Duration="0:0:0.08"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                        <DataTrigger.ExitActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="CloseBtn"
                                                                                     Storyboard.TargetProperty="Opacity"
                                                                                     To="0" Duration="0:0:0.1"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.ExitActions>
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="MinHeight" Value="32"/>
                                                <Setter Property="Padding" Value="0,2"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Grid>
                                                                <!-- 選択背景 (底面 — Setter で制御、アニメーション不使用) -->
                                                                <Border x:Name="SelectedBg" CornerRadius="4" Margin="2,0"
                                                                        Background="Transparent"/>
                                                                <!-- ホバー背景 (前面 — 黒が選択色を完全に覆う) -->
                                                                <Border x:Name="HoverBg" CornerRadius="4" Margin="2,0">
                                                                    <Border.Background>
                                                                        <SolidColorBrush Color="Transparent"/>
                                                                    </Border.Background>
                                                                </Border>
                                                                <!-- 選択時 左アクセントバー（2px, シャープ） -->
                                                                <Border x:Name="AccentBar" HorizontalAlignment="Left"
                                                                        Width="2" CornerRadius="1" Margin="3,5,0,5"
                                                                        Background="{DynamicResource AccentBrush}"
                                                                        Visibility="Collapsed"/>
                                                                <ContentPresenter Margin="12,0,4,0" VerticalAlignment="Center"/>
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <!-- ホバー: チャコールブラック — HoverBg のみ操作 -->
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Trigger.EnterActions>
                                                                        <BeginStoryboard>
                                                                            <Storyboard>
                                                                                <ColorAnimation Storyboard.TargetName="HoverBg"
                                                                                    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                                    To="{StaticResource OnePointDarkColor}" Duration="0:0:0.06"/>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </Trigger.EnterActions>
                                                                    <Trigger.ExitActions>
                                                                        <BeginStoryboard>
                                                                            <Storyboard>
                                                                                <ColorAnimation Storyboard.TargetName="HoverBg"
                                                                                    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                                    To="Transparent" Duration="0:0:0.08"/>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </Trigger.ExitActions>
                                                                </Trigger>
                                                                <!-- 選択中: SelectedBg + アクセントバー (Setter のみ) -->
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="SelectedBg" Property="Background" Value="#EBE8DD"/>
                                                                    <Setter TargetName="AccentBar" Property="Visibility" Value="Visible"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </Border>
                            </Popup>
                            
                            <!-- スライドするアクティブインジケータ（TabIndicatorSlideBehavior が位置を制御） -->
                            <Border x:Name="TabSlideIndicator"
                                    local:TabIndicatorSlideBehavior.IsIndicatorPart="True"
                                    HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                    Height="2" Width="150" Margin="0,0,0,0"
                                    Background="{DynamicResource BorderBrush}"/>
                        </Grid>
                        
                        <!-- コンテンツ領域 -->
                        <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>

            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Grid Margin="0,0,0,0" ClipToBounds="False">
                                    <!-- 非選択タブどうしの区切り線（右側のみ） -->
                                    <Border x:Name="Separator"
                                            BorderBrush="{DynamicResource TabSeparatorBrush}"
                                            BorderThickness="0,0,1,0"
                                            Margin="0,6"
                                            VerticalAlignment="Stretch"/>

                                    <!-- タブ本体の帯（非選択時でも枠として認識できるよう1pxボーダーを付与） -->
                                    <!-- スリムさを保ちつつ、アイコンや閉じるボタンが欠けないよう上下のパディングを控えめに -->
                                    <Border x:Name="Bd"
                                            Background="Transparent"
                                            BorderBrush="{DynamicResource OnePointDarkBackground}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="8,2"
                                            Margin="2,4"
                                            MinWidth="60"
                                            MaxWidth="150"
                                            ClipToBounds="False"
                                            ContextMenuService.Placement="MousePoint">
                                    <Border.ContextMenu>
                                        <ContextMenu Placement="MousePoint" ItemContainerStyle="{StaticResource ContextMenuItemStyle}">
                                            <MenuItem Header="ロック" Command="{Binding ToggleLockCommand}" Visibility="{Binding IsLocked, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                                <MenuItem.Icon>
                                                    <icon:PackIconLucide Kind="Lock" Width="14" Height="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="ロック解除" Command="{Binding ToggleLockCommand}" Visibility="{Binding IsLocked, Converter={StaticResource BoolToVis}}">
                                                <MenuItem.Icon>
                                                    <icon:PackIconLucide Kind="LockOpen" Width="14" Height="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="このペインのタブを全てお気に入りに追加" Command="{Binding AddAllPaneTabsToFavoritesCommand}">
                                                <MenuItem.Icon>
                                                    <icon:PackIconLucide Kind="Star" Width="14" Height="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="反対ペインに移動" Command="{Binding MoveTabToOtherPaneCommand}">
                                                <MenuItem.Icon>
                                                    <icon:PackIconLucide Kind="PanelRight" Width="14" Height="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                        <!-- タブ内部の最小高さを確保し、閉じるボタンの下端がクリップされないようにする -->
                                        <Grid MinHeight="18" ClipToBounds="False">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/> <!-- Icon -->
                                                <ColumnDefinition Width="*"/>    <!-- Text -->
                                                <ColumnDefinition Width="Auto"/> <!-- Lock Icon -->
                                                <ColumnDefinition Width="Auto" MinWidth="20"/> <!-- Close Button -->
                                            </Grid.ColumnDefinitions>

                                            <icon:PackIconLucide x:Name="Icon" Grid.Column="0" Style="{StaticResource SourceTypeIconStyle}" Foreground="{DynamicResource SubTextBrush}"/>
                                            
                                            <TextBlock x:Name="Txt" Grid.Column="1" Text="{Binding TabTitle}" 
                                                       VerticalAlignment="Center" 
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource SubTextBrush}"
                                                       FontSize="12"/>

                                            <icon:PackIconLucide x:Name="LockIcon" Grid.Column="2" Kind="Lock" Width="10" Height="10" 
                                                                 Foreground="{DynamicResource SubTextBrush}"
                                                                 Visibility="{Binding IsLocked, Converter={StaticResource BoolToVis}}"
                                                                 Margin="2,0,0,0"
                                                                 VerticalAlignment="Center"/>
                                            
                                            <Button Grid.Column="3" 
                                                    Style="{StaticResource TabCloseButtonStyle}" 
                                                    Command="{Binding CloseTabCommand}"
                                                    Width="18" Height="18"
                                                    ClipToBounds="False"
                                                    VerticalAlignment="Center"
                                                    Margin="2,0,0,0"
                                                    ToolTip="閉じる (Ctrl+W)"
                                                    Visibility="{Binding IsLocked, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                                <icon:PackIconLucide x:Name="CloseIcon"
                                                                      Kind="X"
                                                                      Width="9" Height="9"
                                                                      VerticalAlignment="Center"
                                                                      Foreground="{DynamicResource SubTextBrush}"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <!-- 非選択タブ: 透明背景＋サブテキスト色。ホバー時のみわずかに濃くして存在範囲を示す -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource TabHoverBrush}"/>
                                    </Trigger>

                                    <!-- 選択タブ（どのペインでも）: ベースは明るい背景＋メインテキスト色 -->
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BackgroundBrush}"/>
                                        <Setter TargetName="Txt" Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                        <Setter TargetName="Icon" Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                        <Setter TargetName="LockIcon" Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                        <Setter TargetName="CloseIcon" Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                        <Setter TargetName="Bd" Property="Panel.ZIndex" Value="1"/>
                                        <!-- 選択タブ自身の右側の仕切り線は控えめに -->
                                        <Setter TargetName="Separator" Property="BorderBrush" Value="{DynamicResource TabSeparatorBrush}"/>
                                    </Trigger>

                                    <!-- アクティブペインかつ選択中のタブだけを「スリムな黒い帯」に（左右の仕切り線を消す） -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                                            <Condition Binding="{Binding IsActive}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource OnePointDarkBackground}"/>
                                        <Setter TargetName="Txt" Property="Foreground" Value="{DynamicResource OnePointDarkText}"/>
                                        <Setter TargetName="Icon" Property="Foreground" Value="{DynamicResource OnePointDarkText}"/>
                                        <Setter TargetName="LockIcon" Property="Foreground" Value="{DynamicResource OnePointDarkText}"/>
                                        <Setter TargetName="CloseIcon" Property="Foreground" Value="{DynamicResource OnePointDarkText}"/>
                                        <Setter TargetName="Txt" Property="FontWeight" Value="SemiBold"/>
                                        <Setter TargetName="Bd" Property="Margin" Value="2,4,2,4"/>
                                        <Setter TargetName="Bd" Property="CornerRadius" Value="4"/>
                                        <Setter TargetName="Bd" Property="Panel.ZIndex" Value="2"/>
                                        <!-- 黒い帯は周囲の境界線を消して独立させる -->
                                        <Setter TargetName="Separator" Property="Visibility" Value="Collapsed"/>
                                    </MultiDataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.ItemContainerStyle>

            <TabControl.ContentTemplate>
                <DataTemplate>
                    <local:TabContentControl/>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </Grid>
</UserControl>
