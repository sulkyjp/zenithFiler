<UserControl x:Class="ZenithFiler.ProjectSetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:local="clr-namespace:ZenithFiler">

    <UserControl.Resources>
        <local:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:WorkingSetToTooltipConverter x:Key="WorkingSetToTooltip"/>

        <!-- フッター内ボタン共通スタイル（チャコール背景に馴染む白文字・アイコン） -->
        <Style x:Key="FooterButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TitleBarTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource OnePointDarkBackground}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource OnePointDarkBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 機能説明 -->
            <RowDefinition Height="Auto"/>  <!-- ツールバー -->
            <RowDefinition Height="*"/>     <!-- セット一覧 -->
            <RowDefinition Height="Auto"/>  <!-- プレビューフッター -->
        </Grid.RowDefinitions>

        <!-- Row 0: 機能説明 -->
        <TextBlock Grid.Row="0"
                   Text="ワーキングセットは、A/B ペインのタブ、選択状態、スクロール位置を一つの「プロジェクト」として保存し、瞬時に切り替えられる機能です。"
                   FontSize="11"
                   Foreground="{DynamicResource SubTextBrush}"
                   TextWrapping="Wrap"
                   Margin="10,5,10,15"/>

        <!-- Row 1: ツールバー -->
        <Border Grid.Row="1" Padding="8,6" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Button Style="{StaticResource IconButton}"
                        Command="{Binding SaveCurrentStateCommand}"
                        HorizontalAlignment="Right"
                        IsTabStop="False"
                        ToolTip="現在の A/B ペイン全タブを保存します">
                    <StackPanel Orientation="Horizontal">
                        <icon:PackIconLucide Kind="Plus" Width="12" Height="12" Margin="0,0,4,0"/>
                        <TextBlock Text="現在の状態を保存" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Row 2: セット一覧 -->
        <Grid Grid.Row="2">
            <!-- 空状態メッセージ -->
            <TextBlock Text="保存済みのワーキングセットはありません"
                       FontSize="11"
                       Foreground="{DynamicResource SubTextBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="16">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Items.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <ListView ItemsSource="{Binding Items}"
                      Background="Transparent"
                      BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      IsTabStop="False">
                <ListView.Style>
                    <Style TargetType="ListView">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Items.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListView.Style>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="ToolTip">
                            <Setter.Value>
                                <ToolTip MaxWidth="800">
                                    <TextBlock Text="{Binding Converter={StaticResource WorkingSetToTooltip}}"
                                               TextWrapping="NoWrap" FontSize="12"/>
                                </ToolTip>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}"/>
                        <EventSetter Event="MouseLeftButtonUp" Handler="ListViewItem_MouseLeftButtonUp"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Margin="4,1" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListHoverBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu>
                                    <MenuItem Header="名前変更"
                                              Command="{Binding PlacementTarget.Tag.RenameSetCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Style="{StaticResource ContextMenuItemStyle}">
                                        <MenuItem.Icon>
                                            <icon:PackIconLucide Kind="Pencil" Width="14" Height="14"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator Style="{StaticResource ContextMenuSeparatorStyle}"/>
                                    <MenuItem Header="削除"
                                              Command="{Binding PlacementTarget.Tag.DeleteSetCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Style="{StaticResource ContextMenuItemStyle}">
                                        <MenuItem.Icon>
                                            <icon:PackIconLucide Kind="Trash2" Width="14" Height="14"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Text="{Binding Name}"
                                       FontWeight="SemiBold"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding CreatedAt}"
                                       FontSize="10"
                                       Foreground="{DynamicResource SubTextBrush}"
                                       Margin="0,1,0,0"/>
                            <TextBlock Grid.Row="2"
                                       FontSize="10"
                                       Foreground="{DynamicResource SubTextBrush}"
                                       Margin="0,1,0,0">
                                <Run Text="Aペイン: "/>
                                <Run Text="{Binding LeftPane.Tabs.Count, Mode=OneWay}"/>
                                <Run Text=" タブ / Bペイン: "/>
                                <Run Text="{Binding RightPane.Tabs.Count, Mode=OneWay}"/>
                                <Run Text=" タブ"/>
                            </TextBlock>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Row 3: プレビューフッター（IsPreviewActive=true のときのみ表示） -->
        <Border Grid.Row="3"
                Background="{DynamicResource OnePointDarkBackground}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,6"
                Visibility="{Binding IsPreviewActive, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 適用ボタン -->
                <Button Grid.Column="0"
                        Style="{StaticResource FooterButton}"
                        Command="{Binding ApplyCommand}"
                        Margin="0,0,4,0"
                        ToolTip="このセットを現在の作業状態として確定します">
                    <StackPanel Orientation="Horizontal">
                        <icon:PackIconLucide Kind="Check" Width="12" Height="12"
                                             Margin="0,0,5,0"
                                             Foreground="{DynamicResource TitleBarTextBrush}"/>
                        <TextBlock Text="このセットを適用する"
                                   FontSize="11"
                                   Foreground="{DynamicResource TitleBarTextBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- キャンセルボタン -->
                <Button Grid.Column="1"
                        Style="{StaticResource FooterButton}"
                        Command="{Binding CancelPreviewCommand}"
                        Padding="7,5"
                        ToolTip="読み込み前の状態に戻します">
                    <icon:PackIconLucide Kind="X" Width="12" Height="12" Foreground="{DynamicResource TitleBarTextBrush}"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
