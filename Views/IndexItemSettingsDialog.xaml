<Window x:Class="ZenithFiler.Views.IndexItemSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ZenithFiler"
        xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="インデックス詳細設定"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height"
        Width="460"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontSize="13">

    <Window.Resources>
        <local:IntEqualityToBooleanConverter x:Key="IntEqualityToBool"/>
        <local:NonEmptyStringToVisibilityConverter x:Key="NonEmptyStringToVis"/>
    </Window.Resources>

    <StackPanel Margin="24,20,24,20">

        <!-- ヘッダー: アイコン + フォルダ名 + パス + 状態 -->
        <StackPanel Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <icon:PackIconLucide Kind="{Binding LocationIconKind}" Width="16" Height="16"
                                     Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding DisplayName}" FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="{Binding Path}" FontSize="11" Foreground="{DynamicResource SubTextBrush}"
                       TextTrimming="CharacterEllipsis" Margin="0,0,0,2"/>
            <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="{DynamicResource SubTextBrush}"
                       Visibility="{Binding StatusText, Converter={StaticResource NonEmptyStringToVis}}"/>
        </StackPanel>

        <!-- アーカイブ（ロック）セクション -->
        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="アーカイブ（ロック）" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,6"/>
                <CheckBox IsChecked="{Binding IsLocked}" Content="インデックス更新をロック" Margin="0,0,0,2"/>
                <TextBlock Text="一括更新・定期更新の対象外にします" FontSize="11"
                           Foreground="{DynamicResource SubTextBrush}" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- スケジュールセクション -->
        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="スケジュール" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,8"/>
                <!-- 曜日チェックボックス -->
                <WrapPanel Margin="0,0,0,8">
                    <CheckBox IsChecked="{Binding ScheduleMonday}" Content="月" MinWidth="42" Margin="0,0,4,2"/>
                    <CheckBox IsChecked="{Binding ScheduleTuesday}" Content="火" MinWidth="42" Margin="0,0,4,2"/>
                    <CheckBox IsChecked="{Binding ScheduleWednesday}" Content="水" MinWidth="42" Margin="0,0,4,2"/>
                    <CheckBox IsChecked="{Binding ScheduleThursday}" Content="木" MinWidth="42" Margin="0,0,4,2"/>
                    <CheckBox IsChecked="{Binding ScheduleFriday}" Content="金" MinWidth="42" Margin="0,0,4,2"/>
                    <CheckBox IsChecked="{Binding ScheduleSaturday}" Content="土" MinWidth="42" Margin="0,0,4,2"/>
                    <CheckBox IsChecked="{Binding ScheduleSunday}" Content="日" MinWidth="42" Margin="0,0,4,2"/>
                </WrapPanel>
                <!-- 時刻選択 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="時刻:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding HourOptions}" SelectedValue="{Binding SelectedHourValue}"
                              SelectedValuePath="Value" DisplayMemberPath="Display"
                              MinWidth="120" VerticalAlignment="Center"/>
                </StackPanel>
                <!-- リセットボタン -->
                <Button Content="スケジュールをリセット" Command="{Binding ResetScheduleCommand}"
                        HorizontalAlignment="Right" Padding="10,4" FontSize="11" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <!-- 更新方式セクション -->
        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="更新方式" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,6"/>
                <RadioButton Content="グローバル設定に従う" IsChecked="{Binding UpdateModeIndex, Converter={StaticResource IntEqualityToBool}, ConverterParameter=0}"
                             Margin="0,0,0,4"/>
                <RadioButton Content="常に差分更新（増分）" IsChecked="{Binding UpdateModeIndex, Converter={StaticResource IntEqualityToBool}, ConverterParameter=1}"
                             Margin="0,0,0,4"/>
                <RadioButton Content="常にフル再作成" IsChecked="{Binding UpdateModeIndex, Converter={StaticResource IntEqualityToBool}, ConverterParameter=2}"/>
            </StackPanel>
        </Border>

        <!-- ボタン -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="OK" IsDefault="True" Click="OkButton_Click"
                    MinWidth="96" MinHeight="30" Padding="14,4" Margin="0,0,12,0"/>
            <Button Content="キャンセル" IsCancel="True"
                    MinWidth="96" MinHeight="30" Padding="14,4"/>
        </StackPanel>
    </StackPanel>
</Window>
