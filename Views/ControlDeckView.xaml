<UserControl x:Class="ZenithFiler.Views.ControlDeckView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:local="clr-namespace:ZenithFiler"
             xmlns:models="clr-namespace:ZenithFiler.Models"
             xmlns:ComponentModel="clr-namespace:System.ComponentModel;assembly=System"
             IsTabStop="False">

    <UserControl.Resources>
        <local:EnumEqualityToBooleanConverter x:Key="EnumEqualityToBool"/>
        <local:EnumEqualityToVisibilityConverter x:Key="EnumEqualityToVis"/>
        <local:IntEqualityToBooleanConverter x:Key="IntEqualityToBool"/>
        <local:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:StringToColorConverter x:Key="StringToColor"/>
        <local:ThemeCategoryIconConverter x:Key="ThemeCategoryIcon"/>
        <local:ThemeCategoryDescriptionConverter x:Key="ThemeCategoryDesc"/>
        <local:ThemePaneBadgeVisibilityConverter x:Key="ThemePaneBadge"/>
        <local:IsCategorySelectedConverter x:Key="IsCategorySelected"/>
        <local:IsCurrentPresetThemeConverter x:Key="IsCurrentPresetTheme"/>
        <local:NonEmptyStringToVisibilityConverter x:Key="NonEmptyStringToVis"/>
        <local:InverseBooleanConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ 左ナビ ═══ -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}"
                CornerRadius="8,0,0,8" Padding="8,12">
            <DockPanel>
                <!-- 下部: 作業に戻るボタン -->
                <Button DockPanel.Dock="Bottom" Margin="0,8,0,0" Padding="12,10"
                        HorizontalContentAlignment="Left" Cursor="Hand" IsTabStop="False"
                        Command="{Binding CloseControlDeckCommand}"
                        Style="{StaticResource IconButton}">
                    <StackPanel Orientation="Horizontal">
                        <icon:PackIconLucide Kind="ArrowLeft" Width="14" Height="14"
                                             VerticalAlignment="Center" Margin="0,0,8,0"
                                             Foreground="{DynamicResource SubTextBrush}"/>
                        <TextBlock Text="作業に戻る" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SubTextBrush}"/>
                    </StackPanel>
                </Button>

                <!-- ナビ項目 -->
                <StackPanel Margin="0,4,0,0">
                    <RadioButton GroupName="ControlDeckNav" Style="{StaticResource ControlDeckNavButton}"
                                 IsChecked="{Binding AppSettings.ActiveCategory, Mode=TwoWay, Converter={StaticResource EnumEqualityToBool}, ConverterParameter={x:Static local:SettingsCategory.General}}">
                        <StackPanel Orientation="Horizontal">
                            <icon:PackIconLucide Kind="Settings" Width="14" Height="14"
                                                 VerticalAlignment="Center" Margin="0,0,10,0"
                                                 Foreground="{DynamicResource SubTextBrush}"/>
                            <TextBlock Text="基本設定" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton GroupName="ControlDeckNav" Style="{StaticResource ControlDeckNavButton}"
                                 IsChecked="{Binding AppSettings.ActiveCategory, Mode=TwoWay, Converter={StaticResource EnumEqualityToBool}, ConverterParameter={x:Static local:SettingsCategory.Display}}">
                        <StackPanel Orientation="Horizontal">
                            <icon:PackIconLucide Kind="Monitor" Width="14" Height="14"
                                                 VerticalAlignment="Center" Margin="0,0,10,0"
                                                 Foreground="{DynamicResource SubTextBrush}"/>
                            <TextBlock Text="表示" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton GroupName="ControlDeckNav" Style="{StaticResource ControlDeckNavButton}"
                                 IsChecked="{Binding AppSettings.ActiveCategory, Mode=TwoWay, Converter={StaticResource EnumEqualityToBool}, ConverterParameter={x:Static local:SettingsCategory.Theme}}">
                        <StackPanel Orientation="Horizontal">
                            <icon:PackIconLucide Kind="Palette" Width="14" Height="14"
                                                 VerticalAlignment="Center" Margin="0,0,10,0"
                                                 Foreground="{DynamicResource SubTextBrush}"/>
                            <TextBlock Text="テーマ" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton GroupName="ControlDeckNav" Style="{StaticResource ControlDeckNavButton}"
                                 IsChecked="{Binding AppSettings.ActiveCategory, Mode=TwoWay, Converter={StaticResource EnumEqualityToBool}, ConverterParameter={x:Static local:SettingsCategory.Search}}">
                        <StackPanel Orientation="Horizontal">
                            <icon:PackIconLucide Kind="Search" Width="14" Height="14"
                                                 VerticalAlignment="Center" Margin="0,0,10,0"
                                                 Foreground="{DynamicResource SubTextBrush}"/>
                            <TextBlock Text="検索" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton GroupName="ControlDeckNav" Style="{StaticResource ControlDeckNavButton}"
                                 IsChecked="{Binding AppSettings.ActiveCategory, Mode=TwoWay, Converter={StaticResource EnumEqualityToBool}, ConverterParameter={x:Static local:SettingsCategory.Index}}">
                        <StackPanel Orientation="Horizontal">
                            <icon:PackIconLucide Kind="Database" Width="14" Height="14"
                                                 VerticalAlignment="Center" Margin="0,0,10,0"
                                                 Foreground="{DynamicResource SubTextBrush}"/>
                            <TextBlock Text="インデックス" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton GroupName="ControlDeckNav" Style="{StaticResource ControlDeckNavButton}"
                                 IsChecked="{Binding AppSettings.ActiveCategory, Mode=TwoWay, Converter={StaticResource EnumEqualityToBool}, ConverterParameter={x:Static local:SettingsCategory.Backup}}">
                        <StackPanel Orientation="Horizontal">
                            <icon:PackIconLucide Kind="ArchiveRestore" Width="14" Height="14"
                                                 VerticalAlignment="Center" Margin="0,0,10,0"
                                                 Foreground="{DynamicResource SubTextBrush}"/>
                            <TextBlock Text="リカバリ" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton GroupName="ControlDeckNav" Style="{StaticResource ControlDeckNavButton}"
                                 IsChecked="{Binding AppSettings.ActiveCategory, Mode=TwoWay, Converter={StaticResource EnumEqualityToBool}, ConverterParameter={x:Static local:SettingsCategory.Shortcut}}">
                        <StackPanel Orientation="Horizontal">
                            <icon:PackIconLucide Kind="Keyboard" Width="14" Height="14"
                                                 VerticalAlignment="Center" Margin="0,0,10,0"
                                                 Foreground="{DynamicResource SubTextBrush}"/>
                            <TextBlock Text="ショートカットキー" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <!-- セパレーター -->
                    <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="8,8,8,4"/>
                    <RadioButton GroupName="ControlDeckNav" Style="{StaticResource ControlDeckNavButton}"
                                 IsChecked="{Binding AppSettings.ActiveCategory, Mode=TwoWay, Converter={StaticResource EnumEqualityToBool}, ConverterParameter={x:Static local:SettingsCategory.License}}">
                        <StackPanel Orientation="Horizontal">
                            <icon:PackIconLucide Kind="KeyRound" Width="14" Height="14"
                                                 VerticalAlignment="Center" Margin="0,0,10,0"
                                                 Foreground="{DynamicResource SubTextBrush}"/>
                            <TextBlock Text="ライセンス" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton GroupName="ControlDeckNav" Style="{StaticResource ControlDeckNavButton}"
                                 IsChecked="{Binding AppSettings.ActiveCategory, Mode=TwoWay, Converter={StaticResource EnumEqualityToBool}, ConverterParameter={x:Static local:SettingsCategory.About}}">
                        <StackPanel Orientation="Horizontal">
                            <icon:PackIconLucide Kind="Info" Width="14" Height="14"
                                                 VerticalAlignment="Center" Margin="0,0,10,0"
                                                 Foreground="{DynamicResource SubTextBrush}"/>
                            <TextBlock Text="バージョン情報" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ 右コンテンツ ═══ -->
        <Border Grid.Column="1" Background="{DynamicResource BackgroundBrush}"
                CornerRadius="0,8,8,0">
            <DockPanel>
                <!-- ヘッダー -->
                <Border DockPanel.Dock="Top" Padding="24,16,16,12"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}"
                                Command="{Binding CloseControlDeckCommand}"
                                ToolTip="閉じる" IsTabStop="False"
                                VerticalAlignment="Center">
                            <icon:PackIconLucide Kind="X" Width="14" Height="14"
                                                 Foreground="{DynamicResource SubTextBrush}"/>
                        </Button>
                        <TextBlock x:Name="CategoryHeaderText" FontSize="16" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Text" Value="基本設定"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AppSettings.ActiveCategory}" Value="{x:Static local:SettingsCategory.Search}">
                                            <Setter Property="Text" Value="検索"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding AppSettings.ActiveCategory}" Value="{x:Static local:SettingsCategory.Index}">
                                            <Setter Property="Text" Value="インデックス"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding AppSettings.ActiveCategory}" Value="{x:Static local:SettingsCategory.Backup}">
                                            <Setter Property="Text" Value="リカバリ"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding AppSettings.ActiveCategory}" Value="{x:Static local:SettingsCategory.Theme}">
                                            <Setter Property="Text" Value="テーマ"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding AppSettings.ActiveCategory}" Value="{x:Static local:SettingsCategory.Display}">
                                            <Setter Property="Text" Value="表示"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding AppSettings.ActiveCategory}" Value="{x:Static local:SettingsCategory.Shortcut}">
                                            <Setter Property="Text" Value="ショートカットキー"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding AppSettings.ActiveCategory}" Value="{x:Static local:SettingsCategory.License}">
                                            <Setter Property="Text" Value="ライセンス"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding AppSettings.ActiveCategory}" Value="{x:Static local:SettingsCategory.About}">
                                            <Setter Property="Text" Value="バージョン情報"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </DockPanel>
                </Border>

                <!-- コンテンツエリア -->
                <Grid x:Name="ContentArea">
                    <!-- ══ General ══ -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Padding="0"
                                  Visibility="{Binding AppSettings.ActiveCategory, Converter={StaticResource EnumEqualityToVis}, ConverterParameter={x:Static local:SettingsCategory.General}}">
                        <WrapPanel Margin="24,20" Orientation="Horizontal">
                            <!-- コンテキストメニュー -->
                            <Border Width="400" Margin="0,0,20,20" Padding="16,14" CornerRadius="6"
                                    Background="{DynamicResource InputBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="コンテキストメニュー" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <RadioButton GroupName="ContextMenuModeDeck" Style="{StaticResource OptionRadioButton}" Margin="0,0,0,6"
                                                IsChecked="{Binding AppSettings.ContextMenuMode, Mode=TwoWay, Converter={StaticResource EnumEqualityToBool}, ConverterParameter={x:Static local:ContextMenuMode.Zenith}}">
                                        <StackPanel>
                                            <TextBlock Text="アプリ独自メニュー（推奨）" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Text="開く・コピー・削除など基本操作を即表示。Shift+右クリックでエクスプローラ互換メニューを表示。"
                                                       FontSize="11" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </RadioButton>
                                    <RadioButton GroupName="ContextMenuModeDeck" Style="{StaticResource OptionRadioButton}"
                                                IsChecked="{Binding AppSettings.ContextMenuMode, Mode=TwoWay, Converter={StaticResource EnumEqualityToBool}, ConverterParameter={x:Static local:ContextMenuMode.Explorer}}">
                                        <StackPanel>
                                            <TextBlock Text="エクスプローラ互換メニュー" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Text="Windows の標準右クリックメニュー（7-Zip 拡張なども含む）を表示。"
                                                       FontSize="11" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </RadioButton>
                                </StackPanel>
                            </Border>

                            <!-- Aペインのホーム -->
                            <Border Width="400" Margin="0,0,20,20" Padding="16,14" CornerRadius="6"
                                    Background="{DynamicResource InputBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Aペインのホーム" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap" Margin="0,0,0,8">
                                        ホームボタンで戻れる基準フォルダーを設定します
                                    </TextBlock>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding AppSettings.LeftPaneHomePath, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,0,4,0" FontSize="12" VerticalContentAlignment="Center"
                                                 IsReadOnly="True" Background="{DynamicResource InputBackgroundBrush}"
                                                 Foreground="{DynamicResource TextBrush}"
                                                 HorizontalAlignment="Stretch" MinWidth="80"/>
                                        <Button Grid.Column="1" Style="{StaticResource IconButton}" Command="{Binding AppSettings.SetLeftPaneHomeFromCurrentCommand}"
                                                ToolTip="表示中のフォルダを設定" IsTabStop="False" Margin="0,0,4,0">
                                            <icon:PackIconLucide Kind="PanelLeft" Width="14" Height="14"/>
                                        </Button>
                                        <Button Grid.Column="2" Style="{StaticResource IconButton}" Command="{Binding AppSettings.SetLeftPaneHomeFromDialogCommand}"
                                                ToolTip="フォルダを選択" IsTabStop="False">
                                            <icon:PackIconLucide Kind="FolderOpen" Width="14" Height="14"/>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Bペインのホーム -->
                            <Border Width="400" Margin="0,0,20,20" Padding="16,14" CornerRadius="6"
                                    Background="{DynamicResource InputBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Bペインのホーム" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap" Margin="0,0,0,8">
                                        ホームボタンで戻れる基準フォルダーを設定します
                                    </TextBlock>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding AppSettings.RightPaneHomePath, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,0,4,0" FontSize="12" VerticalContentAlignment="Center"
                                                 IsReadOnly="True" Background="{DynamicResource InputBackgroundBrush}"
                                                 Foreground="{DynamicResource TextBrush}"
                                                 HorizontalAlignment="Stretch" MinWidth="80"/>
                                        <Button Grid.Column="1" Style="{StaticResource IconButton}" Command="{Binding AppSettings.SetRightPaneHomeFromCurrentCommand}"
                                                ToolTip="表示中のフォルダを設定" IsTabStop="False" Margin="0,0,4,0">
                                            <icon:PackIconLucide Kind="PanelRight" Width="14" Height="14"/>
                                        </Button>
                                        <Button Grid.Column="2" Style="{StaticResource IconButton}" Command="{Binding AppSettings.SetRightPaneHomeFromDialogCommand}"
                                                ToolTip="フォルダを選択" IsTabStop="False">
                                            <icon:PackIconLucide Kind="FolderOpen" Width="14" Height="14"/>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 操作 -->
                            <Border Width="400" Margin="0,0,20,20" Padding="16,14" CornerRadius="6"
                                    Background="{DynamicResource InputBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="操作" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <CheckBox IsChecked="{Binding AppSettings.SingleClickOpenFolder, Mode=TwoWay}"
                                              Margin="0,0,0,2" FontSize="12">
                                        <TextBlock Text="シングルクリックでフォルダを開く" TextWrapping="Wrap"/>
                                    </CheckBox>
                                    <TextBlock Text="オフの場合はダブルクリックでフォルダを開きます"
                                               FontSize="11" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                    <CheckBox IsChecked="{Binding AppSettings.ConfirmDelete, Mode=TwoWay}"
                                              Margin="0,0,0,2" FontSize="12">
                                        <TextBlock Text="ファイル削除時に確認ダイアログを表示する" TextWrapping="Wrap"/>
                                    </CheckBox>
                                    <TextBlock Text="オフにすると削除がワンアクションで即実行されます"
                                               FontSize="11" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                    <CheckBox IsChecked="{Binding AppSettings.RestoreTabsOnStartup, Mode=TwoWay}"
                                              Margin="0,0,0,2" FontSize="12">
                                        <TextBlock Text="起動時に前回のタブを復元する" TextWrapping="Wrap"/>
                                    </CheckBox>
                                    <TextBlock Text="オフにすると起動時にホームフォルダのみ表示します"
                                               FontSize="11" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap" Margin="0,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- 通知 -->
                            <Border Width="400" Margin="0,0,20,20" Padding="16,14" CornerRadius="6"
                                    Background="{DynamicResource InputBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="通知の表示時間" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,10"
                                               Text="ファイルのコピー・移動・削除の完了や、テーマ変更などの操作結果をステータスバーに表示する時間を設定します。短めにすると素早く消え、長めにすると読み逃しを防げます。"/>
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton GroupName="NotificationDurationDeck" Style="{StaticResource OptionRadioButton}" Margin="0,0,12,0"
                                                    IsChecked="{Binding AppSettings.NotificationDurationMs, Mode=TwoWay, Converter={StaticResource IntEqualityToBool}, ConverterParameter=1500}">
                                            <TextBlock Text="短め (1.5秒)" FontSize="12"/>
                                        </RadioButton>
                                        <RadioButton GroupName="NotificationDurationDeck" Style="{StaticResource OptionRadioButton}" Margin="0,0,12,0"
                                                    IsChecked="{Binding AppSettings.NotificationDurationMs, Mode=TwoWay, Converter={StaticResource IntEqualityToBool}, ConverterParameter=3000}">
                                            <TextBlock Text="標準 (3秒)" FontSize="12"/>
                                        </RadioButton>
                                        <RadioButton GroupName="NotificationDurationDeck" Style="{StaticResource OptionRadioButton}"
                                                    IsChecked="{Binding AppSettings.NotificationDurationMs, Mode=TwoWay, Converter={StaticResource IntEqualityToBool}, ConverterParameter=5000}">
                                            <TextBlock Text="長め (5秒)" FontSize="12"/>
                                        </RadioButton>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </ScrollViewer>

                    <!-- ══ Search ══ -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Padding="0"
                                  Visibility="{Binding AppSettings.ActiveCategory, Converter={StaticResource EnumEqualityToVis}, ConverterParameter={x:Static local:SettingsCategory.Search}}">
                        <WrapPanel Margin="24,20" Orientation="Horizontal">
                            <!-- 検索の挙動 -->
                            <Border Width="400" Margin="0,0,20,20" Padding="16,14" CornerRadius="6"
                                    Background="{DynamicResource InputBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="検索の挙動" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <RadioButton GroupName="SearchBehaviorDeck" Style="{StaticResource OptionRadioButton}" Margin="0,0,0,6"
                                                IsChecked="{Binding AppSettings.SearchBehavior, Mode=TwoWay, Converter={StaticResource EnumEqualityToBool}, ConverterParameter={x:Static local:SearchBehavior.SamePaneNewTab}}">
                                        <StackPanel>
                                            <TextBlock Text="同一ペイン・新規タブ" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Text="Enter で検索実行。同じペインに検索結果タブを新規作成。検索結果タブでは入力即検索。"
                                                       FontSize="11" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </RadioButton>
                                    <RadioButton GroupName="SearchBehaviorDeck" Style="{StaticResource OptionRadioButton}" Margin="0,12,0,6"
                                                IsChecked="{Binding AppSettings.SearchBehavior, Mode=TwoWay, Converter={StaticResource EnumEqualityToBool}, ConverterParameter={x:Static local:SearchBehavior.SamePaneCurrentTabInstant}}">
                                        <StackPanel>
                                            <TextBlock Text="同一ペイン・現在タブで即時検索" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Text="入力したら即検索開始（Enter 不要）。現在のタブで検索結果を表示。文字を消すと一覧に戻る。"
                                                       FontSize="11" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </RadioButton>
                                    <RadioButton GroupName="SearchBehaviorDeck" Style="{StaticResource OptionRadioButton}" Margin="0,12,0,0"
                                                IsChecked="{Binding AppSettings.SearchBehavior, Mode=TwoWay, Converter={StaticResource EnumEqualityToBool}, ConverterParameter={x:Static local:SearchBehavior.OtherPaneNewTab}}">
                                        <StackPanel>
                                            <TextBlock Text="反対ペイン・新規タブ" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Text="Enter で検索実行。Aペインで検索→Bペインに、Bペインで検索→Aペインに新規タブで表示。1ペイン時は自動で2ペインに切替。"
                                                       FontSize="11" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </RadioButton>
                                </StackPanel>
                            </Border>

                            <!-- 検索結果のパスクリック時の挙動 -->
                            <Border Width="400" Margin="0,0,20,20" Padding="16,14" CornerRadius="6"
                                    Background="{DynamicResource InputBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="検索結果のパスクリック時の挙動" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <RadioButton GroupName="SearchResultPathDeck" Style="{StaticResource OptionRadioButton}" Margin="0,0,0,6"
                                                IsChecked="{Binding AppSettings.SearchResultPathBehavior, Mode=TwoWay, Converter={StaticResource EnumEqualityToBool}, ConverterParameter={x:Static local:SearchResultPathBehavior.SameTab}}">
                                        <StackPanel>
                                            <TextBlock Text="同一タブで表示" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Text="検索結果ビューから通常の一覧に切り替え、そのパスを同一タブで表示。"
                                                       FontSize="11" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </RadioButton>
                                    <RadioButton GroupName="SearchResultPathDeck" Style="{StaticResource OptionRadioButton}" Margin="0,12,0,6"
                                                IsChecked="{Binding AppSettings.SearchResultPathBehavior, Mode=TwoWay, Converter={StaticResource EnumEqualityToBool}, ConverterParameter={x:Static local:SearchResultPathBehavior.SamePaneNewTab}}">
                                        <StackPanel>
                                            <TextBlock Text="同一ペイン・新規タブ" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Text="同じペインに新規タブを開く（従来の挙動）。"
                                                       FontSize="11" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </RadioButton>
                                    <RadioButton GroupName="SearchResultPathDeck" Style="{StaticResource OptionRadioButton}" Margin="0,12,0,0"
                                                IsChecked="{Binding AppSettings.SearchResultPathBehavior, Mode=TwoWay, Converter={StaticResource EnumEqualityToBool}, ConverterParameter={x:Static local:SearchResultPathBehavior.OtherPaneNewTab}}">
                                        <StackPanel>
                                            <TextBlock Text="反対ペイン・新規タブ" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Text="Aペインの検索結果→Bペインに、Bペインの検索結果→Aペインに新規タブで表示。1ペイン時は自動で2ペインに切替。"
                                                       FontSize="11" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </RadioButton>
                                </StackPanel>
                            </Border>

                            <!-- 検索時の表示設定 -->
                            <Border Width="400" Margin="0,0,20,20" Padding="16,14" CornerRadius="6"
                                    Background="{DynamicResource InputBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="検索時の表示設定" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <CheckBox IsChecked="{Binding AppSettings.AutoSwitchToSinglePaneOnSearch, Mode=TwoWay}"
                                              Margin="0,0,0,6" FontSize="12">
                                        <TextBlock Text="検索時に自動的に1画面モードに切り替える" TextWrapping="Wrap"/>
                                    </CheckBox>
                                    <TextBlock Text="検索実行時に自動的に1画面モードに切り替え、検索結果を広く表示します。Bペインで検索した場合は、検索タブがAペインに表示されます。"
                                               FontSize="11" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                        </WrapPanel>
                    </ScrollViewer>

                    <!-- ══ Index ══ -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Padding="0"
                                  Visibility="{Binding AppSettings.ActiveCategory, Converter={StaticResource EnumEqualityToVis}, ConverterParameter={x:Static local:SettingsCategory.Index}}">
                        <WrapPanel Margin="24,20" Orientation="Horizontal">
                            <!-- 更新タイミング -->
                            <Border Width="400" Margin="0,0,20,20" Padding="16,14" CornerRadius="6"
                                    Background="{DynamicResource InputBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="更新タイミング" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <RadioButton GroupName="IndexUpdateModeDeck" Style="{StaticResource OptionRadioButton}" Margin="0,0,0,6"
                                                IsChecked="{Binding AppSettings.IndexUpdateMode, Mode=TwoWay, Converter={StaticResource EnumEqualityToBool}, ConverterParameter={x:Static local:IndexUpdateMode.Auto}}">
                                        <StackPanel>
                                            <TextBlock Text="変更を自動で取り込む（推奨）" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Text="ファイルやフォルダーの作成・削除・名前変更などを監視し、変更があった部分だけを順次インデックスに反映します。" FontSize="11" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </RadioButton>
                                    <RadioButton GroupName="IndexUpdateModeDeck" Style="{StaticResource OptionRadioButton}" Margin="0,12,0,6"
                                                IsChecked="{Binding AppSettings.IndexUpdateMode, Mode=TwoWay, Converter={StaticResource EnumEqualityToBool}, ConverterParameter={x:Static local:IndexUpdateMode.Interval}}">
                                        <StackPanel>
                                            <TextBlock Text="一定間隔でまとめて更新する" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Text="指定した間隔ごとに差分を更新します。" FontSize="11" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </RadioButton>
                                    <StackPanel Margin="0,0,0,6" Orientation="Horizontal"
                                                Visibility="{Binding AppSettings.IndexUpdateMode, Converter={StaticResource EnumEqualityToVis}, ConverterParameter={x:Static local:IndexUpdateMode.Interval}}">
                                        <RadioButton GroupName="IndexUpdateIntervalDeck" Style="{StaticResource OptionRadioButton}" Margin="0,0,8,0"
                                                    IsChecked="{Binding AppSettings.IndexUpdateIntervalHours, Mode=TwoWay, Converter={StaticResource IntEqualityToBool}, ConverterParameter=1}">
                                            <TextBlock Text="1時間ごと" FontSize="12"/>
                                        </RadioButton>
                                        <RadioButton GroupName="IndexUpdateIntervalDeck" Style="{StaticResource OptionRadioButton}" Margin="0,0,8,0"
                                                    IsChecked="{Binding AppSettings.IndexUpdateIntervalHours, Mode=TwoWay, Converter={StaticResource IntEqualityToBool}, ConverterParameter=2}">
                                            <TextBlock Text="2時間ごと" FontSize="12"/>
                                        </RadioButton>
                                        <RadioButton GroupName="IndexUpdateIntervalDeck" Style="{StaticResource OptionRadioButton}" Margin="0,0,8,0"
                                                    IsChecked="{Binding AppSettings.IndexUpdateIntervalHours, Mode=TwoWay, Converter={StaticResource IntEqualityToBool}, ConverterParameter=4}">
                                            <TextBlock Text="4時間ごと" FontSize="12"/>
                                        </RadioButton>
                                        <RadioButton GroupName="IndexUpdateIntervalDeck" Style="{StaticResource OptionRadioButton}" Margin="0,0,0,0"
                                                    IsChecked="{Binding AppSettings.IndexUpdateIntervalHours, Mode=TwoWay, Converter={StaticResource IntEqualityToBool}, ConverterParameter=24}">
                                            <TextBlock Text="1日ごと" FontSize="12"/>
                                        </RadioButton>
                                    </StackPanel>
                                    <RadioButton GroupName="IndexUpdateModeDeck" Style="{StaticResource OptionRadioButton}" Margin="0,12,0,0"
                                                IsChecked="{Binding AppSettings.IndexUpdateMode, Mode=TwoWay, Converter={StaticResource EnumEqualityToBool}, ConverterParameter={x:Static local:IndexUpdateMode.Manual}}">
                                        <StackPanel>
                                            <TextBlock Text="必要なときだけ更新する" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Text="インデックスビューの「未インデックスを作成」を押したときだけ、未インデックスのフォルダに対して更新します。" FontSize="11" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </RadioButton>
                                </StackPanel>
                            </Border>

                            <!-- パフォーマンスと負荷 -->
                            <Border Width="400" Margin="0,0,20,20" Padding="16,14" CornerRadius="6"
                                    Background="{DynamicResource InputBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="パフォーマンスと負荷" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <CheckBox IsChecked="{Binding AppSettings.IndexEcoMode, Mode=TwoWay}"
                                              Margin="0,0,0,6" FontSize="12">
                                        <TextBlock Text="省エネモードでインデックスを更新する" TextWrapping="Wrap"/>
                                    </CheckBox>
                                    <TextBlock Text="CPU とディスクの使用を抑え、他のアプリケーションへの影響を小さくします。" FontSize="11" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                    <CheckBox IsChecked="{Binding AppSettings.IndexNetworkLowPriority, Mode=TwoWay}"
                                              Margin="0,0,0,6" FontSize="12">
                                        <TextBlock Text="ネットワークドライブは軽めに処理する" TextWrapping="Wrap"/>
                                    </CheckBox>
                                    <TextBlock Text="LAN やクラウドのフォルダーは、ローカルよりもゆっくり処理します。" FontSize="11" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                    <TextBlock Text="フル再インデックス最短間隔" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                        <RadioButton GroupName="IndexFullRebuildCooldownDeck" Style="{StaticResource OptionRadioButton}" Margin="0,0,8,0"
                                                    IsChecked="{Binding AppSettings.IndexFullRebuildCooldownHours, Mode=TwoWay, Converter={StaticResource IntEqualityToBool}, ConverterParameter=6}">
                                            <TextBlock Text="6時間" FontSize="12"/>
                                        </RadioButton>
                                        <RadioButton GroupName="IndexFullRebuildCooldownDeck" Style="{StaticResource OptionRadioButton}" Margin="0,0,8,0"
                                                    IsChecked="{Binding AppSettings.IndexFullRebuildCooldownHours, Mode=TwoWay, Converter={StaticResource IntEqualityToBool}, ConverterParameter=12}">
                                            <TextBlock Text="12時間" FontSize="12"/>
                                        </RadioButton>
                                        <RadioButton GroupName="IndexFullRebuildCooldownDeck" Style="{StaticResource OptionRadioButton}" Margin="0,0,0,0"
                                                    IsChecked="{Binding AppSettings.IndexFullRebuildCooldownHours, Mode=TwoWay, Converter={StaticResource IntEqualityToBool}, ConverterParameter=24}">
                                            <TextBlock Text="24時間" FontSize="12"/>
                                        </RadioButton>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- 検索結果の鮮度 -->
                            <Border Width="400" Margin="0,0,20,20" Padding="16,14" CornerRadius="6"
                                    Background="{DynamicResource InputBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="検索結果の鮮度" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <CheckBox IsChecked="{Binding AppSettings.IndexFreshnessAggressive, Mode=TwoWay}"
                                              Margin="0,0,0,6" FontSize="12">
                                        <TextBlock Text="できるだけ最新の状態を保つ（鮮度優先）" TextWrapping="Wrap"/>
                                    </CheckBox>
                                    <TextBlock Text="積極的に差分更新を行い、必要に応じて未インデックス部分もその場で検索します。" FontSize="11" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                    <CheckBox IsChecked="{Binding AppSettings.IndexFreshnessWarnStale, Mode=TwoWay}"
                                              Margin="0,0,0,6" FontSize="12">
                                        <TextBlock Text="インデックスが古い可能性があるときにメッセージを表示する" TextWrapping="Wrap"/>
                                    </CheckBox>
                                    <TextBlock Text="結果が一部含まれていない可能性がある場合、検索結果に注意メッセージを表示します。" FontSize="11" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </ScrollViewer>

                    <!-- ══ Backup ══ -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Padding="0"
                                  Visibility="{Binding AppSettings.ActiveCategory, Converter={StaticResource EnumEqualityToVis}, ConverterParameter={x:Static local:SettingsCategory.Backup}}">
                        <StackPanel Margin="24,20">
                            <!-- 説明 + バックアップボタン -->
                            <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,12">
                                アプリ終了時に自動でバックアップを作成します。ロックしたバックアップは 30 日が経過しても自動削除されません
                            </TextBlock>
                            <Button Content="今すぐバックアップ"
                                    Style="{StaticResource TextButton}"
                                    Command="{Binding AppSettings.BackupNowCommand}"
                                    HorizontalAlignment="Left"
                                    Padding="12,6" Margin="0,0,0,16"/>

                            <!-- 一覧エリア -->
                            <Border CornerRadius="6" Padding="0"
                                    Background="{DynamicResource InputBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <Grid>
                                    <!-- 空一覧メッセージ -->
                                    <TextBlock Text="バックアップがありません"
                                               FontSize="11" Foreground="{DynamicResource SubTextBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Margin="0,24">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AppSettings.BackupEntries.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- バックアップ一覧 -->
                                    <ItemsControl ItemsSource="{Binding AppSettings.BackupEntries}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="10,7" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="150"/>
                                                            <ColumnDefinition Width="36"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- 日時 -->
                                                        <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat=yyyy/MM/dd HH:mm}"
                                                                   FontSize="11" VerticalAlignment="Center" Opacity="0.8"/>

                                                        <!-- ロックボタン -->
                                                        <Button Grid.Column="1" Padding="4" IsTabStop="False" Cursor="Hand"
                                                                Style="{StaticResource IconButton}"
                                                                Command="{Binding DataContext.AppSettings.ToggleLockCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}">
                                                            <icon:PackIconLucide Width="14" Height="14">
                                                                <icon:PackIconLucide.Style>
                                                                    <Style TargetType="icon:PackIconLucide">
                                                                        <Setter Property="Kind" Value="LockOpen"/>
                                                                        <Setter Property="ToolTip" Value="ロックする"/>
                                                                        <Setter Property="Opacity" Value="0.4"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                                <Setter Property="Kind" Value="Lock"/>
                                                                                <Setter Property="ToolTip" Value="ロックを解除する"/>
                                                                                <Setter Property="Opacity" Value="1.0"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </icon:PackIconLucide.Style>
                                                            </icon:PackIconLucide>
                                                        </Button>

                                                        <!-- 概要セル -->
                                                        <Grid Grid.Column="2" Margin="4,0">
                                                            <!-- 通常表示（非編集中） -->
                                                            <TextBlock Text="{Binding Summary}" FontSize="11"
                                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                                                       Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>

                                                            <!-- 編集中 -->
                                                            <DockPanel Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                                                                <Button DockPanel.Dock="Right" Padding="4" Margin="2,0,0,0"
                                                                        IsTabStop="False" Cursor="Hand"
                                                                        Style="{StaticResource IconButton}"
                                                                        Command="{Binding CancelEditCommand}">
                                                                    <icon:PackIconLucide Kind="X" Width="13" Height="13"/>
                                                                </Button>
                                                                <Button DockPanel.Dock="Right" Padding="4" Margin="2,0,0,0"
                                                                        IsTabStop="False" Cursor="Hand"
                                                                        Style="{StaticResource IconButton}"
                                                                        Command="{Binding CommitEditCommand}">
                                                                    <icon:PackIconLucide Kind="Check" Width="13" Height="13"/>
                                                                </Button>
                                                                <TextBox Text="{Binding EditBuffer, UpdateSourceTrigger=PropertyChanged}"
                                                                         FontSize="11" VerticalAlignment="Center"
                                                                         Padding="4,2"
                                                                         Background="{DynamicResource BackgroundBrush}"
                                                                         Foreground="{DynamicResource TextBrush}"
                                                                         BorderBrush="{DynamicResource BorderBrush}"
                                                                         BorderThickness="1">
                                                                    <TextBox.InputBindings>
                                                                        <KeyBinding Key="Return" Command="{Binding CommitEditCommand}"/>
                                                                        <KeyBinding Key="Escape" Command="{Binding CancelEditCommand}"/>
                                                                    </TextBox.InputBindings>
                                                                </TextBox>
                                                            </DockPanel>
                                                        </Grid>

                                                        <!-- 編集ボタン（非編集中のみ） -->
                                                        <Button Grid.Column="3" Padding="4" IsTabStop="False" Cursor="Hand"
                                                                Style="{StaticResource IconButton}"
                                                                Command="{Binding BeginEditCommand}"
                                                                IsEnabled="{Binding IsLocked, Converter={StaticResource InverseBool}}"
                                                                ToolTip="概要を編集"
                                                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                                            <icon:PackIconLucide Kind="Pencil" Width="13" Height="13" Opacity="0.6"/>
                                                        </Button>

                                                        <!-- 復元ボタン -->
                                                        <Button Grid.Column="4" Padding="4" Margin="2,0,0,0" IsTabStop="False" Cursor="Hand"
                                                                Style="{StaticResource IconButton}"
                                                                Command="{Binding DataContext.AppSettings.RestoreEntryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                ToolTip="この設定で復元する">
                                                            <icon:PackIconLucide Kind="RotateCcw" Width="13" Height="13" Opacity="0.6"/>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>

                            <!-- ページネーションバー -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AppSettings.BackupTotalPages}" Value="1">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <!-- 前ページ -->
                                <Button Style="{StaticResource IconButton}" Padding="6" IsTabStop="False" Cursor="Hand"
                                        Command="{Binding AppSettings.BackupPrevPageCommand}" ToolTip="前のページ">
                                    <icon:PackIconLucide Kind="ChevronLeft" Width="14" Height="14"/>
                                </Button>
                                <!-- ページ番号 -->
                                <ItemsControl ItemsSource="{Binding AppSettings.BackupPageItems}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:BackupPageItem}">
                                            <Grid Margin="1,0">
                                                <!-- 省略記号 -->
                                                <TextBlock Text="…" FontSize="11" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SubTextBrush}" Margin="4,0"
                                                           Visibility="{Binding IsEllipsis, Converter={StaticResource BoolToVis}}"/>
                                                <!-- ページ番号ボタン -->
                                                <Button Content="{Binding Display}" FontSize="11" Padding="6,3" MinWidth="28"
                                                        IsTabStop="False" Cursor="Hand"
                                                        Command="{Binding DataContext.AppSettings.GoToBackupPageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding PageNumber}"
                                                        Visibility="{Binding IsEllipsis, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource TextButton}">
                                                            <Setter Property="Opacity" Value="0.7"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                                    <Setter Property="Opacity" Value="1.0"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <!-- 次ページ -->
                                <Button Style="{StaticResource IconButton}" Padding="6" IsTabStop="False" Cursor="Hand"
                                        Command="{Binding AppSettings.BackupNextPageCommand}" ToolTip="次のページ">
                                    <icon:PackIconLucide Kind="ChevronRight" Width="14" Height="14"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ══ Theme ══ -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Padding="0"
                                  Visibility="{Binding AppSettings.ActiveCategory, Converter={StaticResource EnumEqualityToVis}, ConverterParameter={x:Static local:SettingsCategory.Theme}}">
                        <StackPanel Margin="24,20">

                            <!-- ── テーマ・適用モード ── -->
                            <TextBlock Text="テーマ・適用モード" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SubTextBrush}" Opacity="0.8"
                                       Margin="0,0,0,10"/>
                            <WrapPanel Orientation="Horizontal" Margin="0,0,0,24">

                                <!-- 1. パーソナライズ・プリセット -->
                                <Border Width="320" Margin="0,0,12,12" Padding="16,14" CornerRadius="6" Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <Binding Path="AppSettings.ActiveThemeMode"
                                                                 Converter="{StaticResource EnumEqualityToBool}"
                                                                 ConverterParameter="{x:Static local:ThemeApplyMode.Preset}"/>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="BorderThickness" Value="2.5"/>
                                                    <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding AppSettings.SetThemeModeCommand}"
                                                      CommandParameter="{x:Static local:ThemeApplyMode.Preset}"/>
                                    </Border.InputBindings>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <icon:PackIconLucide Kind="Bookmark" Width="14" Height="14"
                                                                 Foreground="{DynamicResource SubTextBrush}"
                                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="パーソナライズ・プリセット" FontSize="13" FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap">
                                            好きなテーマを自由にクリックして適用する標準モードです
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- 2. 自動選択モード -->
                                <Border Width="320" Margin="0,0,12,12" Padding="16,14" CornerRadius="6" Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <Binding Path="AppSettings.ActiveThemeMode"
                                                                 Converter="{StaticResource EnumEqualityToBool}"
                                                                 ConverterParameter="{x:Static local:ThemeApplyMode.Random}"/>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="BorderThickness" Value="2.5"/>
                                                    <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding AppSettings.SetThemeModeCommand}"
                                                      CommandParameter="{x:Static local:ThemeApplyMode.Random}"/>
                                    </Border.InputBindings>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <icon:PackIconLucide Kind="Shuffle" Width="14" Height="14"
                                                                 Foreground="{DynamicResource SubTextBrush}"
                                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="自動選択モード" FontSize="13" FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}"
                                                   TextWrapping="Wrap" Margin="0,0,0,12">
                                            アプリ起動時に、登録されたテーマの中から自動的に一つを選択します
                                        </TextBlock>
                                        <!-- ペイン個別適用セクションと同一の IsEnabled 制御 -->
                                        <StackPanel IsEnabled="{Binding AppSettings.IsRandomModeActive}">
                                            <RadioButton GroupName="ThemeRandomizeDeck"
                                                         Style="{StaticResource OptionRadioButton}" Margin="0,0,0,6"
                                                         IsChecked="{Binding AppSettings.ThemeRandomizeMode, Mode=TwoWay,
                                                             Converter={StaticResource EnumEqualityToBool},
                                                             ConverterParameter={x:Static local:ThemeRandomizeMode.AllThemes}}">
                                                <TextBlock Text="全テーマからランダム" FontSize="12"/>
                                            </RadioButton>
                                            <RadioButton GroupName="ThemeRandomizeDeck"
                                                         Style="{StaticResource OptionRadioButton}"
                                                         IsChecked="{Binding AppSettings.ThemeRandomizeMode, Mode=TwoWay,
                                                             Converter={StaticResource EnumEqualityToBool},
                                                             ConverterParameter={x:Static local:ThemeRandomizeMode.CurrentCategory}}">
                                                <TextBlock Text="現在のカテゴリからランダム" FontSize="12"/>
                                            </RadioButton>
                                        </StackPanel>
                                        <!-- 即時ランダム抽選ボタン: 自動選択モード時のみ表示 -->
                                        <!-- IsMouseOver Trigger で全域ホバー検知（EventTrigger MouseEnter は子要素キャプチャ時に発火しないため非採用） -->
                                        <Button HorizontalAlignment="Stretch" Padding="0,10" Margin="0,22,0,0"
                                                IsTabStop="False" Cursor="Hand"
                                                Visibility="{Binding AppSettings.IsRandomModeActive, Converter={StaticResource BoolToVis}}"
                                                Command="{Binding AppSettings.DrawRandomThemeCommand}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <!-- Root を Grid に変更: AccentBrush・HoverGlow がパディング込みの全域をカバー -->
                                                                <Grid x:Name="Root">
                                                                    <Grid.RenderTransform>
                                                                        <ScaleTransform x:Name="ScaleT"/>
                                                                    </Grid.RenderTransform>
                                                                    <Grid.RenderTransformOrigin>0.5,0.5</Grid.RenderTransformOrigin>
                                                                    <!-- AccentBrush 塗りつぶし（全域） -->
                                                                    <Border CornerRadius="6" Background="{DynamicResource AccentBrush}"/>
                                                                    <!-- 白発光オーバーレイ（全域・Padding 領域を含む） -->
                                                                    <Border x:Name="HoverGlow" CornerRadius="6"
                                                                            Background="White" Opacity="0"
                                                                            IsHitTestVisible="False"/>
                                                                    <!-- コンテンツ: Padding を Margin で再現 -->
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                      Margin="{TemplateBinding Padding}"/>
                                                                </Grid>
                                                                <ControlTemplate.Triggers>
                                                                    <!-- IsMouseOver: Border 全域でホバー検知・スケールアップ + 白発光 -->
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Trigger.EnterActions>
                                                                            <BeginStoryboard>
                                                                                <Storyboard>
                                                                                    <DoubleAnimation Storyboard.TargetName="ScaleT"
                                                                                                     Storyboard.TargetProperty="ScaleX"
                                                                                                     To="1.04" Duration="0:0:0.15">
                                                                                        <DoubleAnimation.EasingFunction>
                                                                                            <QuadraticEase EasingMode="EaseOut"/>
                                                                                        </DoubleAnimation.EasingFunction>
                                                                                    </DoubleAnimation>
                                                                                    <DoubleAnimation Storyboard.TargetName="ScaleT"
                                                                                                     Storyboard.TargetProperty="ScaleY"
                                                                                                     To="1.04" Duration="0:0:0.15">
                                                                                        <DoubleAnimation.EasingFunction>
                                                                                            <QuadraticEase EasingMode="EaseOut"/>
                                                                                        </DoubleAnimation.EasingFunction>
                                                                                    </DoubleAnimation>
                                                                                    <DoubleAnimation Storyboard.TargetName="HoverGlow"
                                                                                                     Storyboard.TargetProperty="Opacity"
                                                                                                     To="0.18" Duration="0:0:0.15"/>
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </Trigger.EnterActions>
                                                                        <Trigger.ExitActions>
                                                                            <BeginStoryboard>
                                                                                <Storyboard>
                                                                                    <DoubleAnimation Storyboard.TargetName="ScaleT"
                                                                                                     Storyboard.TargetProperty="ScaleX"
                                                                                                     To="1.0" Duration="0:0:0.2"/>
                                                                                    <DoubleAnimation Storyboard.TargetName="ScaleT"
                                                                                                     Storyboard.TargetProperty="ScaleY"
                                                                                                     To="1.0" Duration="0:0:0.2"/>
                                                                                    <DoubleAnimation Storyboard.TargetName="HoverGlow"
                                                                                                     Storyboard.TargetProperty="Opacity"
                                                                                                     To="0" Duration="0:0:0.2"/>
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </Trigger.ExitActions>
                                                                    </Trigger>
                                                                    <!-- IsPressed: アニメーションなし Setter で競合を回避、Opacity で押し込み感 -->
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="Root" Property="Opacity" Value="0.68"/>
                                                                    </Trigger>
                                                                    <!-- 無効時: 淡色 -->
                                                                    <Trigger Property="IsEnabled" Value="False">
                                                                        <Setter Property="Opacity" Value="0.38"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <icon:PackIconLucide Kind="Dices" Width="13" Height="13"
                                                                     Foreground="White"
                                                                     VerticalAlignment="Center" Margin="0,0,7,0"/>
                                                <TextBlock Text="今すぐ抽選" FontSize="12" FontWeight="SemiBold"
                                                           VerticalAlignment="Center" Foreground="White"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <!-- 3. ペイン個別適用 -->
                                <Border Width="320" Margin="0,0,12,12" Padding="16,14" CornerRadius="6" Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <Binding Path="AppSettings.ActiveThemeMode"
                                                                 Converter="{StaticResource EnumEqualityToBool}"
                                                                 ConverterParameter="{x:Static local:ThemeApplyMode.Pane}"/>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="BorderThickness" Value="2.5"/>
                                                    <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding AppSettings.SetThemeModeCommand}"
                                                      CommandParameter="{x:Static local:ThemeApplyMode.Pane}"/>
                                    </Border.InputBindings>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <icon:PackIconLucide Kind="Columns2" Width="14" Height="14"
                                                                 Foreground="{DynamicResource SubTextBrush}"
                                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="ペイン個別適用" FontSize="13" FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}"
                                                   TextWrapping="Wrap" Margin="0,0,0,12">
                                            ナビ・Aペイン・Bペインにそれぞれ異なるテーマを適用する高度な設定です
                                        </TextBlock>
                                        <StackPanel Margin="0,0,0,10"
                                                    IsEnabled="{Binding AppSettings.ActiveThemeMode,
                                                        Converter={StaticResource EnumEqualityToBool},
                                                        ConverterParameter={x:Static local:ThemeApplyMode.Pane}}">
                                            <RadioButton GroupName="PaneTargetDeck"
                                                         Style="{StaticResource OptionRadioButton}" Margin="0,0,0,6"
                                                         IsChecked="{Binding AppSettings.SelectedPaneTarget, Mode=TwoWay,
                                                             Converter={StaticResource EnumEqualityToBool},
                                                             ConverterParameter={x:Static local:PaneTarget.Nav}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="ナビペイン" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding AppSettings.NavPaneThemeName}" FontSize="11"
                                                               Foreground="{DynamicResource AccentBrush}" Opacity="0.85"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </RadioButton>
                                            <RadioButton GroupName="PaneTargetDeck"
                                                         Style="{StaticResource OptionRadioButton}" Margin="0,0,0,6"
                                                         IsChecked="{Binding AppSettings.SelectedPaneTarget, Mode=TwoWay,
                                                             Converter={StaticResource EnumEqualityToBool},
                                                             ConverterParameter={x:Static local:PaneTarget.APane}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="Aペイン" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding AppSettings.APaneThemeName}" FontSize="11"
                                                               Foreground="{DynamicResource AccentBrush}" Opacity="0.85"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </RadioButton>
                                            <RadioButton GroupName="PaneTargetDeck"
                                                         Style="{StaticResource OptionRadioButton}"
                                                         IsChecked="{Binding AppSettings.SelectedPaneTarget, Mode=TwoWay,
                                                             Converter={StaticResource EnumEqualityToBool},
                                                             ConverterParameter={x:Static local:PaneTarget.BPane}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="Bペイン" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding AppSettings.BPaneThemeName}" FontSize="11"
                                                               Foreground="{DynamicResource AccentBrush}" Opacity="0.85"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </RadioButton>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                            </WrapPanel>

                            <!-- ── テーマギャラリー ── -->
                            <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,12">
                                themes フォルダ内のテーマを選択すると即座に配色が切り替わります。カスタマイズした JSON を themes フォルダに置くと自動で読み込まれます
                            </TextBlock>
                            <!-- 割り当てモード ヒントバー -->
                            <Border Margin="0,0,0,12" Padding="12,8" CornerRadius="4"
                                    Background="{DynamicResource AccentBrush}"
                                    Visibility="{Binding AppSettings.IsAssignmentModeActive, Converter={StaticResource BoolToVis}}">
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" IsTabStop="False"
                                            Command="{Binding AppSettings.SetThemeModeCommand}"
                                            CommandParameter="{x:Static local:ThemeApplyMode.Preset}"
                                            Background="Transparent" BorderThickness="0"
                                            Padding="8,2" Cursor="Hand">
                                        <TextBlock Text="解除" FontSize="11" Foreground="White" Opacity="0.85"/>
                                    </Button>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <icon:PackIconLucide Kind="MousePointerClick" Width="13" Height="13"
                                                             Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding AppSettings.GalleryModeHint}" FontSize="12"
                                                   Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                            <ListBox x:Name="ThemeListBox"
                                     ItemsSource="{Binding AppSettings.ThemesView}"
                                     SelectedItem="{Binding AppSettings.SelectedThemeInfo, Mode=TwoWay}"
                                     Margin="0,0,0,16"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     IsTabStop="False"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.ContainerStyle>
                                            <Style TargetType="GroupItem">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="GroupItem">
                                                            <!-- 常時 Padding を確保し、TextBlock の折り返し幅を安定させる。
                                                                 通常時は BorderBrush=Transparent で枠は見えないが余白は常に有効。 -->
                                                            <Border x:Name="CategoryGroupBorder"
                                                                    BorderBrush="Transparent" BorderThickness="1.5"
                                                                    CornerRadius="8"
                                                                    Padding="16,12,16,16" Margin="0,0,0,12"
                                                                    Background="Transparent">
                                                                <Border.InputBindings>
                                                                    <MouseBinding MouseAction="LeftClick"
                                                                                  Command="{Binding DataContext.AppSettings.SelectRandomCategoryCommand,
                                                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                  CommandParameter="{Binding Name}"/>
                                                                </Border.InputBindings>
                                                                <StackPanel Background="Transparent">
                                                                    <ContentPresenter/>
                                                                    <ItemsPresenter/>
                                                                </StackPanel>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <!-- カテゴリランダムモード時: カーソルを Hand に変更 -->
                                                                <DataTrigger Value="True">
                                                                    <DataTrigger.Binding>
                                                                        <Binding Path="DataContext.AppSettings.IsRandomCategoryModeActive"
                                                                                 RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                    </DataTrigger.Binding>
                                                                    <Setter TargetName="CategoryGroupBorder" Property="Cursor" Value="Hand"/>
                                                                </DataTrigger>
                                                                <!-- ホバー（モードアクティブ時のみ有効）: 背景 + AccentBrush 枠 + 発光 -->
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding Path=DataContext.AppSettings.IsRandomCategoryModeActive,
                                                                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                   Value="True"/>
                                                                        <Condition Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsMouseOver}"
                                                                                   Value="True"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter TargetName="CategoryGroupBorder" Property="Background" Value="{DynamicResource ListHoverBrush}"/>
                                                                    <Setter TargetName="CategoryGroupBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                    <Setter TargetName="CategoryGroupBorder" Property="BorderThickness" Value="2"/>
                                                                    <Setter TargetName="CategoryGroupBorder" Property="Effect">
                                                                        <Setter.Value>
                                                                            <DropShadowEffect ShadowDepth="0" BlurRadius="10" Color="#5B9CF6" Opacity="0.28"/>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </MultiDataTrigger>
                                                                <!-- 選択されたカテゴリのみ AccentBrush 太枠 + SelectionBrush 背景 + 強発光 -->
                                                                <DataTrigger Value="True">
                                                                    <DataTrigger.Binding>
                                                                        <MultiBinding Converter="{StaticResource IsCategorySelected}">
                                                                            <Binding Path="Name"/>
                                                                            <Binding Path="DataContext.AppSettings.SelectedRandomCategory"
                                                                                     RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                            <Binding Path="DataContext.AppSettings.IsRandomCategoryModeActive"
                                                                                     RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                        </MultiBinding>
                                                                    </DataTrigger.Binding>
                                                                    <Setter TargetName="CategoryGroupBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                    <Setter TargetName="CategoryGroupBorder" Property="BorderThickness" Value="2"/>
                                                                    <Setter TargetName="CategoryGroupBorder" Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                                                    <Setter TargetName="CategoryGroupBorder" Property="Effect">
                                                                        <Setter.Value>
                                                                            <DropShadowEffect ShadowDepth="0" BlurRadius="18" Color="#5B9CF6" Opacity="0.52"/>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </GroupStyle.ContainerStyle>
                                        <GroupStyle.HeaderTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,0,0" Cursor="Hand" MaxWidth="620">
                                                    <StackPanel.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                                      Command="{Binding DataContext.AppSettings.SelectRandomCategoryCommand,
                                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                      CommandParameter="{Binding Name}"/>
                                                    </StackPanel.InputBindings>
                                                    <StackPanel Orientation="Horizontal">
                                                        <icon:PackIconLucide Width="14" Height="14"
                                                            Kind="{Binding Name, Converter={StaticResource ThemeCategoryIcon}}"
                                                            Foreground="{DynamicResource SubTextBrush}"
                                                            VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource SubTextBrush}"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}"
                                                                   Opacity="0.6" VerticalAlignment="Center" Margin="6,0,0,0">
                                                            <TextBlock.Text>
                                                                <Binding Path="ItemCount" StringFormat="({0})"/>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Name, Converter={StaticResource ThemeCategoryDesc}}"
                                                               FontSize="11" Foreground="{DynamicResource SubTextBrush}"
                                                               Opacity="0.7" Margin="0,15,12,15"
                                                               TextWrapping="Wrap" MaxWidth="280"/>
                                                    <!-- カテゴリ選択誘導インジケーター（カテゴリランダムモード・未選択時のみ表示） -->
                                                    <Border HorizontalAlignment="Left" CornerRadius="4" Padding="7,4"
                                                            Margin="0,0,0,6" BorderThickness="1"
                                                            BorderBrush="{DynamicResource AccentBrush}">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Value="True">
                                                                        <DataTrigger.Binding>
                                                                            <Binding Path="DataContext.AppSettings.IsAwaitingCategorySelection"
                                                                                     RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                        </DataTrigger.Binding>
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                        <DataTrigger.EnterActions>
                                                                            <BeginStoryboard Name="AnchorPulse">
                                                                                <Storyboard>
                                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                                     From="0.4" To="1.0" Duration="0:0:0.85"
                                                                                                     AutoReverse="True" RepeatBehavior="Forever"/>
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </DataTrigger.EnterActions>
                                                                        <DataTrigger.ExitActions>
                                                                            <StopStoryboard BeginStoryboardName="AnchorPulse"/>
                                                                        </DataTrigger.ExitActions>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel Orientation="Horizontal">
                                                            <icon:PackIconLucide Kind="Hand" Width="11" Height="11"
                                                                                 Foreground="{DynamicResource AccentBrush}"
                                                                                 VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                            <TextBlock Text="クリックして選択" FontSize="10"
                                                                       Foreground="{DynamicResource AccentBrush}"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GroupStyle.HeaderTemplate>
                                        <GroupStyle.Panel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </GroupStyle.Panel>
                                    </GroupStyle>
                                </ListBox.GroupStyle>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,12,12"/>
                                        <Setter Property="ToolTip" Value="{Binding Description}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="CardBorder" Width="220"
                                                            Background="{DynamicResource InputBackgroundBrush}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            Padding="14,12"
                                                            Cursor="Hand">
                                                        <Border.RenderTransform>
                                                            <TranslateTransform x:Name="CardTranslate" Y="0"/>
                                                        </Border.RenderTransform>
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource ListHoverBrush}"/>
                                                        </Trigger>
                                                        <!-- Pane モード以外: 適用中テーマを SelectedThemeName 文字列比較で直接判定。
                                                             ListBoxItem.IsSelected への依存を排除し、設定パネル起動直後から確実に発光する。 -->
                                                        <DataTrigger Value="True">
                                                            <DataTrigger.Binding>
                                                                <MultiBinding Converter="{StaticResource IsCurrentPresetTheme}">
                                                                    <Binding Path="Name"/>
                                                                    <Binding Path="DataContext.AppSettings.SelectedThemeName"
                                                                             RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                    <Binding Path="DataContext.AppSettings.ActiveThemeMode"
                                                                             RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                </MultiBinding>
                                                            </DataTrigger.Binding>
                                                            <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                            <Setter TargetName="CardBorder" Property="BorderThickness" Value="2.5"/>
                                                            <Setter TargetName="CardBorder" Property="Padding" Value="12.75,10.75"/>
                                                            <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                                        </DataTrigger>
                                                        <EventTrigger RoutedEvent="MouseEnter">
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="CardTranslate"
                                                                                     Storyboard.TargetProperty="Y"
                                                                                     To="-2" Duration="0:0:0.12"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                        <EventTrigger RoutedEvent="MouseLeave">
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="CardTranslate"
                                                                                     Storyboard.TargetProperty="Y"
                                                                                     To="0" Duration="0:0:0.12"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Bold"
                                                           Foreground="{DynamicResource TextBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <!-- 説明文 -->
                                                <TextBlock Text="{Binding Description}" FontSize="11"
                                                           Foreground="{DynamicResource SubTextBrush}"
                                                           TextWrapping="Wrap" MaxHeight="32"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,4,0,0"/>
                                                <TextBlock Text="{Binding Author, StringFormat='Design by {0}'}"
                                                           FontSize="11" FontWeight="Light"
                                                           Foreground="{DynamicResource SubTextBrush}"
                                                           TextTrimming="CharacterEllipsis" Margin="0,4,0,0"
                                                           Opacity="0.55"
                                                           Visibility="{Binding HasAuthor, Converter={StaticResource BoolToVis}}"/>
                                                <!-- カラーチップ -->
                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                    <Ellipse Width="20" Height="20" Margin="0,0,6,0"
                                                             Fill="{Binding BackgroundColor, Converter={StaticResource StringToColor}}"
                                                             Stroke="{DynamicResource BorderBrush}" StrokeThickness="0.5"/>
                                                    <Ellipse Width="20" Height="20" Margin="0,0,6,0"
                                                             Fill="{Binding SidebarColor, Converter={StaticResource StringToColor}}"
                                                             Stroke="{DynamicResource BorderBrush}" StrokeThickness="0.5"/>
                                                    <Ellipse Width="20" Height="20" Margin="0,0,6,0"
                                                             Fill="{Binding AccentColor, Converter={StaticResource StringToColor}}"
                                                             Stroke="{DynamicResource BorderBrush}" StrokeThickness="0.5"/>
                                                    <Ellipse Width="20" Height="20"
                                                             Fill="{Binding PrimaryTextColor, Converter={StaticResource StringToColor}}"
                                                             Stroke="{DynamicResource BorderBrush}" StrokeThickness="0.5"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <!-- ペインバッジ (右上) -->
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Right" VerticalAlignment="Top">
                                                <Border CornerRadius="3" Padding="4,2" Margin="0,0,3,0"
                                                        Background="{DynamicResource AccentBrush}">
                                                    <TextBlock Text="ナビ" FontSize="9" Foreground="White"/>
                                                    <Border.Visibility>
                                                        <MultiBinding Converter="{StaticResource ThemePaneBadge}" ConverterParameter="Nav">
                                                            <Binding Path="Name"/>
                                                            <Binding Path="DataContext.AppSettings.NavPaneThemeName"
                                                                     RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                            <Binding Path="DataContext.AppSettings.APaneThemeName"
                                                                     RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                            <Binding Path="DataContext.AppSettings.BPaneThemeName"
                                                                     RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                        </MultiBinding>
                                                    </Border.Visibility>
                                                </Border>
                                                <Border CornerRadius="3" Padding="4,2" Margin="0,0,3,0"
                                                        Background="{DynamicResource AccentBrush}">
                                                    <TextBlock Text="A" FontSize="9" Foreground="White"/>
                                                    <Border.Visibility>
                                                        <MultiBinding Converter="{StaticResource ThemePaneBadge}" ConverterParameter="A">
                                                            <Binding Path="Name"/>
                                                            <Binding Path="DataContext.AppSettings.NavPaneThemeName"
                                                                     RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                            <Binding Path="DataContext.AppSettings.APaneThemeName"
                                                                     RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                            <Binding Path="DataContext.AppSettings.BPaneThemeName"
                                                                     RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                        </MultiBinding>
                                                    </Border.Visibility>
                                                </Border>
                                                <Border CornerRadius="3" Padding="4,2"
                                                        Background="{DynamicResource AccentBrush}">
                                                    <TextBlock Text="B" FontSize="9" Foreground="White"/>
                                                    <Border.Visibility>
                                                        <MultiBinding Converter="{StaticResource ThemePaneBadge}" ConverterParameter="B">
                                                            <Binding Path="Name"/>
                                                            <Binding Path="DataContext.AppSettings.NavPaneThemeName"
                                                                     RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                            <Binding Path="DataContext.AppSettings.APaneThemeName"
                                                                     RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                            <Binding Path="DataContext.AppSettings.BPaneThemeName"
                                                                     RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                        </MultiBinding>
                                                    </Border.Visibility>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ══ Display ══ -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Padding="0"
                                  Visibility="{Binding AppSettings.ActiveCategory, Converter={StaticResource EnumEqualityToVis}, ConverterParameter={x:Static local:SettingsCategory.Display}}">
                        <WrapPanel Margin="24,20" Orientation="Horizontal">

                            <!-- ファイル一覧の行高 -->
                            <Border Width="400" Margin="0,0,20,20" Padding="16,14" CornerRadius="6"
                                    Background="{DynamicResource InputBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="ファイル一覧の行高" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,10"
                                               Text="ファイル一覧の各行の高さを調整します。コンパクトにすると一度に多くのファイルを表示でき、ゆったりにするとクリックしやすくなります。"/>
                                    <RadioButton GroupName="ListRowHeightDeck" Style="{StaticResource OptionRadioButton}" Margin="0,0,0,6"
                                                IsChecked="{Binding AppSettings.ListRowHeight, Mode=TwoWay, Converter={StaticResource IntEqualityToBool}, ConverterParameter=24}">
                                        <TextBlock Text="コンパクト (24 px)" FontSize="12"/>
                                    </RadioButton>
                                    <RadioButton GroupName="ListRowHeightDeck" Style="{StaticResource OptionRadioButton}" Margin="0,0,0,6"
                                                IsChecked="{Binding AppSettings.ListRowHeight, Mode=TwoWay, Converter={StaticResource IntEqualityToBool}, ConverterParameter=32}">
                                        <TextBlock Text="標準 (32 px)" FontSize="12"/>
                                    </RadioButton>
                                    <RadioButton GroupName="ListRowHeightDeck" Style="{StaticResource OptionRadioButton}"
                                                IsChecked="{Binding AppSettings.ListRowHeight, Mode=TwoWay, Converter={StaticResource IntEqualityToBool}, ConverterParameter=40}">
                                        <TextBlock Text="ゆったり (40 px)" FontSize="12"/>
                                    </RadioButton>
                                </StackPanel>
                            </Border>

                            <!-- マイクロアニメーション -->
                            <Border Width="400" Margin="0,0,20,20" Padding="16,14" CornerRadius="6"
                                    Background="{DynamicResource InputBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="マイクロアニメーション" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,10"
                                               Text="タブ操作・パネル切り替えなど UI ナビゲーション時のトランジション効果を制御します。"/>
                                    <CheckBox IsChecked="{Binding AppSettings.EnableMicroAnimations, Mode=TwoWay}"
                                              Margin="0,0,0,10" FontSize="12">
                                        <TextBlock Text="マイクロアニメーションを有効にする" TextWrapping="Wrap"/>
                                    </CheckBox>
                                    <TextBlock Text="対象のアニメーション:" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,4"/>
                                    <StackPanel Margin="8,0,0,0">
                                        <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,2" TextWrapping="Wrap"
                                                   Text="・ タブ切り替え — コンテンツのフェードイン"/>
                                        <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,2" TextWrapping="Wrap"
                                                   Text="・ タブインジケーター — アクティブタブ下線のスライド移動"/>
                                        <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,2" TextWrapping="Wrap"
                                                   Text="・ クイックプレビュー — 開閉時のフェード・スライド"/>
                                        <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,2" TextWrapping="Wrap"
                                                   Text="・ タブ D&amp;D — ドラッグ中の挿入マーカーのフェードイン"/>
                                        <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,0" TextWrapping="Wrap"
                                                   Text="・ インデックスポップアップ — ステータスバーのポップアップのフェード"/>
                                    </StackPanel>
                                    <TextBlock Text="無効にすると動作が軽くなる場合があります"
                                               FontSize="11" Foreground="{DynamicResource SubTextBrush}"
                                               TextWrapping="Wrap" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- 一覧表示アニメーション -->
                            <Border Width="400" Margin="0,0,20,20" Padding="16,14" CornerRadius="6"
                                    Background="{DynamicResource InputBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="一覧表示アニメーション" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,10"
                                               Text="ファイル一覧上でのホバーエフェクト（フェード・スケール）を制御します。無効にすると即時切り替えになり、低スペック環境での動作を改善できます。"/>
                                    <CheckBox IsChecked="{Binding AppSettings.EnableListAnimations, Mode=TwoWay}"
                                              Margin="0,0,0,10" FontSize="12">
                                        <TextBlock Text="一覧のホバーアニメーションを有効にする" TextWrapping="Wrap"/>
                                    </CheckBox>
                                    <TextBlock Text="対象のアニメーション:" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,4"/>
                                    <StackPanel Margin="8,0,0,0">
                                        <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,2" TextWrapping="Wrap"
                                                   Text="・ アイコンビュー — ホバー時の情報オーバーレイのフェードイン"/>
                                        <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,2" TextWrapping="Wrap"
                                                   Text="・ お気に入りボタン — ホバー時の円形背景のフェードイン"/>
                                        <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,0" TextWrapping="Wrap"
                                                   Text="・ 検索アイコン — インデックスモード時のホバースケール拡大"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- 起動時の通知 -->
                            <Border Width="400" Margin="0,0,20,20" Padding="16,14" CornerRadius="6"
                                    Background="{DynamicResource InputBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="起動時の通知" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,10"
                                               Text="アプリ起動直後にテーマ適用結果をトースト通知で表示するか設定します。テーマをランダム・カテゴリモードで使用している場合に、どのテーマが適用されたか確認するのに役立ちます。"/>
                                    <CheckBox IsChecked="{Binding AppSettings.ShowStartupToast, Mode=TwoWay}"
                                              FontSize="12">
                                        <TextBlock Text="起動時のテーマ適用通知を表示する" TextWrapping="Wrap"/>
                                    </CheckBox>
                                </StackPanel>
                            </Border>

                            <!-- 新規タブのデフォルト表示 -->
                            <Border Width="400" Margin="0,0,20,20" Padding="16,14" CornerRadius="6"
                                    Background="{DynamicResource InputBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="新規タブのデフォルト表示" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,10"
                                               Text="Ctrl+T やパスを指定して開いた新規タブに適用されるデフォルトの並び順です。検索結果タブには適用されません。"/>
                                    <CheckBox IsChecked="{Binding AppSettings.DefaultGroupFoldersFirst, Mode=TwoWay}"
                                              Margin="0,0,0,10" FontSize="12">
                                        <TextBlock Text="フォルダを先頭に表示する" TextWrapping="Wrap"/>
                                    </CheckBox>
                                    <TextBlock Text="デフォルトのソート順" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"
                                               Foreground="{DynamicResource SubTextBrush}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6" FlowDirection="LeftToRight">
                                        <RadioButton GroupName="DefaultSortPropertyDeck" Style="{StaticResource OptionRadioButton}" Margin="0,0,8,0"
                                                    IsChecked="{Binding AppSettings.DefaultSortProperty, Mode=TwoWay, Converter={StaticResource EnumEqualityToBool}, ConverterParameter=Name}">
                                            <TextBlock Text="名前" FontSize="12"/>
                                        </RadioButton>
                                        <RadioButton GroupName="DefaultSortPropertyDeck" Style="{StaticResource OptionRadioButton}" Margin="0,0,8,0"
                                                    IsChecked="{Binding AppSettings.DefaultSortProperty, Mode=TwoWay, Converter={StaticResource EnumEqualityToBool}, ConverterParameter=LastModified}">
                                            <TextBlock Text="更新日" FontSize="12"/>
                                        </RadioButton>
                                        <RadioButton GroupName="DefaultSortPropertyDeck" Style="{StaticResource OptionRadioButton}" Margin="0,0,8,0"
                                                    IsChecked="{Binding AppSettings.DefaultSortProperty, Mode=TwoWay, Converter={StaticResource EnumEqualityToBool}, ConverterParameter=Size}">
                                            <TextBlock Text="サイズ" FontSize="12"/>
                                        </RadioButton>
                                        <RadioButton GroupName="DefaultSortPropertyDeck" Style="{StaticResource OptionRadioButton}"
                                                    IsChecked="{Binding AppSettings.DefaultSortProperty, Mode=TwoWay, Converter={StaticResource EnumEqualityToBool}, ConverterParameter=Extension}">
                                            <TextBlock Text="拡張子" FontSize="12"/>
                                        </RadioButton>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" FlowDirection="LeftToRight">
                                        <RadioButton GroupName="DefaultSortDirectionDeck" Style="{StaticResource OptionRadioButton}" Margin="0,0,8,0"
                                                    IsChecked="{Binding AppSettings.DefaultSortDirection, Mode=TwoWay, Converter={StaticResource EnumEqualityToBool}, ConverterParameter={x:Static ComponentModel:ListSortDirection.Ascending}}">
                                            <TextBlock Text="昇順" FontSize="12"/>
                                        </RadioButton>
                                        <RadioButton GroupName="DefaultSortDirectionDeck" Style="{StaticResource OptionRadioButton}"
                                                    IsChecked="{Binding AppSettings.DefaultSortDirection, Mode=TwoWay, Converter={StaticResource EnumEqualityToBool}, ConverterParameter={x:Static ComponentModel:ListSortDirection.Descending}}">
                                            <TextBlock Text="降順" FontSize="12"/>
                                        </RadioButton>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                        </WrapPanel>
                    </ScrollViewer>

                    <!-- ═══ ショートカットキー ═══ -->
                    <ScrollViewer Visibility="{Binding AppSettings.ActiveCategory, Converter={StaticResource EnumEqualityToVis}, ConverterParameter={x:Static local:SettingsCategory.Shortcut}}"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,0,4,0"
                                  xmlns:controls="clr-namespace:ZenithFiler.Controls">
                        <StackPanel Margin="24,20" MaxWidth="640">
                            <!-- 一括リセットボタン -->
                            <DockPanel Margin="0,0,0,16">
                                <TextBlock DockPanel.Dock="Left" FontSize="12" VerticalAlignment="Center"
                                           Foreground="{DynamicResource SubTextBrush}"
                                           Text="キーバインドをクリックしてキーを入力すると変更できます"/>
                                <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                                        Style="{StaticResource IconButton}"
                                        Command="{Binding AppSettings.ResetAllKeyBindingsCommand}"
                                        ToolTip="すべてのショートカットキーを標準に戻す"
                                        Padding="8,4">
                                    <StackPanel Orientation="Horizontal">
                                        <icon:PackIconLucide Kind="RotateCcw" Width="12" Height="12"
                                                             VerticalAlignment="Center" Margin="0,0,4,0"
                                                             Foreground="{DynamicResource SubTextBrush}"/>
                                        <TextBlock Text="すべて標準に戻す" FontSize="11" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SubTextBrush}"/>
                                    </StackPanel>
                                </Button>
                            </DockPanel>

                            <!-- グループ別キーバインド一覧 -->
                            <ItemsControl ItemsSource="{Binding AppSettings.KeyBindingGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,20">
                                            <!-- グループ見出し -->
                                            <TextBlock Text="{Binding GroupName}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8"/>
                                            <Border Background="{DynamicResource InputBackgroundBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                    CornerRadius="6" Padding="0">
                                                <ItemsControl ItemsSource="{Binding Bindings}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Padding="12,8"
                                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                                    BorderThickness="0,0,0,1">
                                                                <StackPanel>
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>

                                                                        <!-- アクション名 -->
                                                                        <TextBlock Grid.Column="0" Text="{Binding DisplayName}"
                                                                                   FontSize="12" VerticalAlignment="Center"
                                                                                   Foreground="{DynamicResource TextBrush}"/>

                                                                        <!-- キーバインド表示（HotkeyRecorderControl） -->
                                                                        <controls:HotkeyRecorderControl Grid.Column="1"
                                                                            BindingDefinition="{Binding}"
                                                                            Margin="8,0"
                                                                            KeyChanged="HotkeyRecorder_KeyChanged"/>

                                                                        <!-- 個別リセットボタン（カスタマイズ済みの行のみ表示） -->
                                                                        <Button Grid.Column="2" Style="{StaticResource IconButton}"
                                                                                Command="{Binding DataContext.AppSettings.ResetKeyBindingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                CommandParameter="{Binding ActionId}"
                                                                                ToolTip="デフォルトに戻す"
                                                                                Visibility="{Binding IsCustomized, Converter={StaticResource BoolToVis}}"
                                                                                Padding="4">
                                                                            <icon:PackIconLucide Kind="RotateCcw" Width="10" Height="10"
                                                                                                 Foreground="{DynamicResource SubTextBrush}"/>
                                                                        </Button>
                                                                    </Grid>

                                                                    <!-- 概要説明 -->
                                                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                                                               Foreground="{DynamicResource SubTextBrush}"
                                                                               Margin="0,3,0,0" TextWrapping="Wrap"/>
                                                                </StackPanel>

                                                                <!-- 競合警告 -->
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding ConflictWarning}" Value="">
                                                                                <Setter Property="Tag" Value=""/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Border>
                                            <!-- 競合警告をグループ外に表示 -->
                                            <ItemsControl ItemsSource="{Binding Bindings}" Margin="4,4,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding ConflictWarning}" FontSize="11"
                                                                   Foreground="#E53935" Margin="0,2,0,0"
                                                                   Visibility="{Binding ConflictWarning, Converter={StaticResource NonEmptyStringToVis}}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ═══ ライセンス ═══ -->
                    <ScrollViewer Visibility="{Binding AppSettings.ActiveCategory, Converter={StaticResource EnumEqualityToVis}, ConverterParameter={x:Static local:SettingsCategory.License}}"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,0,4,0">
                        <StackPanel Margin="24,40" HorizontalAlignment="Center" MaxWidth="480">

                            <!-- ライセンス状態バナー -->
                            <Border Background="{DynamicResource PanelBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="8" Padding="24,20" Margin="0,0,0,24">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <!-- Full: チェック / Free: 鍵アイコン -->
                                    <icon:PackIconLucide Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <icon:PackIconLucide.Style>
                                            <Style TargetType="icon:PackIconLucide">
                                                <Setter Property="Kind" Value="Lock"/>
                                                <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AppSettings.IsFullLicense}" Value="True">
                                                        <Setter Property="Kind" Value="ShieldCheck"/>
                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </icon:PackIconLucide.Style>
                                    </icon:PackIconLucide>
                                    <StackPanel>
                                        <TextBlock Text="{Binding AppSettings.LicenseStatusText}" FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBrush}"/>
                                        <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}" Margin="0,2,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="一部の機能に使用回数の制限があります"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding AppSettings.IsFullLicense}" Value="True">
                                                            <Setter Property="Text" Value="すべての機能を無制限にご利用いただけます"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- 機能使用状況リスト -->
                            <TextBlock Text="機能の使用状況" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12"/>
                            <ItemsControl ItemsSource="{Binding AppSettings.FeatureUsages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource PanelBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                CornerRadius="6" Padding="16,12" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextBrush}"/>
                                                    <TextBlock Text="{Binding RemainingText}" FontSize="12"
                                                               Foreground="{DynamicResource SubTextBrush}"
                                                               HorizontalAlignment="Right"/>
                                                </DockPanel>
                                                <Grid Grid.Row="1">
                                                    <ProgressBar Value="{Binding UsageRatio, Mode=OneWay}" Minimum="0" Maximum="1"
                                                                 Height="6" Background="{DynamicResource BackgroundBrush}"
                                                                 Foreground="{DynamicResource AccentBrush}"
                                                                 BorderThickness="0"/>
                                                    <TextBlock Text="{Binding UsageText}" FontSize="11"
                                                               Foreground="{DynamicResource SubTextBrush}"
                                                               HorizontalAlignment="Right" Margin="0,8,0,0"/>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- ライセンスキー入力欄（将来用） -->
                            <Border Background="{DynamicResource PanelBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="8" Padding="24,20" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="ライセンスキー" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SubTextBrush}"
                                               Margin="0,0,0,8"/>
                                    <Border Background="{DynamicResource BackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            CornerRadius="4" Padding="12,10" IsEnabled="False">
                                        <TextBlock Text="XXXX-XXXX-XXXX-XXXX" FontSize="13" FontFamily="Consolas"
                                                   Foreground="{DynamicResource SubTextBrush}" Opacity="0.5"/>
                                    </Border>
                                    <TextBlock Text="※ ライセンスキーによる認証は今後のアップデートで対応予定です" FontSize="11"
                                               Foreground="{DynamicResource SubTextBrush}"
                                               Margin="0,10,0,0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- ═══ バージョン情報 ═══ -->
                    <ScrollViewer Visibility="{Binding AppSettings.ActiveCategory, Converter={StaticResource EnumEqualityToVis}, ConverterParameter={x:Static local:SettingsCategory.About}}"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,0,4,0">
                        <StackPanel Margin="24,40" HorizontalAlignment="Center" MaxWidth="520">
                            <!-- アプリアイコン -->
                            <Image Source="/assets/app_icon2_1.ico" Width="64" Height="64"
                                   HorizontalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"
                                   Margin="0,0,0,16"/>
                            <!-- アプリ名 -->
                            <TextBlock Text="ZenithFiler" FontSize="26" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextBrush}"
                                       Margin="0,0,0,4"/>
                            <!-- バージョン -->
                            <TextBlock Text="Version 0.17.0" FontSize="13"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource SubTextBrush}"
                                       Margin="0,0,0,24"/>
                            <!-- キャッチコピー -->
                            <Border Background="{DynamicResource PanelBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="8" Padding="24,20" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock FontSize="14" FontWeight="SemiBold" TextAlignment="Center"
                                               Foreground="{DynamicResource TextBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,12"
                                               Text="あなたの仕事の流れを、もっとスマートに。"/>
                                    <TextBlock FontSize="12.5" TextAlignment="Center" LineHeight="22"
                                               Foreground="{DynamicResource SubTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="ZenithFiler はデュアルペイン構成とインテリジェント検索を核に、&#x0a;日常のファイル管理をすばやく・直感的に行えるよう設計された&#x0a;モダン Windows ファイラーです。&#x0a;シンプルな操作の中に、プロフェッショナルな効率を。"/>
                                </StackPanel>
                            </Border>
                            <!-- 作者・著作権 -->
                            <Border Background="{DynamicResource PanelBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="8" Padding="20,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="作者" FontSize="12"
                                               Foreground="{DynamicResource SubTextBrush}"
                                               FontWeight="SemiBold" Width="100" Margin="0,0,0,8"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="K.AKASAKA" FontSize="12"
                                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8"/>
