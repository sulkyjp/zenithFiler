<Window x:Class="ZenithFiler.Views.ZenithDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Zenith Filer"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontSize="13">
    <!-- 外枠: DropShadow + 角丸 -->
    <Border Margin="20" CornerRadius="8" Background="{DynamicResource BackgroundBrush}" MinWidth="360" MaxWidth="520">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.25" Direction="315" Color="#000000"/>
        </Border.Effect>
        <Grid Margin="24,20,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- タイトル行 -->
            <TextBlock x:Name="TitleText"
                       Grid.Row="0"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,0,0,12"
                       TextWrapping="Wrap"/>

            <!-- アイコン + メッセージ行 -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
                <icon:PackIconLucide x:Name="DialogIcon"
                                     Width="24" Height="24"
                                     VerticalAlignment="Top"
                                     Margin="0,2,12,0"/>
                <TextBlock x:Name="MessageText"
                           Foreground="{DynamicResource TextBrush}"
                           TextWrapping="Wrap"
                           MaxWidth="420"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- カスタムコンテンツ行 -->
            <ContentPresenter x:Name="CustomContent"
                              Grid.Row="2"
                              Margin="36,0,0,16"
                              Visibility="Collapsed"/>

            <!-- ボタン行 -->
            <StackPanel x:Name="ButtonPanel"
                        Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <!-- ボタンはコードビハインドで動的に追加 -->
            </StackPanel>
        </Grid>
    </Border>
</Window>
