<UserControl x:Class="ZenithFiler.LoadingOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
    <UserControl.Resources>
        <!-- 水平走査ライン アニメーション（起動後は永続ループ） -->
        <Storyboard x:Key="LineStoryboard" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetName="BarTranslate"
                Storyboard.TargetProperty="X"
                Duration="0:0:1.6">
                <!-- 左端（完全に画面外）からスタート -->
                <EasingDoubleKeyFrame KeyTime="0:0:0"   Value="-220"/>
                <!-- 右端へ CubicEase で加速・減速しながら流れる -->
                <EasingDoubleKeyFrame KeyTime="0:0:1.3" Value="1800">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseInOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <!-- 右端で 0.3s 静止 → 次サイクルで -220 にジャンプ -->
                <EasingDoubleKeyFrame KeyTime="0:0:1.6" Value="1800"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>

    <!-- Loaded 時に一度だけアニメーションを開始（RepeatBehavior=Forever で永続） -->
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard Storyboard="{StaticResource LineStoryboard}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <!--
        OverlayRoot:
          IsLoading=True  → 300ms 遅延後に 0.15s でフェードイン（フリッカー防止）
          IsLoading=False → 即時 Opacity=0 にリセット
        Visibility（入力ブロック）は MainWindow.xaml 側の BoolToVis バインディングで制御済み
    -->
    <Grid x:Name="OverlayRoot" Opacity="0">
        <Grid.Style>
            <Style TargetType="Grid">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                        <DataTrigger.EnterActions>
                            <BeginStoryboard x:Name="FadeInSb">
                                <Storyboard>
                                    <DoubleAnimation
                                        Storyboard.TargetProperty="Opacity"
                                        From="0" To="1"
                                        Duration="0:0:0.15"
                                        BeginTime="0:0:0.3"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </DataTrigger.EnterActions>
                        <DataTrigger.ExitActions>
                            <StopStoryboard BeginStoryboardName="FadeInSb"/>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation
                                        Storyboard.TargetProperty="Opacity"
                                        To="0" Duration="0:0:0"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </DataTrigger.ExitActions>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>

        <!-- 半透明背景: チャコールブラック #545B64 @ 40% opacity (0x66 = 102/255 ≈ 0.4) -->
        <Rectangle Fill="{DynamicResource LoadingOverlayBrush}"/>

        <!-- 水平プログレスライン（画面下端） -->
        <Grid Height="10" VerticalAlignment="Bottom" ClipToBounds="True">
            <!-- 走査トラック（薄白でラインの存在を暗示） -->
            <Rectangle Fill="#1AFFFFFF" Height="2" VerticalAlignment="Center"/>

            <!-- 走査バー: 両端グラデードで自然なフェードを演出、DropShadow でグロー -->
            <Rectangle x:Name="AnimBar"
                       HorizontalAlignment="Left"
                       Height="2"
                       Width="220"
                       VerticalAlignment="Center">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#00FFFFFF" Offset="0"/>
                        <GradientStop Color="#BBFFFFFF" Offset="0.25"/>
                        <GradientStop Color="White"     Offset="0.5"/>
                        <GradientStop Color="#BBFFFFFF" Offset="0.75"/>
                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
                <Rectangle.Effect>
                    <DropShadowEffect Color="White" ShadowDepth="0"
                                      BlurRadius="6" Opacity="0.85"/>
                </Rectangle.Effect>
                <Rectangle.RenderTransform>
                    <TranslateTransform x:Name="BarTranslate" X="-220"/>
                </Rectangle.RenderTransform>
            </Rectangle>
        </Grid>
    </Grid>
</UserControl>
