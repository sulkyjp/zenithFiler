<UserControl x:Class="ZenithFiler.TabContentControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:local="clr-namespace:ZenithFiler"
             xmlns:vm="clr-namespace:ZenithFiler.ViewModels"
             UseLayoutRounding="True"
             GotFocus="TabContentControl_GotFocus">
    <UserControl.Resources>
        <local:SortInfoToVisibilityConverter x:Key="SortInfoToVis"/>
        <local:IsColumnActiveConverter x:Key="IsColActive"/>
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:IndexSearchModeTooltipConverter x:Key="IndexSearchModeTooltipConverter"/>
        <local:DoubleToGridLengthConverter x:Key="DoubleToGridLengthConverter"/>
        <local:GridViewStarWidthConverter x:Key="StarWidthConverter"/>
        <local:AdaptiveColumnWidthConverter x:Key="AdaptiveWidthConverter"/>
        <local:PathDisplayConverter x:Key="PathDisplayConverter"/>
        <local:SearchHistoryIconKindConverter x:Key="SearchHistoryIconKindConverter"/>
        <local:EnumEqualityToVisibilityConverter x:Key="EnumEqualityToVis"/>
        <local:EnumEqualityToVisibilityInverseConverter x:Key="EnumEqualityToVisInverse"/>
        <local:EnumEqualityToBooleanConverter x:Key="EnumEqualityToBool"/>
        <local:BytesToMBConverter x:Key="BytesToMBConverter"/>
        <local:EnumEqualityToBooleanInverseConverter x:Key="EnumEqualityToBoolInverse"/>
        <local:ThumbnailOrIconConverter x:Key="ThumbnailOrIcon"/>
        <local:SizeToRoundedRectGeometryConverter x:Key="SizeToRoundedRectGeometryConverter"/>

        <!-- フォーカス中ペインに連動して文字色・アイコン色を切り替える共通スタイル -->
        <!-- 通常時は TextBrush / SubTextBrush、ParentPane.IsActive=True のときは FocusedPaneTextBrush（黒）にする -->
        <Style x:Key="ActivePaneToolbarTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Style.Triggers>
                <!-- 親ペインがアクティブなときは文字色を黒に -->
                <DataTrigger Binding="{Binding DataContext.ParentPane.IsActive, RelativeSource={RelativeSource AncestorType=local:TabContentControl}}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource FocusedPaneTextBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActivePaneSubTextStyle" TargetType="TextBlock" BasedOn="{StaticResource ActivePaneToolbarTextStyle}">
            <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
        </Style>

        <!-- 一覧ビュー／検索ビューのヘッダ文字用: 通常はグレー、フォーカス中ペインでは黒 -->
        <Style x:Key="ActivePaneHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
            <Style.Triggers>
                <!-- 一覧ヘッダ／検索ヘッダはどちらも ListView 配下なので、ListView 経由で ParentPane.IsActive を参照する -->
                <DataTrigger
                    Binding="{Binding DataContext.ParentPane.IsActive,
                                      RelativeSource={RelativeSource AncestorType=ListView}}"
                    Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource FocusedPaneTextBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 一覧ビュー／検索ビューのセル文字用: 通常は TextBrush、フォーカス中ペインでは黒 -->
        <Style x:Key="ActivePaneCellTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Style.Triggers>
                <!-- ListView の DataContext(TabItemViewModel) 経由で ParentPane.IsActive を参照し、アクティブペイン時のみ黒にする -->
                <DataTrigger
                    Binding="{Binding DataContext.ParentPane.IsActive,
                                      RelativeSource={RelativeSource AncestorType=ListView}}"
                    Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource FocusedPaneTextBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActivePaneToolbarIconStyle" TargetType="icon:PackIconLucide">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Style.Triggers>
                <!-- 親ペインがアクティブなときはアイコン色を黒に -->
                <DataTrigger Binding="{Binding DataContext.ParentPane.IsActive, RelativeSource={RelativeSource AncestorType=local:TabContentControl}}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource FocusedPaneTextBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActivePaneToolbarSubIconStyle" TargetType="icon:PackIconLucide" BasedOn="{StaticResource ActivePaneToolbarIconStyle}">
            <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
        </Style>

        <Style x:Key="ActivePaneBreadcrumbButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButton}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.ParentPane.IsActive, RelativeSource={RelativeSource AncestorType=local:TabContentControl}}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource FocusedPaneTextBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- アドレスバー等のテキストボックス用: アクティブペインでは文字色を黒に -->
        <Style x:Key="ActivePaneTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ParentPane.IsActive}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource FocusedPaneTextBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 表示モード・列設定トグル用: アクティブペインではアイコン色を黒に -->
        <Style x:Key="ActivePaneIconToggleButtonStyle"
               TargetType="ToggleButton"
               BasedOn="{StaticResource IconToggleButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ParentPane.IsActive}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource FocusedPaneTextBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 画像ファイル用（サムネイルタイル・ホバーで名前表示・エクスプローラー風余白） -->
        <DataTemplate x:Key="IconViewImageTemplate">
            <Border x:Name="CardBorder" Width="160" Height="160" Margin="3"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    CornerRadius="4" ClipToBounds="False"
                    Background="Transparent" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0">
                <Grid x:Name="CardGrid" Width="160" Height="160">
                    <Grid.Clip>
                        <MultiBinding Converter="{StaticResource SizeToRoundedRectGeometryConverter}">
                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource Self}"/>
                            <Binding Path="ActualHeight" RelativeSource="{RelativeSource Self}"/>
                        </MultiBinding>
                    </Grid.Clip>
                    <Image x:Name="CardImage" Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="HighQuality" ImageFailed="Image_ImageFailed"
                           HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <Image.Source>
                            <MultiBinding Converter="{StaticResource ThumbnailOrIcon}">
                                <Binding Path="Thumbnail"/>
                                <Binding Path="Icon"/>
                            </MultiBinding>
                        </Image.Source>
                    </Image>
                    <Border x:Name="InfoOverlay" VerticalAlignment="Bottom" Opacity="0"
                            Background="#A0000000" CornerRadius="0,0,4,4" Padding="6,4"
                            ToolTip="{Binding Name}"
                            ToolTipService.InitialShowDelay="2000">
                        <StackPanel>
                            <TextBlock x:Name="CardName" Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                                       Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock x:Name="CardSub" Text="{Binding IconViewSubText}" FontSize="10"
                                       Foreground="#E0E0E0" Margin="0,1,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <Trigger SourceName="CardBorder" Property="IsMouseOver" Value="True">
                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                    <Setter TargetName="CardBorder" Property="BorderThickness" Value="2"/>
                    <Setter TargetName="CardBorder" Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15" Color="Black"/>
                        </Setter.Value>
                    </Setter>
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="InfoOverlay" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15">
                                    <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="InfoOverlay" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
                <DataTrigger Binding="{Binding DataContext.FileViewMode, RelativeSource={RelativeSource AncestorType=local:TabContentControl}}" Value="{x:Static local:FileViewMode.MediumIcon}">
                    <Setter TargetName="CardBorder" Property="Width" Value="116"/>
                    <Setter TargetName="CardBorder" Property="Height" Value="116"/>
                    <Setter TargetName="CardBorder" Property="Margin" Value="3"/>
                    <Setter TargetName="CardBorder" Property="CornerRadius" Value="4"/>
                    <Setter TargetName="CardGrid" Property="Width" Value="116"/>
                    <Setter TargetName="CardGrid" Property="Height" Value="116"/>
                    <Setter TargetName="InfoOverlay" Property="CornerRadius" Value="0,0,4,4"/>
                    <Setter TargetName="InfoOverlay" Property="Padding" Value="4,3"/>
                    <Setter TargetName="CardName" Property="FontSize" Value="12"/>
                    <Setter TargetName="CardSub" Property="FontSize" Value="9"/>
                    <Setter TargetName="CardSub" Property="Margin" Value="0,1,0,0"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding DataContext.FileViewMode, RelativeSource={RelativeSource AncestorType=local:TabContentControl}}" Value="{x:Static local:FileViewMode.SmallIcon}">
                    <Setter TargetName="CardBorder" Property="Width" Value="80"/>
                    <Setter TargetName="CardBorder" Property="Height" Value="78"/>
                    <Setter TargetName="CardBorder" Property="Margin" Value="3"/>
                    <Setter TargetName="CardBorder" Property="CornerRadius" Value="4"/>
                    <Setter TargetName="CardGrid" Property="Width" Value="80"/>
                    <Setter TargetName="CardGrid" Property="Height" Value="78"/>
                    <Setter TargetName="InfoOverlay" Property="CornerRadius" Value="0,0,4,4"/>
                    <Setter TargetName="InfoOverlay" Property="Padding" Value="4,3"/>
                    <Setter TargetName="CardName" Property="FontSize" Value="12"/>
                    <Setter TargetName="CardSub" Property="FontSize" Value="9"/>
                    <Setter TargetName="CardSub" Property="Margin" Value="0,1,0,0"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- 非画像ファイル用（エクスプローラー風: カード高さ固定・アイコン/タイトル開始位置固定・長い名前は4行まで表示しそれ以上は...省略） -->
        <DataTemplate x:Key="IconViewNonImageTemplate">
            <Border x:Name="CardBorder" Width="160" Height="156" Margin="3"
                    CornerRadius="4" ClipToBounds="True"
                    Background="Transparent" BorderThickness="0"
                    ToolTip="{Binding Name}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition>
                            <RowDefinition.Style>
                                <Style TargetType="{x:Type RowDefinition}">
<Setter Property="Height" Value="72"/>
                                        <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.FileViewMode, RelativeSource={RelativeSource AncestorType=local:TabContentControl}}" Value="{x:Static local:FileViewMode.MediumIcon}">
                                            <Setter Property="Height" Value="56"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding DataContext.FileViewMode, RelativeSource={RelativeSource AncestorType=local:TabContentControl}}" Value="{x:Static local:FileViewMode.SmallIcon}">
                                            <Setter Property="Height" Value="36"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </RowDefinition.Style>
                        </RowDefinition>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Image x:Name="CardImage" Grid.Row="0" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality" ImageFailed="Image_ImageFailed"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="8,4" MaxHeight="64">
                        <Image.Source>
                            <MultiBinding Converter="{StaticResource ThumbnailOrIcon}">
                                <Binding Path="Thumbnail"/>
                                <Binding Path="Icon"/>
                            </MultiBinding>
                        </Image.Source>
                    </Image>
                    <TextBlock x:Name="CardName" Grid.Row="1" Text="{Binding Name}"
                               Style="{StaticResource ActivePaneToolbarTextStyle}" FontSize="12"
                               TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center"
                               VerticalAlignment="Top" Margin="2,2,2,0" MaxHeight="60"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="CardSub" Grid.Row="1" Text="{Binding IconViewSubText}" FontSize="9"
                               Style="{StaticResource ActivePaneSubTextStyle}" Margin="2,0,2,0"
                               HorizontalAlignment="Center" VerticalAlignment="Bottom" Visibility="Collapsed"/>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding DataContext.FileViewMode, RelativeSource={RelativeSource AncestorType=local:TabContentControl}}" Value="{x:Static local:FileViewMode.MediumIcon}">
                    <Setter TargetName="CardBorder" Property="Width" Value="116"/>
                    <Setter TargetName="CardBorder" Property="Height" Value="132"/>
                    <Setter TargetName="CardBorder" Property="Margin" Value="3"/>
                    <Setter TargetName="CardImage" Property="Margin" Value="6,4"/>
                    <Setter TargetName="CardImage" Property="MaxHeight" Value="48"/>
                    <Setter TargetName="CardName" Property="FontSize" Value="12"/>
                    <Setter TargetName="CardName" Property="MaxHeight" Value="60"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding DataContext.FileViewMode, RelativeSource={RelativeSource AncestorType=local:TabContentControl}}" Value="{x:Static local:FileViewMode.SmallIcon}">
                    <Setter TargetName="CardBorder" Property="Width" Value="80"/>
                    <Setter TargetName="CardBorder" Property="Height" Value="94"/>
                    <Setter TargetName="CardBorder" Property="Margin" Value="3"/>
                    <Setter TargetName="CardImage" Property="Margin" Value="4,2"/>
                    <Setter TargetName="CardImage" Property="MaxHeight" Value="32"/>
                    <Setter TargetName="CardName" Property="FontSize" Value="12"/>
                    <Setter TargetName="CardName" Property="MaxHeight" Value="52"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <local:IconViewTemplateSelector x:Key="IconViewTemplateSelector"
                                       ImageTemplate="{StaticResource IconViewImageTemplate}"
                                       NonImageTemplate="{StaticResource IconViewNonImageTemplate}"/>

        <!-- アイコンビュー用カードテンプレート（上記リソースを ItemTemplateSelector で切り替え） -->

        <!-- 検索フィルターバー用トグルボタンスタイル（モダン・ピル型） -->
        <Style x:Key="FilterToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="{DynamicResource ListHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#E3F2FD"/>
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#FFFFFF"/>
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- カスタムメニュー項目用ボタンスタイル -->
        <Style x:Key="MenuItemButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource ContextMenuTextBrush}"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
            <Setter Property="FontSize" Value="{StaticResource AppFontSize}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}" Margin="0,1">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                       VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource OnePointDarkBackground}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListView">
            <Style.Resources>
                <!-- 縦スクロールバーをコンテンツの上に重ねるためのスタイル -->
                <Style TargetType="ScrollViewer">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollViewer">
                                <Grid Background="{TemplateBinding Background}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- コンテンツ領域。ColumnSpan="2" でスクロールバーの下まで広げる -->
                                    <DockPanel Grid.ColumnSpan="2" Grid.RowSpan="2" Margin="{TemplateBinding Padding}">
                                        <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                              Content="{TemplateBinding Content}"
                                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                                              CanContentScroll="{TemplateBinding CanContentScroll}"/>
                                    </DockPanel>

                                    <ScrollBar x:Name="PART_VerticalScrollBar"
                                               Grid.Column="1"
                                               Maximum="{TemplateBinding ScrollableHeight}"
                                               Minimum="0"
                                               Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                                               ViewportSize="{TemplateBinding ViewportHeight}"
                                               Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                               HorizontalAlignment="Right"
                                               Panel.ZIndex="10"/>

                                    <ScrollBar x:Name="PART_HorizontalScrollBar"
                                               Grid.Row="1"
                                               Orientation="Horizontal"
                                               Maximum="{TemplateBinding ScrollableWidth}"
                                               Minimum="0"
                                               Value="{Binding HorizontalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                                               ViewportSize="{TemplateBinding ViewportWidth}"
                                               Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                                               VerticalAlignment="Bottom"
                                               Panel.ZIndex="10"/>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
        </Style>
        <!-- お気に入りボタン用スタイル（ローカル定義）。ホバー時はアイコンのみ／最小限の円形背景で反応、コンパクト配置 -->
        <Style x:Key="FavoriteStarButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButton}">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinWidth" Value="20"/>
            <Setter Property="MinHeight" Value="20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <Ellipse x:Name="HoverCircle" Width="20" Height="20" Fill="#E0DDD0" Opacity="0"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverCircle" Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverCircle" Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <GridView x:Key="SearchGridView" x:Shared="False">
            <GridView.ColumnHeaderContainerStyle>
                <Style TargetType="GridViewColumnHeader">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <!-- Gripperのないテンプレートを適用してリサイズのみ禁止（ソートクリックは有効） -->
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="GridViewColumnHeader">
                                <Grid>
                                    <Border x:Name="HeaderBorder" BorderThickness="0,0,1,1" BorderBrush="{DynamicResource BorderBrush}" Padding="10,6" Background="Transparent">
                                        <StackPanel Orientation="Horizontal">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                            <Grid Margin="5,0,0,0">
                                                <icon:PackIconLucide Kind="ChevronUp" Width="10" Height="10">
                                                    <icon:PackIconLucide.Style>
                                                        <Style TargetType="icon:PackIconLucide">
                                                            <Setter Property="Opacity" Value="0.3"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Value="True">
                                                                    <DataTrigger.Binding>
                                                                        <MultiBinding Converter="{StaticResource IsColActive}">
                                                                            <Binding Path="DataContext.ActiveSortProperty" RelativeSource="{RelativeSource AncestorType={x:Type local:TabContentControl}}"/>
                                                                            <Binding Path="Column.Header" RelativeSource="{RelativeSource TemplatedParent}"/>
                                                                        </MultiBinding>
                                                                    </DataTrigger.Binding>
                                                                    <Setter Property="Opacity" Value="1.0"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </icon:PackIconLucide.Style>
                                                    <icon:PackIconLucide.Visibility>
                                                        <MultiBinding Converter="{StaticResource SortInfoToVis}" ConverterParameter="Ascending">
                                                            <Binding Path="DataContext.ActiveSortProperty" RelativeSource="{RelativeSource AncestorType={x:Type local:TabContentControl}}"/>
                                                            <Binding Path="DataContext.ActiveSortDirection" RelativeSource="{RelativeSource AncestorType={x:Type local:TabContentControl}}"/>
                                                            <Binding Path="Column.Header" RelativeSource="{RelativeSource TemplatedParent}"/>
                                                        </MultiBinding>
                                                    </icon:PackIconLucide.Visibility>
                                                </icon:PackIconLucide>
                                                <icon:PackIconLucide Kind="ChevronDown" Width="10" Height="10">
                                                    <icon:PackIconLucide.Visibility>
                                                        <MultiBinding Converter="{StaticResource SortInfoToVis}" ConverterParameter="Descending">
                                                            <Binding Path="DataContext.ActiveSortProperty" RelativeSource="{RelativeSource AncestorType={x:Type local:TabContentControl}}"/>
                                                            <Binding Path="DataContext.ActiveSortDirection" RelativeSource="{RelativeSource AncestorType={x:Type local:TabContentControl}}"/>
                                                            <Binding Path="Column.Header" RelativeSource="{RelativeSource TemplatedParent}"/>
                                                        </MultiBinding>
                                                    </icon:PackIconLucide.Visibility>
                                                </icon:PackIconLucide>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                    <!-- Gripperを復活させてリサイズ可能にする -->
                                    <Thumb x:Name="PART_HeaderGripper" HorizontalAlignment="Right" Width="2" Background="Transparent" Cursor="SizeWE" Margin="0,0,-1,0">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}" Value="サイズ">
                                        <Setter TargetName="HeaderBorder" Property="Padding" Value="10,6,20,6"/>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <!-- フォーカス中ペインではヘッダ文字色も黒に -->
                        <DataTrigger Binding="{Binding ParentPane.IsActive}" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource FocusedPaneTextBrush}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </GridView.ColumnHeaderContainerStyle>

            <GridViewColumn Header="名前" Width="240">
                <GridViewColumn.HeaderTemplate>
                    <DataTemplate>
                        <TextBlock Text="名前" Style="{StaticResource ActivePaneHeaderTextStyle}"/>
                    </DataTemplate>
                </GridViewColumn.HeaderTemplate>
                <GridViewColumn.CellTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0" Padding="16,4" Margin="-6,0,-8,0" SnapsToDevicePixels="True">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="{Binding Name}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Style="{StaticResource ActivePaneCellTextStyle}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridViewColumn.CellTemplate>
            </GridViewColumn>

            <GridViewColumn Header="場所" Width="40">
                <GridViewColumn.HeaderTemplate>
                    <DataTemplate>
                        <TextBlock Text="場所" Style="{StaticResource ActivePaneHeaderTextStyle}"/>
                    </DataTemplate>
                </GridViewColumn.HeaderTemplate>
                <GridViewColumn.CellTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0" Padding="10,4" Margin="-6,0,-8,0" SnapsToDevicePixels="True">
                            <Grid ToolTip="{Binding LocationType}">
                                <icon:PackIconLucide Kind="{Binding LocationIconKind}" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource ActivePaneToolbarSubIconStyle}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridViewColumn.CellTemplate>
            </GridViewColumn>

            <GridViewColumn Header="パス" Width="300">
                <GridViewColumn.HeaderTemplate>
                    <DataTemplate>
                        <TextBlock Text="パス" Style="{StaticResource ActivePaneHeaderTextStyle}"/>
                    </DataTemplate>
                </GridViewColumn.HeaderTemplate>
                <!-- Widthはコードビハインドで制御 -->
                <GridViewColumn.CellTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0" Padding="10,4" Margin="-6,0,-8,0" SnapsToDevicePixels="True" Background="Transparent">
                            <TextBlock HorizontalAlignment="Stretch" TextAlignment="Left" VerticalAlignment="Center" TextTrimming="None" ToolTip="{Binding FullPath}">
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource PathDisplayConverter}">
                                        <Binding Path="FullPath"/>
                                        <Binding Path="SearchPathColumnWidth" RelativeSource="{RelativeSource AncestorType=local:TabContentControl}"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                                <TextBlock.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" 
                                                  Command="{Binding DataContext.JumpToPathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding FullPath}"/>
                                </TextBlock.InputBindings>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.ParentPane.IsActive, RelativeSource={RelativeSource AncestorType=local:TabContentControl}}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource FocusedPaneTextBrush}"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="TextDecorations" Value="Underline"/>
                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </DataTemplate>
                </GridViewColumn.CellTemplate>
            </GridViewColumn>

            <GridViewColumn Header="更新日時" Width="140">
                <GridViewColumn.HeaderTemplate>
                    <DataTemplate>
                        <TextBlock Text="更新日時" Style="{StaticResource ActivePaneHeaderTextStyle}"/>
                    </DataTemplate>
                </GridViewColumn.HeaderTemplate>
                <GridViewColumn.CellTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0" Padding="16,4" Margin="-6,0,-8,0" SnapsToDevicePixels="True">
                            <TextBlock Text="{Binding LastModified, StringFormat='yyyy/MM/dd HH:mm'}" VerticalAlignment="Center" Style="{StaticResource ActivePaneToolbarTextStyle}"/>
                        </Border>
                    </DataTemplate>
                </GridViewColumn.CellTemplate>
            </GridViewColumn>

            <GridViewColumn Header="サイズ" Width="105">
                <GridViewColumn.HeaderTemplate>
                    <DataTemplate>
                        <TextBlock Text="サイズ" Style="{StaticResource ActivePaneHeaderTextStyle}"/>
                    </DataTemplate>
                </GridViewColumn.HeaderTemplate>
                <GridViewColumn.CellTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0" Padding="10,2,20,2" Margin="-6,0,-9,0" SnapsToDevicePixels="True">
                            <TextBlock x:Name="SizeText" Text="{Binding DisplaySize}" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource ActivePaneToolbarTextStyle}"/>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                <Setter TargetName="SizeText" Property="FontStyle" Value="Italic"/>
                                <Setter TargetName="SizeText" Property="Foreground" Value="#999999"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </GridViewColumn.CellTemplate>
            </GridViewColumn>
        </GridView>

    </UserControl.Resources>
    
    <Grid>
        <DockPanel>
            <DockPanel.Style>
                <Style TargetType="DockPanel">
                    <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ParentPane.IsActive}" Value="True">
                            <Setter Property="Background" Value="{DynamicResource FocusedPaneBackgroundBrush}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DockPanel.Style>
            <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="6,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource HeaderBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ParentPane.IsActive}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource FocusedPaneHeaderBackgroundBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            <Grid>
                <Grid.RowDefinitions>
                    <!-- 1行目: アクション行 -->
                    <RowDefinition Height="32"/>
                    <!-- 2行目: アドレスバー行 -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 1行目（アクション行） -->
                <Grid Grid.Row="0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左側: アイコン群 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0">
                        <!-- 1. ナビゲーション (履歴・階層) -->
                        <Button Style="{StaticResource IconButton}" Command="{Binding BackCommand}" IsTabStop="False" Margin="0,0,2,0" ToolTip="戻る (Alt+←)">
                            <icon:PackIconLucide Kind="ArrowLeft" Width="12" Height="12" Style="{StaticResource ActivePaneToolbarIconStyle}"/>
                        </Button>
                        <Button Style="{StaticResource IconButton}" Command="{Binding ForwardCommand}" IsTabStop="False" Margin="0,0,4,0" ToolTip="進む (Alt+→)">
                            <icon:PackIconLucide Kind="ArrowRight" Width="12" Height="12" Style="{StaticResource ActivePaneToolbarIconStyle}"/>
                        </Button>
                        <Button Style="{StaticResource IconButton}" Command="{Binding UpCommand}" IsTabStop="False" Margin="0,0,4,0" ToolTip="上へ (Backspace)">
                            <icon:PackIconLucide Kind="ArrowUp" Width="12" Height="12" Style="{StaticResource ActivePaneToolbarIconStyle}"/>
                        </Button>
                        <Button Style="{StaticResource IconButton}" Command="{Binding RefreshCommand}" IsTabStop="False" Margin="0,0,4,0" ToolTip="更新 (F5)">
                            <icon:PackIconLucide Kind="RotateCw" Width="12" Height="12" Style="{StaticResource ActivePaneToolbarIconStyle}"/>
                        </Button>
                        <TextBlock Text="|" Foreground="{DynamicResource ToolbarSeparatorBrush}" Margin="4,0" VerticalAlignment="Center" FontWeight="SemiBold"/>

                        <!-- 2. 場所 (ショートカット) -->
                        <Button Style="{StaticResource IconButton}" Command="{Binding ParentPane.NavigateToHomeCommand}" IsTabStop="False" Margin="0,0,4,0" ToolTip="ホームに移動">
                            <icon:PackIconLucide Kind="Home" Width="12" Height="12" Style="{StaticResource ActivePaneToolbarIconStyle}"/>
                        </Button>
                        <Button Style="{StaticResource IconButton}" Command="{Binding NavigateToDesktopCommand}" IsTabStop="False" Margin="0,0,4,0" ToolTip="デスクトップへ">
                            <icon:PackIconLucide Kind="Monitor" Width="12" Height="12" Style="{StaticResource ActivePaneToolbarIconStyle}"/>
                        </Button>
                        <Button Style="{StaticResource IconButton}" Command="{Binding NavigateToDownloadsCommand}" IsTabStop="False" Margin="0,0,4,0" ToolTip="ダウンロードへ">
                            <icon:PackIconLucide Kind="Download" Width="12" Height="12" Style="{StaticResource ActivePaneToolbarIconStyle}"/>
                        </Button>
                        <TextBlock Text="|" Foreground="{DynamicResource ToolbarSeparatorBrush}" Margin="4,0" VerticalAlignment="Center" FontWeight="SemiBold"/>

                        <!-- 3. 作成・編集 (新規追加) -->
                        <Button Style="{StaticResource IconButton}" Command="{Binding CreateNewFolderCommand}" IsTabStop="False" Margin="0,0,4,0" ToolTip="フォルダを作成 (Ctrl+Shift+N)">
                            <icon:PackIconLucide Kind="FolderPlus" Width="12" Height="12" Style="{StaticResource ActivePaneToolbarIconStyle}"/>
                        </Button>
                        <TextBlock Text="|" Foreground="{DynamicResource ToolbarSeparatorBrush}" Margin="4,0" VerticalAlignment="Center" FontWeight="SemiBold"/>

                        <!-- 4. 管理 (更新・外部) -->
                        <Button Style="{StaticResource IconButton}" Command="{Binding OpenCurrentFolderInExplorerCommand}" IsTabStop="False" Margin="0,0,4,0" ToolTip="エクスプローラーで開く">
                            <icon:PackIconLucide Kind="FolderOpen" Width="12" Height="12" Style="{StaticResource ActivePaneToolbarIconStyle}"/>
                        </Button>
                        <Button Style="{StaticResource IconButton}" Command="{Binding ImportFromExplorerCommand}" IsTabStop="False" Margin="0,0,4,0" ToolTip="フォルダを取り込む">
                            <icon:PackIconLucide Kind="Import" Width="12" Height="12" Style="{StaticResource ActivePaneToolbarIconStyle}"/>
                        </Button>
                        <TextBlock Text="|" Foreground="{DynamicResource ToolbarSeparatorBrush}" Margin="4,0" VerticalAlignment="Center" FontWeight="SemiBold"/>

                        <!-- 表示形式: 一覧ビュー／アイコンビュー（当ペイン専用・列を自動補正と同じ選択時演出） -->
                        <ToggleButton Style="{StaticResource ActivePaneIconToggleButtonStyle}"
                                      IsChecked="{Binding FileViewMode, Converter={StaticResource EnumEqualityToBool}, ConverterParameter={x:Static local:FileViewMode.Details}, Mode=OneWay}"
                                      Command="{Binding ChangeFileViewModeCommand}" CommandParameter="{x:Static local:FileViewMode.Details}"
                                      ToolTip="一覧ビューへの切り替え" Margin="0,0,2,0" IsTabStop="False">
                            <icon:PackIconLucide Kind="Rows3" Width="12" Height="12"/>
                        </ToggleButton>
                        <!-- アイコン表示: 小・中・大の順でツールバーに列挙（選択中が IsChecked で判別可能） -->
                        <ToggleButton Style="{StaticResource ActivePaneIconToggleButtonStyle}"
                                      IsChecked="{Binding FileViewMode, Converter={StaticResource EnumEqualityToBool}, ConverterParameter={x:Static local:FileViewMode.SmallIcon}, Mode=OneWay}"
                                      Command="{Binding ChangeFileViewModeCommand}" CommandParameter="{x:Static local:FileViewMode.SmallIcon}"
                                      ToolTip="小アイコン" Margin="0,0,2,0" IsTabStop="False">
                            <icon:PackIconLucide Kind="LayoutList" Width="12" Height="12"/>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource ActivePaneIconToggleButtonStyle}"
                                      IsChecked="{Binding FileViewMode, Converter={StaticResource EnumEqualityToBool}, ConverterParameter={x:Static local:FileViewMode.MediumIcon}, Mode=OneWay}"
                                      Command="{Binding ChangeFileViewModeCommand}" CommandParameter="{x:Static local:FileViewMode.MediumIcon}"
                                      ToolTip="中アイコン" Margin="0,0,2,0" IsTabStop="False">
                            <icon:PackIconLucide Kind="LayoutGrid" Width="12" Height="12"/>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource ActivePaneIconToggleButtonStyle}"
                                      IsChecked="{Binding FileViewMode, Converter={StaticResource EnumEqualityToBool}, ConverterParameter={x:Static local:FileViewMode.LargeIcon}, Mode=OneWay}"
                                      Command="{Binding ChangeFileViewModeCommand}" CommandParameter="{x:Static local:FileViewMode.LargeIcon}"
                                      ToolTip="大アイコン" Margin="0,0,4,0" IsTabStop="False">
                            <icon:PackIconLucide Kind="PanelTop" Width="12" Height="12"/>
                        </ToggleButton>
                        <TextBlock Text="|" Foreground="{DynamicResource ToolbarSeparatorBrush}" Margin="4,0" VerticalAlignment="Center" FontWeight="SemiBold"/>

                        <!-- 5. 表示設定 -->
                        <ToggleButton Style="{StaticResource ActivePaneIconToggleButtonStyle}" IsChecked="{Binding IsAdaptiveColumnsEnabled, Mode=TwoWay}" IsTabStop="False" Margin="0,0,4,0" ToolTip="列を自動補正">
                            <icon:PackIconLucide Kind="TableColumnsSplit" Width="12" Height="12"/>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource ActivePaneIconToggleButtonStyle}" IsChecked="{Binding IsGroupFoldersFirst, Mode=TwoWay}" IsTabStop="False" Margin="0,0,4,0" ToolTip="フォルダを先に">
                            <icon:PackIconLucide Kind="FolderTree" Width="12" Height="12"/>
                        </ToggleButton>
                    </StackPanel>

                    <!-- 右側: 検索バー -->
                    <Border x:Name="SearchBarBorder" Grid.Column="1" Margin="0,4" CornerRadius="4" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                <Setter Property="Effect" Value="{x:Null}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsIndexSearchMode}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource IndexSearchBackgroundBrush}"/>
                                    </DataTrigger>
                                    <!-- インデックスモード＋検索バーにフォーカス: アンバー枠＋外側発光 -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsIndexSearchMode}" Value="True"/>
                                            <Condition Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource Self}}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.Setters>
                                            <Setter Property="BorderBrush" Value="{DynamicResource IndexSearchFocusBorderBrush}"/>
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="#FFF9C4" BlurRadius="5" ShadowDepth="0" Opacity="0.45"/>
                                                </Setter.Value>
                                            </Setter>
                                        </MultiDataTrigger.Setters>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Command="{Binding ToggleIndexSearchModeCommand}" Style="{StaticResource IconButton}"
                                    Padding="8,0,4,0" IsTabStop="False" Cursor="Hand"
                                    ToolTip="{Binding IsIndexSearchMode, Converter={StaticResource IndexSearchModeTooltipConverter}}">
                                <icon:PackIconLucide Width="12" Height="12" VerticalAlignment="Center"
                                    RenderTransformOrigin="0.5,0.5">
                                    <icon:PackIconLucide.RenderTransform>
                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                    </icon:PackIconLucide.RenderTransform>
                                    <icon:PackIconLucide.Style>
                                        <Style TargetType="icon:PackIconLucide" BasedOn="{StaticResource ActivePaneToolbarSubIconStyle}">
                                            <Setter Property="Kind" Value="Search"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsIndexSearchMode}" Value="True">
                                                    <Setter Property="Kind" Value="Zap"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource IndexSearchIconBrush}"/>
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="#E6B800" BlurRadius="6" ShadowDepth="0" Opacity="0.7"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <!-- インデックスモード時＋ホバー: 拡大＋発光強調 -->
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsIndexSearchMode}" Value="True"/>
                                                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <MultiDataTrigger.Setters>
                                                        <Setter Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect Color="#FFD700" BlurRadius="10" ShadowDepth="0" Opacity="0.9"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </MultiDataTrigger.Setters>
                                                    <MultiDataTrigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                                 To="1.25" Duration="0:0:0.15">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <QuadraticEase EasingMode="EaseOut"/>
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                                 To="1.25" Duration="0:0:0.15">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <QuadraticEase EasingMode="EaseOut"/>
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </MultiDataTrigger.EnterActions>
                                                    <MultiDataTrigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                                 To="1" Duration="0:0:0.15">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <QuadraticEase EasingMode="EaseOut"/>
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                                 To="1" Duration="0:0:0.15">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <QuadraticEase EasingMode="EaseOut"/>
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </MultiDataTrigger.ExitActions>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </icon:PackIconLucide.Style>
                                </icon:PackIconLucide>
                            </Button>
                            <!-- Col 1: スコープフィルターボタン (インデックスモード時のみ表示) -->
                            <Button x:Name="ScopeFilterButton" Grid.Column="1"
                                    Click="ScopeFilterButton_Click"
                                    Style="{StaticResource IconButton}"
                                    Padding="2,0,4,0" IsTabStop="False" Cursor="Hand"
                                    ToolTip="検索対象フォルダを絞り込む">
                                <Button.Visibility>
                                    <Binding Path="IsIndexSearchMode" Converter="{StaticResource BooleanToVisibilityConverter}"/>
                                </Button.Visibility>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <icon:PackIconLucide Width="11" Height="11" VerticalAlignment="Center" Margin="0,0,2,0">
                                        <icon:PackIconLucide.Style>
                                            <Style TargetType="icon:PackIconLucide" BasedOn="{StaticResource ActivePaneToolbarSubIconStyle}">
                                                <Setter Property="Kind" Value="FolderSearch"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IndexSearchSettings.IsScopeFiltered, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource IndexSearchIconBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </icon:PackIconLucide.Style>
                                    </icon:PackIconLucide>
                                    <TextBlock FontSize="10" VerticalAlignment="Center"
                                               Text="{Binding DataContext.IndexSearchSettings.ScopeBadgeText, RelativeSource={RelativeSource AncestorType=Window}}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource ActivePaneSubTextStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IndexSearchSettings.IsScopeFiltered, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource IndexSearchIconBrush}"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Button>
                            <!-- スコープ Popup（精密な計器 — 高密度レイアウト） -->
                            <Popup x:Name="ScopeFilterPopup"
                                   PlacementTarget="{Binding ElementName=ScopeFilterButton}"
                                   Placement="Bottom" StaysOpen="True"
                                   AllowsTransparency="True" PopupAnimation="None"
                                   Opened="ScopeFilterPopup_Opened">
                                <Border x:Name="ScopePopupBorder"
                                        Background="{DynamicResource BackgroundBrush}"
                                        BorderBrush="#B8B3A4" BorderThickness="1"
                                        CornerRadius="8" Padding="0,4,0,4"
                                        MinWidth="320" MaxWidth="500" MaxHeight="440"
                                        RenderTransformOrigin="0.5,0" Opacity="0">
                                    <Border.RenderTransform>
                                        <TranslateTransform X="0" Y="-5"/>
                                    </Border.RenderTransform>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="28" ShadowDepth="4" Opacity="0.18" Direction="290" Color="#000000"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- ═══ ヘッダー行（ボタンをリスト右端と揃える） ═══ -->
                                        <Border Grid.Row="0" Padding="10,3,17,5">
                                            <Border.BorderBrush>
                                                <SolidColorBrush Color="{StaticResource BorderColor}" Opacity="0.6"/>
                                            </Border.BorderBrush>
                                            <Border.BorderThickness>
                                                <Thickness>0,0,0,1</Thickness>
                                            </Border.BorderThickness>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="検索スコープ" FontSize="11" FontWeight="Medium"
                                                           Foreground="#000000" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <Button Command="{Binding DataContext.IndexSearchSettings.SelectAllScopeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            Cursor="Hand" IsTabStop="False" Focusable="False">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <TextBlock x:Name="Lbl" Text="すべて選択" FontSize="11"
                                                                           Foreground="#000000" Opacity="0.55" Padding="5,2"/>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Lbl" Property="Opacity" Value="1"/>
                                                                        <Setter TargetName="Lbl" Property="TextDecorations" Value="Underline"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                    <TextBlock Text="|" FontSize="10" Foreground="#000000" Opacity="0.25"
                                                               VerticalAlignment="Center"/>
                                                    <Button Command="{Binding DataContext.IndexSearchSettings.DeselectAllScopeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            Cursor="Hand" IsTabStop="False" Focusable="False">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <TextBlock x:Name="Lbl" Text="すべて解除" FontSize="11"
                                                                           Foreground="#000000" Opacity="0.55" Padding="5,2"/>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Lbl" Property="Opacity" Value="1"/>
                                                                        <Setter TargetName="Lbl" Property="TextDecorations" Value="Underline"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- ═══ リスト ═══ -->
                                        <ListBox Grid.Row="1" x:Name="ScopeListBox"
                                                 ItemsSource="{Binding DataContext.IndexSearchSettings.ScopeItems, RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Background="Transparent" BorderThickness="0" Padding="0,1,0,1"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 MaxHeight="370" SelectionMode="Single"
                                                 FocusVisualStyle="{x:Null}">

                                            <!-- ─── Popup ローカルリソース: ステルス・スクロールバー + コンパクト CheckBox ─── -->
                                            <ListBox.Resources>
                                                <!-- 4px 極細スクロールバー -->
                                                <Style TargetType="{x:Type ScrollBar}">
                                                    <Setter Property="Width" Value="5"/>
                                                    <Setter Property="MinWidth" Value="5"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="{x:Type ScrollBar}">
                                                                <Grid SnapsToDevicePixels="true" Background="{TemplateBinding Background}">
                                                                    <Track x:Name="PART_Track"
                                                                           IsEnabled="{TemplateBinding IsEnabled}"
                                                                           IsDirectionReversed="true">
                                                                        <Track.Thumb>
                                                                            <Thumb>
                                                                                <Thumb.Template>
                                                                                    <ControlTemplate TargetType="{x:Type Thumb}">
                                                                                        <Border x:Name="rectangle"
                                                                                                SnapsToDevicePixels="True"
                                                                                                Background="{DynamicResource SubTextBrush}"
                                                                                                Opacity="0.25"
                                                                                                CornerRadius="2"
                                                                                                Margin="1,2"/>
                                                                                        <ControlTemplate.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type ScrollBar}}}" Value="True">
                                                                                                <Setter TargetName="rectangle" Property="Opacity" Value="0.55"/>
                                                                                                <Setter TargetName="rectangle" Property="Margin" Value="0,2"/>
                                                                                            </DataTrigger>
                                                                                            <Trigger Property="IsDragging" Value="true">
                                                                                                <Setter TargetName="rectangle" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                                                <Setter TargetName="rectangle" Property="Opacity" Value="0.85"/>
                                                                                                <Setter TargetName="rectangle" Property="Margin" Value="0,2"/>
                                                                                            </Trigger>
                                                                                        </ControlTemplate.Triggers>
                                                                                    </ControlTemplate>
                                                                                </Thumb.Template>
                                                                            </Thumb>
                                                                        </Track.Thumb>
                                                                        <Track.IncreaseRepeatButton>
                                                                            <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Opacity="0" Focusable="false"/>
                                                                        </Track.IncreaseRepeatButton>
                                                                        <Track.DecreaseRepeatButton>
                                                                            <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Opacity="0" Focusable="false"/>
                                                                        </Track.DecreaseRepeatButton>
                                                                    </Track>
                                                                </Grid>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>

                                                <!-- コンパクト CheckBox（15x15, CornerRadius=3） -->
                                                <Style TargetType="CheckBox">
                                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="CheckBox">
                                                                <Border x:Name="CheckBoxBorder"
                                                                        Width="15" Height="15"
                                                                        Background="{DynamicResource InputBackgroundBrush}"
                                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="3"
                                                                        VerticalAlignment="Center">
                                                                    <icon:PackIconLucide x:Name="CheckMark" Kind="Check"
                                                                                         Width="10" Height="10"
                                                                                         Foreground="White"
                                                                                         Visibility="Collapsed"
                                                                                         HorizontalAlignment="Center"
                                                                                         VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsChecked" Value="True">
                                                                        <Setter TargetName="CheckBoxBorder" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                        <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                        <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                                    </Trigger>
                                                                    <MultiTrigger>
                                                                        <MultiTrigger.Conditions>
                                                                            <Condition Property="IsMouseOver" Value="True"/>
                                                                            <Condition Property="IsChecked" Value="False"/>
                                                                        </MultiTrigger.Conditions>
                                                                        <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{DynamicResource TextBrush}"/>
                                                                        <Setter TargetName="CheckBoxBorder" Property="Background" Value="{DynamicResource CheckboxHoverBrush}"/>
                                                                    </MultiTrigger>
                                                                    <MultiTrigger>
                                                                        <MultiTrigger.Conditions>
                                                                            <Condition Property="IsChecked" Value="True"/>
                                                                            <Condition Property="IsMouseOver" Value="True"/>
                                                                        </MultiTrigger.Conditions>
                                                                        <Setter TargetName="CheckBoxBorder" Property="Background" Value="{DynamicResource CheckedHoverAccentBrush}"/>
                                                                        <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{DynamicResource CheckedHoverAccentBrush}"/>
                                                                        <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                                    </MultiTrigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.Resources>

                                            <!-- ─── アイテム・テンプレート（3カラム: 24px / * / Auto） ─── -->
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0" MouseLeftButtonDown="ScopeItem_MouseLeftButtonDown">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="24"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Col0: コンパクト CheckBox -->
                                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                                                  VerticalAlignment="Center" IsTabStop="False"/>

                                                        <!-- Col1: フォルダ名 + パス（行間詰め・高コントラスト） -->
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                                            <TextBlock x:Name="FolderName" Text="{Binding DisplayName}"
                                                                       FontSize="12" FontWeight="SemiBold"
                                                                       Foreground="#000000"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock x:Name="FolderPath" Text="{Binding Path}"
                                                                       FontSize="9" Foreground="#666666"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>

                                                        <!-- Col2: ロック + 件数 -->
                                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,2,0">
                                                            <icon:PackIconLucide x:Name="LockIcon" Kind="Lock" Width="9" Height="9"
                                                                                 VerticalAlignment="Center" Margin="0,0,4,0"
                                                                                 Foreground="#888888"
                                                                                 Visibility="{Binding IsLocked, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                            <TextBlock x:Name="CountText" VerticalAlignment="Center"
                                                                       FontSize="10" FontFamily="Consolas"
                                                                       Foreground="#555555"
                                                                       Text="{Binding DocumentCount, StringFormat='{}{0:N0}件'}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding DocumentCount}" Value="0">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Grid>

                                                    <DataTemplate.Triggers>
                                                        <!-- ホバー時: 濃色背景に対し白系へ反転 -->
                                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                            <Setter TargetName="FolderName" Property="Foreground" Value="#FFFFFF"/>
                                                            <Setter TargetName="FolderPath" Property="Foreground" Value="#C0BBAC"/>
                                                            <Setter TargetName="LockIcon" Property="Foreground" Value="#BBBBBB"/>
                                                            <Setter TargetName="CountText" Property="Foreground" Value="#CCCCCC"/>
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>

                                            <!-- ─── アイテム・コンテナ・スタイル（高密度・全幅ホバーバンド） ─── -->
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <Grid>
                                                                    <Border x:Name="HoverBg" CornerRadius="4" Margin="2,0">
                                                                        <Border.Background>
                                                                            <SolidColorBrush Color="Transparent"/>
                                                                        </Border.Background>
                                                                    </Border>
                                                                    <ContentPresenter Margin="10,4,12,4" VerticalAlignment="Center"/>
                                                                </Grid>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Trigger.EnterActions>
                                                                            <BeginStoryboard>
                                                                                <Storyboard>
                                                                                    <ColorAnimation Storyboard.TargetName="HoverBg"
                                                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                                        To="#48505A" Duration="0:0:0.10"/>
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </Trigger.EnterActions>
                                                                        <Trigger.ExitActions>
                                                                            <BeginStoryboard>
                                                                                <Storyboard>
                                                                                    <ColorAnimation Storyboard.TargetName="HoverBg"
                                                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                                        To="Transparent" Duration="0:0:0.12"/>
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </Trigger.ExitActions>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                        </ListBox>
                                    </Grid>
                                </Border>
                            </Popup>

                            <!-- Col 2: サイズフィルタボタン -->
                            <Button x:Name="SizeFilterButton" Grid.Column="2"
                                    Click="SizeFilterButton_Click"
                                    MouseRightButtonUp="SizeFilterButton_MouseRightButtonUp"
                                    Style="{StaticResource IconButton}"
                                    Padding="2,0,4,0" IsTabStop="False" Cursor="Hand"
                                    ToolTip="サイズで絞り込む&#x0a;右クリック: サイズフィルタをクリア">
                                <StackPanel>
                                    <icon:PackIconLucide Width="11" Height="11"
                                                         VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <icon:PackIconLucide.Style>
                                            <Style TargetType="icon:PackIconLucide"
                                                   BasedOn="{StaticResource ActivePaneToolbarSubIconStyle}">
                                                <Setter Property="Kind" Value="Scale"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.SearchFilter.IsSizeFilterActive,
                                                        RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </icon:PackIconLucide.Style>
                                    </icon:PackIconLucide>
                                    <!-- アクティブ・アンダーライン (1px charcoal gray) -->
                                    <Border Height="1" Background="#333333" Margin="1,2,1,0"
                                            HorizontalAlignment="Stretch" CornerRadius="0.5">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.SearchFilter.IsSizeFilterActive,
                                                        RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     To="1" Duration="0:0:0.1"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                        <DataTrigger.ExitActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     To="0" Duration="0:0:0.1"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.ExitActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </StackPanel>
                            </Button>
                            <!-- サイズフィルタ Popup -->
                            <Popup x:Name="SizeFilterPopup"
                                   PlacementTarget="{Binding ElementName=SizeFilterButton}"
                                   Placement="Bottom" StaysOpen="True"
                                   AllowsTransparency="True" PopupAnimation="None"
                                   Opened="SizeFilterPopup_Opened">
                                <Border x:Name="SizePopupBorder"
                                        Background="{DynamicResource BackgroundBrush}"
                                        BorderBrush="#B8B3A4" BorderThickness="1"
                                        CornerRadius="8" Padding="0,4,0,4"
                                        MinWidth="240" MaxWidth="320"
                                        RenderTransformOrigin="0.5,0" Opacity="0">
                                    <Border.RenderTransform>
                                        <TranslateTransform X="0" Y="-5"/>
                                    </Border.RenderTransform>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="28" ShadowDepth="4" Opacity="0.18" Direction="290" Color="#000000"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <!-- ヘッダー -->
                                        <Border Padding="10,3,10,5">
                                            <Border.BorderBrush>
                                                <SolidColorBrush Color="{StaticResource BorderColor}" Opacity="0.6"/>
                                            </Border.BorderBrush>
                                            <Border.BorderThickness>
                                                <Thickness>0,0,0,1</Thickness>
                                            </Border.BorderThickness>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="サイズ指定" FontSize="11" FontWeight="Medium"
                                                           Foreground="#000000" VerticalAlignment="Center"/>
                                                <Button Grid.Column="1"
                                                        Command="{Binding DataContext.SearchFilter.ResetSizeFilterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        Cursor="Hand" IsTabStop="False" Focusable="False">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <TextBlock x:Name="Lbl" Text="リセット" FontSize="11"
                                                                       Foreground="#000000" Opacity="0.55" Padding="5,2"/>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Lbl" Property="Opacity" Value="1"/>
                                                                    <Setter TargetName="Lbl" Property="TextDecorations" Value="Underline"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                        </Border>
                                        <!-- 入力エリア -->
                                        <StackPanel Margin="10,6,10,2">
                                            <!-- ガイドテキスト -->
                                            <TextBlock Text="単位: k=KB  m=MB  g=GB (未指定=MB)   例: 500k, 2.5g"
                                                       FontSize="10" Foreground="#000000"
                                                       Opacity="0.5" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                            <!-- 最小サイズ -->
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="28"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Min" FontSize="11"
                                                           Foreground="#000000" VerticalAlignment="Center"/>
                                                <TextBox x:Name="SizeMinTextBox" Grid.Column="1" FontSize="11" Padding="5,3"
                                                         Foreground="#000000" VerticalContentAlignment="Center"
                                                         Text="{Binding DataContext.SearchFilter.MinSizeText,
                                                             RelativeSource={RelativeSource AncestorType=Window},
                                                             UpdateSourceTrigger=PropertyChanged}"
                                                         PreviewKeyDown="SizeTextBox_PreviewKeyDown">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.SearchFilter.HasMinSizeError,
                                                                    RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource ErrorTextBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>
                                                <TextBlock Grid.Column="2" FontSize="10" Margin="6,0,0,0"
                                                           Foreground="#000000" Opacity="0.6" VerticalAlignment="Center"
                                                           Text="{Binding DataContext.SearchFilter.MinSizePreview,
                                                               RelativeSource={RelativeSource AncestorType=Window}}"/>
                                            </Grid>
                                            <!-- 最大サイズ -->
                                            <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="28"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Max" FontSize="11"
                                                           Foreground="#000000" VerticalAlignment="Center"/>
                                                <TextBox x:Name="SizeMaxTextBox" Grid.Column="1" FontSize="11" Padding="5,3"
                                                         Foreground="#000000" VerticalContentAlignment="Center"
                                                         Text="{Binding DataContext.SearchFilter.MaxSizeText,
                                                             RelativeSource={RelativeSource AncestorType=Window},
                                                             UpdateSourceTrigger=PropertyChanged}"
                                                         PreviewKeyDown="SizeTextBox_PreviewKeyDown">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.SearchFilter.HasMaxSizeError,
                                                                    RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource ErrorTextBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>
                                                <TextBlock Grid.Column="2" FontSize="10" Margin="6,0,0,0"
                                                           Foreground="#000000" Opacity="0.6" VerticalAlignment="Center"
                                                           Text="{Binding DataContext.SearchFilter.MaxSizePreview,
                                                               RelativeSource={RelativeSource AncestorType=Window}}"/>
                                            </Grid>
                                        </StackPanel>
                                        <!-- 整合性エラー -->
                                        <TextBlock Text="Min が Max を超えています" FontSize="10" Foreground="{DynamicResource ErrorTextBrush}"
                                                   Margin="10,2,10,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DataContext.SearchFilter.HasSizeRangeError,
                                                            RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- セパレータ -->
                                        <Border Margin="10,4,10,2" Height="1">
                                            <Border.Background>
                                                <SolidColorBrush Color="#000000" Opacity="0.1"/>
                                            </Border.Background>
                                        </Border>
                                        <!-- クイックチップ -->
                                        <WrapPanel Margin="10,4,10,6" HorizontalAlignment="Left">
                                            <WrapPanel.Resources>
                                                <Style x:Key="SizeChipStyle" TargetType="Button">
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                    <Setter Property="IsTabStop" Value="False"/>
                                                    <Setter Property="Focusable" Value="False"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="ChipBorder" CornerRadius="2" Padding="8,3" Margin="0,0,4,4"
                                                                        Background="#FFFFFF" BorderBrush="#000000" BorderThickness="1">
                                                                    <TextBlock x:Name="ChipText" Text="{TemplateBinding Content}"
                                                                               FontSize="11" Foreground="#000000"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="ChipBorder" Property="Background" Value="{DynamicResource TextBrush}"/>
                                                                        <Setter TargetName="ChipBorder" Property="BorderBrush" Value="{DynamicResource TextBrush}"/>
                                                                        <Setter TargetName="ChipText" Property="Foreground" Value="#FFFFFF"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </WrapPanel.Resources>
                                            <Button Content="&lt; 100 KB" Style="{StaticResource SizeChipStyle}"
                                                    Command="{Binding DataContext.SearchFilter.ApplySizeChipCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="|100k"/>
                                            <Button Content="100 KB ~ 10 MB" Style="{StaticResource SizeChipStyle}"
                                                    Command="{Binding DataContext.SearchFilter.ApplySizeChipCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="100k|10m"/>
                                            <Button Content="10 MB ~ 1 GB" Style="{StaticResource SizeChipStyle}"
                                                    Command="{Binding DataContext.SearchFilter.ApplySizeChipCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="10m|1g"/>
                                            <Button Content="&gt; 1 GB" Style="{StaticResource SizeChipStyle}"
                                                    Command="{Binding DataContext.SearchFilter.ApplySizeChipCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="1g|"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </Popup>

                            <!-- Col 3: 日付フィルタボタン -->
                            <Button x:Name="DateFilterButton" Grid.Column="3"
                                    Click="DateFilterButton_Click"
                                    MouseRightButtonUp="DateFilterButton_MouseRightButtonUp"
                                    Style="{StaticResource IconButton}"
                                    Padding="2,0,4,0" IsTabStop="False" Cursor="Hand"
                                    ToolTip="日付で絞り込む&#x0a;右クリック: 日付フィルタをクリア">
                                <StackPanel>
                                    <icon:PackIconLucide Width="11" Height="11"
                                                         VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <icon:PackIconLucide.Style>
                                            <Style TargetType="icon:PackIconLucide"
                                                   BasedOn="{StaticResource ActivePaneToolbarSubIconStyle}">
                                                <Setter Property="Kind" Value="Calendar"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.SearchFilter.IsDateFilterActive,
                                                        RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </icon:PackIconLucide.Style>
                                    </icon:PackIconLucide>
                                    <Border Height="1" Background="#333333" Margin="1,2,1,0"
                                            HorizontalAlignment="Stretch" CornerRadius="0.5">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.SearchFilter.IsDateFilterActive,
                                                        RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     To="1" Duration="0:0:0.1"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                        <DataTrigger.ExitActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     To="0" Duration="0:0:0.1"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.ExitActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </StackPanel>
                            </Button>
                            <!-- 日付フィルタ Popup -->
                            <Popup x:Name="DateFilterPopup"
                                   PlacementTarget="{Binding ElementName=DateFilterButton}"
                                   Placement="Bottom" StaysOpen="True"
                                   AllowsTransparency="True" PopupAnimation="None"
                                   Opened="DateFilterPopup_Opened">
                                <Border x:Name="DatePopupBorder"
                                        Background="{DynamicResource BackgroundBrush}"
                                        BorderBrush="#B8B3A4" BorderThickness="1"
                                        CornerRadius="8" Padding="0,4,0,4"
                                        MinWidth="280" MaxWidth="320"
                                        RenderTransformOrigin="0.5,0" Opacity="0">
                                    <Border.RenderTransform>
                                        <TranslateTransform X="0" Y="-5"/>
                                    </Border.RenderTransform>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="28" ShadowDepth="4" Opacity="0.18" Direction="290" Color="#000000"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <!-- ヘッダー -->
                                        <Border Padding="10,3,10,5">
                                            <Border.BorderBrush>
                                                <SolidColorBrush Color="{StaticResource BorderColor}" Opacity="0.6"/>
                                            </Border.BorderBrush>
                                            <Border.BorderThickness>
                                                <Thickness>0,0,0,1</Thickness>
                                            </Border.BorderThickness>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="日付指定" FontSize="11" FontWeight="Medium"
                                                           Foreground="#000000" VerticalAlignment="Center"/>
                                                <Button Grid.Column="1"
                                                        Command="{Binding DataContext.SearchFilter.ResetDateFilterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        Cursor="Hand" IsTabStop="False" Focusable="False">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <TextBlock x:Name="Lbl" Text="リセット" FontSize="11"
                                                                       Foreground="#000000" Opacity="0.55" Padding="5,2"/>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Lbl" Property="Opacity" Value="1"/>
                                                                    <Setter TargetName="Lbl" Property="TextDecorations" Value="Underline"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                        </Border>
                                        <!-- 入力エリア -->
                                        <StackPanel Margin="10,6,10,2">
                                            <!-- ガイドテキスト -->
                                            <TextBlock Text="形式: 20260228 / 0228 / 2026/2/28"
                                                       FontSize="10" Foreground="#000000"
                                                       Opacity="0.5" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                            <!-- 開始日 -->
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="28"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="開始" FontSize="11"
                                                           Foreground="#000000" VerticalAlignment="Center"/>
                                                <TextBox x:Name="DateStartTextBox" Grid.Column="1" FontSize="11" Padding="5,3"
                                                         Foreground="#000000" VerticalContentAlignment="Center"
                                                         Text="{Binding DataContext.SearchFilter.StartDateText,
                                                             RelativeSource={RelativeSource AncestorType=Window},
                                                             UpdateSourceTrigger=PropertyChanged}"
                                                         GotFocus="DateStartTextBox_GotFocus"
                                                         PreviewKeyDown="DateTextBox_PreviewKeyDown">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.SearchFilter.HasStartDateError,
                                                                    RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource ErrorTextBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>
                                                <TextBlock Grid.Column="2" FontSize="10" Margin="6,0,0,0"
                                                           Foreground="#000000" Opacity="0.6" VerticalAlignment="Center"
                                                           Text="{Binding DataContext.SearchFilter.StartDatePreview,
                                                               RelativeSource={RelativeSource AncestorType=Window}}"/>
                                            </Grid>
                                            <!-- 終了日 -->
                                            <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="28"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="終了" FontSize="11"
                                                           Foreground="#000000" VerticalAlignment="Center"/>
                                                <TextBox x:Name="DateEndTextBox" Grid.Column="1" FontSize="11" Padding="5,3"
                                                         Foreground="#000000" VerticalContentAlignment="Center"
                                                         Text="{Binding DataContext.SearchFilter.EndDateText,
                                                             RelativeSource={RelativeSource AncestorType=Window},
                                                             UpdateSourceTrigger=PropertyChanged}"
                                                         GotFocus="DateEndTextBox_GotFocus"
                                                         PreviewKeyDown="DateTextBox_PreviewKeyDown">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.SearchFilter.HasEndDateError,
                                                                    RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource ErrorTextBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>
                                                <TextBlock Grid.Column="2" FontSize="10" Margin="6,0,0,0"
                                                           Foreground="#000000" Opacity="0.6" VerticalAlignment="Center"
                                                           Text="{Binding DataContext.SearchFilter.EndDatePreview,
                                                               RelativeSource={RelativeSource AncestorType=Window}}"/>
                                            </Grid>
                                        </StackPanel>
                                        <!-- 整合性エラー -->
                                        <TextBlock Text="開始が終了を超えています" FontSize="10" Foreground="{DynamicResource ErrorTextBrush}"
                                                   Margin="10,2,10,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DataContext.SearchFilter.HasDateRangeError,
                                                            RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- セパレータ -->
                                        <Border Margin="10,4,10,2" Height="1">
                                            <Border.Background>
                                                <SolidColorBrush Color="#000000" Opacity="0.1"/>
                                            </Border.Background>
                                        </Border>
                                        <!-- クイックチップ (9 プリセット: 短期・中期・期間) -->
                                        <StackPanel Margin="10,4,10,2">
                                            <StackPanel.Resources>
                                                <Style x:Key="DateChipStyle" TargetType="Button">
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                    <Setter Property="IsTabStop" Value="False"/>
                                                    <Setter Property="Focusable" Value="False"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="ChipBorder" CornerRadius="2" Padding="8,3" Margin="0,0,4,4"
                                                                        Background="#FFFFFF" BorderBrush="#000000" BorderThickness="1">
                                                                    <TextBlock x:Name="ChipText" Text="{TemplateBinding Content}"
                                                                               FontSize="11" Foreground="#000000"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="ChipBorder" Property="Background" Value="{DynamicResource TextBrush}"/>
                                                                        <Setter TargetName="ChipBorder" Property="BorderBrush" Value="{DynamicResource TextBrush}"/>
                                                                        <Setter TargetName="ChipText" Property="Foreground" Value="#FFFFFF"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </StackPanel.Resources>
                                            <!-- 短期 -->
                                            <WrapPanel HorizontalAlignment="Left">
                                                <Button Content="今日" Style="{StaticResource DateChipStyle}"
                                                        Command="{Binding DataContext.SearchFilter.ApplyDatePresetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="Today"/>
                                                <Button Content="昨日" Style="{StaticResource DateChipStyle}"
                                                        Command="{Binding DataContext.SearchFilter.ApplyDatePresetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="Yesterday"/>
                                                <Button Content="直近 3 日" Style="{StaticResource DateChipStyle}"
                                                        Command="{Binding DataContext.SearchFilter.ApplyDatePresetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="Last3Days"/>
                                            </WrapPanel>
                                            <!-- 中期 -->
                                            <WrapPanel HorizontalAlignment="Left">
                                                <Button Content="直近 7 日" Style="{StaticResource DateChipStyle}"
                                                        Command="{Binding DataContext.SearchFilter.ApplyDatePresetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="Last7Days"/>
                                                <Button Content="直近 14 日" Style="{StaticResource DateChipStyle}"
                                                        Command="{Binding DataContext.SearchFilter.ApplyDatePresetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="Last14Days"/>
                                                <Button Content="直近 30 日" Style="{StaticResource DateChipStyle}"
                                                        Command="{Binding DataContext.SearchFilter.ApplyDatePresetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="Last30Days"/>
                                            </WrapPanel>
                                            <!-- 期間 -->
                                            <WrapPanel HorizontalAlignment="Left">
                                                <Button Content="今月" Style="{StaticResource DateChipStyle}"
                                                        Command="{Binding DataContext.SearchFilter.ApplyDatePresetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="ThisMonth"/>
                                                <Button Content="先月" Style="{StaticResource DateChipStyle}"
                                                        Command="{Binding DataContext.SearchFilter.ApplyDatePresetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="LastMonth"/>
                                                <Button Content="今年" Style="{StaticResource DateChipStyle}"
                                                        Command="{Binding DataContext.SearchFilter.ApplyDatePresetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="ThisYear"/>
                                            </WrapPanel>
                                        </StackPanel>
                                        <!-- セパレータ -->
                                        <Border Margin="10,2,10,2" Height="1">
                                            <Border.Background>
                                                <SolidColorBrush Color="#000000" Opacity="0.1"/>
                                            </Border.Background>
                                        </Border>
                                        <!-- Calendar (常時表示 / Zenith Style) -->
                                        <Calendar x:Name="DateCalendar"
                                                  SelectionMode="SingleRange"
                                                  Margin="4,2,4,6"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Foreground="#000000"
                                                  SelectedDatesChanged="DateCalendar_SelectedDatesChanged">
                                            <Calendar.Resources>
                                                <!-- CalendarDayButton: 選択色を黒系に -->
                                                <Style TargetType="CalendarDayButton">
                                                    <Setter Property="Foreground" Value="#000000"/>
                                                    <Setter Property="FontSize" Value="11"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background">
                                                                <Setter.Value>
                                                                    <SolidColorBrush Color="{StaticResource PrimaryTextColor}"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                                        </Trigger>
                                                        <Trigger Property="IsToday" Value="True">
                                                            <Setter Property="Background">
                                                                <Setter.Value>
                                                                    <SolidColorBrush Color="#E8E6E0"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Setter Property="Foreground" Value="#000000"/>
                                                        </Trigger>
                                                        <MultiTrigger>
                                                            <MultiTrigger.Conditions>
                                                                <Condition Property="IsToday" Value="True"/>
                                                                <Condition Property="IsSelected" Value="True"/>
                                                            </MultiTrigger.Conditions>
                                                            <Setter Property="Background">
                                                                <Setter.Value>
                                                                    <SolidColorBrush Color="{StaticResource PrimaryTextColor}"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                                        </MultiTrigger>
                                                        <Trigger Property="IsInactive" Value="True">
                                                            <Setter Property="Foreground">
                                                                <Setter.Value>
                                                                    <SolidColorBrush Color="#000000" Opacity="0.3"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                                <!-- CalendarButton (月/年選択ボタン) -->
                                                <Style TargetType="CalendarButton">
                                                    <Setter Property="Foreground" Value="#000000"/>
                                                    <Setter Property="FontSize" Value="11"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsInactive" Value="True">
                                                            <Setter Property="Foreground">
                                                                <Setter.Value>
                                                                    <SolidColorBrush Color="#000000" Opacity="0.3"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Calendar.Resources>
                                        </Calendar>
                                    </StackPanel>
                                </Border>
                            </Popup>

                            <!-- Col 4: プリセットボタン ★ -->
                            <Button x:Name="SearchPresetButton" Grid.Column="4"
                                    Click="SearchPresetButton_Click"
                                    MouseRightButtonUp="SearchPresetButton_MouseRightButtonUp"
                                    Style="{StaticResource IconButton}"
                                    Padding="2,0,4,0" IsTabStop="False" Cursor="Hand"
                                    ToolTip="検索プリセット&#x0a;右クリック: 検索条件をすべてクリア">
                                <StackPanel>
                                    <icon:PackIconLucide Width="11" Height="11"
                                                         VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <icon:PackIconLucide.Style>
                                            <Style TargetType="icon:PackIconLucide"
                                                   BasedOn="{StaticResource ActivePaneToolbarSubIconStyle}">
                                                <Setter Property="Kind" Value="Star"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.SearchPresets.HasPresetsForCurrentMode,
                                                        RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </icon:PackIconLucide.Style>
                                    </icon:PackIconLucide>
                                    <!-- アクティブ・アンダーライン (1px charcoal gray) -->
                                    <Border Height="1" Background="#333333" Margin="1,2,1,0"
                                            HorizontalAlignment="Stretch" CornerRadius="0.5">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.SearchPresets.HasPresetsForCurrentMode,
                                                        RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     To="1" Duration="0:0:0.1"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                        <DataTrigger.ExitActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     To="0" Duration="0:0:0.1"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.ExitActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </StackPanel>
                            </Button>
                            <!-- プリセット Popup -->
                            <Popup x:Name="SearchPresetPopup"
                                   PlacementTarget="{Binding ElementName=SearchPresetButton}"
                                   Placement="Bottom" StaysOpen="True"
                                   AllowsTransparency="True" PopupAnimation="None"
                                   Opened="SearchPresetPopup_Opened">
                                <Border x:Name="PresetPopupBorder"
                                        Background="{DynamicResource BackgroundBrush}"
                                        BorderBrush="#B8B3A4" BorderThickness="1"
                                        CornerRadius="8" Padding="0,4,0,4"
                                        MinWidth="260" MaxWidth="400" MaxHeight="400"
                                        RenderTransformOrigin="0.5,0" Opacity="0">
                                    <Border.RenderTransform>
                                        <TranslateTransform X="0" Y="-5"/>
                                    </Border.RenderTransform>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="28" ShadowDepth="4" Opacity="0.18" Direction="290" Color="#000000"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <!-- ヘッダー -->
                                        <Border Padding="10,3,10,5">
                                            <Border.BorderBrush>
                                                <SolidColorBrush Color="{StaticResource BorderColor}" Opacity="0.6"/>
                                            </Border.BorderBrush>
                                            <Border.BorderThickness>
                                                <Thickness>0,0,0,1</Thickness>
                                            </Border.BorderThickness>
                                            <TextBlock Text="検索プリセット" FontSize="11" FontWeight="Medium"
                                                       Foreground="#000000" VerticalAlignment="Center"/>
                                        </Border>
                                        <!-- プリセットリスト -->
                                        <ListBox x:Name="PresetListBox"
                                                 ItemsSource="{Binding DataContext.SearchPresets.FilteredPresets, RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Background="Transparent" BorderThickness="0" Padding="0,1,0,1"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 MaxHeight="280" SelectionMode="Single"
                                                 FocusVisualStyle="{x:Null}">
                                            <ListBox.Resources>
                                                <!-- 5px 極細スクロールバー -->
                                                <Style TargetType="{x:Type ScrollBar}">
                                                    <Setter Property="Width" Value="5"/>
                                                    <Setter Property="MinWidth" Value="5"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="{x:Type ScrollBar}">
                                                                <Grid SnapsToDevicePixels="true" Background="{TemplateBinding Background}">
                                                                    <Track x:Name="PART_Track"
                                                                           IsEnabled="{TemplateBinding IsEnabled}"
                                                                           IsDirectionReversed="true">
                                                                        <Track.Thumb>
                                                                            <Thumb>
                                                                                <Thumb.Template>
                                                                                    <ControlTemplate TargetType="{x:Type Thumb}">
                                                                                        <Border x:Name="rectangle"
                                                                                                SnapsToDevicePixels="True"
                                                                                                Background="{DynamicResource SubTextBrush}"
                                                                                                Opacity="0.25"
                                                                                                CornerRadius="2"
                                                                                                Margin="1,2"/>
                                                                                    <ControlTemplate.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type ScrollBar}}}" Value="True">
                                                                                            <Setter TargetName="rectangle" Property="Opacity" Value="0.55"/>
                                                                                            <Setter TargetName="rectangle" Property="Margin" Value="0,2"/>
                                                                                        </DataTrigger>
                                                                                        <Trigger Property="IsDragging" Value="true">
                                                                                            <Setter TargetName="rectangle" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                                            <Setter TargetName="rectangle" Property="Opacity" Value="0.85"/>
                                                                                            <Setter TargetName="rectangle" Property="Margin" Value="0,2"/>
                                                                                        </Trigger>
                                                                                    </ControlTemplate.Triggers>
                                                                                    </ControlTemplate>
                                                                                </Thumb.Template>
                                                                            </Thumb>
                                                                        </Track.Thumb>
                                                                        <Track.IncreaseRepeatButton>
                                                                            <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Opacity="0" Focusable="false"/>
                                                                        </Track.IncreaseRepeatButton>
                                                                        <Track.DecreaseRepeatButton>
                                                                            <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Opacity="0" Focusable="false"/>
                                                                        </Track.DecreaseRepeatButton>
                                                                    </Track>
                                                                </Grid>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.Resources>
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="Margin" Value="0"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    <Setter Property="ToolTipService.InitialShowDelay" Value="400"/>
                                                    <Setter Property="ToolTipService.ShowDuration" Value="30000"/>
                                                    <Setter Property="ToolTipService.Placement" Value="Right"/>
                                                    <Setter Property="ToolTip">
                                                        <Setter.Value>
                                                            <ToolTip>
                                                                <ToolTip.Style>
                                                                    <Style TargetType="ToolTip">
                                                                        <Setter Property="Background" Value="Transparent"/>
                                                                        <Setter Property="BorderThickness" Value="0"/>
                                                                        <Setter Property="Padding" Value="0"/>
                                                                        <Setter Property="HasDropShadow" Value="False"/>
                                                                        <Setter Property="Template">
                                                                            <Setter.Value>
                                                                                <ControlTemplate TargetType="ToolTip">
                                                                                    <ContentPresenter/>
                                                                                </ControlTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </Style>
                                                                </ToolTip.Style>
                                                                <Border Background="{DynamicResource BackgroundBrush}"
                                                                        BorderBrush="#B8B3A4" BorderThickness="1"
                                                                        CornerRadius="6" Padding="10,7,10,7"
                                                                        MinWidth="180" MaxWidth="320">
                                                                    <Border.Effect>
                                                                        <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.15" Direction="290" Color="#000000"/>
                                                                    </Border.Effect>
                                                                    <StackPanel>
                                                                        <!-- プリセット名 -->
                                                                        <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                                                                   Foreground="#000000" Margin="0,0,0,4" TextWrapping="Wrap"/>
                                                                        <!-- キーワード -->
                                                                        <Grid Margin="0,0,0,2">
                                                                            <Grid.Style>
                                                                                <Style TargetType="Grid">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasKeyword}" Value="False">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Grid.Style>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="64"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Grid.Column="0" Text="キーワード" FontSize="10"
                                                                                       Foreground="#000000" Opacity="0.5"/>
                                                                            <TextBlock Grid.Column="1" Text="{Binding SearchText}" FontSize="10"
                                                                                       Foreground="#000000" TextTrimming="CharacterEllipsis"/>
                                                                        </Grid>
                                                                        <!-- サイズ -->
                                                                        <Grid Margin="0,0,0,2">
                                                                            <Grid.Style>
                                                                                <Style TargetType="Grid">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasSize}" Value="False">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Grid.Style>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="64"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Grid.Column="0" Text="サイズ" FontSize="10"
                                                                                       Foreground="#000000" Opacity="0.5"/>
                                                                            <TextBlock Grid.Column="1" Text="{Binding DisplaySize}" FontSize="10"
                                                                                       Foreground="#000000" TextTrimming="CharacterEllipsis"/>
                                                                        </Grid>
                                                                        <!-- 日付 -->
                                                                        <Grid Margin="0,0,0,2">
                                                                            <Grid.Style>
                                                                                <Style TargetType="Grid">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasDate}" Value="False">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Grid.Style>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="64"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Grid.Column="0" Text="日付" FontSize="10"
                                                                                       Foreground="#000000" Opacity="0.5"/>
                                                                            <TextBlock Grid.Column="1" Text="{Binding DisplayDate}" FontSize="10"
                                                                                       Foreground="#000000" TextTrimming="CharacterEllipsis"/>
                                                                        </Grid>
                                                                        <!-- フィルタ -->
                                                                        <Grid Margin="0,0,0,2">
                                                                            <Grid.Style>
                                                                                <Style TargetType="Grid">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasFilters}" Value="False">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Grid.Style>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="64"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Grid.Column="0" Text="フィルタ" FontSize="10"
                                                                                       Foreground="#000000" Opacity="0.5"/>
                                                                            <TextBlock Grid.Column="1" Text="{Binding DisplayFilters}" FontSize="10"
                                                                                       Foreground="#000000" TextWrapping="Wrap"/>
                                                                        </Grid>
                                                                        <!-- スコープ -->
                                                                        <Grid Margin="0,0,0,2">
                                                                            <Grid.Style>
                                                                                <Style TargetType="Grid">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasScope}" Value="False">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Grid.Style>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="64"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Grid.Column="0" Text="スコープ" FontSize="10"
                                                                                       Foreground="#000000" Opacity="0.5"/>
                                                                            <TextBlock Grid.Column="1" Text="{Binding DisplayScope}" FontSize="10"
                                                                                       Foreground="#000000" TextWrapping="Wrap"/>
                                                                        </Grid>
                                                                        <!-- ソート -->
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="64"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Grid.Column="0" Text="ソート" FontSize="10"
                                                                                       Foreground="#000000" Opacity="0.5"/>
                                                                            <TextBlock Grid.Column="1" Text="{Binding DisplaySort}" FontSize="10"
                                                                                       Foreground="#000000"/>
                                                                        </Grid>
                                                                    </StackPanel>
                                                                </Border>
                                                            </ToolTip>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <Border x:Name="Bd" Background="Transparent" Padding="8,5,6,5"
                                                                        CornerRadius="2" Margin="2,0">
                                                                    <Grid MouseLeftButtonDown="PresetItem_MouseLeftButtonDown">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock x:Name="PresetName" Grid.Column="0" Text="{Binding Name}"
                                                                                   FontSize="11" Foreground="#000000"
                                                                                   VerticalAlignment="Center"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   Margin="0,0,6,0"/>
                                                                        <Border x:Name="DeleteBorder" Grid.Column="1"
                                                                                Width="18" Height="18" CornerRadius="3"
                                                                                Background="Transparent" Opacity="0"
                                                                                VerticalAlignment="Center">
                                                                            <Button Command="{Binding DataContext.SearchPresets.DeletePresetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                    CommandParameter="{Binding}"
                                                                                    Cursor="Hand" IsTabStop="False" Focusable="False">
                                                                                <Button.Template>
                                                                                    <ControlTemplate TargetType="Button">
                                                                                        <Border x:Name="XBd" Background="Transparent" CornerRadius="3"
                                                                                                Width="18" Height="18">
                                                                                            <icon:PackIconLucide x:Name="XIcon" Kind="X" Width="9" Height="9"
                                                                                                                 Foreground="#FFFFFF" Opacity="0.7"
                                                                                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                        </Border>
                                                                                        <ControlTemplate.Triggers>
                                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                                <Setter TargetName="XBd" Property="Background" Value="#60FFFFFF"/>
                                                                                                <Setter TargetName="XIcon" Property="Opacity" Value="1"/>
                                                                                            </Trigger>
                                                                                        </ControlTemplate.Triggers>
                                                                                    </ControlTemplate>
                                                                                </Button.Template>
                                                                            </Button>
                                                                        </Border>
                                                                    </Grid>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Bd" Property="Background" Value="#48505A"/>
                                                                        <Setter TargetName="PresetName" Property="Foreground" Value="#FFFFFF"/>
                                                                        <Setter TargetName="DeleteBorder" Property="Opacity" Value="1"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                        </ListBox>
                                        <!-- 空状態テキスト -->
                                        <TextBlock Text="(プリセットがありません)" FontSize="11"
                                                   Foreground="#000000" Opacity="0.4"
                                                   HorizontalAlignment="Center" Margin="10,6,10,6">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DataContext.SearchPresets.FilteredPresets.Count,
                                                            RelativeSource={RelativeSource AncestorType=Window}}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- セパレータ -->
                                        <Border Margin="10,2,10,2" Height="1">
                                            <Border.Background>
                                                <SolidColorBrush Color="#000000" Opacity="0.1"/>
                                            </Border.Background>
                                        </Border>
                                        <!-- リセット + 保存ボタン -->
                                        <StackPanel Orientation="Horizontal" Margin="10,4,10,6">
                                            <!-- リセットボタン -->
                                            <Button Command="{Binding DataContext.SearchPresets.ResetAllSettingsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    Cursor="Hand" IsTabStop="False" Focusable="False" Margin="0,0,6,0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="ResetBorder" CornerRadius="4" Padding="10,4"
                                                                Background="Transparent" BorderBrush="#000000" BorderThickness="1"
                                                                Opacity="0.45">
                                                            <StackPanel Orientation="Horizontal">
                                                                <icon:PackIconLucide x:Name="ResetIcon" Kind="RotateCcw" Width="11" Height="11"
                                                                                     Foreground="#000000" VerticalAlignment="Center"
                                                                                     Margin="0,0,5,0"/>
                                                                <TextBlock x:Name="ResetText" Text="条件をリセット"
                                                                           FontSize="11" Foreground="#000000"
                                                                           VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="ResetBorder" Property="Opacity" Value="1"/>
                                                                <Setter TargetName="ResetBorder" Property="Background" Value="{DynamicResource TextBrush}"/>
                                                                <Setter TargetName="ResetBorder" Property="BorderBrush" Value="{DynamicResource TextBrush}"/>
                                                                <Setter TargetName="ResetText" Property="Foreground" Value="#FFFFFF"/>
                                                                <Setter TargetName="ResetIcon" Property="Foreground" Value="#FFFFFF"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <!-- 保存ボタン -->
                                            <Button Command="{Binding DataContext.SearchPresets.SaveCurrentAsPresetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    Cursor="Hand" IsTabStop="False" Focusable="False">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="SaveBorder" CornerRadius="4" Padding="10,4"
                                                                Background="#FFFFFF" BorderBrush="#000000" BorderThickness="1">
                                                            <StackPanel Orientation="Horizontal">
                                                                <icon:PackIconLucide x:Name="SaveIcon" Kind="Plus" Width="11" Height="11"
                                                                                     Foreground="#000000" VerticalAlignment="Center"
                                                                                     Margin="0,0,5,0"/>
                                                                <TextBlock x:Name="SaveText" Text="現在の条件を保存"
                                                                           FontSize="11" Foreground="#000000"
                                                                           VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="SaveBorder" Property="Background" Value="{DynamicResource TextBrush}"/>
                                                                <Setter TargetName="SaveBorder" Property="BorderBrush" Value="{DynamicResource TextBrush}"/>
                                                                <Setter TargetName="SaveText" Property="Foreground" Value="#FFFFFF"/>
                                                                <Setter TargetName="SaveIcon" Property="Foreground" Value="#FFFFFF"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Popup>

                            <TextBox x:Name="SearchTextBox" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=50}"
                                     Background="Transparent" BorderThickness="0"
                                     VerticalContentAlignment="Center" Padding="6,2"
                                     Grid.Column="5" FontSize="12"
                                     GotFocus="SearchTextBox_GotFocus"
                                     LostKeyboardFocus="SearchTextBox_LostKeyboardFocus"
                                     PreviewMouseDown="SearchTextBox_PreviewMouseDown"
                                     PreviewKeyDown="SearchTextBox_PreviewKeyDown">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding ExecuteSearchCommand}" CommandParameter="{Binding Text, RelativeSource={RelativeSource AncestorType=TextBox}}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <TextBlock Grid.Column="5" IsHitTestVisible="False" VerticalAlignment="Center" Margin="8,0,0,0"
                                       FontSize="12" Opacity="0.5">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource ActivePaneSubTextStyle}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Setter Property="Text" Value="フォルダ以下を検索。虫眼鏡アイコンクリックにてインデックス検索モードに遷移。"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Text, ElementName=SearchTextBox}" Value=""/>
                                                    <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=SearchTextBox}" Value="False"/>
                                                    <Condition Binding="{Binding IsIndexSearchMode}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Text, ElementName=SearchTextBox}" Value="{x:Null}"/>
                                                    <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=SearchTextBox}" Value="False"/>
                                                    <Condition Binding="{Binding IsIndexSearchMode}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Text, ElementName=SearchTextBox}" Value=""/>
                                                    <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=SearchTextBox}" Value="False"/>
                                                    <Condition Binding="{Binding IsIndexSearchMode}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Setter Property="Text" Value="設定フォルダを横串検索。稲妻アイコンクリックにて通常検索モードに遷移。"/>
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Text, ElementName=SearchTextBox}" Value="{x:Null}"/>
                                                    <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=SearchTextBox}" Value="False"/>
                                                    <Condition Binding="{Binding IsIndexSearchMode}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Setter Property="Text" Value="設定フォルダを横串検索。稲妻アイコンクリックにて通常検索モードに遷移。"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Popup x:Name="SearchHistoryPopup" PlacementTarget="{Binding ElementName=SearchTextBox}" 
                                   StaysOpen="False" AllowsTransparency="True" PopupAnimation="None"
                                   Placement="Bottom" FocusManager.IsFocusScope="True">
                                <Border Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        Focusable="True"
                                        CornerRadius="0" Margin="0,0,0,0" MaxHeight="300"
                                        Width="{Binding ElementName=SearchTextBox, Path=ActualWidth}">
                                    <Grid Grid.IsSharedSizeScope="True">
                                        <ListBox x:Name="SearchHistoryListBox" ItemsSource="{Binding SearchHistory}"
                                                 BorderThickness="0" Background="Transparent" Padding="0"
                                                 FocusVisualStyle="{x:Null}"
                                                 VirtualizingStackPanel.IsVirtualizing="False"
                                                 LostKeyboardFocus="SearchHistoryListBox_LostKeyboardFocus"
                                                 Visibility="{Binding HasSearchHistory, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                 PreviewKeyDown="SearchHistoryListBox_PreviewKeyDown"
                                                 SelectionChanged="SearchHistoryListBox_SelectionChanged"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="SearchHistoryItem_PreviewMouseLeftButtonDown"/>
                                                    <Setter Property="Padding" Value="8,5"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                    <Setter Property="FontSize" Value="12"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="2" Padding="{TemplateBinding Padding}">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="HistPreset"/>
                                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="HistSize"/>
                                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="HistDate"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <!-- Col 0: 検索モードアイコン -->
                                                                        <icon:PackIconLucide Kind="{Binding IsIndexSearch, Converter={StaticResource SearchHistoryIconKindConverter}}" Width="12" Height="12" Margin="0,0,6,0" VerticalAlignment="Center">
                                                                            <icon:PackIconLucide.Style>
                                                                                <Style TargetType="icon:PackIconLucide">
                                                                                    <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsIndexSearch}" Value="True">
                                                                                            <Setter Property="Foreground" Value="{DynamicResource IndexSearchIconBrush}"/>
                                                                                            <Setter Property="Effect">
                                                                                                <Setter.Value>
                                                                                                    <DropShadowEffect Color="#E6B800" BlurRadius="6" ShadowDepth="0" Opacity="0.7"/>
                                                                                                </Setter.Value>
                                                                                            </Setter>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </icon:PackIconLucide.Style>
                                                                        </icon:PackIconLucide>
                                                                        <!-- Col 1: キーワード (主役・左詰め) -->
                                                                        <TextBlock Grid.Column="1" Text="{Binding Keyword}" Foreground="#000000"
                                                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                                        <!-- Col 2: プリセット: [名前] -->
                                                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0"
                                                                                    Visibility="{Binding HasPreset, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                            <TextBlock Text="プリセット: " FontSize="10" Foreground="#AAAAAA"/>
                                                                            <TextBlock Text="{Binding PresetName}" FontSize="10" Foreground="#888888"/>
                                                                        </StackPanel>
                                                                        <!-- Col 3: サイズ: [略称] -->
                                                                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0"
                                                                                    Visibility="{Binding HasSize, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                            <TextBlock Text="サイズ: " FontSize="10" Foreground="#AAAAAA"/>
                                                                            <TextBlock Text="{Binding SizeSummary}" FontSize="10" Foreground="#888888"/>
                                                                        </StackPanel>
                                                                        <!-- Col 4: 日付: [略称] -->
                                                                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0"
                                                                                    Visibility="{Binding HasDate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                            <TextBlock Text="日付: " FontSize="10" Foreground="#AAAAAA"/>
                                                                            <TextBlock Text="{Binding DateSummary}" FontSize="10" Foreground="#888888"/>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Bd" Property="Background" Value="#15000000"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsSelected" Value="True">
                                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                        </ListBox>
                        <TextBlock Text="履歴はありません" Style="{StaticResource ActivePaneSubTextStyle}" FontSize="12"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,12"
                                                   PreviewMouseLeftButtonDown="SearchHistoryEmpty_PreviewMouseLeftButtonDown"
                                                   Visibility="{Binding HasSearchHistory, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                    </Grid>
                                </Border>
                            </Popup>
                            <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0"
                                        Visibility="{Binding IsSearching, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <!-- 0件時の警告アイコン -->
                                <icon:PackIconLucide Kind="CircleAlert" Width="11" Height="11"
                                                     Margin="0,0,3,0" VerticalAlignment="Center"
                                                     Foreground="{DynamicResource IndexSearchIconBrush}">
                                    <icon:PackIconLucide.Style>
                                        <Style TargetType="icon:PackIconLucide">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowEmptySearchResult}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </icon:PackIconLucide.Style>
                                </icon:PackIconLucide>
                                <!-- 件数テキスト（フィルタ適用後の件数、0件時はアンバー色） -->
                                <TextBlock Text="{Binding FilteredSearchResultCount, StringFormat='{}{0} items'}"
                                           FontSize="11" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource ActivePaneSubTextStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowEmptySearchResult}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource IndexSearchIconBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="7" Command="{Binding ClearSearchCommand}"
                                    Margin="0,0,4,0" IsTabStop="False" Width="20" Height="20">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchText}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <icon:PackIconLucide Kind="X" Width="12" Height="12" Style="{StaticResource ActivePaneToolbarSubIconStyle}"/>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 2行目（アドレスバー行 / 検索時はフィルターバーに置換） -->
                <Border x:Name="AddressBarBorder" Grid.Row="1" Grid.ColumnSpan="3" Height="24" CornerRadius="0" BorderThickness="0"
                        VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="0,4,0,4" ClipToBounds="False"
                        Visibility="{Binding IsSearching, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}">
                    <!-- ベースはヘッダーと同系色を維持 -->
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource HeaderBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource FocusedPaneHeaderBackgroundBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <!-- 明るいヘッダーの中に浮かぶスリムなダーク・バンド -->
                    <Border x:Name="AddressBarDarkBand"
                            Background="{DynamicResource OnePointDarkBackground}"
                            CornerRadius="4"
                            Margin="2,2"
                            VerticalAlignment="Stretch"
                            HorizontalAlignment="Stretch">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                        <!-- パスを編集ボタン（左端） -->
                        <ToggleButton Grid.Column="0" IsChecked="{Binding IsPathEditMode}" IsTabStop="False" Checked="PathEditButton_Checked" Margin="0,0,2,0" VerticalAlignment="Center">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton" BasedOn="{StaticResource IconToggleButton}">
                                    <Setter Property="ToolTip" Value="パスを編集"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="ToolTip" Value="パンくずに切替"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ToggleButton.Style>
                            <icon:PackIconLucide Width="12" Height="12" Foreground="White">
                                <icon:PackIconLucide.Style>
                                    <Style TargetType="icon:PackIconLucide" BasedOn="{StaticResource ActivePaneToolbarIconStyle}">
                                        <Setter Property="Kind" Value="Pencil"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                                                <Setter Property="Kind" Value="ChevronRight"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </icon:PackIconLucide.Style>
                            </icon:PackIconLucide>
                        </ToggleButton>

                        <!-- お気に入り登録ボタン（コピーの左・コンパクト配置） -->
                        <Grid Grid.Column="2" Margin="0,0,0,0">
                            <Button x:Name="FavoriteStarButton" Style="{StaticResource FavoriteStarButtonStyle}" Command="{Binding AddToFavoritesCommand}" IsTabStop="False" VerticalAlignment="Center" Margin="0,0,2,0" ToolTip="お気に入りに追加">
                                <icon:PackIconLucide x:Name="FavoriteStarIcon" Kind="Star" Width="12" Height="12" VerticalAlignment="Center">
                                    <icon:PackIconLucide.Style>
                                        <Style TargetType="icon:PackIconLucide">
                                            <!-- 通常時はアドレスバー帯に合わせて白で表示 -->
                                            <Setter Property="Foreground" Value="White"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFavoriteActionActive}" Value="True">
                                                    <Setter Property="Foreground" Value="#F1C40F"/>
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" From="1" To="1.5" Duration="0:0:0.2" AutoReverse="True"/>
                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" From="1" To="1.5" Duration="0:0:0.2" AutoReverse="True"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsFavoriteActionFailed}" Value="True">
                                                    <Setter Property="Foreground" Value="#E74C3C"/>
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.X)" From="0" To="-3" Duration="0:0:0.05" AutoReverse="True" RepeatBehavior="3x"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </icon:PackIconLucide.Style>
                                    <icon:PackIconLucide.RenderTransformOrigin>0.5,0.5</icon:PackIconLucide.RenderTransformOrigin>
                                    <icon:PackIconLucide.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform x:Name="StarScale" ScaleX="1" ScaleY="1"/>
                                            <TranslateTransform x:Name="StarTranslate" X="0" Y="0"/>
                                        </TransformGroup>
                                    </icon:PackIconLucide.RenderTransform>
                                </icon:PackIconLucide>
                            </Button>
                            
                            <!-- 特別なアクション用の「Saved!」テキスト -->
                            <TextBlock x:Name="SavedText" Text="Saved!" FontSize="10" Foreground="#F1C40F" FontWeight="Bold" IsHitTestVisible="False"
                                       HorizontalAlignment="Left" VerticalAlignment="Center" Opacity="0" Margin="24,0,0,0" Visibility="Collapsed">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform X="0" Y="0"/>
                                </TextBlock.RenderTransform>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFavoriteActionActive}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="0" To="-15" Duration="0:0:0.5"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" BeginTime="0:0:2.5" Duration="0:0:0.5"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- お気に入り登録失敗テキスト -->
                            <TextBlock x:Name="LockedText" Text="登録できませんでした" FontSize="10" Foreground="#E74C3C" FontWeight="Bold" IsHitTestVisible="False"
                                       HorizontalAlignment="Left" VerticalAlignment="Center" Opacity="0" Margin="24,0,0,0" Visibility="Collapsed">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform X="0" Y="0"/>
                                </TextBlock.RenderTransform>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFavoriteActionFailed}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.1"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="0" To="-15" Duration="0:0:0.4"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" BeginTime="0:0:1.0" Duration="0:0:0.3"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <!-- コンテンツエリア（ブレッドクラム/テキストボックス） -->
                        <Grid Grid.Column="1">
                            <!-- アドレスバー内ハイライト用レイヤー（レイアウト固定） -->
                            <Border x:Name="AddressBarHighlight" Background="White" Opacity="0" CornerRadius="2" IsHitTestVisible="False"/>

                            <!-- ブレッドクラム表示モード -->
                            <Grid x:Name="BreadcrumbContainer"
                                  Visibility="{Binding IsPathEditMode, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"
                                  Background="Transparent" MouseLeftButtonDown="PathBreadcrumb_MouseLeftButtonDown" VerticalAlignment="Center">
                                <ScrollViewer x:Name="BreadcrumbScrollViewer" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" PanningMode="HorizontalOnly"
                                              Loaded="BreadcrumbScrollViewer_Loaded" SizeChanged="BreadcrumbScrollViewer_SizeChanged" ScrollChanged="BreadcrumbScrollViewer_ScrollChanged">
                                    <ItemsControl ItemsSource="{Binding PathSegments}" Margin="4,0" VerticalAlignment="Center"
                                                   HorizontalAlignment="Stretch">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" AllowDrop="True"
                                                            DragOver="BreadcrumbSegment_DragOver" Drop="BreadcrumbSegment_Drop">
                                                    <!-- フォルダ名ボタン -->
                                                    <Button Padding="5,0" Height="22" MaxWidth="260"
                                                            Style="{StaticResource IconButton}"
                                                            Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding FullPath}" IsTabStop="False">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="12"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Style="{StaticResource ActivePaneToolbarTextStyle}"
                                                                   Foreground="White"/>
                                                    </Button>
                                                    
                                                    <!-- セパレーター兼ドロップダウンボタン -->
                                                    <ToggleButton x:Name="BreadcrumbDropdownButton" Style="{StaticResource IconToggleButton}" Width="16" Height="22" Padding="0" IsTabStop="False"
                                                                  Visibility="{Binding IsLast, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"
                                                                  Click="BreadcrumbDropdownButton_Click">
                                                        <icon:PackIconLucide Kind="ChevronRight" Width="10" Height="10" Style="{StaticResource ActivePaneToolbarSubIconStyle}" VerticalAlignment="Center" Foreground="White">
                                                            <icon:PackIconLucide.RenderTransformOrigin>0.5,0.5</icon:PackIconLucide.RenderTransformOrigin>
                                                            <icon:PackIconLucide.RenderTransform>
                                                                <RotateTransform x:Name="IconRotate" Angle="0"/>
                                                            </icon:PackIconLucide.RenderTransform>
                                                        </icon:PackIconLucide>
                                                        <ToggleButton.Triggers>
                                                            <EventTrigger RoutedEvent="ToggleButton.Checked">
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="IconRotate" Storyboard.TargetProperty="Angle" To="90" Duration="0:0:0.15"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </EventTrigger>
                                                            <EventTrigger RoutedEvent="ToggleButton.Unchecked">
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="IconRotate" Storyboard.TargetProperty="Angle" To="0" Duration="0:0:0.15"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </EventTrigger>
                                                        </ToggleButton.Triggers>
                                                    </ToggleButton>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>

                            <!-- テキスト入力モード（ダーク帯上でも文字がくっきり見えるよう白字＋白キャレット） -->
                            <TextBox x:Name="PathTextBox" Background="Transparent" Style="{StaticResource ActivePaneTextBoxStyle}" BorderThickness="0" Padding="8,0" 
                                     Text="{Binding CurrentPath, UpdateSourceTrigger=PropertyChanged}" FontSize="12" VerticalContentAlignment="Center"
                                     Foreground="White" CaretBrush="White"
                                     IsTabStop="False"
                                     Visibility="{Binding IsPathEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding NavigateCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=TextBox}, Path=Text}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                        </Grid>
                        
                        <!-- コピーボタン（右端） -->
                        <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="2,0,4,0" VerticalAlignment="Center">
                            <Button Style="{StaticResource IconButton}" Command="{Binding CopyAddressCommand}" ToolTip="パスをコピー" Width="22" Height="22" IsTabStop="False">
                                <icon:PackIconLucide Kind="Copy" Width="12" Height="12" Style="{StaticResource ActivePaneToolbarSubIconStyle}" Foreground="White"/>
                            </Button>
                        </StackPanel>
                        </Grid>
                    </Border>
                </Border>

                <!-- 2行目（検索時のみ表示：フィルターバー） -->
                <Border x:Name="FilterBarBorder" Grid.Row="1" Grid.ColumnSpan="3" Height="26" CornerRadius="3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="0,4,0,4" ClipToBounds="False"
                        Visibility="{Binding IsSearching, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <DockPanel VerticalAlignment="Center" Margin="4,0">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Command="{Binding SelectAllFiltersCommand}" Style="{StaticResource IconButton}" IsTabStop="False"
                                    Padding="6,2" Margin="0,0,2,0" ToolTip="すべて選択">
                                <icon:PackIconLucide Kind="Check" Width="12" Height="12" Style="{StaticResource ActivePaneToolbarIconStyle}"/>
                            </Button>
                            <Button Command="{Binding ClearAllFiltersCommand}" Style="{StaticResource IconButton}" IsTabStop="False"
                                    Padding="6,2" ToolTip="すべて解除">
                                <icon:PackIconLucide Kind="X" Width="12" Height="12" Style="{StaticResource ActivePaneToolbarIconStyle}"/>
                            </Button>
                            <Border Width="1" Height="16" Margin="8,0" Background="{DynamicResource BorderBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding FileTypeFilterItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ToggleButton IsChecked="{Binding IsEnabled, Mode=TwoWay}" Content="{Binding DisplayName}"
                                                  Margin="3,0" Padding="8,3" FontSize="11" IsTabStop="False" Cursor="Hand"
                                                  Style="{StaticResource FilterToggleButtonStyle}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>

        <!-- パンくずセグメントのサブフォルダ一覧ドロップダウン（エクスプローラー同様）。マウスがメニュー外に出るかEscで閉じる -->
        <Popup x:Name="BreadcrumbSubfoldersPopup" StaysOpen="False" AllowsTransparency="True"
               Placement="Bottom" PopupAnimation="Fade" Opened="BreadcrumbSubfoldersPopup_Opened" Closed="BreadcrumbSubfoldersPopup_Closed">
            <Border Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4" Margin="4" MaxHeight="400" MinWidth="200"
                    PreviewKeyDown="BreadcrumbPopup_PreviewKeyDown">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.2" Color="Black"/>
                </Border.Effect>
                <ListBox x:Name="BreadcrumbSubfoldersListBox" BorderThickness="0" Background="Transparent" Padding="2"
                         DisplayMemberPath="Name" SelectionChanged="BreadcrumbSubfoldersListBox_SelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,4"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="2" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#15000000"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Border>
        </Popup>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <!-- 検索結果の鮮度警告（インデックス検索時のみ） -->
            <Border Grid.Row="0" Background="#FFF9E6" BorderBrush="#E6B800" BorderThickness="0,0,0,1" Padding="8,6" Margin="0"
                    Visibility="{Binding ShowIndexFreshnessWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <icon:PackIconLucide Kind="TriangleAlert" Width="14" Height="14" Foreground="#B8860B" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding IndexFreshnessWarningMessage}" FontSize="11" Style="{StaticResource ActivePaneToolbarTextStyle}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding DismissIndexFreshnessWarningCommand}" ToolTip="警告を閉じる"
                            Style="{StaticResource MenuItemButtonStyle}" Padding="6,4" Margin="4,0,0,0" VerticalAlignment="Center"
                            Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Center">
                        <icon:PackIconLucide Kind="X" Width="12" Height="12" Foreground="#B8860B"/>
                    </Button>
                </Grid>
            </Border>
        <!-- 方針G-2: ItemsSource はコードビハインド (SyncListItemsSources) で管理。非表示時は null にして CollectionChanged 処理を排除 -->
        <ListView x:Name="FileListView" Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="0" Padding="0"
                  HorizontalContentAlignment="Stretch" HorizontalAlignment="Stretch"
                  SelectionMode="Extended"
                  AllowDrop="True"
                  Visibility="{Binding FileViewMode, Converter={StaticResource EnumEqualityToVis}, ConverterParameter={x:Static local:FileViewMode.Details}}"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  VirtualizingStackPanel.ScrollUnit="Pixel"
                  VirtualizingStackPanel.CacheLengthUnit="Item"
                  VirtualizingStackPanel.CacheLength="10,10"
                  ScrollViewer.CanContentScroll="True"
                  MouseDoubleClick="ListView_MouseDoubleClick"
                  MouseDown="ListView_MouseDown"
                  PreviewMouseLeftButtonDown="ListView_PreviewMouseLeftButtonDown"
                  PreviewMouseRightButtonDown="ListView_PreviewMouseRightButtonDown"
                  MouseMove="ListView_MouseMove"
                  DragOver="ListView_DragOver"
                  Drop="ListView_Drop"
                  PreviewKeyDown="ListView_KeyDown"
                  KeyDown="ListView_KeyDown"
                  MouseRightButtonUp="ListView_MouseRightButtonUp"
                  SelectionChanged="FileList_SelectionChanged"
                  GridViewColumnHeader.Click="GridViewColumnHeader_Click"
                  ScrollViewer.VerticalScrollBarVisibility="Visible"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.ScrollChanged="FileListView_ScrollChanged">
            <ListView.Style>
                <Style TargetType="ListView">
                    <!-- 通常時の一覧テキスト色 -->
                    <Setter Property="TextElement.Foreground" Value="{DynamicResource TextBrush}"/>
                    <!-- フォーカス中ペインでは一覧テキストを黒に -->
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ParentPane.IsActive}" Value="True">
                            <Setter Property="TextElement.Foreground" Value="{DynamicResource FocusedPaneTextBrush}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListView.Style>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Tag" Value="{Binding RelativeSource={RelativeSource AncestorType=ListView}}"/>
                    <Setter Property="FocusVisualStyle" Value="{StaticResource DetailsFocusVisualStyle}"/>
                    <!-- デフォルトの行の文字色（非アクティブペイン時）はグレー -->
                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                    <!-- EventSetter: 右クリック時に選択を更新し、シェルメニュー用の位置・パスを保存 -->
                    <EventSetter Event="PreviewMouseRightButtonUp" Handler="ListViewItem_PreviewMouseRightButtonUp"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <Border x:Name="Bd" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="true">
                                    <Border.Background>
                                        <SolidColorBrush x:Name="BdHoverBrush" Color="Transparent"/>
                                    </Border.Background>
                                    <GridViewRowPresenter VerticalAlignment="Stretch" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <!-- ホバーエフェクト: ドラッグ中以外のみ有効（60ms in / 80ms out） -->
                                    <!-- ※TargetName を名前付きインラインブラシに直接指定し、選択トリガーが -->
                                    <!--   Background を共有リソース（SelectionBrush）に差し替えた際に -->
                                    <!--   アニメーションが共有ブラシの Color を破壊しないようにする -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                            <Condition Binding="{Binding IsDragging, RelativeSource={RelativeSource AncestorType=local:TabContentControl}}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="BdHoverBrush"
                                                        Storyboard.TargetProperty="Color"
                                                        To="{StaticResource ListHoverColor}" Duration="0:0:0.06"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </MultiDataTrigger.EnterActions>
                                        <MultiDataTrigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="BdHoverBrush"
                                                        Storyboard.TargetProperty="Color"
                                                        To="Transparent" Duration="0:0:0.08"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </MultiDataTrigger.ExitActions>
                                    </MultiDataTrigger>

                                    <!-- 選択状態: 常に青ハイライト（プロパティトリガーで即座に反応、フォールバック兼用） -->
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                    </Trigger>
                                    <!-- 非アクティブペインでは選択色をグレーに上書き -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                                            <Condition Binding="{Binding DataContext.ParentPane.IsActive, RelativeSource={RelativeSource AncestorType=local:TabContentControl}}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource InactiveSelectionBrush}"/>
                                    </MultiDataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <!-- 親ペインがアクティブなときは行全体の文字色を黒に -->
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ParentPane.IsActive, RelativeSource={RelativeSource AncestorType=local:TabContentControl}}" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource FocusedPaneTextBrush}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.View>
                <GridView>
                    <GridView.ColumnHeaderContainerStyle>
                        <Style TargetType="GridViewColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="GridViewColumnHeader">
                                        <Grid>
                                            <Border x:Name="HeaderBorder" BorderThickness="0,0,1,1" BorderBrush="{DynamicResource BorderBrush}" Padding="10,6" Background="Transparent">
                                                <StackPanel Orientation="Horizontal">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                    <Grid Margin="5,0,0,0">
                                                        <icon:PackIconLucide Kind="ChevronUp" Width="10" Height="10">
                                                            <icon:PackIconLucide.Style>
                                                                <Style TargetType="icon:PackIconLucide">
                                                                    <Setter Property="Opacity" Value="0.3"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Value="True">
                                                                            <DataTrigger.Binding>
                                                                                <MultiBinding Converter="{StaticResource IsColActive}">
                                                                                    <Binding Path="DataContext.ActiveSortProperty" RelativeSource="{RelativeSource AncestorType={x:Type local:TabContentControl}}"/>
                                                                                    <Binding Path="Column.Header" RelativeSource="{RelativeSource TemplatedParent}"/>
                                                                                </MultiBinding>
                                                                            </DataTrigger.Binding>
                                                                            <Setter Property="Opacity" Value="1.0"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </icon:PackIconLucide.Style>
                                                            <icon:PackIconLucide.Visibility>
                                                                <MultiBinding Converter="{StaticResource SortInfoToVis}" ConverterParameter="Ascending">
                                                                    <Binding Path="DataContext.ActiveSortProperty" RelativeSource="{RelativeSource AncestorType={x:Type local:TabContentControl}}"/>
                                                                    <Binding Path="DataContext.ActiveSortDirection" RelativeSource="{RelativeSource AncestorType={x:Type local:TabContentControl}}"/>
                                                                    <Binding Path="Column.Header" RelativeSource="{RelativeSource TemplatedParent}"/>
                                                                </MultiBinding>
                                                            </icon:PackIconLucide.Visibility>
                                                        </icon:PackIconLucide>
                                                        <icon:PackIconLucide Kind="ChevronDown" Width="10" Height="10">
                                                            <icon:PackIconLucide.Visibility>
                                                                <MultiBinding Converter="{StaticResource SortInfoToVis}" ConverterParameter="Descending">
                                                                    <Binding Path="DataContext.ActiveSortProperty" RelativeSource="{RelativeSource AncestorType={x:Type local:TabContentControl}}"/>
                                                                    <Binding Path="DataContext.ActiveSortDirection" RelativeSource="{RelativeSource AncestorType={x:Type local:TabContentControl}}"/>
                                                                    <Binding Path="Column.Header" RelativeSource="{RelativeSource TemplatedParent}"/>
                                                                </MultiBinding>
                                                            </icon:PackIconLucide.Visibility>
                                                        </icon:PackIconLucide>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                            <Thumb x:Name="PART_HeaderGripper" HorizontalAlignment="Right" Width="2" Background="Transparent" Cursor="SizeWE" Margin="0,0,-1,0">
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border Background="Transparent"/>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}" Value="サイズ">
                                                <Setter TargetName="HeaderBorder" Property="Padding" Value="10,6,20,6"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GridView.ColumnHeaderContainerStyle>
                    
    <!-- セル側の BorderBrush も BorderBrush リソースに統一 -->
    <GridViewColumn Header="名前" Width="200">
        <GridViewColumn.HeaderTemplate>
            <DataTemplate>
                <TextBlock Text="名前" Style="{StaticResource ActivePaneHeaderTextStyle}"/>
            </DataTemplate>
        </GridViewColumn.HeaderTemplate>
        <GridViewColumn.CellTemplate>
            <DataTemplate>
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0" Padding="16,2" Margin="-6,0,-8,0" SnapsToDevicePixels="True">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                   Style="{StaticResource ActivePaneCellTextStyle}"/>
                    </StackPanel>
                </Border>
            </DataTemplate>
        </GridViewColumn.CellTemplate>
    </GridViewColumn>

    <GridViewColumn x:Name="LocationCol" Header="場所">
        <GridViewColumn.HeaderTemplate>
            <DataTemplate>
                <TextBlock Text="場所" Style="{StaticResource ActivePaneHeaderTextStyle}"/>
            </DataTemplate>
        </GridViewColumn.HeaderTemplate>
        <GridViewColumn.Width>
            <MultiBinding Converter="{StaticResource AdaptiveWidthConverter}" ConverterParameter="Location">
                <Binding ElementName="FileListView"/>
                <Binding ElementName="FileListView" Path="ActualWidth"/>
                <Binding Path="IsAdaptiveColumnsEnabled"/>
                <Binding ElementName="FileListView" Path="ActualHeight"/>
                <Binding ElementName="FileListView" Path="Items.Count"/>
            </MultiBinding>
        </GridViewColumn.Width>
        <GridViewColumn.CellTemplate>
            <DataTemplate>
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0" Padding="10,2" Margin="-6,0,-8,0" SnapsToDevicePixels="True">
                    <Grid ToolTip="{Binding LocationType}">
                        <icon:PackIconLucide Kind="{Binding LocationIconKind}" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource ActivePaneToolbarSubIconStyle}"/>
                    </Grid>
                </Border>
            </DataTemplate>
        </GridViewColumn.CellTemplate>
    </GridViewColumn>

    <GridViewColumn x:Name="DateCol" Header="更新日時">
        <GridViewColumn.HeaderTemplate>
            <DataTemplate>
                <TextBlock Text="更新日時" Style="{StaticResource ActivePaneHeaderTextStyle}"/>
            </DataTemplate>
        </GridViewColumn.HeaderTemplate>
        <GridViewColumn.Width>
            <MultiBinding Converter="{StaticResource AdaptiveWidthConverter}" ConverterParameter="Date">
                <Binding ElementName="FileListView"/>
                <Binding ElementName="FileListView" Path="ActualWidth"/>
                <Binding Path="IsAdaptiveColumnsEnabled"/>
                <Binding ElementName="FileListView" Path="ActualHeight"/>
                <Binding ElementName="FileListView" Path="Items.Count"/>
            </MultiBinding>
        </GridViewColumn.Width>
        <GridViewColumn.CellTemplate>
            <DataTemplate>
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0" Padding="16,2" Margin="-6,0,-8,0" SnapsToDevicePixels="True">
                    <TextBlock Text="{Binding LastModified, StringFormat='yyyy/MM/dd HH:mm'}" VerticalAlignment="Center"
                               Style="{StaticResource ActivePaneCellTextStyle}"/>
                </Border>
            </DataTemplate>
        </GridViewColumn.CellTemplate>
    </GridViewColumn>

    <GridViewColumn x:Name="TypeCol" Header="種類">
        <GridViewColumn.HeaderTemplate>
            <DataTemplate>
                <TextBlock Text="種類" Style="{StaticResource ActivePaneHeaderTextStyle}"/>
            </DataTemplate>
        </GridViewColumn.HeaderTemplate>
        <GridViewColumn.Width>
            <MultiBinding Converter="{StaticResource AdaptiveWidthConverter}" ConverterParameter="Type">
                <Binding ElementName="FileListView"/>
                <Binding ElementName="FileListView" Path="ActualWidth"/>
                <Binding Path="IsAdaptiveColumnsEnabled"/>
                <Binding ElementName="FileListView" Path="ActualHeight"/>
                <Binding ElementName="FileListView" Path="Items.Count"/>
            </MultiBinding>
        </GridViewColumn.Width>
        <GridViewColumn.CellTemplate>
            <DataTemplate>
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0" Padding="16,2" Margin="-6,0,-8,0" SnapsToDevicePixels="True">
                    <TextBlock Text="{Binding TypeName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                               Style="{StaticResource ActivePaneCellTextStyle}"/>
                </Border>
            </DataTemplate>
        </GridViewColumn.CellTemplate>
    </GridViewColumn>

    <GridViewColumn x:Name="SizeCol" Header="サイズ">
        <GridViewColumn.HeaderTemplate>
            <DataTemplate>
                <TextBlock Text="サイズ" Style="{StaticResource ActivePaneHeaderTextStyle}"/>
            </DataTemplate>
        </GridViewColumn.HeaderTemplate>
        <GridViewColumn.Width>
            <MultiBinding Converter="{StaticResource AdaptiveWidthConverter}" ConverterParameter="Size">
                <Binding ElementName="FileListView"/>
                <Binding ElementName="FileListView" Path="ActualWidth"/>
                <Binding Path="IsAdaptiveColumnsEnabled"/>
                <Binding ElementName="FileListView" Path="ActualHeight"/>
                <Binding ElementName="FileListView" Path="Items.Count"/>
            </MultiBinding>
        </GridViewColumn.Width>
        <GridViewColumn.CellTemplate>
            <DataTemplate>
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0" Padding="10,2,20,2" Margin="-6,0,-9,0" SnapsToDevicePixels="True">
                    <TextBlock x:Name="SizeText" Text="{Binding DisplaySize}" HorizontalAlignment="Right" VerticalAlignment="Center"
                               Style="{StaticResource ActivePaneCellTextStyle}"/>
                </Border>
                <DataTemplate.Triggers>
                    <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                        <Setter TargetName="SizeText" Property="FontStyle" Value="Italic"/>
                        <Setter TargetName="SizeText" Property="Foreground" Value="#999999"/>
                    </DataTrigger>
                </DataTemplate.Triggers>
            </DataTemplate>
        </GridViewColumn.CellTemplate>
    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- アイコンビュー（大・中・小アイコン） -->
        <!-- 方針H-2: UniformGrid（固定列数・幅非依存レイアウト）で ScrollViewer↔WrapPanel 測定ループを根絶 -->
        <!-- Border でラップしてペイン端の余白を確実に反映（ListBox の Padding はデフォルトテンプレートで効かないため）。右 Padding は 0 で縦スクロールバーを一覧ビューと同じ位置に揃える -->
        <Border Grid.Row="1" Padding="12,10,0,10" Background="Transparent"
                Visibility="{Binding FileViewMode, Converter={StaticResource EnumEqualityToVisInverse}, ConverterParameter={x:Static local:FileViewMode.Details}}">
        <ListBox x:Name="FileListBox" Background="Transparent" BorderThickness="0" Margin="0" Padding="0"
                 ItemTemplateSelector="{StaticResource IconViewTemplateSelector}"
                 SelectionMode="Extended" AllowDrop="True"
                 VirtualizingStackPanel.IsVirtualizing="False"
                 ScrollViewer.CanContentScroll="False"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 MouseDoubleClick="ListView_MouseDoubleClick"
                 MouseDown="ListView_MouseDown"
                 PreviewMouseLeftButtonDown="ListView_PreviewMouseLeftButtonDown"
                 PreviewMouseRightButtonDown="ListView_PreviewMouseRightButtonDown"
                 MouseMove="ListView_MouseMove"
                 DragOver="ListView_DragOver"
                 Drop="ListView_Drop"
                 PreviewKeyDown="ListView_KeyDown"
                 KeyDown="ListView_KeyDown"
                 MouseRightButtonUp="ListView_MouseRightButtonUp"
                 SelectionChanged="FileList_SelectionChanged">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="{Binding IconColumnCount, RelativeSource={RelativeSource AncestorType=local:TabContentControl}}"
                                 Width="{Binding IconViewGridWidth, RelativeSource={RelativeSource AncestorType=local:TabContentControl}}"
                                 HorizontalAlignment="Left" VerticalAlignment="Top"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <!-- アイコンビュー: ハイライトとクリック領域をカード（サムネイル＋名前）部分に限定 -->
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <EventSetter Event="PreviewMouseRightButtonUp" Handler="ListViewItem_PreviewMouseRightButtonUp"/>
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    <Setter Property="VerticalContentAlignment" Value="Top"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="FocusVisualStyle" Value="{StaticResource SubtleFocusVisualStyle}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Grid>
                                    <Border x:Name="SelectionBorder" HorizontalAlignment="Left" VerticalAlignment="Top"
                                            BorderThickness="0" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush x:Name="IconHoverBrush" Color="Transparent"/>
                                        </Border.Background>
                                        <ContentPresenter Content="{TemplateBinding Content}"
                                                          ContentTemplateSelector="{Binding ItemTemplateSelector, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                          HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                    </Border>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <!-- ホバーエフェクト: 名前付きインラインブラシを直接ターゲット -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                            <Condition Binding="{Binding IsDragging, RelativeSource={RelativeSource AncestorType=local:TabContentControl}}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="IconHoverBrush"
                                                        Storyboard.TargetProperty="Color"
                                                        To="{StaticResource ListHoverColor}" Duration="0:0:0.06"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </MultiDataTrigger.EnterActions>
                                        <MultiDataTrigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="IconHoverBrush"
                                                        Storyboard.TargetProperty="Color"
                                                        To="Transparent" Duration="0:0:0.08"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </MultiDataTrigger.ExitActions>
                                    </MultiDataTrigger>
                                    <!-- 選択状態: 常に青ハイライト（プロパティトリガーで即座に反応、フォールバック兼用） -->
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="SelectionBorder" Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                    </Trigger>
                                    <!-- 非アクティブペインでは選択色をグレーに上書き -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                                            <Condition Binding="{Binding DataContext.ParentPane.IsActive, RelativeSource={RelativeSource AncestorType=local:TabContentControl}}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="SelectionBorder" Property="Background" Value="{DynamicResource InactiveSelectionBrush}"/>
                                    </MultiDataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>
        </Border>

        <!-- Watermark: 検索中かつ0件の場合にリスト中央へ表示 -->
        <TextBlock Grid.Row="1"
                   Text="該当する項目が見つかりませんでした"
                   VerticalAlignment="Center" HorizontalAlignment="Center"
                   FontSize="16" Opacity="0.35"
                   IsHitTestVisible="False"
                   Foreground="{DynamicResource TextBrush}">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowEmptySearchResult}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        </Grid>

        </DockPanel>

        <!-- Box共有リンク整形成功時のグリーンフラッシュ演出 -->
        <Border x:Name="SuccessFlashOverlay" Background="#4CAF50" Opacity="0" IsHitTestVisible="False"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Panel.ZIndex="100">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsNotificationFlashActive}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="0.3" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" BeginTime="0:0:0.15" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>

        <!-- カスタム右ドラッグメニュー（オーバーレイ） -->
        <!-- 標準 ContextMenu の NullReferenceException 回避のため、自作の Canvas/Border で実装 -->
        <Grid x:Name="CustomMenuOverlay" Visibility="Collapsed" Panel.ZIndex="2000">
            <!-- 背景クリックで閉じるための透明レイヤー -->
            <Border Background="Transparent" MouseLeftButtonDown="CustomMenuOverlay_MouseLeftButtonDown"/>
            
            <!-- メニュー本体: 外側ラッパーで ClipToBounds し左上の影をカット -->
            <Border x:Name="CustomMenuBorder" HorizontalAlignment="Left" VerticalAlignment="Top"
                    Background="Transparent" ClipToBounds="True"
                    UseLayoutRounding="True" SnapsToDevicePixels="True">
                <Border BorderBrush="{DynamicResource ContextMenuBorderBrush}" BorderThickness="1" Background="{DynamicResource ContextMenuOuterBackgroundBrush}"
                        CornerRadius="5" Padding="1" MinWidth="180"
                        Margin="0,0,28,28">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.22" Direction="315" Color="{StaticResource ShadowColor}"/>
                    </Border.Effect>
                    <Border Background="{DynamicResource ContextMenuBackgroundBrush}" CornerRadius="4" ClipToBounds="True">
                        <StackPanel Margin="0,3,0,3">
                            <Button Content="ここにコピー" Click="MenuCopy_Click" Style="{StaticResource MenuItemButtonStyle}"/>
                            <Button Content="ここに移動" Click="MenuMove_Click" Style="{StaticResource MenuItemButtonStyle}"/>
                            <Button Content="ここにショートカットを作成" Click="MenuShortcut_Click" Style="{StaticResource MenuItemButtonStyle}"/>
                            <Button Content="キャンセル" Click="MenuCancel_Click" Style="{StaticResource MenuItemButtonStyle}"/>
                        </StackPanel>
                    </Border>
                </Border>
            </Border>
        </Grid>
    </Grid>
</UserControl>