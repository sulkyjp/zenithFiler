<ui:FluentWindow x:Class="ZenithFiler.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:ZenithFiler"
        xmlns:views="clr-namespace:ZenithFiler.Views"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="{Binding AppTitle}" Height="700" Width="1100"
        Icon="pack://application:,,,/assets/app_icon2_1.ico"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}"
        Topmost="{Binding IsAlwaysOnTop}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Visibility="Hidden"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">

    <ui:FluentWindow.DataContext>
        <local:MainViewModel/>
    </ui:FluentWindow.DataContext>

    <!-- InputBindings はコードビハインドで動的に構築（KeyBindingService 連携） -->
    
    <ui:FluentWindow.Resources>
        <local:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:BooleanToVisibilityInverseConverter x:Key="BoolToVisInverse"/>
        <local:IntToVisibilityConverter x:Key="IntToVis"/>
        <local:EqualityToBooleanConverter x:Key="EqualityToBool"/>
        <local:EnumEqualityToBooleanConverter x:Key="EnumEqualityToBool"/>
        <local:EnumEqualityToBooleanInverseConverter x:Key="EnumEqualityToBoolInverse"/>
        <local:IntEqualityToBooleanConverter x:Key="IntEqualityToBool"/>
        <local:EnumEqualityToVisibilityConverter x:Key="EnumEqualityToVis"/>
        <local:IsTodayConverter x:Key="IsToday"/>
        <local:InverseBooleanConverter x:Key="InverseBool"/>
        <local:FavoriteToolTipConverter x:Key="FavoriteToolTip"/>
        <local:NonEmptyStringToVisibilityConverter x:Key="NonEmptyStringToVis"/>
        <local:FavoritesSearchModeToBoolConverter x:Key="FavoritesSearchModeToBool"/>
        <local:FavoritesSearchModeToTooltipConverter x:Key="FavoritesSearchModeToTooltip"/>
        <local:BooleanToLockTooltipConverter x:Key="BooleanToLockTooltip"/>
        <local:BusyNotIndexingConverter x:Key="BusyNotIndexing"/>
        <local:TreeLineVisibilityConverter x:Key="TreeLineVis"/>
    </ui:FluentWindow.Resources>

    <Grid x:Name="RootContent" Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- TitleBar -->
            <RowDefinition Height="*"/>    <!-- Main Content -->
            <RowDefinition Height="30"/>   <!-- Status Bar（2px グロウ + 28px コンテンツ = 30px 固定） -->
        </Grid.RowDefinitions>

        <!-- タイトルバー（マニュアル・履歴ウィンドウのシステムタイトルバーと同じ高さに合わせる） -->
        <ui:TitleBar Title="{Binding AppTitle}" Grid.Row="0" Height="32" Background="{DynamicResource TitleBarBrush}" Foreground="{DynamicResource TitleBarTextBrush}" ButtonsForeground="{DynamicResource TitleBarTextBrush}"
                     MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                     MouseLeftButtonUp="TitleBar_MouseLeftButtonUp">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/assets/app_icon2_1.ico" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- メインコンテンツ -->
        <Grid Grid.Row="1" local:SidebarWidthAnimationBehavior.IsEnabled="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition>
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="{Binding SidebarWidth, Mode=TwoWay}"/>
                            <Setter Property="MinWidth" Value="180"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSidebarVisible}" Value="False">
                                    <Setter Property="Width" Value="0"/>
                                    <Setter Property="MinWidth" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- サイドバー（ナビペイン） -->
            <Border x:Name="SidebarBorder" Grid.Column="0" Background="{DynamicResource SidebarBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0"
                    Visibility="{Binding IsSidebarVisible, Converter={StaticResource BoolToVis}}"
                    PreviewMouseLeftButtonDown="Sidebar_PreviewMouseLeftButtonDown">
                <DockPanel>
                    <!-- ビュー切り替えバー -->
                    <Border DockPanel.Dock="Top" Height="32" Padding="8,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <RadioButton x:Name="SidebarFavoritesBtn" Style="{StaticResource IconRadioButton}"
                                             IsChecked="{Binding SidebarMode, Converter={StaticResource EqualityToBool}, ConverterParameter={x:Static local:SidebarViewMode.Favorites}, Mode=OneWay}"
                                             Command="{Binding SetSidebarModeCommand}"
                                             CommandParameter="{x:Static local:SidebarViewMode.Favorites}"
                                             ToolTip="お気に入り">
                                    <icon:PackIconLucide Kind="Star" Width="12" Height="12"/>
                                </RadioButton>
                                <RadioButton x:Name="SidebarTreeBtn" Style="{StaticResource IconRadioButton}"
                                             IsChecked="{Binding SidebarMode, Converter={StaticResource EqualityToBool}, ConverterParameter={x:Static local:SidebarViewMode.Tree}, Mode=OneWay}"
                                             Command="{Binding SetSidebarModeCommand}"
                                             CommandParameter="{x:Static local:SidebarViewMode.Tree}"
                                             ToolTip="ツリービュー" Margin="4,0,0,0">
                                    <icon:PackIconLucide Kind="FolderTree" Width="12" Height="12"/>
                                </RadioButton>
                                <RadioButton x:Name="SidebarHistoryBtn" Style="{StaticResource IconRadioButton}"
                                             IsChecked="{Binding SidebarMode, Converter={StaticResource EqualityToBool}, ConverterParameter={x:Static local:SidebarViewMode.History}, Mode=OneWay}"
                                             Command="{Binding SetSidebarModeCommand}"
                                             CommandParameter="{x:Static local:SidebarViewMode.History}"
                                             ToolTip="参照履歴" Margin="4,0,0,0">
                                    <icon:PackIconLucide Kind="History" Width="12" Height="12"/>
                                </RadioButton>
                                <RadioButton x:Name="SidebarIndexSearchBtn" Style="{StaticResource IconRadioButton}"
                                             IsChecked="{Binding SidebarMode, Converter={StaticResource EqualityToBool}, ConverterParameter={x:Static local:SidebarViewMode.IndexSearch}, Mode=OneWay}"
                                             Command="{Binding SetSidebarModeCommand}"
                                             CommandParameter="{x:Static local:SidebarViewMode.IndexSearch}"
                                             ToolTip="インデックス検索設定" Margin="4,0,0,0">
                                    <icon:PackIconLucide Kind="FolderSearch" Width="12" Height="12"/>
                                </RadioButton>
                                <RadioButton x:Name="SidebarWorkingSetBtn" Style="{StaticResource IconRadioButton}"
                                             IsChecked="{Binding SidebarMode, Converter={StaticResource EqualityToBool}, ConverterParameter={x:Static local:SidebarViewMode.WorkingSet}, Mode=OneWay}"
                                             Command="{Binding SetSidebarModeCommand}"
                                             CommandParameter="{x:Static local:SidebarViewMode.WorkingSet}"
                                             ToolTip="ワーキングセット" Margin="4,0,0,0"
                                             IsTabStop="False">
                                    <icon:PackIconLucide Kind="Briefcase" Width="12" Height="12"/>
                                </RadioButton>
                            </StackPanel>

                            <!-- 右側ボタン群 -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <!-- アプリ設定ボタン -->
                                <Button x:Name="OpenSettingsBtn" Style="{StaticResource IconButton}"
                                        Command="{Binding OpenControlDeckCommand}"
                                        ToolTip="アプリ設定を開く"
                                        Margin="0,0,8,0"
                                        IsTabStop="False">
                                    <icon:PackIconLucide Kind="Settings" Width="12" Height="12" Foreground="{DynamicResource SubTextBrush}"/>
                                </Button>
                                <!-- マニュアルボタン -->
                                <Button Style="{StaticResource IconButton}"
                                        Command="{Binding ShowManualCommand}"
                                        ToolTip="マニュアルを開く"
                                        Margin="0,0,8,0"
                                        IsTabStop="False">
                                    <icon:PackIconLucide Kind="BookOpen" Width="12" Height="12" Foreground="{DynamicResource SubTextBrush}"/>
                                </Button>

                                <!-- 更新履歴ボタン -->
                                <Button Style="{StaticResource IconButton}"
                                        Command="{Binding ShowChangelogCommand}"
                                        ToolTip="更新履歴を開く"
                                        IsTabStop="False">
                                    <icon:PackIconLucide Kind="ScrollText" Width="12" Height="12" Foreground="{DynamicResource SubTextBrush}"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- コンテンツエリア -->
                    <Grid>
                        <!-- お気に入りビュー -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SidebarMode}" Value="{x:Static local:SidebarViewMode.Favorites}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="32"/>
                            </Grid.RowDefinitions>

                            <!-- 検索ボックス（履歴ビューと同様のスタイル） -->
                            <Border Grid.Row="0" Margin="10,10,10,5" Background="{DynamicResource BackgroundBrush}" 
                                    CornerRadius="4" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <icon:PackIconLucide Kind="Search" Width="14" Height="14" Margin="8,0,0,0" 
                                                         VerticalAlignment="Center" Foreground="{DynamicResource SubTextBrush}"/>
                                    <TextBox x:Name="FavoritesSearchBox"
                                             Text="{Binding FavoritesSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent" BorderThickness="0"
                                             VerticalContentAlignment="Center" Padding="6"
                                             Grid.Column="1">
                                        <TextBox.Resources>
                                            <VisualBrush x:Key="CueBannerBrush" TileMode="None" Opacity="0.5" Stretch="None" AlignmentX="Left">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="お気に入りを検索..." Foreground="{DynamicResource SubTextBrush}" FontSize="12"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </TextBox.Resources>
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Style.Triggers>
                                                    <Trigger Property="Text" Value="{x:Null}">
                                                        <Setter Property="Background" Value="{DynamicResource CueBannerBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter Property="Background" Value="{DynamicResource CueBannerBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Esc" Command="{Binding Favorites.ClearFavoritesSearchCommand}"/>
                                        </TextBox.InputBindings>
                                    </TextBox>
                                    <Button Grid.Column="2" Command="{Binding Favorites.ClearFavoritesSearchCommand}"
                                            Margin="0,0,4,0" IsTabStop="False">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FavoritesSearchText}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FavoritesSearchText}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <icon:PackIconLucide Kind="X" Width="14" Height="14" Foreground="{DynamicResource SubTextBrush}"/>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- TreeView（検索なし時） -->
                            <TreeView x:Name="FavoritesTree" Grid.Row="1"
                                      local:TreeViewDragDropBehavior.IsEnabled="True"
                                      ItemsSource="{Binding Favorites.Items}" 
                                      BorderThickness="0" Background="Transparent" Padding="0,5"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      HorizontalContentAlignment="Stretch"
                                      PreviewMouseLeftButtonDown="FavoritesTree_PreviewMouseLeftButtonDown"
                                      PreviewKeyDown="FavoritesTreeView_PreviewKeyDown"
                                      PreviewMouseRightButtonDown="FavoritesTree_PreviewMouseRightButtonDown"
                                      Visibility="{Binding Favorites.IsSearching, Converter={StaticResource BoolToVisInverse}}">
                                <TreeView.Style>
                                    <Style TargetType="TreeView">
                                        <!-- Visibility はバインディングで制御するため Style トリガーは削除 -->
                                    </Style>
                                </TreeView.Style>
                            <TreeView.ContextMenu>
                                <ContextMenu Placement="MousePoint" ItemContainerStyle="{StaticResource ContextMenuItemStyle}">
                                    <MenuItem Header="新しいフォルダ" Command="{Binding Favorites.AddFolderCommand}">
                                        <MenuItem.Icon>
                                            <icon:PackIconLucide Kind="FolderPlus" Width="14" Height="14"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </TreeView.ContextMenu>
                            <TreeView.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{StaticResource SelectionColor}"/>
                                <!-- 選択時もメインテキストは黒系で維持する -->
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="{StaticResource PrimaryTextColor}"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="{StaticResource InactiveSelectionColor}"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="{StaticResource PrimaryTextColor}"/>
                            </TreeView.Resources>
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                    <Setter Property="Padding" Value="1,1"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <TransformGroup>
                                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                            </TransformGroup>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="ToolTip" Value="{Binding Converter={StaticResource FavoriteToolTip}}"/>
                                    <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}"/>
                                    <EventSetter Event="MouseDown" Handler="FavoriteItem_MouseDown"/>
                                    <EventSetter Event="Selected" Handler="TreeViewItem_Selected"/>
                                    <EventSetter Event="PreviewMouseRightButtonDown" Handler="TreeViewItem_PreviewMouseRightButtonDown"/>
                                    <!-- 全幅背景を持つスリムな帯デザイン -->
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TreeViewItem">
                                                <Grid SnapsToDevicePixels="True">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition/>
                                                    </Grid.RowDefinitions>
                                                    <!-- ツリー接続線: 非末尾子の縦線（Row 0 のみ） -->
                                                    <Rectangle x:Name="TreeLineVertFull"
                                                               Grid.Row="0"
                                                               Width="1" HorizontalAlignment="Left"
                                                               Fill="{DynamicResource TreeLineBrush}"
                                                               Margin="-7,0,0,0"
                                                               SnapsToDevicePixels="True"
                                                               Visibility="{Binding RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource TreeLineVis}, ConverterParameter=vert-full}"/>
                                                    <!-- ツリー接続線: 末尾子の縦線（上端→行中央の L 字角まで） -->
                                                    <Rectangle x:Name="TreeLineVertLast"
                                                               Grid.Row="0"
                                                               Width="1" HorizontalAlignment="Left"
                                                               VerticalAlignment="Top"
                                                               Fill="{DynamicResource TreeLineBrush}"
                                                               Margin="-7,0,0,0"
                                                               SnapsToDevicePixels="True"
                                                               Height="{Binding ActualHeight, ElementName=FullRowBackground, Converter={x:Static local:HalfValueConverter.Instance}}"
                                                               Visibility="{Binding RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource TreeLineVis}, ConverterParameter=vert-last}"/>
                                                    <!-- ツリー接続線: 水平コネクタ（ZIndex で Border 上に描画しアイコン左端まで到達） -->
                                                    <Rectangle x:Name="TreeLineHorz"
                                                               Grid.Row="0"
                                                               Width="27" Height="1"
                                                               HorizontalAlignment="Left"
                                                               VerticalAlignment="Center"
                                                               Fill="{DynamicResource TreeLineBrush}"
                                                               Margin="-7,0,0,0"
                                                               Panel.ZIndex="1"
                                                               IsHitTestVisible="False"
                                                               SnapsToDevicePixels="True"
                                                               Visibility="{Binding RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource TreeLineVis}, ConverterParameter=horz}"/>
                                                    <!-- ツリー接続線: 子要素領域の継続縦線（深い階層でも線が途切れない） -->
                                                    <Rectangle x:Name="TreeLineContinuation"
                                                               Grid.Row="1"
                                                               Width="1" HorizontalAlignment="Left"
                                                               Fill="{DynamicResource TreeLineBrush}"
                                                               Margin="-7,0,0,0"
                                                               SnapsToDevicePixels="True"
                                                               Visibility="{Binding RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource TreeLineVis}, ConverterParameter=vert-full}"/>
                                                    <!-- ナビペイン全幅を貫く背景（右端はスクロールバー用に余白を残す） -->
                                                    <Border x:Name="FullRowBackground"
                                                            Grid.Row="0"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="3"
                                                            Margin="0,0,10,0"
                                                            SnapsToDevicePixels="True">
                                                        <Grid>
                                                            <!-- 第1階層カテゴリ用のスリムなアクセントライン（左端） -->
                                                            <Rectangle x:Name="AccentLine"
                                                                       Width="3"
                                                                       HorizontalAlignment="Left"
                                                                       VerticalAlignment="Stretch"
                                                                       Margin="1,3"
                                                                       RadiusX="1.5"
                                                                       RadiusY="1.5"
                                                                       Fill="{DynamicResource AccentBrush}"
                                                                       Visibility="Collapsed"/>
                                                            <Grid Margin="{TemplateBinding Padding}">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" MinWidth="19"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <!-- 展開トグル -->
                                                                <ToggleButton x:Name="Expander"
                                                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                                              ClickMode="Press"
                                                                              Focusable="False"
                                                                              Width="16" Height="16"
                                                                              Margin="0,0,2,0">
                                                                    <ToggleButton.Template>
                                                                        <ControlTemplate TargetType="ToggleButton">
                                                                            <Border Background="Transparent" Width="16" Height="16">
                                                                                <icon:PackIconLucide x:Name="ExpanderIcon"
                                                                                                     Kind="ChevronRight"
                                                                                                     Width="10" Height="10"
                                                                                                     VerticalAlignment="Center"
                                                                                                     HorizontalAlignment="Center"
                                                                                                     Foreground="{DynamicResource SubTextBrush}"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsChecked" Value="True">
                                                                                    <Setter TargetName="ExpanderIcon" Property="Kind" Value="ChevronDown"/>
                                                                                </Trigger>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="ExpanderIcon" Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </ToggleButton.Template>
                                                                </ToggleButton>
                                                                <!-- ヘッダーコンテンツ -->
                                                                <ContentPresenter x:Name="PART_Header"
                                                                                  Grid.Column="1"
                                                                                  ContentSource="Header"
                                                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                                            </Grid>
                                                        </Grid>
                                                    </Border>
                                                    <!-- 子ノード（標準のインデント） -->
                                                    <ItemsPresenter x:Name="ItemsHost"
                                                                    Grid.Row="1"
                                                                    Margin="19,0,0,0"
                                                                    Visibility="Collapsed"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsExpanded" Value="True">
                                                        <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                                                    </Trigger>
                                                    <Trigger Property="HasItems" Value="False">
                                                        <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                                    </Trigger>
                                                    <!-- 通常行のホバー／選択 -->
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="FullRowBackground" Property="Background" Value="{DynamicResource ListHoverBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="FullRowBackground" Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                                    </Trigger>
                                                    <!-- 第1階層の仮想フォルダをスリムな全幅帯として強調 -->
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding Level}" Value="0"/>
                                                            <Condition Binding="{Binding IsContainer}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <!-- 落ち着いたスレートグレーの帯 -->
                                                        <Setter TargetName="FullRowBackground" Property="Background" Value="{DynamicResource OnePointDarkBackground}"/>
                                                        <!-- スクロールバー領域を避ける右マージンと、上下のスリムな余白 -->
                                                        <Setter TargetName="FullRowBackground" Property="Margin" Value="2,2,10,2"/>
                                                        <Setter Property="MinHeight" Value="24"/>
                                                        <Setter TargetName="AccentLine" Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="ContextMenu">
                                        <Setter.Value>
                                            <ContextMenu Placement="MousePoint" ItemContainerStyle="{StaticResource ContextMenuItemStyle}">
                                                <MenuItem Header="Aペインで開く" 
                                                          Command="{Binding PlacementTarget.Tag.Favorites.OpenInAPaneCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Visibility="{Binding PlacementTarget.DataContext.IsPhysicalFolder, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}">
                                                    <MenuItem.Icon>
                                                        <icon:PackIconLucide Kind="PanelLeft" Width="14" Height="14"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Bペインで開く" 
                                                          Command="{Binding PlacementTarget.Tag.Favorites.OpenInBPaneCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Visibility="{Binding PlacementTarget.DataContext.IsPhysicalFolder, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}">
                                                    <MenuItem.Icon>
                                                        <icon:PackIconLucide Kind="PanelRight" Width="14" Height="14"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator Style="{StaticResource ContextMenuSeparatorStyle}" Visibility="{Binding PlacementTarget.DataContext.IsPhysicalFolder, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}"/>
                                                <MenuItem Header="新しいフォルダ" Command="{Binding PlacementTarget.Tag.Favorites.AddFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon>
                                                        <icon:PackIconLucide Kind="FolderPlus" Width="14" Height="14"/>
                                                    </MenuItem.Icon>
                                                    <MenuItem.CommandParameter>
                                                        <Binding Path="PlacementTarget.DataContext" RelativeSource="{RelativeSource AncestorType=ContextMenu}"/>
                                                    </MenuItem.CommandParameter>
                                                </MenuItem>
                                                <MenuItem Header="名前の変更" Command="{Binding PlacementTarget.Tag.Favorites.RenameItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon>
                                                        <icon:PackIconLucide Kind="Pencil" Width="14" Height="14"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="概要を編集" Command="{Binding PlacementTarget.Tag.Favorites.EditDescriptionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon>
                                                        <icon:PackIconLucide Kind="FileText" Width="14" Height="14"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator Style="{StaticResource ContextMenuSeparatorStyle}"/>
                                                <MenuItem Header="削除" Style="{StaticResource ContextMenuDestructiveItemStyle}" Command="{Binding PlacementTarget.Tag.Favorites.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon>
                                                        <icon:PackIconLucide Kind="Trash2" Width="14" Height="14"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSuccessHighlighted}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard Storyboard="{StaticResource SuccessHighlightStoryboard}"/>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <Grid Margin="0,0,4,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- メインアイコン（環境アイコン列を廃止し直接配置） -->
                                        <Grid Grid.Column="0" Width="16" Height="16" Margin="0,0,4,0" VerticalAlignment="Center">
                                            <!-- 整理用フォルダ (仮想) -->
                                            <Image Source="{Binding Icon}"
                                                   Visibility="{Binding IsContainer, Converter={StaticResource BoolToVis}}"/>
                                            <!-- お気に入りフォルダ (物理) -->
                                            <icon:PackIconLucide Kind="{Binding LocationIconKind}" Width="14" Height="14"
                                                                 Foreground="{DynamicResource SubTextBrush}"
                                                                 Visibility="{Binding IsPhysicalFolder, Converter={StaticResource BoolToVis}}"/>
                                            <!-- ファイル -->
                                            <Image Source="{Binding Icon}"
                                                   Visibility="{Binding IsFile, Converter={StaticResource BoolToVis}}"/>
                                        </Grid>
                                        <Grid Grid.Column="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Name}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,0,4,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                        <Style.Triggers>
                                                            <!-- 第1階層カテゴリは白く太字でヘッダー感を強調 -->
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding Level}" Value="0"/>
                                                                    <Condition Binding="{Binding IsContainer}" Value="True"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Foreground" Value="White"/>
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <!-- パス不正警告（リンク切れ時のみ表示） -->
                                            <icon:PackIconLucide Grid.Column="1" Kind="TriangleAlert" Width="12" Height="12"
                                                                 VerticalAlignment="Center"
                                                                 Foreground="#C4A03C"
                                                                 Margin="0,0,4,0"
                                                                 ToolTip="パスが見つかりません"
                                                                 Visibility="{Binding IsPathMissing, Converter={StaticResource BoolToVis}}"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Description, StringFormat='({0})'}"
                                                       VerticalAlignment="Center"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis"
                                                       Visibility="{Binding Description, Converter={StaticResource NonEmptyStringToVis}}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
                                                        <Setter Property="Opacity" Value="0.7"/>
                                                        <Style.Triggers>
                                                            <!-- 濃い帯の上でも読みやすいように明るいトーンへ -->
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding Level}" Value="0"/>
                                                                    <Condition Binding="{Binding IsContainer}" Value="True"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Foreground" Value="#E0E0E0"/>
                                                                <Setter Property="Opacity" Value="0.9"/>
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Grid>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>

                            <!-- ListView（検索時・フラット表示） -->
                            <ListView x:Name="FavoritesFilteredList" Grid.Row="1"
                                      ItemsSource="{Binding Favorites.FavoriteItemsView}"
                                      SelectedItem="{Binding Favorites.SelectedSearchItem, Mode=TwoWay}"
                                      BorderThickness="0" Background="{DynamicResource BackgroundBrush}" Padding="0"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      VerticalAlignment="Stretch"
                                      VerticalContentAlignment="Stretch"
                                      VirtualizingStackPanel.IsVirtualizing="False"
                                      Visibility="{Binding Favorites.IsSearching, Converter={StaticResource BoolToVis}}">
                                <ListView.Style>
                                    <Style TargetType="ListView">
                                        <!-- Visibility はバインディングで制御するため Style トリガーは削除 -->
                                    </Style>
                                </ListView.Style>
                                <ListView.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{StaticResource SelectionColor}"/>
                                    <!-- 選択時もメインテキストは黒系で維持する -->
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="{StaticResource PrimaryTextColor}"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="{StaticResource InactiveSelectionColor}"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="{StaticResource PrimaryTextColor}"/>
                                </ListView.Resources>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}"/>
                                        <Setter Property="Padding" Value="4,2"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <TransformGroup>
                                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                </TransformGroup>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                        <Setter Property="MinHeight" Value="24"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="ToolTip" Value="{Binding Converter={StaticResource FavoriteToolTip}}"/>
                                        <EventSetter Event="MouseDoubleClick" Handler="FavoritesFilteredItem_MouseDoubleClick"/>
                                        <EventSetter Event="MouseDown" Handler="FavoritesFilteredItem_MouseDown"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListViewItem">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListHoverBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                                            <!-- 選択時もメインテキストは黒系で維持する -->
                                                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/> 
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="ContextMenu">
                                            <Setter.Value>
                                                <ContextMenu Placement="MousePoint" ItemContainerStyle="{StaticResource ContextMenuItemStyle}">
                                                    <MenuItem Header="Aペインで開く" 
                                                              Command="{Binding PlacementTarget.Tag.Favorites.OpenInAPaneCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              Visibility="{Binding PlacementTarget.DataContext.IsPhysicalFolder, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}">
                                                        <MenuItem.Icon>
                                                            <icon:PackIconLucide Kind="PanelLeft" Width="14" Height="14"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="Bペインで開く" 
                                                              Command="{Binding PlacementTarget.Tag.Favorites.OpenInBPaneCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              Visibility="{Binding PlacementTarget.DataContext.IsPhysicalFolder, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}">
                                                        <MenuItem.Icon>
                                                            <icon:PackIconLucide Kind="PanelRight" Width="14" Height="14"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSuccessHighlighted}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard Storyboard="{StaticResource SuccessHighlightStoryboard}"/>
                                                </DataTrigger.EnterActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid MinHeight="24">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- メインアイコン（環境アイコン列を廃止し直接配置） -->
                                            <Grid Grid.Column="0" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center">
                                                <Image Source="{Binding Icon}"
                                                       Visibility="{Binding IsContainer, Converter={StaticResource BoolToVis}}"/>
                                                <icon:PackIconLucide Kind="{Binding LocationIconKind}" Width="14" Height="14"
                                                                     Foreground="{DynamicResource SubTextBrush}"
                                                                     Visibility="{Binding IsPhysicalFolder, Converter={StaticResource BoolToVis}}"/>
                                                <Image Source="{Binding Icon}"
                                                       Visibility="{Binding IsFile, Converter={StaticResource BoolToVis}}"/>
                                            </Grid>
                                            <Grid Grid.Column="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,4,0" Foreground="{DynamicResource TextBrush}"/>
                                                <!-- パス不正警告（リンク切れ時のみ表示） -->
                                                <icon:PackIconLucide Grid.Column="1" Kind="TriangleAlert" Width="12" Height="12"
                                                                     VerticalAlignment="Center"
                                                                     Foreground="#C4A03C"
                                                                     Margin="0,0,4,0"
                                                                     ToolTip="パスが見つかりません"
                                                                     Visibility="{Binding IsPathMissing, Converter={StaticResource BoolToVis}}"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Description, StringFormat='({0})'}"
                                                           VerticalAlignment="Center"
                                                           FontSize="11"
                                                           Opacity="0.7"
                                                           Foreground="{DynamicResource SubTextBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Visibility="{Binding Description, Converter={StaticResource NonEmptyStringToVis}}"/>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                        <StackPanel Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Margin="0,0,10,0" Orientation="Horizontal">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SidebarMode}" Value="{x:Static local:SidebarViewMode.Favorites}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <!-- お気に入りExcelバックアップ（アイコン群の左端） -->
                            <Button Command="{Binding Favorites.ExportFavoritesToExcelCommand}"
                                    Style="{StaticResource IconButton}"
                                    ToolTip="お気に入りをエクセルでバックアップ保存"
                                    IsTabStop="False"
                                    Margin="0,0,5,0">
                                <icon:PackIconLucide Kind="FileSpreadsheet" Width="16" Height="16" Foreground="{DynamicResource SubTextBrush}"/>
                            </Button>
                            <!-- クイックアクセスからインポート -->
                            <Button Command="{Binding Favorites.ImportFromQuickAccessCommand}"
                                    Style="{StaticResource IconButton}"
                                    ToolTip="エクスプローラのクイックアクセスをインポート"
                                    IsTabStop="False"
                                    Margin="0,0,5,0">
                                <icon:PackIconLucide Kind="Download" Width="16" Height="16" Foreground="{DynamicResource SubTextBrush}"/>
                            </Button>
                            <!-- お気に入り検索モード切替（名前・概要 ⇔ フルパス・概要）・4つのうち左端 -->
                            <ToggleButton IsChecked="{Binding Favorites.SearchMode, Converter={StaticResource FavoritesSearchModeToBool}, Mode=TwoWay}"
                                          Style="{StaticResource IconToggleButton}"
                                          ToolTip="{Binding Favorites.SearchMode, Converter={StaticResource FavoritesSearchModeToTooltip}}"
                                          IsTabStop="False"
                                          Margin="0,0,5,0">
                                <icon:PackIconLucide Width="16" Height="16">
                                    <icon:PackIconLucide.Style>
                                        <Style TargetType="icon:PackIconLucide">
                                            <Setter Property="Kind" Value="Type"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Favorites.SearchMode, Converter={StaticResource FavoritesSearchModeToBool}}" Value="True">
                                                    <Setter Property="Kind" Value="Route"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </icon:PackIconLucide.Style>
                                </icon:PackIconLucide>
                            </ToggleButton>
                            <!-- ナビ幅ロックトグル（お気に入りビューのみ表示） -->
                            <ToggleButton IsChecked="{Binding IsNavWidthLocked, Mode=TwoWay}"
                                          Style="{StaticResource IconToggleButton}"
                                          ToolTip="{Binding IsNavWidthLocked, Converter={StaticResource BooleanToLockTooltip}, ConverterParameter=NavWidthLock}"
                                          IsTabStop="False"
                                          Margin="0,0,5,0">
                                <icon:PackIconLucide Width="16" Height="16">
                                    <icon:PackIconLucide.Style>
                                        <Style TargetType="icon:PackIconLucide">
                                            <Setter Property="Kind" Value="PanelLeftOpen"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Path=IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                                                    <Setter Property="Kind" Value="PanelLeftClose"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </icon:PackIconLucide.Style>
                                </icon:PackIconLucide>
                            </ToggleButton>
                            <!-- ポップアップ確認トグル -->
                            <ToggleButton IsChecked="{Binding Favorites.ConfirmDelete, Mode=TwoWay}"
                                          Style="{StaticResource IconToggleButton}"
                                          ToolTip="{Binding Favorites.ConfirmDelete, Converter={StaticResource BooleanToLockTooltip}, ConverterParameter=DeleteConfirm}"
                                          IsTabStop="False">
                                <icon:PackIconLucide Width="16" Height="16">
                                    <icon:PackIconLucide.Style>
                                        <Style TargetType="icon:PackIconLucide">
                                            <Setter Property="Kind" Value="MessageSquare"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Path=IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="False">
                                                    <Setter Property="Kind" Value="MessageSquareOff"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </icon:PackIconLucide.Style>
                                </icon:PackIconLucide>
                            </ToggleButton>

                            <!-- お気に入りロックボタン -->
                            <Grid Margin="5,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <!-- ロック解除を促す矢印 -->
                                    <icon:PackIconLucide Kind="ArrowRight" Width="16" Height="16" Foreground="{DynamicResource AccentBrush}" Margin="0,0,2,0">
                                        <icon:PackIconLucide.Style>
                                            <Style TargetType="icon:PackIconLucide">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Favorites.IsLockWarningActive}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </icon:PackIconLucide.Style>
                                    </icon:PackIconLucide>
                                    
                                    <ToggleButton IsChecked="{Binding Favorites.IsLocked, Mode=TwoWay}"
                                                  Style="{StaticResource IconToggleButton}"
                                                  ToolTip="{Binding Favorites.IsLocked, Converter={StaticResource BooleanToLockTooltip}, ConverterParameter=FavoritesLock}"
                                                  IsTabStop="False"
                                                  IsHitTestVisible="True">
                                        <icon:PackIconLucide Width="16" Height="16">
                                            <icon:PackIconLucide.Style>
                                                <Style TargetType="icon:PackIconLucide">
                                                    <Setter Property="Kind" Value="LockOpen"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Path=IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                                                            <Setter Property="Kind" Value="Lock"/>
                                                        </DataTrigger>
                                                        <!-- ロック時に変更しようとした場合の点滅 -->
                                                        <DataTrigger Binding="{Binding Favorites.IsLockWarningActive}" Value="True">
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard x:Name="BlinkStoryboard">
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                         From="1.0" To="0.2" Duration="0:0:0.3"
                                                                                         AutoReverse="True" RepeatBehavior="Forever"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                            <DataTrigger.ExitActions>
                                                                <StopStoryboard BeginStoryboardName="BlinkStoryboard"/>
                                                            </DataTrigger.ExitActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </icon:PackIconLucide.Style>
                                        </icon:PackIconLucide>
                                    </ToggleButton>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                        </Grid>
                        
                        <!-- ツリービュー -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SidebarMode}" Value="{x:Static local:SidebarViewMode.Tree}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="32"/>
                            </Grid.RowDefinitions>
                            
                            <TreeView x:Name="DirectoryTree" Grid.Row="0"
                                      ItemsSource="{Binding DirectoryTree.Drives}" 
                                      local:TreeViewDragDropBehavior.IsEnabled="True"
                                      PreviewKeyDown="DirectoryTree_PreviewKeyDown"
                                      PreviewMouseRightButtonDown="DirectoryTree_PreviewMouseRightButtonDown"
                                      BorderThickness="0" Background="Transparent" Padding="0,5"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <TreeView.ContextMenu>
                                    <ContextMenu Placement="MousePoint" ItemContainerStyle="{StaticResource ContextMenuItemStyle}">
                                        <MenuItem Header="ツリーを更新" Command="{Binding PlacementTarget.DataContext.RefreshDirectoryTreeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Icon>
                                                <icon:PackIconLucide Kind="RefreshCw" Width="14" Height="14"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </TreeView.ContextMenu>
                                <TreeView.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{StaticResource SelectionColor}"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="{StaticResource AccentColor}"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="{StaticResource InactiveSelectionColor}"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="{StaticResource PrimaryTextColor}"/>
                                </TreeView.Resources>
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                        <Setter Property="Padding" Value="1,1"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="ToolTip" Value="ダブルクリックでペインに表示、Ctrl+ダブルクリックで反対ペインに表示。Shift+クリックでアイコンビュー表示、Shift+Ctrl+クリックで反対ペインにアイコンビュー表示。"/>
                                        <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}"/>
                                        <EventSetter Event="Selected" Handler="TreeViewItem_Selected"/>
                                        <EventSetter Event="PreviewMouseLeftButtonDown" Handler="DirectoryTreeItem_PreviewMouseLeftButtonDown"/>
                                        <EventSetter Event="MouseDoubleClick" Handler="DirectoryTreeItem_MouseDoubleClick"/>
                                        <EventSetter Event="PreviewMouseRightButtonDown" Handler="TreeViewItem_PreviewMouseRightButtonDown"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TreeViewItem">
                                                    <Grid SnapsToDevicePixels="True">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition/>
                                                        </Grid.RowDefinitions>
                                                        <!-- ツリー接続線: 非末尾子の縦線 -->
                                                        <Rectangle x:Name="TreeLineVertFull"
                                                                   Grid.Row="0"
                                                                   Width="1" HorizontalAlignment="Left"
                                                                   Fill="{DynamicResource TreeLineBrush}"
                                                                   Margin="-7,0,0,0"
                                                                   SnapsToDevicePixels="True"
                                                                   Visibility="{Binding RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource TreeLineVis}, ConverterParameter=vert-full}"/>
                                                        <!-- ツリー接続線: 末尾子の縦線（L 字角まで） -->
                                                        <Rectangle x:Name="TreeLineVertLast"
                                                                   Grid.Row="0"
                                                                   Width="1" HorizontalAlignment="Left"
                                                                   VerticalAlignment="Top"
                                                                   Fill="{DynamicResource TreeLineBrush}"
                                                                   Margin="-7,0,0,0"
                                                                   SnapsToDevicePixels="True"
                                                                   Height="{Binding ActualHeight, ElementName=DirFullRowBg, Converter={x:Static local:HalfValueConverter.Instance}}"
                                                                   Visibility="{Binding RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource TreeLineVis}, ConverterParameter=vert-last}"/>
                                                        <!-- ツリー接続線: 水平コネクタ -->
                                                        <Rectangle x:Name="TreeLineHorz"
                                                                   Grid.Row="0"
                                                                   Width="27" Height="1"
                                                                   HorizontalAlignment="Left"
                                                                   VerticalAlignment="Center"
                                                                   Fill="{DynamicResource TreeLineBrush}"
                                                                   Margin="-7,0,0,0"
                                                                   Panel.ZIndex="1"
                                                                   IsHitTestVisible="False"
                                                                   SnapsToDevicePixels="True"
                                                                   Visibility="{Binding RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource TreeLineVis}, ConverterParameter=horz}"/>
                                                        <!-- ツリー接続線: 子要素領域の継続縦線 -->
                                                        <Rectangle x:Name="TreeLineContinuation"
                                                                   Grid.Row="1"
                                                                   Width="1" HorizontalAlignment="Left"
                                                                   Fill="{DynamicResource TreeLineBrush}"
                                                                   Margin="-7,0,0,0"
                                                                   SnapsToDevicePixels="True"
                                                                   Visibility="{Binding RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource TreeLineVis}, ConverterParameter=vert-full}"/>
                                                        <Border x:Name="DirFullRowBg"
                                                                Grid.Row="0"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="3"
                                                                Margin="0,0,10,0"
                                                                SnapsToDevicePixels="True">
                                                            <Grid Margin="{TemplateBinding Padding}">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" MinWidth="19"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <ToggleButton x:Name="Expander"
                                                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                                              ClickMode="Press"
                                                                              Focusable="False"
                                                                              Width="16" Height="16"
                                                                              Margin="0,0,2,0">
                                                                    <ToggleButton.Template>
                                                                        <ControlTemplate TargetType="ToggleButton">
                                                                            <Border Background="Transparent" Width="16" Height="16">
                                                                                <icon:PackIconLucide x:Name="ExpanderIcon"
                                                                                                     Kind="ChevronRight"
                                                                                                     Width="10" Height="10"
                                                                                                     VerticalAlignment="Center"
                                                                                                     HorizontalAlignment="Center"
                                                                                                     Foreground="{DynamicResource SubTextBrush}"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsChecked" Value="True">
                                                                                    <Setter TargetName="ExpanderIcon" Property="Kind" Value="ChevronDown"/>
                                                                                </Trigger>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="ExpanderIcon" Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </ToggleButton.Template>
                                                                </ToggleButton>
                                                                <ContentPresenter x:Name="PART_Header"
                                                                                  Grid.Column="1"
                                                                                  ContentSource="Header"
                                                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                                            </Grid>
                                                        </Border>
                                                        <ItemsPresenter x:Name="ItemsHost"
                                                                        Grid.Row="1"
                                                                        Margin="19,0,0,0"
                                                                        Visibility="Collapsed"/>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsExpanded" Value="True">
                                                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                                                        </Trigger>
                                                        <Trigger Property="HasItems" Value="False">
                                                            <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="DirFullRowBg" Property="Background" Value="{DynamicResource ListHoverBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="DirFullRowBg" Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="ContextMenu">
                                            <Setter.Value>
                                                <ContextMenu Placement="MousePoint" ItemContainerStyle="{StaticResource ContextMenuItemStyle}">
                                                    <MenuItem Header="Aペインに表示" 
                                                              Command="{Binding PlacementTarget.Tag.OpenTreeItemInAPaneCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Icon>
                                                            <icon:PackIconLucide Kind="PanelLeft" Width="14" Height="14"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="Bペインに表示" 
                                                              Command="{Binding PlacementTarget.Tag.OpenTreeItemInBPaneCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Icon>
                                                            <icon:PackIconLucide Kind="PanelRight" Width="14" Height="14"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <Separator Style="{StaticResource ContextMenuSeparatorStyle}"/>
                                                    <MenuItem Header="名前の変更" 
                                                              Command="{Binding PlacementTarget.Tag.RequestRenameTreeFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Icon>
                                                            <icon:PackIconLucide Kind="Pencil" Width="14" Height="14"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="削除" Style="{StaticResource ContextMenuDestructiveItemStyle}"
                                                              Command="{Binding PlacementTarget.Tag.RequestDeleteTreeFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Icon>
                                                            <icon:PackIconLucide Kind="Trash2" Width="14" Height="14"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <Grid Margin="0,0,4,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Image Grid.Column="0" Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextBrush}"/>
                                        </Grid>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                            <!-- ツリービュー用パネル（右下・ツリービューロック） -->
                            <StackPanel Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Margin="0,0,10,0" Orientation="Horizontal">
                                <Grid Margin="0,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <icon:PackIconLucide Kind="ArrowRight" Width="16" Height="16" Foreground="{DynamicResource AccentBrush}" Margin="0,0,2,0">
                                            <icon:PackIconLucide.Style>
                                                <Style TargetType="icon:PackIconLucide">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsTreeViewLockWarningActive}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </icon:PackIconLucide.Style>
                                        </icon:PackIconLucide>
                                        <ToggleButton x:Name="TreeViewLockButton" IsChecked="{Binding IsTreeViewLocked, Mode=TwoWay}"
                                                      Style="{StaticResource IconToggleButton}"
                                                      ToolTip="{Binding IsTreeViewLocked, Converter={StaticResource BooleanToLockTooltip}, ConverterParameter=TreeLock}"
                                                      IsTabStop="False"
                                                      IsHitTestVisible="True">
                                            <icon:PackIconLucide Width="16" Height="16">
                                                <icon:PackIconLucide.Style>
                                                    <Style TargetType="icon:PackIconLucide">
                                                        <Setter Property="Kind" Value="LockOpen"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Path=IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                                                                <Setter Property="Kind" Value="Lock"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsTreeViewLockWarningActive}" Value="True">
                                                                <DataTrigger.EnterActions>
                                                                    <BeginStoryboard x:Name="TreeLockBlinkStoryboard">
                                                                        <Storyboard>
                                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                             From="1.0" To="0.2" Duration="0:0:0.3"
                                                                                             AutoReverse="True" RepeatBehavior="Forever"/>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </DataTrigger.EnterActions>
                                                                <DataTrigger.ExitActions>
                                                                    <StopStoryboard BeginStoryboardName="TreeLockBlinkStoryboard"/>
                                                                </DataTrigger.ExitActions>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </icon:PackIconLucide.Style>
                                            </icon:PackIconLucide>
                                        </ToggleButton>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <!-- 参照履歴ビュー -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SidebarMode}" Value="{x:Static local:SidebarViewMode.History}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="32"/>
                            </Grid.RowDefinitions>

                            <!-- 検索ボックス -->
                            <Border Grid.Row="0" Margin="10,10,10,5" Background="{DynamicResource BackgroundBrush}" 
                                    CornerRadius="4" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <icon:PackIconLucide Kind="Search" Width="14" Height="14" Margin="8,0,0,0" 
                                                         VerticalAlignment="Center" Foreground="{DynamicResource SubTextBrush}"/>
                                    <TextBox x:Name="HistorySearchBox"
                                             Text="{Binding HistorySearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent" BorderThickness="0"
                                             VerticalContentAlignment="Center" Padding="6"
                                             Grid.Column="1">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Esc" Command="{Binding ClearHistorySearchCommand}"/>
                                        </TextBox.InputBindings>
                                    </TextBox>
                                    <Button Grid.Column="2" Command="{Binding ClearHistorySearchCommand}"
                                            Margin="0,0,4,0" IsTabStop="False">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HistorySearchText}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HistorySearchText}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <icon:PackIconLucide Kind="X" Width="14" Height="14" Foreground="{DynamicResource SubTextBrush}"/>
                                    </Button>
                                </Grid>
                            </Border>

                            <ListView x:Name="HistoryList"
                                      Grid.Row="1" ItemsSource="{Binding HistoryView}" 
                                      BorderThickness="0" Background="Transparent" Padding="0"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      PreviewMouseLeftButtonDown="HistoryList_PreviewMouseLeftButtonDown"
                                      MouseMove="HistoryList_MouseMove">
                                <ListView.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.ContainerStyle>
                                            <Style TargetType="{x:Type GroupItem}">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="{x:Type GroupItem}">
                                                            <Expander IsExpanded="{Binding Name, Converter={StaticResource IsToday}, Mode=OneTime}" 
                                                                      Background="Transparent"
                                                                      BorderBrush="{DynamicResource BorderBrush}" 
                                                                      BorderThickness="0,0,0,1">
                                                                <Expander.Header>
                                                                    <StackPanel Orientation="Horizontal" Margin="4,2">
                                                                        <icon:PackIconLucide Kind="Calendar" Width="12" Height="12" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="{DynamicResource SubTextBrush}"/>
                                                                        <TextBlock Text="{Binding Name, StringFormat='yyyy/MM/dd(ddd)', ConverterCulture=ja-JP}" 
                                                                                   FontWeight="SemiBold" 
                                                                                   Foreground="{DynamicResource SubTextBrush}" 
                                                                                   VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                </Expander.Header>
                                                                <ItemsPresenter />
                                                            </Expander>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </GroupStyle.ContainerStyle>
                                    </GroupStyle>
                                </ListView.GroupStyle>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                                        <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}"/>
                                        <Setter Property="ToolTip" Value="{Binding Path}"/>
                                        <EventSetter Event="MouseDoubleClick" Handler="HistoryItem_MouseDoubleClick"/>
                                        <Setter Property="ContextMenu">
                                            <Setter.Value>
                                                <ContextMenu Placement="MousePoint" ItemContainerStyle="{StaticResource ContextMenuItemStyle}">
                                                    <MenuItem Header="Aペインに表示" 
                                                              Command="{Binding PlacementTarget.Tag.OpenHistoryInAPaneCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Icon>
                                                            <icon:PackIconLucide Kind="PanelLeft" Width="14" Height="14"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="Bペインに表示" 
                                                              Command="{Binding PlacementTarget.Tag.OpenHistoryInBPaneCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Icon>
                                                            <icon:PackIconLucide Kind="PanelRight" Width="14" Height="14"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.View>
                                    <GridView>
                                        <GridView.ColumnHeaderContainerStyle>
                                            <Style TargetType="GridViewColumnHeader">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="GridViewColumnHeader">
                                                            <Border BorderThickness="0,0,1,1" BorderBrush="{DynamicResource BorderBrush}" Padding="8,4" Background="Transparent">
                                                                <ContentPresenter VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </GridView.ColumnHeaderContainerStyle>
                                        <GridViewColumn Header="名前" Width="150">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="4,0">
                                                        <icon:PackIconLucide Kind="{Binding IconKind}" Width="14" Height="14" Margin="0,0,8,0" Foreground="{DynamicResource AccentBrush}"/>
                                                        <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                                   local:TextBlockHighlightBehavior.Text="{Binding Name}"
                                                                   local:TextBlockHighlightBehavior.HighlightText="{Binding DataContext.HistorySearchText, RelativeSource={RelativeSource AncestorType=ListView}}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="参照日時" Width="110">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding LastAccessed, StringFormat='yyyy/MM/dd HH:mm'}" FontSize="11" VerticalAlignment="Center" Foreground="{DynamicResource SubTextBrush}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="回数" Width="40">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding AccessCount}" FontSize="11" VerticalAlignment="Center" Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Right"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>

                            <!-- 履歴クリア（ゴミ箱）ボタン：過去履歴ビューの右下 -->
                            <Button Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Margin="0,0,10,0"
                                    Style="{StaticResource IconButton}"
                                    Command="{Binding ClearHistoryCommand}"
                                    ToolTip="履歴をクリア"
                                    IsTabStop="False">
                                <icon:PackIconLucide Kind="Trash2" Width="16" Height="16" Foreground="{DynamicResource SubTextBrush}"/>
                            </Button>
                        </Grid>

                        <!-- インデックス検索設定ビュー -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SidebarMode}" Value="{x:Static local:SidebarViewMode.IndexSearch}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Margin="10,10,10,4" FontSize="12" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap">
                                インデックス検索の対象にするフォルダを登録します。ここで登録したフォルダ内が検索対象になります。
                            </TextBlock>

                            <!-- インデックスの状態 -->
                            <Border Grid.Row="1" Margin="10,0,10,6" Padding="8,6" Background="{DynamicResource BackgroundBrush}" CornerRadius="4" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4">インデックスの状態</TextBlock>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}">
                                        <Run Text="状態: "/>
                                        <Run Text="{Binding IndexSearchSettings.IndexStatusText, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}" Margin="0,2,0,0">
                                        <Run Text="インデックス: "/>
                                        <Run Text="{Binding IndexSearchSettings.IndexedDocumentCount, StringFormat={}{0:N0}, Mode=OneWay}"/>
                                        <Run Text=" 件"/>
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <Button Style="{StaticResource IconButton}" Command="{Binding IndexSearchSettings.UpdateNowCommand}"
                                                ToolTip="未インデックスのフォルダだけ今すぐインデックスを作成します" IsTabStop="False" Margin="0,0,4,0">
                                            <StackPanel Orientation="Horizontal">
                                                <icon:PackIconLucide Kind="RefreshCw" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="未インデックスを作成" VerticalAlignment="Center" FontSize="12"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource IconButton}" Command="{Binding IndexSearchSettings.PauseIndexingCommand}"
                                                ToolTip="インデックス更新だけを一時停止します。検索はそのまま利用できます"
                                                Visibility="{Binding IndexSearchSettings.IsPaused, Converter={StaticResource BoolToVisInverse}}"
                                                IsTabStop="False" Margin="0,0,4,0">
                                            <StackPanel Orientation="Horizontal">
                                                <icon:PackIconLucide Kind="Pause" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="一時停止" VerticalAlignment="Center" FontSize="12"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource IconButton}" Command="{Binding IndexSearchSettings.ResumeIndexingCommand}"
                                                ToolTip="インデックス更新を再開します"
                                                Visibility="{Binding IndexSearchSettings.IsPaused, Converter={StaticResource BoolToVis}}"
                                                IsTabStop="False" Margin="0,0,4,0">
                                            <StackPanel Orientation="Horizontal">
                                                <icon:PackIconLucide Kind="Play" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="再開" VerticalAlignment="Center" FontSize="12"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="IndexMenuButton" Style="{StaticResource IconButton}" ToolTip="その他の操作" IsTabStop="False" Margin="0,0,4,0"
                                                Tag="{Binding}" Click="IndexMenuButton_Click">
                                            <Button.Content>
                                                <TextBlock Text="⋯" VerticalAlignment="Center" FontSize="14"/>
                                            </Button.Content>
                                            <Button.ContextMenu>
                                                <ContextMenu Placement="Bottom" ItemContainerStyle="{StaticResource ContextMenuItemStyle}">
                                                    <MenuItem Header="フル再構築を実行…"
                                                              Command="{Binding PlacementTarget.Tag.IndexSearchSettings.RequestFullRebuildCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              ToolTip="すべてのフォルダを最初から再インデックスします。確認ダイアログが表示されます">
                                                        <MenuItem.Icon>
                                                            <icon:PackIconLucide Kind="RotateCcw" Width="14" Height="14"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="インデックスの設定を開く"
                                                              Command="{Binding PlacementTarget.Tag.IndexSearchSettings.OpenAppSettingsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              ToolTip="オプションのインデックス関連設定を開きます">
                                                        <MenuItem.Icon>
                                                            <icon:PackIconLucide Kind="Settings" Width="14" Height="14"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="10,0,10,6">
                                <Button Style="{StaticResource IconButton}" Command="{Binding IndexSearchSettings.AddFolderCommand}"
                                        ToolTip="フォルダを追加（ツリーから選択）" IsTabStop="False" Margin="0,0,4,0">
                                    <StackPanel Orientation="Horizontal">
                                        <icon:PackIconLucide Kind="FolderPlus" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="フォルダを追加" VerticalAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource IconButton}" Command="{Binding IndexSearchSettings.AddCurrentFolderCommand}"
                                        ToolTip="表示中のフォルダを追加" IsTabStop="False">
                                    <StackPanel Orientation="Horizontal">
                                        <icon:PackIconLucide Kind="PanelLeft" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="現在のフォルダを追加" VerticalAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!-- ドロップ受付ゾーン（ListView + 空状態プレースホルダーを包括） -->
                            <Border x:Name="IndexDropZone" Grid.Row="4" Margin="10,0"
                                    AllowDrop="True" Background="Transparent"
                                    DragEnter="IndexDropZone_DragEnter" DragOver="IndexDropZone_DragOver"
                                    DragLeave="IndexDropZone_DragLeave" Drop="IndexDropZone_Drop">
                                <Grid>
                                    <ListBox x:Name="IndexSearchTargetList"
                                             ItemsSource="{Binding IndexSearchSettings.Items}"
                                             SelectedItem="{Binding IndexSearchSettings.SelectedItem, Mode=TwoWay}"
                                             BorderThickness="0" Background="Transparent" Padding="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             VirtualizingPanel.IsVirtualizing="True"
                                             Grid.IsSharedSizeScope="True">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                                <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                                                <Setter Property="ToolTip" Value="{Binding Path}"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Margin" Value="0"/>
                                                <EventSetter Event="MouseDoubleClick" Handler="IndexSearchTargetItem_MouseDoubleClick"/>
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <TransformGroup>
                                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                        </TransformGroup>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                                <Setter Property="ContextMenu">
                                                    <Setter.Value>
                                                        <ContextMenu Placement="MousePoint" ItemContainerStyle="{StaticResource ContextMenuItemStyle}">
                                                            <MenuItem Header="インデックス登録確認"
                                                                      Command="{Binding PlacementTarget.Tag.IndexSearchSettings.ConfirmIndexingCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding}"
                                                                      ToolTip="このフォルダのインデックス登録内容を一覧表示します">
                                                                <MenuItem.Icon>
                                                                    <icon:PackIconLucide Kind="Search" Width="14" Height="14"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <Separator Style="{StaticResource ContextMenuSeparatorStyle}"/>
                                                            <MenuItem Header="インデックスを再作成"
                                                                      Command="{Binding PlacementTarget.Tag.IndexSearchSettings.RebuildRootCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding}"
                                                                      ToolTip="インデックスを一度削除して最初から再作成します。削除済みファイルも反映されます">
                                                                <MenuItem.Icon>
                                                                    <icon:PackIconLucide Kind="RotateCcw" Width="14" Height="14"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="インデックスを差分更新"
                                                                      Command="{Binding PlacementTarget.Tag.IndexSearchSettings.UpdateRootDiffCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding}"
                                                                      ToolTip="インデックスは削除せず、新規・更新されたファイルだけを反映します">
                                                                <MenuItem.Icon>
                                                                    <icon:PackIconLucide Kind="RefreshCw" Width="14" Height="14"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <Separator Style="{StaticResource ContextMenuSeparatorStyle}"/>
                                                            <MenuItem Command="{Binding PlacementTarget.Tag.IndexSearchSettings.ToggleLockCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding}">
                                                                <MenuItem.Style>
                                                                    <Style TargetType="MenuItem" BasedOn="{StaticResource ContextMenuItemStyle}">
                                                                        <Setter Property="Header" Value="インデックス更新をロック"/>
                                                                        <Setter Property="ToolTip" Value="一括更新・定期更新の対象外にします"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                                <Setter Property="Header" Value="ロックを解除"/>
                                                                                <Setter Property="ToolTip" Value="一括更新・定期更新の対象に戻します"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </MenuItem.Style>
                                                                <MenuItem.Icon>
                                                                    <icon:PackIconLucide Kind="Lock" Width="14" Height="14"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <!-- 詳細設定 -->
                                                            <MenuItem Header="詳細設定..."
                                                                      Command="{Binding PlacementTarget.Tag.IndexSearchSettings.OpenItemSettingsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding}"
                                                                      ToolTip="スケジュール・ロック・更新方式を設定します">
                                                                <MenuItem.Icon>
                                                                    <icon:PackIconLucide Kind="Settings" Width="14" Height="14"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <Separator Style="{StaticResource ContextMenuSeparatorStyle}"/>
                                                            <MenuItem Header="削除"
                                                                      Command="{Binding PlacementTarget.Tag.IndexSearchSettings.RemoveCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding}">
                                                                <MenuItem.Icon>
                                                                    <icon:PackIconLucide Kind="Trash2" Width="14" Height="14"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                        </ContextMenu>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSuccessHighlighted}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard Storyboard="{StaticResource SuccessHighlightStoryboard}"/>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <!-- 4カラム単一行: Icon | Name | DateTime | Count/Status -->
                                                <Border x:Name="ItemRowBorder" CornerRadius="4" Padding="6,2,6,2" Background="Transparent">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="IdxDate"/>
                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="IdxStatus"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Col 0: 場所アイコン + ロックアイコン -->
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,0">
                                                            <icon:PackIconLucide Kind="{Binding LocationIconKind}" Width="13" Height="13"
                                                                                 Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center"/>
                                                            <icon:PackIconLucide x:Name="LockIcon" Kind="Lock" Width="10" Height="10"
                                                                                 Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center" Margin="3,0,0,0"
                                                                                 Visibility="Collapsed" ToolTip="{Binding LockToolTipText}"/>
                                                            <icon:PackIconLucide x:Name="ScheduleIcon" Kind="CalendarClock" Width="10" Height="10"
                                                                                 Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center" Margin="3,0,0,0"
                                                                                 Visibility="Collapsed" ToolTip="{Binding ScheduleDisplayText}"/>
                                                        </StackPanel>

                                                        <!-- Col 1: フォルダ名 -->
                                                        <TextBlock Grid.Column="1" Text="{Binding DisplayName}" FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>

                                                        <!-- Col 2: 完了日時（Indexed 時のみ表示） -->
                                                        <TextBlock x:Name="DateTimeLabel" Grid.Column="2" Text="{Binding CompactDateText}" FontSize="12"
                                                                   Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center" Margin="0,0,10,0"
                                                                   Visibility="Collapsed"/>

                                                        <!-- Col 3: 件数（Indexed 時）or ステータス（非 Indexed 時） -->
                                                        <!-- 件数バッジ（Indexed 時のみ） -->
                                                        <TextBlock x:Name="CountLabel" Grid.Column="3" Text="{Binding CountBadgeText}" FontSize="12"
                                                                   Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"
                                                                   Visibility="Collapsed"/>
                                                        <!-- ステータス（非 Indexed 時） -->
                                                        <StackPanel x:Name="StatusPanel" Grid.Column="3" Orientation="Horizontal"
                                                                    VerticalAlignment="Center" HorizontalAlignment="Right">
                                                            <!-- スピナー（作成中のみ） -->
                                                            <icon:PackIconLucide x:Name="SpinnerIcon" Kind="LoaderCircle" Width="12" Height="12"
                                                                                 Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,4,0"
                                                                                 Visibility="Collapsed" RenderTransformOrigin="0.5,0.5"
                                                                                 MouseEnter="ItemSpinner_MouseEnter"
                                                                                 MouseLeave="ItemSpinner_MouseLeave">
                                                                <icon:PackIconLucide.RenderTransform>
                                                                    <RotateTransform x:Name="SpinnerRotation" Angle="0"/>
                                                                </icon:PackIconLucide.RenderTransform>
                                                            </icon:PackIconLucide>
                                                            <TextBlock x:Name="StatusLabel" Text="{Binding StatusText}" FontSize="12"
                                                                       Foreground="{DynamicResource IndexStatusNormalBrush}" VerticalAlignment="Center"/>
                                                            <Popup StaysOpen="True" AllowsTransparency="True"
                                                                   Placement="Top" PlacementTarget="{Binding ElementName=SpinnerIcon}"
                                                                   VerticalOffset="-4" PopupAnimation="Fade" IsHitTestVisible="False"
                                                                   IsOpen="{Binding IsTelemetryPopupOpen, Mode=OneWay}">
                                                                <Border Background="{DynamicResource TelemetryBackgroundBrush}" CornerRadius="6" Padding="12,10" MinWidth="260"
                                                                        BorderBrush="{DynamicResource TelemetryBorderBrush}" BorderThickness="0.5">
                                                                    <Border.Effect>
                                                                        <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.3" Color="Black"/>
                                                                    </Border.Effect>
                                                                    <StackPanel>
                                                                        <TextBlock Text="Index Telemetry" FontFamily="Consolas" FontSize="11"
                                                                                   Foreground="{DynamicResource TelemetryTitleBrush}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                                        <Border Background="#30FFFFFF" Height="1" Margin="0,0,0,6"/>
                                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                                            <TextBlock Text="Scan:   " FontFamily="Consolas" FontSize="10.5" Foreground="{DynamicResource SubTextBrush}"/>
                                                                            <TextBlock Text="{Binding TelemetryScanText}" FontFamily="Consolas" FontSize="10.5"
                                                                                       Foreground="{DynamicResource TelemetryValueBrush}" TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                                                                        </StackPanel>
                                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                                            <TextBlock Text="Speed:  " FontFamily="Consolas" FontSize="10.5" Foreground="{DynamicResource SubTextBrush}"/>
                                                                            <TextBlock Text="{Binding TelemetrySpeedText}" FontFamily="Consolas" FontSize="10.5"
                                                                                       Foreground="{DynamicResource TelemetryValueBrush}"/>
                                                                        </StackPanel>
                                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                                            <TextBlock Text="DB:     " FontFamily="Consolas" FontSize="10.5" Foreground="{DynamicResource SubTextBrush}"/>
                                                                            <TextBlock Text="{Binding TelemetryDbText}" FontFamily="Consolas" FontSize="10.5"
                                                                                       Foreground="{DynamicResource TelemetryValueBrush}"/>
                                                                        </StackPanel>
                                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                                            <TextBlock Text="Thread: " FontFamily="Consolas" FontSize="10.5" Foreground="{DynamicResource SubTextBrush}"/>
                                                                            <TextBlock Text="{Binding TelemetryThreadText}" FontFamily="Consolas" FontSize="10.5"
                                                                                       Foreground="{DynamicResource TelemetryValueBrush}"/>
                                                                        </StackPanel>
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <TextBlock Text="Time:   " FontFamily="Consolas" FontSize="10.5" Foreground="{DynamicResource SubTextBrush}"/>
                                                                            <TextBlock Text="{Binding TelemetryElapsedText}" FontFamily="Consolas" FontSize="10.5"
                                                                                       Foreground="{DynamicResource TelemetryValueBrush}"/>
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                </Border>
                                                            </Popup>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <DataTemplate.Triggers>
                                                    <!-- === 作成中 === -->
                                                    <DataTrigger Binding="{Binding StatusKind}" Value="InProgress">
                                                        <Setter TargetName="SpinnerIcon" Property="Visibility" Value="Visible"/>
                                                        <Setter TargetName="StatusLabel" Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                        <Setter TargetName="StatusLabel" Property="FontWeight" Value="SemiBold"/>
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard x:Name="SpinStoryboard">
                                                                <Storyboard RepeatBehavior="Forever">
                                                                    <DoubleAnimation Storyboard.TargetName="SpinnerRotation"
                                                                                     Storyboard.TargetProperty="Angle"
                                                                                     From="0" To="360" Duration="0:0:1.2"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                        <DataTrigger.ExitActions>
                                                            <StopStoryboard BeginStoryboardName="SpinStoryboard"/>
                                                        </DataTrigger.ExitActions>
                                                    </DataTrigger>
                                                    <!-- === 待機中 === -->
                                                    <DataTrigger Binding="{Binding StatusKind}" Value="Waiting">
                                                        <Setter TargetName="StatusLabel" Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
                                                        <Setter TargetName="StatusLabel" Property="FontStyle" Value="Italic"/>
                                                    </DataTrigger>
                                                    <!-- === 完了（インデックス済み）: StatusPanel を隠し、DateTimeLabel + CountLabel を表示 === -->
                                                    <DataTrigger Binding="{Binding StatusKind}" Value="Indexed">
                                                        <Setter TargetName="StatusPanel" Property="Visibility" Value="Collapsed"/>
                                                        <Setter TargetName="DateTimeLabel" Property="Visibility" Value="Visible"/>
                                                        <Setter TargetName="CountLabel" Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <!-- === ロック済み（アーカイブ）: 南京錠アイコン表示 + 凍結された日時・件数を表示 === -->
                                                    <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                        <Setter TargetName="LockIcon" Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <!-- === スケジュール設定済み === -->
                                                    <DataTrigger Binding="{Binding HasCustomSchedule}" Value="True">
                                                        <Setter TargetName="ScheduleIcon" Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusKind}" Value="Locked">
                                                        <Setter TargetName="StatusPanel" Property="Visibility" Value="Collapsed"/>
                                                        <Setter TargetName="DateTimeLabel" Property="Visibility" Value="Visible"/>
                                                        <Setter TargetName="CountLabel" Property="Visibility" Value="Visible"/>
                                                        <Setter TargetName="DateTimeLabel" Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
                                                        <Setter TargetName="CountLabel" Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
                                                    </DataTrigger>
                                                    <!-- === 完了 + 鮮度アラート（24時間超過）: 日時・件数をアンバーに === -->
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding StatusKind}" Value="Indexed"/>
                                                            <Condition Binding="{Binding IsStale}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter TargetName="DateTimeLabel" Property="Foreground" Value="{DynamicResource IndexStatusWarmBrush}"/>
                                                        <Setter TargetName="CountLabel" Property="Foreground" Value="{DynamicResource IndexStatusWarmBrush}"/>
                                                    </MultiDataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="4"
                                            Visibility="{Binding IndexSearchSettings.IsEmpty, Converter={StaticResource BoolToVis}}"
                                            MinHeight="80" VerticalAlignment="Top" Margin="0,4">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16">
                                            <icon:PackIconLucide Kind="FolderDown" Width="24" Height="24" Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                            <TextBlock Text="検索対象のフォルダがありません"
                                                       Foreground="{DynamicResource SubTextBrush}" FontSize="12" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                                            <TextBlock Text="ペインからフォルダをドロップするか&#x0a;「フォルダを追加」で登録してください"
                                                       Foreground="{DynamicResource SubTextBrush}" FontSize="11" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,4,0,0" Opacity="0.7"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <Button Grid.Row="5" HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Margin="0,4,10,8"
                                    Style="{StaticResource IconButton}"
                                    Command="{Binding IndexSearchSettings.RemoveCommand}"
                                    CommandParameter="{Binding IndexSearchSettings.SelectedItem}"
                                    ToolTip="選択項目を削除"
                                    IsTabStop="False">
                                <StackPanel Orientation="Horizontal">
                                    <icon:PackIconLucide Kind="Trash2" Width="14" Height="14" Margin="0,0,4,0" Foreground="{DynamicResource SubTextBrush}"/>
                                    <TextBlock Text="削除" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource SubTextBrush}"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- アプリ設定ビュー（Control Deck に移行済み） -->


                        <!-- ワーキングセットビュー -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SidebarMode}" Value="{x:Static local:SidebarViewMode.WorkingSet}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <local:ProjectSetsView DataContext="{Binding ProjectSets}"/>
                        </Grid>

                    </Grid>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="1" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="Black"
                          Visibility="{Binding IsSidebarVisible, Converter={StaticResource BoolToVis}}"
                          IsEnabled="{Binding IsNavWidthLocked, Converter={StaticResource InverseBool}}"/>

            <!-- メインエリア（ワーキングセット切り替え時はコードビハインドで Opacity を直接制御） -->
            <Grid x:Name="PaneContentArea" Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="{Binding SplitterWidth}"/>
                    <ColumnDefinition Width="{Binding RightPaneWidth}"/>
                </Grid.ColumnDefinitions>

                <!-- 左ペイン -->
                <ContentControl Grid.Column="0" DataContext="{Binding LeftPane}">
                    <local:FilePaneControl x:Name="LeftPaneControl"/>
                </ContentControl>

                <GridSplitter Grid.Column="1" Width="1" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="Black"
                              Visibility="{Binding PaneCount, Converter={StaticResource IntToVis}, ConverterParameter=2}"/>

                <!-- 右ペイン -->
                <ContentControl Grid.Column="2" DataContext="{Binding RightPane}"
                                Visibility="{Binding PaneCount, Converter={StaticResource IntToVis}, ConverterParameter=2}">
                    <local:FilePaneControl x:Name="RightPaneControl"/>
                </ContentControl>
            </Grid>
        </Grid>

        <!-- ステータスバー -->
        <Border Grid.Row="2" Background="{DynamicResource HeaderBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="2"/>  <!-- グロウ・プログレスバー -->
                    <RowDefinition Height="28"/> <!-- コンテンツ（高さを固定して、内部要素の移動による枠の伸縮を防ぐ） -->
                </Grid.RowDefinitions>

                <!-- ════ グロウ・プログレスバー（Zenith Turbo Engine 進捗表示）════ -->
                <!-- ファイル操作中のみフェードイン。AccentBrush + Cyan DropShadow で発光 -->
                <Grid Grid.Row="0">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Opacity" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFileOperationActive}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="0" Duration="0:0:0.5">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseIn"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <ProgressBar x:Name="GlowProgressBar"
                                 Minimum="0" Maximum="100"
                                 FlowDirection="{Binding ProgressFlowDirection}"
                                 Background="Transparent"
                                 Foreground="{DynamicResource AccentBrush}"
                                 BorderThickness="0"
                                 Height="2"
                                 OverridesDefaultStyle="True">
                        <ProgressBar.Template>
                            <ControlTemplate TargetType="ProgressBar">
                                <Grid>
                                    <Rectangle x:Name="PART_Track" Fill="Transparent"/>
                                    <Rectangle x:Name="PART_Indicator"
                                               HorizontalAlignment="Left"
                                               Fill="{TemplateBinding Foreground}"/>
                                </Grid>
                            </ControlTemplate>
                        </ProgressBar.Template>
                        <ProgressBar.Effect>
                            <DropShadowEffect Color="Cyan" BlurRadius="8" ShadowDepth="0" Direction="270"/>
                        </ProgressBar.Effect>
                    </ProgressBar>
                </Grid>

                <!-- ════ スキャンバー（IsLoading 連動：フォルダ読み込み・検索中に表示）════ -->
                <Grid Grid.Row="0" ClipToBounds="True">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Opacity" Value="0"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsLoading}" Value="True"/>
                                        <Condition Binding="{Binding AppSettings.ShowScanBar}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <MultiDataTrigger.EnterActions>
                                        <BeginStoryboard x:Name="ScanBarFadeIn">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </MultiDataTrigger.EnterActions>
                                    <MultiDataTrigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="ScanBarFadeIn"/>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="0" Duration="0:0:0.3"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </MultiDataTrigger.ExitActions>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.Resources>
                        <Storyboard x:Key="ScanLineStoryboard" RepeatBehavior="Forever">
                            <DoubleAnimationUsingKeyFrames
                                Storyboard.TargetName="ScanBarTranslate"
                                Storyboard.TargetProperty="X"
                                Duration="0:0:1.6">
                                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="-220"/>
                                <EasingDoubleKeyFrame KeyTime="0:0:1.3" Value="1800">
                                    <EasingDoubleKeyFrame.EasingFunction>
                                        <CubicEase EasingMode="EaseInOut"/>
                                    </EasingDoubleKeyFrame.EasingFunction>
                                </EasingDoubleKeyFrame>
                                <EasingDoubleKeyFrame KeyTime="0:0:1.6" Value="1800"/>
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </Grid.Resources>
                    <Grid.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard Storyboard="{StaticResource ScanLineStoryboard}"/>
                        </EventTrigger>
                    </Grid.Triggers>
                    <!-- 走査トラック（薄白でラインの存在を暗示） -->
                    <Rectangle Fill="#1AFFFFFF" Height="2" VerticalAlignment="Center"/>
                    <!-- 走査バー: 両端グラデードで自然なフェード、DropShadow でグロー -->
                    <Rectangle HorizontalAlignment="Left" Height="2" Width="220" VerticalAlignment="Center">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#0090CAF9" Offset="0"/>
                                <GradientStop Color="#BB90CAF9" Offset="0.25"/>
                                <GradientStop Color="{StaticResource ScanBarColor}"   Offset="0.5"/>
                                <GradientStop Color="#BB90CAF9" Offset="0.75"/>
                                <GradientStop Color="#0090CAF9" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                        <Rectangle.Effect>
                            <DropShadowEffect Color="{StaticResource ScanBarColor}" ShadowDepth="0" BlurRadius="6" Opacity="0.85"/>
                        </Rectangle.Effect>
                        <Rectangle.RenderTransform>
                            <TranslateTransform x:Name="ScanBarTranslate" X="-220"/>
                        </Rectangle.RenderTransform>
                    </Rectangle>
                </Grid>

                <!-- ════ ステータスバー本体コンテンツ ════ -->
                <Grid Grid.Row="1" Margin="8,0">
                <!-- 左側情報 -->
                <Grid VerticalAlignment="Center" HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- ウィンドウ配置制御ボタン（左端: 左下1/4 → 左半分 → 最大化 → 下半分 → 右半分 → 右下1/4） -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,0">
                        <Button Style="{StaticResource IconButton}" 
                                Command="{Binding SnapBottomLeftCommand}" 
                                ToolTip="左下に配置" 
                                IsTabStop="False">
                            <icon:PackIconLucide Kind="CornerDownLeft" Width="12" Height="12" Foreground="{DynamicResource SubTextBrush}"/>
                        </Button>
                        <Button Style="{StaticResource IconButton}" 
                                Command="{Binding SnapLeftCommand}" 
                                ToolTip="左に配置" 
                                Margin="4,0" 
                                IsTabStop="False">
                            <icon:PackIconLucide Kind="AlignLeft" Width="12" Height="12" Foreground="{DynamicResource SubTextBrush}"/>
                        </Button>
                        <Button Style="{StaticResource IconButton}" 
                                Command="{Binding MaximizeWindowCommand}" 
                                ToolTip="最大化" 
                                Margin="4,0" 
                                IsTabStop="False">
                            <icon:PackIconLucide Kind="Maximize" Width="12" Height="12" Foreground="{DynamicResource SubTextBrush}"/>
                        </Button>
                        <Button Style="{StaticResource IconButton}" 
                                Command="{Binding SnapBottomCommand}" 
                                ToolTip="下半分に配置" 
                                Margin="4,0" 
                                IsTabStop="False">
                            <icon:PackIconLucide Kind="PanelBottom" Width="12" Height="12" Foreground="{DynamicResource SubTextBrush}"/>
                        </Button>
                        <Button Style="{StaticResource IconButton}" 
                                Command="{Binding SnapRightCommand}" 
                                ToolTip="右に配置" 
                                Margin="4,0" 
                                IsTabStop="False">
                            <icon:PackIconLucide Kind="AlignRight" Width="12" Height="12" Foreground="{DynamicResource SubTextBrush}"/>
                        </Button>
                        <Button Style="{StaticResource IconButton}" 
                                Command="{Binding SnapBottomRightCommand}" 
                                ToolTip="右下に配置" 
                                Margin="4,0" 
                                IsTabStop="False">
                            <icon:PackIconLucide Kind="CornerDownRight" Width="12" Height="12" Foreground="{DynamicResource SubTextBrush}"/>
                        </Button>
                    </StackPanel>

                    <!-- ウェルカムアニメーション中は非表示。退場完了後にクロスフェードインする。Opacity はアニメ側で制御。 -->
                    <!-- スタートアップフェーズ中は Opacity=0 で非表示。FadeInStatusInfoGroup() でフェードイン。 -->
                    <Grid x:Name="StatusInfoGroup" Grid.Column="1" VerticalAlignment="Center" Opacity="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding ActivePane.StatusText}" Foreground="{DynamicResource SubTextBrush}" FontSize="10.5" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Width="1" Height="12" Background="{DynamicResource BorderBrush}" Margin="10,0" VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePane.SelectionInfoText}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ActivePane.SelectionInfoText}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <TextBlock Grid.Column="2" Text="{Binding ActivePane.SelectionInfoText}" Foreground="{DynamicResource SubTextBrush}" FontSize="10.5" VerticalAlignment="Center"/>
                    </Grid>
                </Grid>

                <!-- 中央通知メッセージ -->
                <Grid x:Name="CenterNotificationGroup" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                    <Grid x:Name="StatusMessageGrid">
                        <TextBlock Text="{Binding Notification.StatusMessage}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SubTextBrush}"
                                   FontSize="10.5">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Opacity" Value="0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Notification.IsStatusMessageVisible}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="FadeInStory">
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         To="1" Duration="0:0:0.3">
                                                            <DoubleAnimation.EasingFunction>
                                                                <QuadraticEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <BeginStoryboard x:Name="FadeOutStory">
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         To="0" Duration="0:0:0.6">
                                                            <DoubleAnimation.EasingFunction>
                                                                <QuadraticEase EasingMode="EaseIn"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>

                <!-- 右側設定 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- キャンセルボタン（ファイル操作中のみ表示） -->
                    <Button Command="{Binding CancelFileOperationCommand}"
                            Padding="2,0" Margin="0,0,6,0" VerticalAlignment="Center"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            ToolTip="コピー/移動をキャンセル (Esc)"
                            IsTabStop="False"
                            Visibility="{Binding IsFileOperationActive, Converter={StaticResource BoolToVis}}">
                        <icon:PackIconLucide Kind="X" Width="10" Height="10" Foreground="{DynamicResource AccentBrush}"/>
                    </Button>

                    <!-- ローディングインジケータ（IsGeneralBusy=IsBusy かつファイル操作中でない。インデックス作成中も非表示） -->
                    <Grid Margin="0,0,10,0" VerticalAlignment="Center">
                        <Grid.Visibility>
                            <MultiBinding Converter="{StaticResource BusyNotIndexing}">
                                <Binding Path="IsGeneralBusy"/>
                                <Binding Path="Notification.IsIndexing"/>
                            </MultiBinding>
                        </Grid.Visibility>
                        <icon:PackIconLucide Kind="Loader" Width="12" Height="12" Foreground="{DynamicResource AccentBrush}" RenderTransformOrigin="0.5,0.5">
                            <icon:PackIconLucide.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </icon:PackIconLucide.RenderTransform>
                            <icon:PackIconLucide.Style>
                                <Style TargetType="icon:PackIconLucide">
                                    <Style.Triggers>
                                        <Trigger Property="Visibility" Value="Visible">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                         From="0" To="360" Duration="0:0:1" RepeatBehavior="Forever"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </icon:PackIconLucide.Style>
                        </icon:PackIconLucide>
                    </Grid>

                    <!-- インデックス作成中：進捗メッセージ＋アイコン（クリックで中止確認） -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                Visibility="{Binding Notification.IsIndexing, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding Notification.IndexingStatusMessage}"
                                  Foreground="{DynamicResource SubTextBrush}" FontSize="10" VerticalAlignment="Center"
                                  Margin="0,0,6,0" TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                        <Button x:Name="IndexSpinnerButton"
                                Command="{Binding CancelIndexingCommand}" Padding="2,0" Margin="0,0,6,0" VerticalAlignment="Center"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                ToolTip="インデックス作成を中止"
                                MouseEnter="IndexSpinner_MouseEnter"
                                MouseLeave="IndexSpinner_MouseLeave">
                        <icon:PackIconLucide Kind="Loader" Width="10" Height="10" Foreground="{DynamicResource AccentBrush}" RenderTransformOrigin="0.5,0.5">
                            <icon:PackIconLucide.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </icon:PackIconLucide.RenderTransform>
                            <icon:PackIconLucide.Style>
                                <Style TargetType="icon:PackIconLucide">
                                    <Style.Triggers>
                                        <Trigger Property="Visibility" Value="Visible">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                         From="0" To="360" Duration="0:0:1" RepeatBehavior="Forever"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </icon:PackIconLucide.Style>
                        </icon:PackIconLucide>
                    </Button>
                    <Popup x:Name="IndexTelemetryPopup" StaysOpen="True" AllowsTransparency="True"
                           Placement="Top" PlacementTarget="{Binding ElementName=IndexSpinnerButton}"
                           VerticalOffset="-4" PopupAnimation="None" IsHitTestVisible="False">
                        <Border x:Name="IndexTelemetryBorder" Background="{DynamicResource TelemetryBackgroundBrush}" CornerRadius="6" Padding="12,10" MinWidth="280"
                                BorderBrush="{DynamicResource TelemetryBorderBrush}" BorderThickness="0.5" Opacity="0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.3" Color="Black"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Indexing Telemetry" FontFamily="Consolas" FontSize="11"
                                           Foreground="{DynamicResource TelemetryTitleBrush}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Border Background="#30FFFFFF" Height="1" Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                    <TextBlock Text="Scan:   " FontFamily="Consolas" FontSize="10.5" Foreground="{DynamicResource SubTextBrush}"/>
                                    <TextBlock x:Name="TelemetryScanFolder" FontFamily="Consolas" FontSize="10.5"
                                               Foreground="{DynamicResource TelemetryValueBrush}" TextTrimming="CharacterEllipsis" MaxWidth="220"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                    <TextBlock Text="Speed:  " FontFamily="Consolas" FontSize="10.5" Foreground="{DynamicResource SubTextBrush}"/>
                                    <TextBlock x:Name="TelemetryThroughput" FontFamily="Consolas" FontSize="10.5"
                                               Foreground="{DynamicResource TelemetryValueBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                    <TextBlock Text="DB:     " FontFamily="Consolas" FontSize="10.5" Foreground="{DynamicResource SubTextBrush}"/>
                                    <TextBlock x:Name="TelemetryDbStats" FontFamily="Consolas" FontSize="10.5"
                                               Foreground="{DynamicResource TelemetryValueBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                    <TextBlock Text="Thread: " FontFamily="Consolas" FontSize="10.5" Foreground="{DynamicResource SubTextBrush}"/>
                                    <TextBlock x:Name="TelemetryThreads" FontFamily="Consolas" FontSize="10.5"
                                               Foreground="{DynamicResource TelemetryValueBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Time:   " FontFamily="Consolas" FontSize="10.5" Foreground="{DynamicResource SubTextBrush}"/>
                                    <TextBlock x:Name="TelemetryElapsed" FontFamily="Consolas" FontSize="10.5"
                                               Foreground="{DynamicResource TelemetryValueBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Popup>
                    </StackPanel>

                    <!-- 記録中アイコン（ログアイコンの左側に表示） -->
                    <icon:PackIconLucide Kind="Pencil" Width="10" Height="10" Margin="0,0,6,0" Foreground="{DynamicResource AccentBrush}"
                                         VerticalAlignment="Center"
                                         Visibility="{Binding Notification.IsLogging, Converter={StaticResource BoolToVis}}">
                        <icon:PackIconLucide.Style>
                            <Style TargetType="icon:PackIconLucide">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Notification.IsLogging}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1.0" To="0.3" Duration="0:0:0.3"
                                                                     AutoReverse="True" RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </icon:PackIconLucide.Style>
                    </icon:PackIconLucide>
                    <!-- ログフォルダボタン -->
                    <Button Style="{StaticResource IconButton}" 
                            Command="{Binding OpenLogFolderCommand}"
                            ToolTip="ログを表示" Margin="0,0,10,0" IsTabStop="False">
                        <icon:PackIconLucide Kind="FileText" Width="14" Height="14" Foreground="{DynamicResource SubTextBrush}"/>
                    </Button>
                    
                    <TextBlock Text="|" Foreground="{DynamicResource BorderBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>

                    <!-- モード変更アイコン -->
                    <Button Style="{StaticResource IconButton}" 
                            Command="{Binding SetPaneCountCommand}" CommandParameter="1"
                            ToolTip="1分割" Margin="0,0,5,0" IsTabStop="False">
                        <icon:PackIconLucide Kind="Square" Width="14" Height="14">
                            <icon:PackIconLucide.Style>
                                <Style TargetType="icon:PackIconLucide">
                                    <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PaneCount, Converter={StaticResource EqualityToBool}, ConverterParameter=1}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </icon:PackIconLucide.Style>
                        </icon:PackIconLucide>
                    </Button>
                    <Button Style="{StaticResource IconButton}" 
                            Command="{Binding SetPaneCountCommand}" CommandParameter="2"
                            ToolTip="2分割" Margin="0,0,10,0" IsTabStop="False">
                        <icon:PackIconLucide Kind="Columns2" Width="14" Height="14">
                            <icon:PackIconLucide.Style>
                                <Style TargetType="icon:PackIconLucide">
                                    <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PaneCount, Converter={StaticResource EqualityToBool}, ConverterParameter=2}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </icon:PackIconLucide.Style>
                        </icon:PackIconLucide>
                    </Button>

                    <TextBlock Text="|" Foreground="{DynamicResource BorderBrush}" Margin="5,0,15,0" VerticalAlignment="Center"/>

                    <!-- ナビペイン表示トグル -->
                    <ToggleButton Style="{StaticResource IconToggleButton}" 
                                  IsChecked="{Binding IsSidebarVisible, Mode=TwoWay}"
                                  ToolTip="{Binding IsSidebarVisible, Converter={StaticResource BooleanToLockTooltip}, ConverterParameter=SidebarVisibility}" Margin="0,0,10,0" IsTabStop="False">
                        <icon:PackIconLucide Kind="PanelLeft" Width="14" Height="14"/>
                    </ToggleButton>

                    <!-- 最前面表示トグル -->
                    <ToggleButton Style="{StaticResource IconToggleButton}" 
                                  IsChecked="{Binding IsAlwaysOnTop, Mode=TwoWay}"
                                  ToolTip="{Binding IsAlwaysOnTop, Converter={StaticResource BooleanToLockTooltip}, ConverterParameter=AlwaysOnTop}" Margin="0,0,10,0" IsTabStop="False">
                        <icon:PackIconLucide Kind="Pin" Width="14" Height="14"/>
                    </ToggleButton>

                </StackPanel>

                <!-- ════ 起動ウェルカムアニメーション（Fade-In & Slide-Up → Steps → Wait → Fade-Out）════ -->
                <!-- 単一の TextBlock でステップ実行し、色は SubTextBrush で統一。 -->
                <!-- StackPanel は使用せず Grid で絶対位置を確保し、表示切替時のレイアウト変動を防ぐ -->
                <Grid x:Name="WelcomePanel"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      IsHitTestVisible="False"
                      Opacity="0">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="WelcomeTrans" Y="8"/>
                    </Grid.RenderTransform>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 固定部: 文頭位置を絶対固定 -->
                    <TextBlock Grid.Column="0"
                               Text="Welcome to Zenith Filer - Turbo Engine Ready"
                               Foreground="{DynamicResource SubTextBrush}"
                               FontSize="10.5"
                               FontWeight="Normal"
                               VerticalAlignment="Center"/>

                    <!-- 可変部: ここにドットとCompleteを追記 -->
                    <TextBlock x:Name="WelcomeProgressText"
                               Grid.Column="1"
                               Text=""
                               Foreground="{DynamicResource SubTextBrush}"
                               FontSize="10.5"
                               FontWeight="Normal"
                               VerticalAlignment="Center"
                               Margin="0,0,0,0"/>
                </Grid>

                </Grid><!-- /Grid Row="1" コンテンツ -->
            </Grid><!-- /2行アウターGrid -->
        </Border>

        <!-- ════ テーマ切り替えトランジション（ZIndex=850: ControlDeckの下・コンテンツの上） ════ -->
        <Border x:Name="ThemeTransitionOverlay"
                Grid.RowSpan="3" Panel.ZIndex="850"
                Background="{DynamicResource BackgroundBrush}"
                Visibility="Collapsed" Opacity="0"
                IsHitTestVisible="False"/>

        <!-- ════ Control Deck オーバーレイ ════ -->
        <Grid x:Name="ControlDeckOverlay" Grid.RowSpan="3" Panel.ZIndex="900"
              Visibility="Collapsed" Opacity="0">
            <!-- ディミング背景 -->
            <Border Background="#66000000" MouseLeftButtonDown="ControlDeckDimming_MouseLeftButtonDown"/>
            <!-- Control Deck パネル -->
            <Border HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Margin="40,32,40,30"
                    Background="{DynamicResource BackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="6" Opacity="0.3" Color="#000000"/>
                </Border.Effect>
                <views:ControlDeckView/>
            </Border>
        </Grid>

        <!-- ════ Quick Preview オーバーレイ ════ -->
        <Grid x:Name="QuickPreviewOverlay" Grid.RowSpan="3" Panel.ZIndex="1000"
              Visibility="Collapsed" Opacity="0">
            <!-- 半透明ディミング背景 -->
            <Border Background="#66000000" MouseLeftButtonDown="QuickPreviewDimming_MouseLeftButtonDown"/>
            <!-- プレビューパネル（80% サイズ、中央配置） -->
            <Border x:Name="QuickPreviewPanel"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource BackgroundBrush}"
                    BorderBrush="{DynamicResource PreviewPanelBorderBrush}" BorderThickness="1" CornerRadius="6">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="32" ShadowDepth="4" Opacity="0.25" Color="#000000"/>
                </Border.Effect>
                <Grid Margin="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- ヘッダー: ファイル情報 + [Esc] 閉じる -->
                    <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,10">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3" Padding="4,1">
                                    <TextBlock Text="Esc" FontSize="10" Foreground="{DynamicResource SubTextBrush}"/>
                                </Border>
                                <TextBlock Text=" 閉じる" FontSize="11" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center"/>
                                <Button Style="{StaticResource IconButton}" Click="QuickPreviewCloseButton_Click"
                                        ToolTip="プレビューを閉じる" Margin="8,0,0,0" IsTabStop="False">
                                    <icon:PackIconLucide Kind="X" Width="14" Height="14" Foreground="{DynamicResource SubTextBrush}"/>
                                </Button>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Image x:Name="PreviewFileIcon" Width="16" Height="16" Margin="0,0,8,0"/>
                                <TextBlock x:Name="PreviewFileName" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"
                                           TextTrimming="CharacterEllipsis" MaxWidth="500"/>
                                <TextBlock x:Name="PreviewFileInfo" FontSize="11" Foreground="{DynamicResource SubTextBrush}" Margin="12,0,0,0"/>
                                <TextBlock x:Name="PreviewPositionCounter" FontSize="11" Foreground="{DynamicResource SubTextBrush}" Margin="12,0,0,0"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <!-- コンテンツエリア（ナビゲーション アニメーション用ラッパー） -->
                    <Grid x:Name="PreviewContentArea" Grid.Row="1" RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform><TranslateTransform/></Grid.RenderTransform>

                    <!-- テキストプレビュー（ReadOnly TextBox + 等幅フォント） -->
                    <TextBox x:Name="PreviewTextBox"
                             IsReadOnly="True" IsTabStop="False"
                             FontFamily="Cascadia Code, Consolas, MS Gothic, Courier New"
                             FontSize="12.5" Foreground="{DynamicResource TextBrush}"
                             Background="Transparent" BorderThickness="0"
                             TextWrapping="NoWrap" Padding="16,12"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Visible"
                             PreviewKeyDown="QuickPreviewTextBox_PreviewKeyDown"/>

                    <!-- 画像プレビュー -->
                    <Image x:Name="PreviewImage"
                           Visibility="Collapsed"
                           Stretch="Uniform" StretchDirection="DownOnly"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Margin="8"/>

                    <!-- PDF プレビュー（PDFtoImage でページ画像表示） -->
                    <ScrollViewer x:Name="PreviewPdfScrollViewer"
                                  Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Background="{DynamicResource PreviewPdfBackgroundBrush}"
                                  PreviewKeyDown="QuickPreviewTextBox_PreviewKeyDown">
                        <StackPanel x:Name="PreviewPdfImagePanel"
                                    HorizontalAlignment="Center"
                                    Margin="0,8"/>
                    </ScrollViewer>

                    <!-- HTML プレビュー用 WebView2（遅延初期化・非表示時 Collapsed） -->
                    <wv2:WebView2 x:Name="PreviewWebView"
                                  Visibility="Collapsed"
                                  DefaultBackgroundColor="Transparent"/>

                    <!-- ローディングインジケーター（Office→PDF 変換中 / WebView2 初期化中） -->
                    <StackPanel x:Name="PreviewLoadingPanel"
                                Visibility="Collapsed"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <icon:PackIconLucide Kind="Loader" Width="28" Height="28"
                                             Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Center"
                                             RenderTransformOrigin="0.5,0.5">
                            <icon:PackIconLucide.RenderTransform>
                                <RotateTransform x:Name="PreviewLoadingRotate" Angle="0"/>
                            </icon:PackIconLucide.RenderTransform>
                        </icon:PackIconLucide>
                        <TextBlock x:Name="PreviewLoadingText" Text="変換中..."
                                   FontSize="12" Foreground="{DynamicResource SubTextBrush}"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- スプレッドシートプレビュー（DataGrid） -->
                    <Grid x:Name="PreviewSpreadsheetPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <DataGrid x:Name="PreviewDataGrid" Grid.Row="0"
                                  AutoGenerateColumns="True" IsReadOnly="True"
                                  CanUserSortColumns="True" IsTabStop="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="All"
                                  HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                                  VerticalGridLinesBrush="{DynamicResource BorderBrush}"
                                  RowHeight="24" ColumnHeaderHeight="28"
                                  MaxColumnWidth="300"
                                  FontFamily="Cascadia Code, Consolas, MS Gothic, Courier New"
                                  FontSize="12" Foreground="{DynamicResource TextBrush}"
                                  Background="Transparent" BorderThickness="0"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  SelectionMode="Single"
                                  SelectionUnit="Cell"
                                  PreviewKeyDown="QuickPreviewTextBox_PreviewKeyDown">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="{DynamicResource SidebarBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="11.5"/>
                                    <Setter Property="Padding" Value="6,4"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="AlternationIndex" Value="1">
                                            <Setter Property="Background" Value="{DynamicResource ListHoverBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding" Value="4,2"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                        </DataGrid>
                        <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,6">
                            <TextBlock x:Name="PreviewSpreadsheetFooter"
                                       FontSize="11" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Left"/>
                        </Border>
                    </Grid>

                    <!-- 未対応ファイル形式メッセージ -->
                    <TextBlock x:Name="PreviewUnsupportedText"
                               Visibility="Collapsed"
                               Text="このファイル形式のプレビューには対応していません"
                               Foreground="{DynamicResource TextBrush}" FontSize="13"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid> <!-- /PreviewContentArea -->
                </Grid>
            </Border>
        </Grid>

        <!-- 起動時テーマ通知トースト（右下コーナー・スライドイン） -->
        <Border x:Name="ThemeToastBorder" Grid.Row="1"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                MaxWidth="300"
                Margin="0,0,20,16"
                CornerRadius="10" Padding="16,12"
                IsHitTestVisible="False" Opacity="0"
                Visibility="Collapsed"
                Background="{DynamicResource BackgroundBrush}"
                BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1.5">
            <Border.RenderTransform>
                <TranslateTransform Y="14"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="16" Color="#000000" Opacity="0.30"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <icon:PackIconLucide Kind="Palette" Width="14" Height="14"
                                     Foreground="{DynamicResource AccentBrush}"
                                     VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding Notification.ThemeToastLabel}"
                               FontSize="9" FontWeight="Medium"
                               Foreground="{DynamicResource AccentBrush}" Opacity="0.75"
                               Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding Notification.ThemeToastName}"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               TextWrapping="NoWrap"/>
                </StackPanel>
            </StackPanel>
        </Border>

    </Grid>
</ui:FluentWindow>
