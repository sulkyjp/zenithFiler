<Window x:Class="ZenithFiler.Views.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Zenith Filer へようこそ"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Width="640" Height="680"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontSize="13"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Margin="20"
            CornerRadius="8"
            Background="{DynamicResource BackgroundBrush}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.25" Direction="315" Color="Black"/>
        </Border.Effect>

        <Grid Margin="28,24,28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Header (common across all pages) -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                <Image Source="/assets/app_icon2_1.png" Width="36" Height="36"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Zenith Filer へようこそ"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="2画面ファイラーで、ファイル操作をもっと快適に"
                               FontSize="11"
                               Foreground="{DynamicResource SubTextBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Row 1: Content area — 9 pages stacked, visibility-toggled -->
            <Grid Grid.Row="1" Margin="0,0,0,12">

                <!-- Page 0: ようこそ -->
                <StackPanel x:Name="Page0">
                    <TextBlock TextWrapping="Wrap"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="12.5" LineHeight="20"
                               Margin="0,0,0,12">
                        Zenith Filer は左右2画面のファイラーです。ファイルのコピー・移動・比較がドラッグ&amp;ドロップや
                        キーボードショートカットで直感的に行えます。タブ機能で複数フォルダを同時に開き、
                        お気に入りやプロジェクトセットですぐにアクセスできます。
                    </TextBlock>

                    <Border Background="{DynamicResource SidebarBrush}"
                            CornerRadius="6" Padding="12,10" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <icon:PackIconLucide Kind="HardDrive" Width="18" Height="18"
                                                 Foreground="{DynamicResource AccentBrush}"
                                                 VerticalAlignment="Top" Margin="0,2,10,0"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18"
                                       Foreground="{DynamicResource TextBrush}"
                                       MaxWidth="480">
                                BOX や SharePoint Online のファイルを扱うには、BOX Drive や OneDrive の
                                デスクトップアプリが必要です。インストール後、同期フォルダをナビペインに
                                登録すれば、ローカルファイルと同じ操作感で管理できます。
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Button x:Name="ManualButton" Click="ManualButton_Click"
                            HorizontalAlignment="Left" Cursor="Hand"
                            Margin="0,0,0,4" IsTabStop="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent"
                                        CornerRadius="4" Padding="6,4">
                                    <StackPanel Orientation="Horizontal">
                                        <icon:PackIconLucide Kind="BookOpen" Width="14" Height="14"
                                                             Foreground="{DynamicResource AccentBrush}"
                                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="マニュアルを開く"
                                                   FontSize="12.5"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center"
                                                   TextDecorations="Underline"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource ListHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- Page 1: お気に入り -->
                <StackPanel x:Name="Page1" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <icon:PackIconLucide Kind="Star" Width="40" Height="40"
                                             Foreground="{DynamicResource AccentBrush}"
                                             VerticalAlignment="Center" Margin="0,0,14,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="お気に入り" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock TextWrapping="Wrap" FontSize="12.5" LineHeight="20"
                               Foreground="{DynamicResource TextBrush}" Margin="0,8,0,12">
                        よく使うフォルダを登録して、すばやくアクセスできるビューです。
                        ナビペインのお気に入りにフォルダをドラッグ&amp;ドロップするだけで登録完了。
                        仮想フォルダを作成して階層的に整理することもできます。
                    </TextBlock>
                    <Border CornerRadius="6" Margin="0,0,0,12"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                        <Border.OpacityMask>
                            <VisualBrush>
                                <VisualBrush.Visual>
                                    <Border CornerRadius="6" Background="White"
                                            Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}"
                                            Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Border}}"/>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Border.OpacityMask>
                        <Image Source="/assets/welcome/favorites.png"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <Border Background="{DynamicResource SidebarBrush}"
                            CornerRadius="6" Padding="12,10">
                        <StackPanel Orientation="Horizontal">
                            <icon:PackIconLucide Kind="Lightbulb" Width="16" Height="16"
                                                 Foreground="{DynamicResource AccentBrush}"
                                                 VerticalAlignment="Top" Margin="0,2,8,0"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18"
                                       Foreground="{DynamicResource TextBrush}" MaxWidth="480">
                                ヒント: D&amp;Dでフォルダ登録、仮想フォルダで階層化できます
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Page 2: ツリービュー -->
                <StackPanel x:Name="Page2" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <icon:PackIconLucide Kind="FolderTree" Width="40" Height="40"
                                             Foreground="{DynamicResource AccentBrush}"
                                             VerticalAlignment="Center" Margin="0,0,14,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="ツリービュー" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock TextWrapping="Wrap" FontSize="12.5" LineHeight="20"
                               Foreground="{DynamicResource TextBrush}" Margin="0,8,0,12">
                        PC に接続されているすべてのドライブをツリー形式で表示します。
                        フォルダを展開しながら目的の場所まで辿り着き、
                        ダブルクリックでペインに表示できます。
                    </TextBlock>
                    <Border CornerRadius="6" Margin="0,0,0,12"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                        <Border.OpacityMask>
                            <VisualBrush>
                                <VisualBrush.Visual>
                                    <Border CornerRadius="6" Background="White"
                                            Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}"
                                            Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Border}}"/>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Border.OpacityMask>
                        <Image Source="/assets/welcome/tree.png"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <Border Background="{DynamicResource SidebarBrush}"
                            CornerRadius="6" Padding="12,10">
                        <StackPanel Orientation="Horizontal">
                            <icon:PackIconLucide Kind="Lightbulb" Width="16" Height="16"
                                                 Foreground="{DynamicResource AccentBrush}"
                                                 VerticalAlignment="Top" Margin="0,2,8,0"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18"
                                       Foreground="{DynamicResource TextBrush}" MaxWidth="480">
                                ヒント: 全ドライブをツリー表示、ダブルクリックでペインに表示できます
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Page 3: 参照履歴 -->
                <StackPanel x:Name="Page3" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <icon:PackIconLucide Kind="History" Width="40" Height="40"
                                             Foreground="{DynamicResource AccentBrush}"
                                             VerticalAlignment="Center" Margin="0,0,14,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="参照履歴" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock TextWrapping="Wrap" FontSize="12.5" LineHeight="20"
                               Foreground="{DynamicResource TextBrush}" Margin="0,8,0,12">
                        フォルダへのアクセス履歴を日別に自動記録します。
                        「あのフォルダどこだっけ？」というときに、過去の閲覧履歴から
                        すぐに見つけ出せます。キーワード検索にも対応しています。
                    </TextBlock>
                    <Border CornerRadius="6" Margin="0,0,0,12"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                        <Border.OpacityMask>
                            <VisualBrush>
                                <VisualBrush.Visual>
                                    <Border CornerRadius="6" Background="White"
                                            Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}"
                                            Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Border}}"/>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Border.OpacityMask>
                        <Image Source="/assets/welcome/history.png"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <Border Background="{DynamicResource SidebarBrush}"
                            CornerRadius="6" Padding="12,10">
                        <StackPanel Orientation="Horizontal">
                            <icon:PackIconLucide Kind="Lightbulb" Width="16" Height="16"
                                                 Foreground="{DynamicResource AccentBrush}"
                                                 VerticalAlignment="Top" Margin="0,2,8,0"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18"
                                       Foreground="{DynamicResource TextBrush}" MaxWidth="480">
                                ヒント: 日別にアクセス履歴を自動記録、検索も可能です
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Page 4: インデックス検索 -->
                <StackPanel x:Name="Page4" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <icon:PackIconLucide Kind="FolderSearch" Width="40" Height="40"
                                             Foreground="{DynamicResource AccentBrush}"
                                             VerticalAlignment="Center" Margin="0,0,14,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="インデックス検索" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock TextWrapping="Wrap" FontSize="12.5" LineHeight="20"
                               Foreground="{DynamicResource TextBrush}" Margin="0,8,0,12">
                        登録フォルダのファイル名インデックスを構築し、高速検索を実現します。
                        Ctrl+Shift+F で検索ボックスを開き、ファイル名の一部を入力するだけで
                        瞬時に候補が絞り込まれます。
                    </TextBlock>
                    <Border CornerRadius="6" Margin="0,0,0,12"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                        <Border.OpacityMask>
                            <VisualBrush>
                                <VisualBrush.Visual>
                                    <Border CornerRadius="6" Background="White"
                                            Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}"
                                            Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Border}}"/>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Border.OpacityMask>
                        <Image Source="/assets/welcome/index.png"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <Border Background="{DynamicResource SidebarBrush}"
                            CornerRadius="6" Padding="12,10">
                        <StackPanel Orientation="Horizontal">
                            <icon:PackIconLucide Kind="Lightbulb" Width="16" Height="16"
                                                 Foreground="{DynamicResource AccentBrush}"
                                                 VerticalAlignment="Top" Margin="0,2,8,0"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18"
                                       Foreground="{DynamicResource TextBrush}" MaxWidth="480">
                                ヒント: Ctrl+Shift+F でファイル名の高速検索が可能です
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Page 5: ワーキングセット -->
                <StackPanel x:Name="Page5" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <icon:PackIconLucide Kind="Briefcase" Width="40" Height="40"
                                             Foreground="{DynamicResource AccentBrush}"
                                             VerticalAlignment="Center" Margin="0,0,14,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="ワーキングセット" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock TextWrapping="Wrap" FontSize="12.5" LineHeight="20"
                               Foreground="{DynamicResource TextBrush}" Margin="0,8,0,12">
                        現在開いているタブの状態を丸ごと保存し、いつでも復元できます。
                        プロジェクトごとに作業フォルダのセットを保存しておけば、
                        作業の切り替えがワンクリックで完了します。
                    </TextBlock>
                    <Border CornerRadius="6" Margin="0,0,0,12"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                        <Border.OpacityMask>
                            <VisualBrush>
                                <VisualBrush.Visual>
                                    <Border CornerRadius="6" Background="White"
                                            Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}"
                                            Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Border}}"/>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Border.OpacityMask>
                        <Image Source="/assets/welcome/workingset.png"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <Border Background="{DynamicResource SidebarBrush}"
                            CornerRadius="6" Padding="12,10">
                        <StackPanel Orientation="Horizontal">
                            <icon:PackIconLucide Kind="Lightbulb" Width="16" Height="16"
                                                 Foreground="{DynamicResource AccentBrush}"
                                                 VerticalAlignment="Top" Margin="0,2,8,0"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18"
                                       Foreground="{DynamicResource TextBrush}" MaxWidth="480">
                                ヒント: タブの状態を丸ごと保存・復元できます
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Page 6: アプリ設定 -->
                <StackPanel x:Name="Page6" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <icon:PackIconLucide Kind="Settings" Width="40" Height="40"
                                             Foreground="{DynamicResource AccentBrush}"
                                             VerticalAlignment="Center" Margin="0,0,14,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="アプリ設定" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock TextWrapping="Wrap" FontSize="12.5" LineHeight="20"
                               Foreground="{DynamicResource TextBrush}" Margin="0,8,0,12">
                        ホームフォルダ、検索挙動、テーマなどアプリ全体の設定を管理します。
                        ナビペインの設定アイコンからいつでもアクセスでき、
                        使い方に合わせてカスタマイズできます。
                    </TextBlock>
                    <Border CornerRadius="6" Margin="0,0,0,12"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                        <Border.OpacityMask>
                            <VisualBrush>
                                <VisualBrush.Visual>
                                    <Border CornerRadius="6" Background="White"
                                            Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}"
                                            Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Border}}"/>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Border.OpacityMask>
                        <Image Source="/assets/welcome/settings.png"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <Border Background="{DynamicResource SidebarBrush}"
                            CornerRadius="6" Padding="12,10">
                        <StackPanel Orientation="Horizontal">
                            <icon:PackIconLucide Kind="Lightbulb" Width="16" Height="16"
                                                 Foreground="{DynamicResource AccentBrush}"
                                                 VerticalAlignment="Top" Margin="0,2,8,0"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18"
                                       Foreground="{DynamicResource TextBrush}" MaxWidth="480">
                                ヒント: ホームフォルダ・検索挙動・テーマなどを設定できます
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Page 7: テーマ選択 -->
                <DockPanel x:Name="Page7" Visibility="Collapsed">
                    <TextBlock DockPanel.Dock="Top"
                               Text="お好みのスタイルで始めましょう"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               Margin="0,0,0,14"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="ThemeCardsHost">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton GroupName="ThemeGroup"
                                             Checked="ThemeCard_Checked"
                                             Margin="3" Cursor="Hand"
                                             IsTabStop="False">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="CardBorder"
                                                    CornerRadius="6"
                                                    BorderThickness="2"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    Background="{DynamicResource BackgroundBrush}"
                                                    Padding="10,8" MinHeight="44">
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="12.5" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               FontSize="10.5"
                                                               Foreground="{DynamicResource SubTextBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="CardBorder" Property="Background"
                                                            Value="{DynamicResource ListHoverBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="CardBorder" Property="BorderBrush"
                                                            Value="{DynamicResource AccentBrush}"/>
                                                    <Setter TargetName="CardBorder" Property="Background"
                                                            Value="{DynamicResource SelectionBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    </ScrollViewer>
                </DockPanel>

                <!-- Page 8: EULA 同意 -->
                <DockPanel x:Name="Page8" Visibility="Collapsed">
                    <TextBlock DockPanel.Dock="Top"
                               Text="ソフトウェア使用許諾契約"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               Margin="0,0,0,14"/>

                    <CheckBox x:Name="EulaAgreeCheckBox"
                              DockPanel.Dock="Bottom"
                              Content="上記の使用許諾契約に同意します"
                              Foreground="{DynamicResource TextBrush}"
                              Margin="0,14,0,0"
                              VerticalContentAlignment="Center"
                              Checked="EulaAgreeCheckBox_Changed"
                              Unchecked="EulaAgreeCheckBox_Changed"/>

                    <Border BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Background="{DynamicResource InputBackgroundBrush}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Padding="16,12">
                            <TextBlock x:Name="EulaTextBlock"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12"
                                       LineHeight="20"/>
                        </ScrollViewer>
                    </Border>
                </DockPanel>

                <!-- Page 9: 準備完了 -->
                <StackPanel x:Name="Page9" Visibility="Collapsed"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                    <icon:PackIconLucide Kind="Check" Width="48" Height="48"
                                         Foreground="{DynamicResource AccentBrush}"
                                         HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="準備が整いました"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock x:Name="SelectedThemeText"
                               FontSize="12"
                               Foreground="{DynamicResource SubTextBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,28"/>
                    <TextBlock TextAlignment="Center"
                               FontSize="13" LineHeight="22"
                               Foreground="{DynamicResource TextBrush}"
                               HorizontalAlignment="Center">
                        Zenith Filer をお選びいただきありがとうございます<LineBreak/>
                        右下の「アプリを起動」ボタンから始めましょう
                    </TextBlock>
                </StackPanel>

            </Grid>

            <!-- Row 2: Footer — indicators + navigation buttons -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Page indicators -->
                <StackPanel x:Name="IndicatorPanel" Grid.Column="0"
                            Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="Dot0" Width="8" Height="8" Margin="0,0,6,0"
                             Fill="{DynamicResource AccentBrush}"/>
                    <Ellipse x:Name="Dot1" Width="8" Height="8" Margin="0,0,6,0"
                             Fill="{DynamicResource SubTextBrush}"/>
                    <Ellipse x:Name="Dot2" Width="8" Height="8" Margin="0,0,6,0"
                             Fill="{DynamicResource SubTextBrush}"/>
                    <Ellipse x:Name="Dot3" Width="8" Height="8" Margin="0,0,6,0"
                             Fill="{DynamicResource SubTextBrush}"/>
                    <Ellipse x:Name="Dot4" Width="8" Height="8" Margin="0,0,6,0"
                             Fill="{DynamicResource SubTextBrush}"/>
                    <Ellipse x:Name="Dot5" Width="8" Height="8" Margin="0,0,6,0"
                             Fill="{DynamicResource SubTextBrush}"/>
                    <Ellipse x:Name="Dot6" Width="8" Height="8" Margin="0,0,6,0"
                             Fill="{DynamicResource SubTextBrush}"/>
                    <Ellipse x:Name="Dot7" Width="8" Height="8" Margin="0,0,6,0"
                             Fill="{DynamicResource SubTextBrush}"/>
                    <Ellipse x:Name="Dot8" Width="8" Height="8" Margin="0,0,6,0"
                             Fill="{DynamicResource SubTextBrush}"/>
                    <Ellipse x:Name="Dot9" Width="8" Height="8"
                             Fill="{DynamicResource SubTextBrush}"/>
                </StackPanel>

                <!-- Navigation buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <!-- Back button -->
                    <Button x:Name="BackButton" Click="BackButton_Click"
                            Visibility="Collapsed"
                            MinWidth="80" MinHeight="32"
                            Padding="12,4" Margin="0,0,8,0" Cursor="Hand"
                            IsTabStop="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder"
                                        CornerRadius="6"
                                        Background="Transparent"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <icon:PackIconLucide Kind="ArrowLeft"
                                                             Width="14" Height="14"
                                                             Foreground="{DynamicResource TextBrush}"
                                                             VerticalAlignment="Center"
                                                             Margin="0,0,6,0"/>
                                        <TextBlock Text="戻る"
                                                   FontSize="12.5"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Background"
                                                Value="{DynamicResource ListHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Next button (pages 0–8) -->
                    <Button x:Name="NextButton" Click="NextButton_Click"
                            MinWidth="100" MinHeight="32"
                            Padding="14,4" Cursor="Hand"
                            IsTabStop="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder"
                                        CornerRadius="6"
                                        Background="{DynamicResource AccentBrush}"
                                        Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="次へ"
                                                   FontSize="12.5" FontWeight="SemiBold"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"/>
                                        <icon:PackIconLucide Kind="ArrowRight"
                                                             Width="14" Height="14"
                                                             Foreground="White"
                                                             VerticalAlignment="Center"
                                                             Margin="6,0,0,0"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Launch button (page 9 — 次へ と同じ位置に表示) -->
                    <Button x:Name="LaunchButton" Click="LaunchButton_Click"
                            Visibility="Collapsed"
                            MinWidth="100" MinHeight="32"
                            Padding="14,4" Cursor="Hand"
                            IsTabStop="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder"
                                        CornerRadius="6"
                                        Background="{DynamicResource AccentBrush}"
                                        Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <icon:PackIconLucide Kind="Rocket"
                                                             Width="14" Height="14"
                                                             Foreground="White"
                                                             VerticalAlignment="Center"
                                                             Margin="0,0,6,0"/>
                                        <TextBlock Text="アプリを起動"
                                                   FontSize="12.5" FontWeight="SemiBold"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
