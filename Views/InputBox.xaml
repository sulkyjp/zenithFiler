<Window x:Class="ZenithFiler.InputBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="名前の変更"
        Height="200"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        SizeToContent="Width"
        MinWidth="360"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontSize="13"
        FocusManager.FocusedElement="{Binding ElementName=InputTextBox}">
    <StackPanel Margin="24,18,24,18">
        <TextBlock Text="新しい名前を入力してください:" Margin="0,0,0,10"/>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- テキストボックス（ウィンドウ幅いっぱい） -->
            <TextBox x:Name="InputTextBox"
                     Grid.Row="0" Grid.Column="0"
                     Padding="6"
                     VerticalContentAlignment="Center"/>
            <TextBlock x:Name="ExtensionLabel"
                       Grid.Row="0" Grid.Column="1"
                       VerticalAlignment="Center"
                       Margin="4,0,0,0"
                       Foreground="{DynamicResource TextBrush}"
                       IsHitTestVisible="False"
                       Visibility="Collapsed"/>

            <!-- ボタン行（右下に揃えたボタン群） -->
            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,20,0,0">
                <Button x:Name="TodayButton"
                        Content="本日の日付"
                        Click="TodayButton_Click"
                        MinWidth="96"
                        MinHeight="30"
                        Padding="14,4"
                        Margin="0,0,12,0"/>
                <Button Content="OK"
                        IsDefault="True"
                        Click="OkButton_Click"
                        MinWidth="96"
                        MinHeight="30"
                        Padding="14,4"
                        Margin="0,0,12,0"/>
                <Button Content="キャンセル"
                        Click="CancelButton_Click"
                        MinWidth="96"
                        MinHeight="30"
                        Padding="14,4"/>
            </StackPanel>
        </Grid>
    </StackPanel>
</Window>